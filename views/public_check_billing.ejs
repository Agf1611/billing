<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<%
  const publicBillingLogo = (settings && settings.company_logo_url) ? settings.company_logo_url : '/img/logo.png';
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cek Pembayaran | <%= settings.company_header || 'Portal ISP' %></title>
  <meta name="theme-color" content="#eef4ff">
  <script>
    (function () {
      try {
        var savedTheme = localStorage.getItem('customer-portal-theme');
        var theme = savedTheme === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/img/logo.png">
  <style>
    :root{
      --page-bg:
        radial-gradient(1200px 720px at 10% 0%, rgba(111, 141, 255, 0.18) 0%, rgba(255,255,255,0) 58%),
        radial-gradient(900px 560px at 100% 0%, rgba(77, 189, 255, 0.12) 0%, rgba(255,255,255,0) 50%),
        #eef3ff;
      --panel-bg: rgba(255,255,255,0.95);
      --panel-soft: rgba(248,250,252,0.98);
      --panel-border: rgba(170,186,215,.24);
      --text-main: #1b2740;
      --text-soft: #6b7b97;
      --field-bg: rgba(248,250,252,.98);
      --field-border: rgba(170,186,215,.30);
      --chip-bg: rgba(226,232,240,.75);
      --brand: #4f6ef7;
      --brand-2: #6f8dff;
      --shadow: 0 22px 60px rgba(85, 104, 148, 0.16);
      --table-border: rgba(148,163,184,.16);
      --method-bg: rgba(248,250,252,.98);
      --method-selected: rgba(79,110,247,.08);
      --method-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
      --link: #3654db;
    }
    html[data-theme="dark"]{
      --page-bg:
        radial-gradient(1200px 720px at 10% 0%, rgba(111, 141, 255, 0.20) 0%, rgba(15, 23, 42, 0) 60%),
        radial-gradient(900px 560px at 100% 0%, rgba(77, 189, 255, 0.16) 0%, rgba(15, 23, 42, 0) 50%),
        #09111d;
      --panel-bg: rgba(17, 24, 39, 0.94);
      --panel-soft: rgba(15, 23, 42, 0.72);
      --panel-border: rgba(71,85,105,.6);
      --text-main: #edf2ff;
      --text-soft: rgba(150, 163, 191, 0.92);
      --field-bg: rgba(15, 23, 42, 0.64);
      --field-border: rgba(71,85,105,.72);
      --chip-bg: rgba(15,23,42,.52);
      --shadow: 0 25px 60px rgba(0, 0, 0, 0.45);
      --table-border: rgba(148,163,184,.18);
      --method-bg: rgba(15, 23, 42, 0.74);
      --method-selected: rgba(111,141,255,.14);
      --method-shadow: 0 10px 28px rgba(0, 0, 0, 0.25);
      --link: #c8d6ff;
    }
    body{
      background: var(--page-bg);
      color: var(--text-main);
      font-family: "Plus Jakarta Sans","Manrope",-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
      -webkit-tap-highlight-color: transparent;
      transition: background .2s ease, color .2s ease;
    }
    .wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px 14px}
    .cardx{
      background: var(--panel-bg);
      backdrop-filter: blur(16px);
      border:1px solid var(--panel-border);
      border-radius:24px;
      box-shadow: var(--shadow);
      overflow:hidden;
      max-width:760px;
      width:100%;
    }
    .brand-hero{
      display:flex;
      align-items:center;
      gap:14px;
      margin-bottom:16px;
      padding:14px 15px;
      border-radius:22px;
      background: var(--panel-bg);
      border:1px solid var(--panel-border);
      box-shadow:0 16px 34px rgba(85,104,148,.10);
    }
    .brand-hero-logo{
      width:60px;
      height:60px;
      flex:0 0 60px;
      display:grid;
      place-items:center;
      border-radius:18px;
      background: var(--panel-soft);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.92), 0 16px 28px rgba(79,110,247,.10);
    }
    .brand-hero-logo img{width:44px;height:44px;object-fit:contain}
    .brand-hero-copy{min-width:0}
    .brand-hero-copy strong{
      display:inline-flex;align-items:center;gap:7px;margin-bottom:6px;padding:7px 11px;border-radius:999px;
      background:rgba(79,110,247,.10);border:1px solid rgba(79,110,247,.14);color:var(--brand);
      font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;
    }
    .brand-hero-copy h1{margin:0 0 4px;font-size:22px;line-height:1.04;font-weight:800;letter-spacing:-.04em}
    .brand-hero-copy p{margin:0;color:var(--text-soft);font-size:12px;line-height:1.45}
    html[data-theme="dark"] .brand-hero,
    html[data-theme="dark"] .brand-hero-logo{
      box-shadow:0 16px 34px rgba(0,0,0,.28);
    }
    html[data-theme="dark"] .brand-hero-copy strong{
      background:rgba(111,141,255,.14);
      border-color:rgba(111,141,255,.28);
      color:#dbe6ff;
    }
    .head{
      background: linear-gradient(135deg, rgba(111, 141, 255, 0.08) 0%, rgba(77, 189, 255, 0.05) 100%);
      padding:18px 20px;
      border-bottom:1px solid var(--table-border);
    }
    .body{padding:20px}
    .form-control,.form-select{
      background: var(--field-bg);
      border:1px solid var(--field-border);
      color: var(--text-main);
      border-radius:14px;
      min-height:48px;
    }
    .form-control:focus,.form-select:focus{
      background: var(--field-bg);
      border-color: rgba(99, 102, 241, 0.85);
      box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.18);
      color: var(--text-main);
    }
    .form-control::placeholder{color:var(--text-soft)}
    .muted{color:var(--text-soft)}
    .mini-help{font-size:12px;color:var(--text-soft)}
    .tbl{width:100%;border-collapse:separate;border-spacing:0}
    .tbl th,.tbl td{padding:10px 12px;border-bottom:1px solid var(--table-border);vertical-align:middle}
    .tbl thead th{font-size:11px;text-transform:uppercase;letter-spacing:.4px;color:var(--text-soft)}
    .tbl tbody tr{background:var(--panel-soft)}
    .tbl tbody tr:hover{background:var(--chip-bg)}
    .tbl td{color:var(--text-main)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:999px;font-size:12px;font-weight:700;border:1px solid rgba(148,163,184,.18)}
    .pill-u{background: linear-gradient(180deg, rgba(224,93,109,.16), rgba(224,93,109,.08));color:#c34b5b;border-color: rgba(224,93,109,.18)}
    .pill-p{background: linear-gradient(180deg, rgba(28,165,111,.16), rgba(28,165,111,.08));color:#158b5d;border-color: rgba(28,165,111,.18)}
    html[data-theme="dark"] .pill-u{color:#fecdd3;background:rgba(251,113,133,.18);border-color:rgba(251,113,133,.34)}
    html[data-theme="dark"] .pill-p{color:#bbf7d0;background:rgba(34,197,94,.16);border-color:rgba(34,197,94,.28)}
    html[data-theme="dark"] .alert{
      background:var(--panel-soft);
      color:var(--text-main);
      border-color:var(--panel-border);
    }
    html[data-theme="dark"] .alert-danger{color:#fecdd3}
    html[data-theme="dark"] .alert-warning{color:#fde68a}
    html[data-theme="dark"] .alert-success{color:#bbf7d0}
    html[data-theme="dark"] .alert-info{color:#bfdbfe}
    .btnx{border-radius:14px;font-weight:700}
    .btn-primary{background: linear-gradient(135deg, var(--brand-2) 0%, var(--brand) 100%);border:none;box-shadow:0 16px 28px rgba(79,110,247,.18)}
    .btn-outline-light{
      border-color: var(--field-border);
      color: var(--text-main);
      background: var(--field-bg);
    }
    .btn-outline-light:hover{background: var(--chip-bg);color: var(--text-main);border-color: var(--field-border)}
    a{color:var(--link)}
    .section-card{
      background: var(--panel-soft);
      border:1px solid var(--table-border);
      border-radius:20px;
      padding:14px;
      box-shadow:0 12px 28px rgba(85,104,148,.08);
    }
    .section-title{
      font-size:13px;
      font-weight:800;
      letter-spacing:.06em;
      text-transform:uppercase;
      color:var(--text-soft);
      margin-bottom:8px;
    }
    .payment-summary{font-size:12px;color:var(--text-main);font-weight:800}
    .pay-mode-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-bottom:12px}
    .pay-mode-radio{position:absolute;opacity:0;pointer-events:none}
    .pay-mode-card{
      display:flex;
      align-items:center;
      gap:10px;
      min-height:62px;
      padding:11px 12px;
      border-radius:18px;
      border:1px solid var(--table-border);
      background:var(--method-bg);
      box-shadow:var(--method-shadow);
      cursor:pointer;
      transition:all .18s ease;
    }
    .pay-mode-card i{font-size:20px;color:var(--brand)}
    .pay-mode-card strong{display:block;font-size:13px;line-height:1.25;color:var(--text-main)}
    .pay-mode-card span{display:block;font-size:11px;line-height:1.35;color:var(--text-soft)}
    .pay-mode-radio:checked + .pay-mode-card{
      border-color:rgba(99, 102, 241, .82);
      background:var(--method-selected);
      box-shadow:0 14px 28px rgba(99,102,241,.14);
    }
    .billing-row-single.is-disabled{opacity:.48}
    .invoice-flags{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px}
    .invoice-flag{
      display:inline-flex;
      align-items:center;
      gap:4px;
      padding:3px 7px;
      border-radius:999px;
      font-size:10px;
      line-height:1.2;
      font-weight:800;
      border:1px solid rgba(148,163,184,.18);
      white-space:nowrap;
    }
    .invoice-flag.late{background:rgba(245,158,11,.12);color:#b45309;border-color:rgba(245,158,11,.24)}
    .invoice-flag.isolated{background:rgba(239,68,68,.12);color:#be123c;border-color:rgba(239,68,68,.22)}
    html[data-theme="dark"] .invoice-flag.late{background:rgba(245,158,11,.18);color:#fde68a;border-color:rgba(245,158,11,.30)}
    html[data-theme="dark"] .invoice-flag.isolated{background:rgba(244,63,94,.18);color:#fecdd3;border-color:rgba(244,63,94,.34)}
    .payment-methods-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    @media (min-width: 768px){.payment-methods-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
    .pay-scroll{max-height:320px;overflow:auto;padding-right:4px}
    .pm-radio{position:absolute;opacity:0;pointer-events:none}
    .pay-method-item{
      position:relative;
      display:flex;
      flex-direction:column;
      align-items:flex-start;
      gap:12px;
      padding:14px 12px 12px;
      background: var(--method-bg);
      border:1px solid var(--table-border);
      border-radius:18px;
      cursor:pointer;
      transition: all .18s ease;
      overflow:hidden;
      min-height:124px;
      box-shadow: var(--method-shadow);
    }
    .pay-method-item:hover{transform: translateY(-1px);border-color: rgba(99, 102, 241, 0.45)}
    .pm-radio:checked + .pay-method-item,
    .pay-method-item.is-selected{
      background: var(--method-selected);
      border-color: rgba(99, 102, 241, 0.82);
      box-shadow: 0 14px 28px rgba(99, 102, 241, 0.14);
    }
    .pm-radio:checked + .pay-method-item::after,
    .pay-method-item.is-selected::after{
      content:"";
      position:absolute;
      inset:0;
      border-radius:18px;
      pointer-events:none;
      box-shadow:inset 0 0 0 2px rgba(79,110,247,.34);
    }
    .pm-radio:checked + .pay-method-item .p-icon,
    .pay-method-item.is-selected .p-icon{
      border-color:rgba(79,110,247,.45);
      background:rgba(79,110,247,.12);
    }
    .pm-radio:checked + .pay-method-item .p-chip,
    .pay-method-item.is-selected .p-chip{
      background:rgba(79,110,247,.16);
      border-color:rgba(79,110,247,.28);
      color:var(--brand);
    }
    .p-icon{
      width:48px;height:48px;
      background: rgba(255,255,255,.8);
      border-radius:14px;
      display:flex;align-items:center;justify-content:center;
      font-size:22px;color:var(--brand);
      overflow:hidden;flex:0 0 auto;
      border:1px solid rgba(148,163,184,.12);
    }
    html[data-theme="dark"] .p-icon{background: rgba(30,41,59,.92)}
    .p-logo{width:100%;height:100%;object-fit:contain;padding:7px;background: rgba(255, 255, 255, 0.96)}
    html[data-theme="dark"] .p-logo{background:rgba(226,232,240,.92)}
    .p-badge{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;letter-spacing:.2px;text-transform:uppercase}
    .pb-dana{background: linear-gradient(135deg, rgba(59,130,246,0.95), rgba(14,165,233,0.95));color:#0b1220}
    .pb-ovo{background: linear-gradient(135deg, rgba(168,85,247,0.95), rgba(99,102,241,0.95));color:#0b1220}
    .pb-shopeepay{background: linear-gradient(135deg, rgba(249,115,22,0.95), rgba(244,63,94,0.95));color:#0b1220}
    .pb-linkaja{background: linear-gradient(135deg, rgba(239,68,68,0.95), rgba(244,63,94,0.95));color:#0b1220}
    .pb-gopay{background: linear-gradient(135deg, rgba(34,197,94,0.95), rgba(16,185,129,0.95));color:#0b1220}
    .pb-bank{background: linear-gradient(135deg, rgba(15,23,42,0.82), rgba(30,41,59,0.92));color:#e2e8f0}
    .p-info{display:flex;flex-direction:column;gap:5px;min-width:0;width:100%}
    .p-name{
      font-size:14px;
      font-weight:800;
      color:var(--text-main);
      line-height:1.3;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
      overflow:hidden;
      min-width:0;
      word-break:break-word;
    }
    .p-sub{
      font-size:11px;
      color: var(--text-soft);
      display:block;
      min-width:0;
      line-height:1.45;
    }
    .p-chip{
      position:absolute;
      top:10px;
      right:10px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:3px 8px;
      max-width:72px;
      border-radius:999px;
      border:1px solid rgba(148, 163, 184, 0.18);
      background: var(--chip-bg);
      color: var(--text-soft);
      font-size:10px;
      font-weight:800;
      letter-spacing:.03em;
      line-height:1.2;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .manual-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
      margin-top:10px;
    }
    .manual-item{
      padding:11px 12px;
      border-radius:16px;
      background: var(--field-bg);
      border:1px solid var(--table-border);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.28);
    }
    .manual-item.full{grid-column:1/-1}
    .manual-item small{display:block;color:var(--text-soft);margin-bottom:3px}
    .manual-item strong{color:var(--text-main)}
    @media (max-width: 576px){
      .wrap{padding:10px}
      .cardx{border-radius:18px}
      .brand-hero{padding:12px 13px;gap:12px}
      .brand-hero-logo{width:54px;height:54px;flex-basis:54px}
      .brand-hero-logo img{width:40px;height:40px}
      .brand-hero-copy h1{font-size:20px}
      .head,.body{padding:16px 14px}
      .manual-grid{grid-template-columns:1fr}
      .pay-mode-grid{grid-template-columns:1fr}
      .p-name{font-size:13px}
      .p-icon{width:44px;height:44px;font-size:20px}
      .btnx{border-radius:12px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div style="width:100%;max-width:760px">
      <div class="brand-hero">
        <div class="brand-hero-logo">
          <img src="<%= publicBillingLogo %>" alt="Logo <%= settings.company_header || 'Portal ISP' %>">
        </div>
        <div class="brand-hero-copy">
          <strong><i class="bi bi-credit-card-2-front-fill"></i> Cek Pembayaran</strong>
          <h1><%= settings.company_header || 'Portal ISP' %></h1>
        </div>
      </div>

      <div class="cardx">
      <div class="head">
        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
          <div>
            <div class="fw-bold" style="font-size:18px">Cek Pembayaran</div>
          </div>
          <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-light btn-sm btnx" type="button" id="themeToggleBtn" aria-label="Ubah tema" title="Ubah tema">
              <i class="bi bi-moon-stars" id="themeToggleIcon"></i>
            </button>
            <a class="btn btn-outline-light btn-sm btnx" href="/customer/login">
              <i class="bi bi-box-arrow-in-right me-1"></i> Login
            </a>
          </div>
        </div>
      </div>
      <div class="body">
        <form method="GET" action="/customer/check-billing" class="mb-3">
          <div class="row g-2 align-items-center">
            <div class="col-12 col-md-8">
              <input class="form-control" name="q" value="<%= query || '' %>" placeholder="Masukkan nama, nomor HP, atau ID pelanggan" required>
            </div>
            <div class="col-12 col-md-4 d-grid">
              <button class="btn btn-primary btnx" type="submit">
                <i class="bi bi-search me-1"></i> Cek
              </button>
            </div>
          </div>
        </form>

        <% if (error) { %>
          <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
          </div>
        <% } %>
        <% if (info) { %>
          <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i><%= info %>
          </div>
        <% } %>

        <% if (query && !customer && (!matches || matches.length === 0)) { %>
          <div class="alert alert-warning">
            <i class="bi bi-info-circle me-2"></i>Pelanggan tidak ditemukan. Pastikan data yang dimasukkan sudah benar.
          </div>
        <% } %>

        <% if (!customer && matches && matches.length > 0) { %>
          <div class="mb-2 fw-bold">Hasil Pencarian</div>
          <div class="table-responsive">
            <table class="tbl">
              <thead>
                <tr>
                  <th>Pelanggan</th>
                  <th class="text-end">Belum Bayar</th>
                  <th class="text-end">Total</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% matches.forEach(m => { %>
                  <tr>
                    <td>
                      <div class="fw-semibold"><%= m.customer_name %></div>
                      <div class="muted small">
                        ID: <%= m.customer_code || m.customer_id %><% if (m.customer_phone) { %> - WA: <%= m.customer_phone %><% } %>
                      </div>
                    </td>
                    <td class="text-end fw-semibold"><%= Number(m.unpaid_count || 0) %></td>
                    <td class="text-end fw-semibold">Rp <%= Number(m.total_amount || 0).toLocaleString('id-ID') %></td>
                    <td class="text-end">
                      <a class="btn btn-outline-light btn-sm btnx" href="/customer/check-billing?q=<%= encodeURIComponent(String(m.customer_code || m.customer_id)) %>">
                        Lihat
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (customer) { %>
          <div class="mb-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
              <div>
                <div class="fw-bold"><%= customer.name %></div>
                <div class="muted small">
                  ID: <%= customer.id %>
                  <% if (customer.phone) { %> - WA: <%= customer.phone %><% } %>
                  <% if (customer.package_name) { %> - Paket: <%= customer.package_name %><% } %>
                </div>
              </div>
              <div>
                <% const unpaidCount = unpaidInvoices ? unpaidInvoices.length : 0; %>
                <% if (unpaidCount > 0) { %>
                  <span class="pill pill-u"><i class="bi bi-exclamation-circle"></i> <%= unpaidCount %> Belum Bayar</span>
                <% } else { %>
                  <span class="pill pill-p"><i class="bi bi-check-circle"></i> Lunas</span>
                <% } %>
              </div>
            </div>
          </div>

          <% const monthNames = ['','Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des']; %>

          <% if (!unpaidInvoices || unpaidInvoices.length === 0) { %>
            <div class="alert alert-success">
              <i class="bi bi-check-circle me-2"></i>Semua tagihan sudah lunas.
            </div>
          <% } else { %>
            <%
              const unpaidTotalAmount = (unpaidInvoices || []).reduce((sum, inv) => sum + (Number(inv.amount || 0) || 0), 0);
              const canBulkPay = unpaidInvoices.length > 1 && !!(typeof bulkToken !== 'undefined' && bulkToken);
            %>
            <div class="mb-2 fw-bold">Tagihan Belum Dibayar</div>
            <% if (canBulkPay) { %>
              <div class="pay-mode-grid" aria-label="Pilihan cara bayar">
                <input class="pay-mode-radio" type="radio" id="mode_bulk" name="pay_mode" value="bulk" checked>
                <label class="pay-mode-card" for="mode_bulk">
                  <i class="bi bi-credit-card-2-front-fill"></i>
                  <span>
                    <strong>Bayar Semua</strong>
                    <span><%= unpaidInvoices.length %> tagihan - Rp <%= Number(unpaidTotalAmount || 0).toLocaleString('id-ID') %></span>
                  </span>
                </label>
                <input class="pay-mode-radio" type="radio" id="mode_single" name="pay_mode" value="single">
                <label class="pay-mode-card" for="mode_single">
                  <i class="bi bi-list-check"></i>
                  <span>
                    <strong>Bayar 1 Tagihan</strong>
                    <span>Pilih periode tertentu saja</span>
                  </span>
                </label>
              </div>
            <% } %>
            <div class="table-responsive">
              <table class="tbl">
                <thead>
                  <tr>
                    <th>Periode</th>
                    <th class="text-end">Nominal</th>
                    <th class="text-end" style="width: 80px">Pilih</th>
                  </tr>
                </thead>
                <tbody>
                  <% unpaidInvoices.forEach((inv, idx) => { %>
                    <% const flags = inv.public_flags || {}; %>
                    <tr class="billing-row-single <%= canBulkPay ? 'is-disabled' : '' %>">
                      <td>
                        <div class="fw-semibold"><%= monthNames[Number(inv.period_month)] %> <%= inv.period_year %></div>
                        <div class="muted small">INV-<%= inv.id %></div>
                        <% if (flags.pastPeriod || flags.duePassed || flags.isolated) { %>
                          <div class="invoice-flags">
                            <% if (flags.pastPeriod) { %>
                              <span class="invoice-flag late"><i class="bi bi-clock-history"></i> Invoice terlewat</span>
                            <% } else if (flags.duePassed) { %>
                              <span class="invoice-flag late"><i class="bi bi-exclamation-circle"></i> Lewat jatuh tempo</span>
                            <% } %>
                            <% if (flags.isolated) { %>
                              <span class="invoice-flag isolated"><i class="bi bi-wifi-off"></i> Isolir/Suspend</span>
                            <% } %>
                          </div>
                        <% } %>
                      </td>
                      <td class="text-end fw-semibold">Rp <%= Number(inv.amount || 0).toLocaleString('id-ID') %></td>
                      <td class="text-end">
                        <input
                          class="form-check-input inv-radio"
                          type="radio"
                          name="inv_select"
                          value="<%= inv.id %>"
                          data-inv-id="<%= inv.id %>"
                          data-amount="<%= Number(inv.amount || 0) %>"
                          data-token="<%= (invoiceTokens && invoiceTokens[String(inv.id)]) ? invoiceTokens[String(inv.id)] : '' %>"
                          <%= idx === 0 ? 'checked' : '' %>
                          <%= idx === 0 ? 'required' : '' %>
                        >
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <div class="mt-3" style="border-top:1px solid var(--table-border); padding-top: 14px">
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                <div class="fw-bold">Pembayaran</div>
                <div class="payment-summary">
                  <span id="pay_inv_text"></span>
                  <span id="pay_amount_text"></span>
                </div>
              </div>

              <form id="payForm" method="POST" action="/customer/public/payment/create/0" class="d-grid gap-2">
                <input type="hidden" name="token" id="pay_token" value="">
                <input type="hidden" id="bulk_token" value="<%= bulkToken || '' %>">
                <input type="hidden" id="bulk_amount" value="<%= Number(unpaidTotalAmount || 0) %>">
                <input type="hidden" id="bulk_count" value="<%= Number(unpaidInvoices.length || 0) %>">

                <% if (paymentChannels && paymentChannels.length > 0) { %>
                  <div class="payment-methods-grid pay-scroll">
                    <%
                      const sortedChannels = [...paymentChannels].sort((a, b) => {
                        const rank = (channel) => {
                          const code = String(channel.code || '').toUpperCase();
                          const source = String(channel.source || '').toLowerCase();
                          const group = String(channel.group || '');
                          if (source === 'tripay' && code.startsWith('QRIS')) return 1;
                          if (code.startsWith('QRIS')) return 2;
                          if (group === 'E-Wallet') return 10;
                          if (group === 'Virtual Account') return 20;
                          if (group === 'Convenience Store') return 30;
                          if (code === 'STATICQRIS') return 90;
                          return 80;
                        };
                        const prioA = rank(a);
                        const prioB = rank(b);
                        return prioA - prioB;
                      });
                      const activeChannels = sortedChannels.filter(c => c.active);
                      activeChannels.forEach((channel, idx) => {
                        const code = String(channel.code || '').toUpperCase();
                        const iconUrl = channel.icon_url || channel.iconUrl || '';
                        const brandMap = {
                          DANA: { label: 'DANA', cls: 'pb-dana' },
                          OVO: { label: 'OVO', cls: 'pb-ovo' },
                          SHOPEEPAY: { label: 'SP', cls: 'pb-shopeepay' },
                          LINKAJA: { label: 'LA', cls: 'pb-linkaja' },
                          GOPAY: { label: 'GoPay', cls: 'pb-gopay' }
                        };
                        let brand = null;
                        for (const k of Object.keys(brandMap)) { if (code.includes(k)) { brand = brandMap[k]; break; } }
                        const bankMap = { BCAVA: 'BCA', BNIVA: 'BNI', BRIVA: 'BRI', MANDIRIVA: 'Mandiri', PERMATAVA: 'Permata', CIMBVA: 'CIMB', DANAMONVA: 'Danamon' };
                        if (!brand && bankMap[code]) brand = { label: bankMap[code], cls: 'pb-bank' };
                        const nameMap = { BCAVA: 'BCA VA', BNIVA: 'BNI VA', BRIVA: 'BRI VA', MANDIRIVA: 'Mandiri VA', PERMATAVA: 'Permata VA', CIMBVA: 'CIMB VA', DANAMONVA: 'Danamon VA', QRIS: 'Bayar Online Tripay', QRIS2: 'Bayar Online Tripay' };
                        let shortName = nameMap[code] || String(channel.name || '').trim();
                        shortName = shortName.replace(/virtual account/ig, 'VA').replace(/QRIS/ig, 'Bayar Online').replace(/^bank\s+/ig, '').replace(/\s+/g, ' ').trim();
                        if (!nameMap[code] && code.includes('QRIS') && brand) shortName = `Bayar Online ${brand.label}`;
                        const group = String(channel.group || '');
                        const isQrisTripay = code.startsWith('QRIS');
                        const groupIcon = isQrisTripay ? 'bi-credit-card-2-front' : group === 'Virtual Account' ? 'bi-bank2' : group === 'E-Wallet' ? 'bi-wallet2' : group === 'Convenience Store' ? 'bi-shop' : 'bi-credit-card-2-front';
                        const shortGroup = isQrisTripay ? 'Online' : group === 'Virtual Account' ? 'VA' : group === 'E-Wallet' ? 'E-Wallet' : group === 'Convenience Store' ? 'CS' : group === 'QRIS' ? 'Online' : String(group || '').replace(/QRIS/ig, 'Online');
                        const radioId = `pm_${idx}_${code}`;
                    %>
                      <input class="pm-radio" type="radio" id="<%= radioId %>" name="method" value="<%= channel.code %>" <%= idx === 0 ? 'checked required' : '' %>>
                      <label class="pay-method-item" for="<%= radioId %>">
                        <div class="p-icon">
                          <% if (iconUrl) { %>
                            <img class="p-logo" src="<%= iconUrl %>" alt="<%= channel.name %>" loading="lazy" referrerpolicy="no-referrer">
                          <% } else if (brand) { %>
                            <span class="p-badge <%= brand.cls %>"><%= brand.label %></span>
                          <% } else { %>
                            <i class="bi <%= groupIcon %>"></i>
                          <% } %>
                        </div>
                        <div class="p-info">
                          <span class="p-name"><%= shortName %></span>
                          <span class="p-sub"><%= isQrisTripay ? 'Payment gateway otomatis' : group === 'Virtual Account' ? 'Transfer bank otomatis' : group === 'E-Wallet' ? 'Bayar langsung dari e-wallet' : group === 'QRIS' ? 'Pembayaran online otomatis' : 'Pembayaran digital' %></span>
                        </div>
                        <span class="p-chip"><%= shortGroup %></span>
                      </label>
                    <% }) %>
                  </div>
                <% } else { %>
                  <% const staticQrisEnabled = !!(settings && settings.qris_static_enabled !== false && settings.qris_static_enabled !== 'false' && (settings.qris_static_qr_url || settings.qris_static_payload)); %>
                  <input type="hidden" name="method" value="<%= staticQrisEnabled ? 'STATICQRIS' : 'QRIS' %>">
                  <div class="payment-methods-grid">
                    <div class="pay-method-item" style="cursor: default">
                      <div class="p-icon"><i class="bi bi-credit-card-2-front"></i></div>
                      <div class="p-info">
                        <span class="p-name"><%= staticQrisEnabled ? 'Bayar Online Cadangan' : 'Bayar Online / E-Wallet' %></span>
                        <span class="p-sub">Ikuti instruksi pembayaran agar otomatis terbaca.</span>
                      </div>
                      <span class="p-chip">Online</span>
                    </div>
                  </div>
                <% } %>

                <div class="form-check">
                  <input class="form-check-input" type="checkbox" value="1" id="tos_pay" name="tos" required>
                  <label class="form-check-label muted" for="tos_pay">
                    Saya setuju dengan <a href="/customer/tos" target="_blank" rel="noopener">Syarat & Ketentuan</a>
                  </label>
                </div>

                <button id="payBtn" class="btn btn-primary btnx" type="submit" disabled>
                  <i class="bi bi-credit-card me-1"></i> Bayar
                </button>
              </form>

              <% if (settings.manual_payment_bank && settings.manual_payment_account_number) { %>
                <div class="section-card mt-3">
                  <div class="section-title mb-2">Transfer Manual</div>
                  <div class="manual-grid">
                    <div class="manual-item">
                      <small>Bank</small>
                      <strong><%= settings.manual_payment_bank %></strong>
                    </div>
                    <div class="manual-item">
                      <small>No. Rekening</small>
                      <strong><%= settings.manual_payment_account_number %></strong>
                    </div>
                    <% if (settings.manual_payment_account_name) { %>
                      <div class="manual-item">
                        <small>Atas Nama</small>
                        <strong><%= settings.manual_payment_account_name %></strong>
                      </div>
                    <% } %>
                    <% if (settings.manual_payment_notes) { %>
                      <div class="manual-item full">
                        <small>Catatan</small>
                        <strong><%= settings.manual_payment_notes %></strong>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>

            <script>
              (function () {
                const radios = Array.from(document.querySelectorAll('.inv-radio'));
                const payForm = document.getElementById('payForm');
                const payToken = document.getElementById('pay_token');
                const payBtn = document.getElementById('payBtn');
                const invText = document.getElementById('pay_inv_text');
                const amtText = document.getElementById('pay_amount_text');
                const modeRadios = Array.from(document.querySelectorAll('.pay-mode-radio'));
                const bulkToken = document.getElementById('bulk_token');
                const bulkAmount = document.getElementById('bulk_amount');
                const bulkCount = document.getElementById('bulk_count');
                const singleRows = Array.from(document.querySelectorAll('.billing-row-single'));
                const methodRadios = Array.from(document.querySelectorAll('.pm-radio[name="method"]'));

                function syncSelectedPaymentMethod() {
                  methodRadios.forEach(input => {
                    const card = input.nextElementSibling;
                    if (!card || !card.classList || !card.classList.contains('pay-method-item')) return;
                    const checked = !!input.checked;
                    card.classList.toggle('is-selected', checked);
                    card.setAttribute('aria-pressed', checked ? 'true' : 'false');
                  });
                }

                function currentMode() {
                  const checked = modeRadios.find(r => r.checked);
                  return checked ? String(checked.value || 'single') : 'single';
                }

                function setRowsEnabled(enabled) {
                  singleRows.forEach(row => row.classList.toggle('is-disabled', !enabled));
                  radios.forEach(r => { r.disabled = !enabled; });
                }

                function setBulkSelected() {
                  if (!payForm || !payToken || !payBtn || !bulkToken) return;
                  const token = String(bulkToken.value || '').trim();
                  const amount = Number(bulkAmount?.value || 0) || 0;
                  const count = Number(bulkCount?.value || 0) || 0;
                  payForm.action = '/customer/public/payment/create/bulk';
                  payToken.value = token;
                  if (invText) invText.textContent = count ? `${count} tagihan - ` : 'Semua tagihan - ';
                  if (amtText) amtText.textContent = amount ? `Rp ${amount.toLocaleString('id-ID')}` : '';
                  payBtn.disabled = !token || !amount;
                  payBtn.innerHTML = '<i class="bi bi-credit-card me-1"></i> Bayar Semua';
                  setRowsEnabled(false);
                }

                function setSelected(r) {
                  if (!r || !payForm || !payToken || !payBtn) return;
                  const invId = String(r.dataset.invId || r.value || '').trim();
                  const token = String(r.dataset.token || '').trim();
                  const amount = Number(r.dataset.amount || 0) || 0;

                  payForm.action = `/customer/public/payment/create/${encodeURIComponent(invId)}`;
                  payToken.value = token;
                  if (invText) invText.textContent = invId ? `INV-${invId} - ` : '';
                  if (amtText) amtText.textContent = amount ? `Rp ${amount.toLocaleString('id-ID')}` : '';
                  payBtn.disabled = !invId || !token;
                  payBtn.innerHTML = '<i class="bi bi-credit-card me-1"></i> Bayar Tagihan Ini';
                  setRowsEnabled(true);
                }

                function refreshPaymentTarget() {
                  if (currentMode() === 'bulk') {
                    setBulkSelected();
                    return;
                  }
                  const selected = radios.find(r => r.checked) || radios[0];
                  if (selected) setSelected(selected);
                }

                modeRadios.forEach(r => r.addEventListener('change', refreshPaymentTarget));
                radios.forEach(r => r.addEventListener('change', () => {
                  const singleMode = document.getElementById('mode_single');
                  if (singleMode) singleMode.checked = true;
                  refreshPaymentTarget();
                }));
                methodRadios.forEach(r => r.addEventListener('change', syncSelectedPaymentMethod));
                const first = radios.find(r => r.checked) || radios[0];
                if (first) refreshPaymentTarget();
                syncSelectedPaymentMethod();
              })();
            </script>
          <% } %>

          <% const paidInvoices = (invoices || []).filter(i => i.status === 'paid'); %>
          <% if (paidInvoices.length > 0) { %>
            <div class="mt-4">
              <div class="mb-2 fw-bold">Riwayat Pembayaran</div>
              <div class="table-responsive mt-2">
                <table class="tbl">
                  <thead>
                    <tr>
                      <th>Periode</th>
                      <th class="text-end">Nominal</th>
                      <th>Tanggal</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% paidInvoices.slice(0, 10).forEach(inv => { %>
                      <tr>
                        <td>
                          <div class="fw-semibold"><%= monthNames[Number(inv.period_month)] %> <%= inv.period_year %></div>
                          <div class="muted small">INV-<%= inv.id %></div>
                        </td>
                        <td class="text-end">Rp <%= Number(inv.amount || 0).toLocaleString('id-ID') %></td>
                        <td class="muted small"><%= inv.paid_at ? new Date(inv.paid_at).toLocaleString('id-ID') : '-' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>
        <% } %>

        <div class="muted small mt-4">
          &copy; <%= new Date().getFullYear() %> <%= settings.company_header || '' %>
        </div>
      </div>
    </div>
    </div>
  </div>
  <script>
    (function () {
      const btn = document.getElementById('themeToggleBtn');
      const icon = document.getElementById('themeToggleIcon');
      const meta = document.querySelector('meta[name="theme-color"]');

      function applyTheme(theme, persist) {
        const nextTheme = theme === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', nextTheme);
        if (icon) {
          icon.className = `bi ${nextTheme === 'dark' ? 'bi-sun-fill' : 'bi-moon-stars'}`;
        }
        if (meta) {
          meta.setAttribute('content', nextTheme === 'dark' ? '#0f172a' : '#eef4ff');
        }
        if (persist) {
          try { localStorage.setItem('customer-portal-theme', nextTheme); } catch (e) {}
        }
      }

      btn?.addEventListener('click', function () {
        const current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        applyTheme(current === 'dark' ? 'light' : 'dark', true);
      });

      applyTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light', false);
    })();
  </script>
</body>
</html>
