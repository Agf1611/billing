<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">

<head>
  <% const logoSrc = (settings && settings.company_logo_url) ? settings.company_logo_url : '/img/mss-logo.png'; %>
  <% const waContact = settings.company_phone || (settings.whatsapp_admin_numbers ? settings.whatsapp_admin_numbers[0] : ''); %>
  <% const waLink = waContact ? buildWhatsAppLink(waContact) : '#'; %>
  <% const supportEmail = settings.company_email || `support@${company.toLowerCase().replace(/\s+/g, '')}.com`; %>
  <% const supportHours = settings.operational_hours || 'Setiap Hari: 08.00 - 22.00 WIB'; %>
  <% const supportAddress = settings.company_address || 'Jl. Utama ISP No. 123, Indonesia'; %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= t('customer.pages.contact.meta_title', 'Kontak Support') %> | <%= company %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#f6faff">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="apple-touch-icon" href="<%= logoSrc %>">
  <link rel="icon" href="<%= logoSrc %>">
  <style>
    :root {
      --bg-top: #ffffff;
      --bg-bottom: #eef5ff;
      --surface: rgba(255, 255, 255, 0.94);
      --surface-soft: #f8fbff;
      --line: rgba(98, 128, 184, 0.16);
      --text-main: #1a2740;
      --text-soft: #697897;
      --text-faint: #8c99b0;
      --brand: #073dcc;
      --brand-deep: #0634b0;
      --mint: #10a37f;
      --amber: #f59e0b;
      --rose: #ea580c;
      --sky: #0284c7;
      --shadow: 0 28px 70px rgba(41, 79, 143, 0.12);
    }

    * { box-sizing: border-box; }

    html, body {
      min-height: 100%;
      margin: 0;
      font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text-main);
      background:
        radial-gradient(circle at top left, rgba(67, 156, 255, 0.18) 0%, rgba(67, 156, 255, 0) 34%),
        radial-gradient(circle at top right, rgba(16, 163, 127, 0.12) 0%, rgba(16, 163, 127, 0) 28%),
        linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
      -webkit-tap-highlight-color: transparent;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.16;
      background-image:
        linear-gradient(rgba(45, 107, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(45, 107, 255, 0.04) 1px, transparent 1px);
      background-size: 34px 34px;
    }

    .page-wrap {
      position: relative;
      z-index: 1;
      width: min(100%, 980px);
      margin: 0 auto;
      padding: calc(20px + env(safe-area-inset-top)) 18px calc(96px + env(safe-area-inset-bottom));
    }

    .hero-card,
    .content-card {
      border-radius: 28px;
      background: var(--surface);
      border: 1px solid rgba(255, 255, 255, 0.72);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .hero-card {
      padding: 18px;
      margin-bottom: 16px;
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
    }

    .brand-mark {
      width: 64px;
      height: 64px;
      flex: 0 0 64px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      background: linear-gradient(145deg, rgba(255,255,255,0.98), rgba(236,244,255,0.95));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.86), 0 16px 28px rgba(45, 107, 255, 0.12);
    }

    .brand-mark img {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }

    .brand-copy strong {
      display: block;
      margin-bottom: 4px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 800;
      color: var(--text-faint);
    }

    .brand-copy span {
      display: block;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 24px;
      line-height: 1.04;
      font-weight: 800;
      letter-spacing:0;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
      gap: 14px;
      align-items: stretch;
    }

    .hero-copy {
      padding: 18px;
      border-radius: 22px;
      background: linear-gradient(145deg, rgba(255,255,255,0.95), rgba(244,249,255,0.92));
      border: 1px solid rgba(255,255,255,0.7);
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(16, 163, 127, 0.1);
      color: #0c8a6f;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 12px;
    }

    .hero-copy h1 {
      margin: 0 0 8px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: clamp(28px, 4vw, 38px);
      line-height: 1.02;
      font-weight: 800;
      letter-spacing:0;
    }

    .hero-copy p {
      margin: 0;
      color: var(--text-soft);
      font-size: 14px;
      line-height: 1.65;
      max-width: 60ch;
    }

    .quick-panel {
      padding: 18px;
      border-radius: 22px;
      background: linear-gradient(155deg, rgba(45, 107, 255, 0.96), rgba(31, 79, 215, 0.92));
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .quick-panel strong {
      display: block;
      margin-bottom: 6px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing:0;
    }

    .quick-panel p {
      margin: 0;
      font-size: 12px;
      line-height: 1.6;
      color: rgba(255,255,255,0.88);
    }

    .quick-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .quick-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 11px;
      border-radius: 999px;
      background: rgba(255,255,255,0.14);
      font-size: 11px;
      color: #fff;
      text-decoration: none;
    }

    .legal-tabs {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 16px;
    }

    .legal-tab {
      min-height: 46px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 12px;
      border-radius: 15px;
      text-decoration: none;
      border: 1px solid rgba(45, 107, 255, 0.12);
      background: rgba(255,255,255,0.88);
      color: var(--brand-deep);
      font-size: 12px;
      font-weight: 800;
      transition: 0.2s ease;
    }

    .legal-tab.active {
      background: linear-gradient(135deg, var(--brand) 0%, #4d8cff 100%);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 14px 26px rgba(45, 107, 255, 0.18);
    }

    .legal-tab:hover {
      color: inherit;
      transform: translateY(-1px);
    }

    .content-card {
      padding: 20px;
    }

    .lead-copy {
      margin-bottom: 16px;
      padding: 16px 18px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(247,250,255,0.95), rgba(240,246,255,0.92));
      border: 1px solid var(--line);
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-soft);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .contact-card {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 18px;
      border-radius: 20px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
      transition: 0.2s ease;
    }

    .contact-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 28px rgba(41, 79, 143, 0.08);
      color: inherit;
    }

    .contact-card.full {
      grid-column: span 2;
    }

    .contact-icon {
      width: 48px;
      height: 48px;
      flex: 0 0 48px;
      display: grid;
      place-items: center;
      border-radius: 16px;
      font-size: 18px;
    }

    .contact-card:nth-child(1) .contact-icon {
      background: rgba(16, 163, 127, 0.12);
      color: var(--mint);
    }

    .contact-card:nth-child(2) .contact-icon {
      background: rgba(234, 88, 12, 0.12);
      color: var(--rose);
    }

    .contact-card:nth-child(3) .contact-icon {
      background: rgba(245, 158, 11, 0.14);
      color: var(--amber);
    }

    .contact-card:nth-child(4) .contact-icon {
      background: rgba(2, 132, 199, 0.12);
      color: var(--sky);
    }

    .contact-card strong,
    .contact-card span {
      display: block;
    }

    .contact-card strong {
      margin-bottom: 5px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 16px;
      font-weight: 800;
      letter-spacing:0;
      color: var(--text-main);
    }

    .contact-card span {
      font-size: 13px;
      line-height: 1.65;
      color: var(--text-soft);
      word-break: break-word;
    }

    .page-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--line);
    }

    .page-actions .note {
      font-size: 12px;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 46px;
      padding: 0 16px;
      border-radius: 15px;
      border: 1px solid rgba(45, 107, 255, 0.14);
      background: rgba(45, 107, 255, 0.06);
      color: var(--brand-deep);
      text-decoration: none;
      font-size: 13px;
      font-weight: 800;
      transition: 0.2s ease;
    }

    .btn-back:hover {
      color: var(--brand-deep);
      background: rgba(45, 107, 255, 0.1);
      border-color: rgba(45, 107, 255, 0.24);
      transform: translateY(-1px);
    }

    .footer {
      text-align: center;
      margin-top: 18px;
      font-size: 12px;
      color: var(--text-soft);
    }

    @media (max-width: 860px) {
      .hero-grid,
      .contact-grid {
        grid-template-columns: 1fr;
      }

      .contact-card.full {
        grid-column: span 1;
      }
    }

    @media (max-width: 640px) {
      .page-wrap {
        padding-left: 14px;
        padding-right: 14px;
      }

      .brand-row {
        align-items: flex-start;
      }

      .brand-mark {
        width: 56px;
        height: 56px;
        flex-basis: 56px;
      }

      .brand-mark img {
        width: 42px;
        height: 42px;
      }

      .brand-copy span {
        font-size: 21px;
      }

      .hero-copy,
      .quick-panel,
      .content-card,
      .contact-card {
        padding-left: 14px;
        padding-right: 14px;
      }

      .legal-tabs {
        grid-template-columns: 1fr;
      }

      .page-actions {
        flex-direction: column;
        align-items: stretch;
      }
    }
  </style>
</head>

<body>
  <div class="page-wrap">
    <section class="hero-card">
      <div class="brand-row">
        <div class="brand-mark">
          <img src="<%= logoSrc %>" alt="Logo <%= company %>">
        </div>
        <div class="brand-copy">
          <strong>Portal Pelanggan</strong>
          <span><%= company %></span>
        </div>
      </div>

      <div class="hero-grid">
        <div class="hero-copy">
          <div class="eyebrow"><i class="bi bi-headset"></i> Bantuan Resmi</div>
          <h1><%= t('customer.pages.contact.title', 'Hubungi Kami') %></h1>
          <p><%= t('customer.pages.contact.subtitle', 'Kami siap membantu setiap kendala internet Anda.') %></p>
        </div>

        <aside class="quick-panel">
          <div>
            <strong>Respon lebih cepat</strong>
            <p>Gunakan kontak resmi di bawah untuk bantuan teknis, pertanyaan pembayaran, atau informasi pemasangan baru.</p>
          </div>
          <div class="quick-pills">
            <span class="quick-pill"><i class="bi bi-clock-history"></i> <%= supportHours %></span>
            <% if (waContact) { %>
              <a href="<%= waLink %>" class="quick-pill"><i class="bi bi-whatsapp"></i> WhatsApp</a>
            <% } %>
          </div>
        </aside>
      </div>

      <div class="legal-tabs">
        <a href="/customer/tos" class="legal-tab">
          <i class="bi bi-file-text"></i>
          <span>Ketentuan</span>
        </a>
        <a href="/customer/privacy" class="legal-tab">
          <i class="bi bi-shield-check"></i>
          <span>Privasi</span>
        </a>
        <a href="/customer/contact" class="legal-tab active">
          <i class="bi bi-headset"></i>
          <span>Kontak</span>
        </a>
      </div>
    </section>

    <section class="content-card">
      <div class="lead-copy">
        <%= t('customer.pages.contact.p1', 'Tim support kami tersedia untuk melayani pertanyaan teknis, bantuan pembayaran, atau informasi pemasangan baru.') %>
      </div>

      <div class="contact-grid">
        <a href="<%= waLink %>" class="contact-card">
          <div class="contact-icon">
            <i class="bi bi-whatsapp"></i>
          </div>
          <div>
            <strong><%= t('customer.pages.contact.whatsapp_title', 'WhatsApp Support') %></strong>
            <span><%= waContact || t('customer.pages.contact.whatsapp_fallback', 'Hubungi WhatsApp Kami') %> • <%= t('customer.pages.contact.fast_response', 'Respon Cepat') %></span>
          </div>
        </a>

        <div class="contact-card">
          <div class="contact-icon">
            <i class="bi bi-envelope"></i>
          </div>
          <div>
            <strong><%= t('customer.pages.contact.email_title', 'Email Support') %></strong>
            <span><%= supportEmail %></span>
          </div>
        </div>

        <div class="contact-card">
          <div class="contact-icon">
            <i class="bi bi-clock-history"></i>
          </div>
          <div>
            <strong><%= t('customer.pages.contact.hours_title', 'Jam Operasional') %></strong>
            <span><%= supportHours %></span>
          </div>
        </div>

        <div class="contact-card full">
          <div class="contact-icon">
            <i class="bi bi-geo-alt"></i>
          </div>
          <div>
            <strong><%= t('customer.pages.contact.address_title', 'Alamat Kantor') %></strong>
            <span><%= supportAddress %></span>
          </div>
        </div>
      </div>

      <div class="page-actions">
        <div class="note">Gunakan kanal kontak resmi di atas agar proses bantuan pelanggan, pembayaran, dan gangguan lebih cepat ditangani.</div>
        <a href="<%= isLoggedIn ? '/customer/dashboard' : '/customer/login' %>" class="btn-back">
          <i class="bi bi-arrow-left"></i>
          <span><%= t('common.back_to', 'Kembali ke') %> <%= isLoggedIn ? t('customer.dashboard_title', 'Dashboard Pelanggan') : t('common.portal', 'Portal') %></span>
        </a>
      </div>
    </section>

    <div class="footer">
      &copy; <%= new Date().getFullYear() %> <%= company %> • <%= t('customer.pages.contact.footer_tagline', 'Kepuasan Pelanggan adalah Kebanggaan Kami') %>
    </div>
  </div>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/customer/' }).catch(() => {});
      });
    }
  </script>
  <%- include('partials/customer_bottom_nav', { activeNav: 'ticket' }) %>
</body>

</html>
