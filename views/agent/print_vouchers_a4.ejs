<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Print Voucher Agent #<%= batch.id %></title>
  <style>
    @page{size:A4;margin:5mm}
    *{box-sizing:border-box}
    body{margin:0;font-family:Arial,Helvetica,sans-serif;color:#111827;background:#fff}
    .sheet{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:27.2mm;gap:1mm;break-after:page}
    .sheet:last-child{break-after:auto}
    .voucher{
      position:relative;
      overflow:hidden;
      border:1.2px solid #111827;
      border-radius:1mm;
      background:
        radial-gradient(16mm 14mm at 84% 20%, var(--vc-soft), transparent 72%),
        linear-gradient(135deg, #ffffff 0%, #ffffff 64%, var(--vc-wash) 100%);
      padding:1.3mm 1.6mm 4.1mm;
      display:grid;
      grid-template-columns:minmax(0,1fr) 14.2mm;
      gap:1mm;
      min-height:27.2mm;
    }
    .voucher:before{
      content:"";
      position:absolute;
      width:21mm;height:21mm;
      right:-7mm;top:-9mm;
      border-radius:50%;
      background:var(--vc-soft);
    }
    .voucher:after{
      content:"SICKAS";
      position:absolute;
      right:15mm;bottom:6.4mm;
      color:var(--vc-mark);
      font-size:13pt;
      font-weight:900;
      transform:rotate(-12deg);
    }
    .logo-row{display:flex;align-items:center;gap:1mm;min-width:0}
    .logo-box{width:9.5mm;height:5.8mm;border-radius:.7mm;background:#fff;border:1px solid var(--vc-accent);display:grid;place-items:center;flex:0 0 auto}
    .logo{max-width:8.5mm;max-height:4.8mm;object-fit:contain}
    .brand{font-weight:950;font-size:7.1pt;line-height:.95;color:var(--vc-brand);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-transform:uppercase}
    .brand-sub{font-size:4.2pt;font-weight:950;color:#4b5563;text-transform:uppercase;letter-spacing:.12mm;line-height:1.05;margin-top:.2mm}
    .label{font-size:4.9pt;font-weight:950;color:#111827;margin-top:1mm;text-transform:uppercase}
    .code{font-size:12.8pt;font-weight:950;letter-spacing:.12mm;line-height:1;color:#050816;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .info-row{display:grid;grid-template-columns:1fr 1fr;gap:.7mm;margin-top:.8mm}
    .info-chip{border:1px solid #e5e7eb;background:#fff;border-radius:.9mm;padding:.55mm .7mm;min-width:0}
    .info-chip small{display:block;font-size:3.7pt;font-weight:950;color:#4b5563;text-transform:uppercase;line-height:1}
    .info-chip b{display:block;font-size:5.25pt;font-weight:950;color:#050816;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.12;margin-top:.35mm}
    .pass{font-size:5.6pt;font-weight:900;color:#050816;margin-top:.55mm;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .hint{font-size:4.2pt;font-weight:800;line-height:1.05;color:#111827;margin-top:.75mm;max-height:4.4mm;overflow:hidden}
    .side{text-align:right;display:flex;flex-direction:column;align-items:flex-end;min-width:0}
    .price-k{font-size:5.6pt;font-weight:950;color:var(--vc-accent);line-height:1}
    .price{
      max-width:15mm;
      font-size:10.8pt;
      font-weight:950;
      color:var(--vc-accent);
      line-height:1;
      margin-bottom:1mm;
      white-space:nowrap;
      transform-origin:right top;
      transform:scaleX(.88);
    }
    .valid{font-size:4.55pt;font-weight:950;color:#111827;margin-top:.3mm;text-transform:uppercase;line-height:1.05}
    .wifi-mark{
      margin-top:auto;
      width:11.2mm;height:7.5mm;
      border-radius:.9mm;
      display:grid;
      place-items:center;
      background:var(--vc-wash);
      color:var(--vc-brand);
      font-size:4.5pt;
      font-weight:950;
      text-transform:uppercase;
      border:1px solid var(--vc-accent);
    }
    .status{
      margin-top:.7mm;
      border:1px solid #111827;
      font-size:4.5pt;
      font-weight:950;
      padding:.7mm .9mm;
      text-transform:uppercase;
      color:#111827;
      background:#fff;
    }
    .foot{
      position:absolute;left:0;right:0;bottom:0;
      background:var(--vc-accent);color:#fff;font-size:5.5pt;font-weight:950;
      padding:.85mm 1.6mm;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    }
    .no-print{padding:8px 10px;margin-bottom:8px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;font-size:12px}
    @media print{.no-print{display:none}}
  </style>
</head>
<body>
  <div class="no-print">
    Print A4 Batch #<%= batch.id %> - <%= vouchers.length %> voucher siap cetak.
    <% if (Number(skippedCount || 0) > 0) { %>
      <strong><%= Number(skippedCount || 0) %> voucher yang sudah terjual/digunakan/dicetak tidak ikut dicetak.</strong>
    <% } %>
  </div>
  <%
    const logo = settings.company_logo_url || '/img/logo.png';
    const phone = (settings.whatsapp_admin_numbers && settings.whatsapp_admin_numbers.length > 0)
      ? '+' + settings.whatsapp_admin_numbers[0]
      : (settings.company_phone || '-');
    function voucherTheme(price) {
      const value = Number(price || 0);
      const palettes = [
        { accent:'#a21caf', brand:'#0891b2', soft:'rgba(162,28,175,.10)', wash:'#fdf4ff', mark:'rgba(8,145,178,.08)' },
        { accent:'#2563eb', brand:'#0f766e', soft:'rgba(37,99,235,.12)', wash:'#eff6ff', mark:'rgba(15,118,110,.08)' },
        { accent:'#dc2626', brand:'#be123c', soft:'rgba(220,38,38,.11)', wash:'#fff1f2', mark:'rgba(190,18,60,.08)' },
        { accent:'#16a34a', brand:'#047857', soft:'rgba(22,163,74,.12)', wash:'#f0fdf4', mark:'rgba(4,120,87,.08)' },
        { accent:'#ea580c', brand:'#c2410c', soft:'rgba(234,88,12,.12)', wash:'#fff7ed', mark:'rgba(194,65,12,.08)' },
        { accent:'#7c3aed', brand:'#4338ca', soft:'rgba(124,58,237,.12)', wash:'#f5f3ff', mark:'rgba(67,56,202,.08)' }
      ];
      return palettes[Math.abs(Math.floor(value / 1000)) % palettes.length];
    }
    const theme = voucherTheme(batch.price);
    const themeStyle = `--vc-accent:${theme.accent};--vc-brand:${theme.brand};--vc-soft:${theme.soft};--vc-wash:${theme.wash};--vc-mark:${theme.mark};`;
    const chunks = [];
    for (let i = 0; i < vouchers.length; i += 40) chunks.push(vouchers.slice(i, i + 40));
  %>
  <% if (!vouchers.length) { %>
    <div class="no-print">Tidak ada voucher siap cetak di batch ini.</div>
  <% } %>
  <% chunks.forEach(chunk => { %>
    <section class="sheet">
      <% chunk.forEach(v => { %>
        <article class="voucher" style="<%= themeStyle %>">
          <div>
            <div class="logo-row">
              <div class="logo-box"><img class="logo" src="<%= logo %>" alt=""></div>
              <div>
                <div class="brand"><%= settings.company_header || company %></div>
                <div class="brand-sub">Voucher WiFi</div>
              </div>
            </div>
            <div class="label">Kode Voucher</div>
            <div class="code"><%= v.code %></div>
            <% if (v.password && v.password !== v.code) { %><div class="pass">Pass: <%= v.password %></div><% } %>
            <div class="info-row">
              <div class="info-chip"><small>Paket</small><b><%= batch.profile_name || v.profile_name || '-' %></b></div>
              <div class="info-chip"><small>Aktif</small><b><%= batch.validity || '-' %></b></div>
            </div>
            <div class="hint">
              Hubungkan ke WiFi, buka browser, login memakai kode voucher.
            </div>
          </div>
          <div class="side">
            <div class="price-k">Rp</div>
            <div class="price"><%= Number(batch.price || 0).toLocaleString('id-ID') %></div>
            <div class="valid">Login<br>User=Kode</div>
            <div class="wifi-mark">WiFi<br>Access</div>
            <div class="status"><%= (v.sold_at || v.used_at) ? 'Terjual' : (v.printed_at ? 'Dicetak' : 'Siap Dijual') %></div>
          </div>
          <div class="foot">CS: <%= phone %></div>
        </article>
      <% }) %>
    </section>
  <% }) %>
  <script>
    window.addEventListener('load', function () {
      setTimeout(function () { window.print(); }, 400);
    });
  </script>
</body>
</html>
