<script>
  (function () {
    const btn = document.getElementById('agentThemeToggle');
    const root = document.documentElement;
    if (!btn) return;
    const apply = (theme) => {
      root.setAttribute('data-theme', theme);
      const icon = btn.querySelector('i');
      if (icon) icon.className = theme === 'light' ? 'bi bi-moon-stars' : 'bi bi-sun';
    };
    apply(root.getAttribute('data-theme') || 'dark');
    btn.addEventListener('click', () => {
      const next = (root.getAttribute('data-theme') || 'dark') === 'light' ? 'dark' : 'light';
      try { localStorage.setItem('agent-theme', next); } catch (e) {}
      apply(next);
    });
  })();

  function agentBuildVoucherText(data) {
    const lines = [
      'Voucher WiFi',
      data.profile ? `Paket: ${data.profile}` : '',
      `Kode Voucher: ${data.code || '-'}`,
      data.password && data.password !== data.code ? `Password: ${data.password}` : '',
      `Masa Aktif: ${data.validity || '-'}`,
      `Harga: ${data.price || '-'}`,
      'Silakan simpan voucher ini.'
    ].filter(Boolean);
    return lines.join('\n');
  }

  async function agentCopyText(text, button) {
    const value = String(text || '').trim();
    if (!value) return;
    try {
      await navigator.clipboard.writeText(value);
    } catch (e) {
      const ta = document.createElement('textarea');
      ta.value = value;
      ta.style.position = 'fixed';
      ta.style.left = '-999px';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      ta.remove();
    }
    if (button) {
      const old = button.innerHTML;
      button.innerHTML = '<i class="bi bi-check2"></i> Tersalin';
      setTimeout(() => { button.innerHTML = old; }, 1200);
    }
  }

  async function agentShareText(text) {
    const value = String(text || '').trim();
    if (!value) return;
    if (navigator.share) {
      try {
        await navigator.share({ text: value });
        return;
      } catch (e) {}
    }
    window.open('https://wa.me/?text=' + encodeURIComponent(value), '_blank');
  }

  async function agentMarkVoucherSold(voucherId, button) {
    const id = Number(voucherId || 0);
    if (!id) return null;
    try {
      const res = await fetch('/agent/vouchers/' + id + '/sold', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ source: 'agent-ui' })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || data.success === false) throw new Error(data.error || 'Gagal tandai terjual');
      const card = button ? button.closest('[data-voucher-state]') : null;
      if (card && card.getAttribute('data-voucher-state') === 'ready') {
        card.setAttribute('data-voucher-state', 'sold');
        card.classList.remove('state-ready');
        card.classList.add('state-sold');
        const badge = card.querySelector('.voucher-status-label');
        if (badge) {
          badge.className = 'badgey w voucher-status-label';
          badge.textContent = 'Terjual';
        }
        const meta = card.querySelector('[data-voucher-meta]');
        if (meta) {
          const now = new Date();
          meta.textContent = 'Terjual ' + now.toLocaleString('id-ID', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
        }
        const actions = card.querySelector('[data-voucher-actions]');
        if (actions) {
          agentRenderSoldVoucherActions(actions, button ? button.dataset : {});
        }
        agentAdjustVoucherCounts(-1, 1);
        agentShowSoldVoucherFocus(button ? button.dataset : {});
        const list = card.closest('.listx');
        if (list) {
          card.hidden = false;
          list.prepend(card);
          document.querySelectorAll('[data-voucher-filter]').forEach((chip) => {
            const isAll = chip.getAttribute('data-voucher-filter') === 'all';
            chip.classList.toggle('active', isAll);
          });
          document.documentElement.dataset.agentVoucherFilter = 'all';
        }
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return data.voucher || null;
    } catch (error) {
      console.warn('[AgentVoucher] mark sold failed:', error.message || error);
      return null;
    }
  }

  function agentCopyDataset(source, target, keys) {
    if (!source || !target) return;
    keys.forEach((key) => {
      const value = source[key];
      if (value !== undefined) target.dataset[key] = value;
    });
  }

  function agentShowSoldVoucherFocus(data) {
    const panel = document.getElementById('agentSoldFocus');
    if (!panel || !data) return;
    const code = panel.querySelector('[data-sold-focus-code]');
    const meta = panel.querySelector('[data-sold-focus-meta]');
    const actions = panel.querySelector('[data-sold-focus-actions]');
    if (code) code.textContent = data.code || '-';
    if (meta) {
      meta.textContent = [
        data.profile || 'Voucher',
        data.validity ? 'Masa aktif ' + data.validity : '',
        data.price || ''
      ].filter(Boolean).join(' - ');
    }
    if (actions) agentRenderSoldVoucherActions(actions, data, { primaryShare: true });
    panel.hidden = false;
    panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function agentRenderSoldVoucherActions(actions, data, options) {
    if (!actions) return;
    actions.innerHTML = '';

    const share = document.createElement('button');
    share.type = 'button';
    share.className = options && options.primaryShare ? 'btn-action' : 'btn-mini';
    share.setAttribute('data-agent-voucher-image', '');
    share.setAttribute('data-voucher-id', data.voucherId || '');
    agentCopyDataset(data, share, ['company', 'logo', 'profile', 'code', 'password', 'validity', 'price', 'accent', 'brand', 'soft', 'wash', 'mark']);
    share.innerHTML = '<i class="bi bi-share"></i> Bagikan Gambar';

    const copy = document.createElement('button');
    copy.type = 'button';
    copy.className = 'btn-mini';
    copy.setAttribute('data-agent-copy', data.copyText || agentBuildVoucherText(data));
    copy.setAttribute('data-voucher-id', data.voucherId || '');
    copy.innerHTML = '<i class="bi bi-clipboard"></i> Salin';

    actions.appendChild(share);
    actions.appendChild(copy);
  }

  function agentUpdateCountElements(selector, delta, withTotal) {
    document.querySelectorAll(selector).forEach((el) => {
      const current = Number(el.getAttribute('data-count-value') || el.textContent || 0) || 0;
      const next = Math.max(0, current + delta);
      el.setAttribute('data-count-value', String(next));
      const total = Number(el.getAttribute('data-count-total') || 0) || 0;
      el.textContent = withTotal && total ? `${next}/${total}` : String(next);
    });
  }

  function agentAdjustVoucherCounts(readyDelta, soldDelta) {
    agentUpdateCountElements('[data-agent-ready-count], [data-voucher-filter-count="ready"]', readyDelta, false);
    agentUpdateCountElements('[data-agent-sold-count]', soldDelta, true);
    agentUpdateCountElements('[data-voucher-filter-count="sold"]', soldDelta, false);
  }

  function agentRoundRect(ctx, x, y, w, h, r) {
    const radius = Math.min(r, w / 2, h / 2);
    ctx.beginPath();
    ctx.moveTo(x + radius, y);
    ctx.arcTo(x + w, y, x + w, y + h, radius);
    ctx.arcTo(x + w, y + h, x, y + h, radius);
    ctx.arcTo(x, y + h, x, y, radius);
    ctx.arcTo(x, y, x + w, y, radius);
    ctx.closePath();
  }

  function agentDrawFitText(ctx, text, x, y, maxWidth, fontSize, weight, color, align) {
    const value = String(text || '-');
    let size = fontSize;
    ctx.textAlign = align || 'left';
    ctx.fillStyle = color;
    do {
      ctx.font = weight + ' ' + size + 'px Arial, sans-serif';
      if (ctx.measureText(value).width <= maxWidth || size <= 18) break;
      size -= 2;
    } while (size > 18);
    ctx.fillText(value, x, y);
    ctx.textAlign = 'left';
  }

  function agentLoadImage(src) {
    return new Promise((resolve) => {
      const url = String(src || '').trim();
      if (!url) return resolve(null);
      try {
        const parsed = new URL(url, window.location.origin);
        if (parsed.origin !== window.location.origin && !url.startsWith('data:')) return resolve(null);
      } catch (e) {
        if (!url.startsWith('/')) return resolve(null);
      }
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = () => resolve(null);
      img.src = url;
    });
  }

  async function agentBuildVoucherImageBlob(data) {
    const canvas = document.createElement('canvas');
    canvas.width = 1200;
    canvas.height = 760;
    const ctx = canvas.getContext('2d');
    const company = String(data.company || 'PT Media Solusi Sukses').trim();
    const profile = String(data.profile || '-').trim();
    const code = String(data.code || '-').trim();
    const password = String(data.password || '').trim();
    const validity = String(data.validity || '-').trim();
    const price = String(data.price || '-').trim();
    const logo = await agentLoadImage(data.logo || '/img/mss-logo.png');
    const numericPrice = Number(price.replace(/[^\d]/g, '')) || 0;
    const palettes = [
      { accent:'#073dcc', brand:'#073dcc', soft:'#fdf4ff', wash:'#fff7ff', mark:'rgba(8,145,178,.08)' },
      { accent:'#073dcc', brand:'#0634b0', soft:'#eff6ff', wash:'#f8fbff', mark:'rgba(15,118,110,.08)' },
      { accent:'#dc2626', brand:'#be123c', soft:'#fff1f2', wash:'#fff7f7', mark:'rgba(190,18,60,.08)' },
      { accent:'#073dcc', brand:'#073dcc', soft:'#f0fdf4', wash:'#fbfffd', mark:'rgba(4,120,87,.08)' },
      { accent:'#ea580c', brand:'#c2410c', soft:'#fff7ed', wash:'#fffaf5', mark:'rgba(194,65,12,.08)' },
      { accent:'#073dcc', brand:'#073dcc', soft:'#f5f3ff', wash:'#fbfaff', mark:'rgba(67,56,202,.08)' }
    ];
    const fallbackTheme = palettes[Math.abs(Math.floor(numericPrice / 1000)) % palettes.length];
    const accent = data.accent || fallbackTheme.accent;
    const brand = data.brand || fallbackTheme.brand;
    const soft = data.soft || fallbackTheme.soft;
    const wash = data.wash || fallbackTheme.wash;
    const mark = data.mark || fallbackTheme.mark;

    const grad = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    grad.addColorStop(0, '#ffffff');
    grad.addColorStop(0.62, '#ffffff');
    grad.addColorStop(1, wash);
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.save();
    ctx.globalAlpha = 0.9;
    const deco = ctx.createRadialGradient(1040, 105, 20, 1040, 105, 360);
    deco.addColorStop(0, soft);
    deco.addColorStop(0.5, soft);
    deco.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = deco;
    ctx.beginPath();
    ctx.arc(1040, 105, 330, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();

    ctx.lineWidth = 9;
    agentRoundRect(ctx, 34, 34, 1132, 646, 40);
    ctx.fillStyle = '#ffffff';
    ctx.fill();
    ctx.strokeStyle = '#111827';
    ctx.stroke();

    ctx.save();
    agentRoundRect(ctx, 74, 74, 132, 82, 18);
    ctx.fillStyle = '#ffffff';
    ctx.fill();
    ctx.strokeStyle = accent;
    ctx.lineWidth = 2;
    ctx.stroke();
    if (logo) {
      const ratio = Math.min(104 / logo.width, 60 / logo.height);
      const w = logo.width * ratio;
      const h = logo.height * ratio;
      ctx.drawImage(logo, 88 + (104 - w) / 2, 85 + (60 - h) / 2, w, h);
    } else {
      ctx.fillStyle = brand;
      ctx.font = '900 34px Arial, sans-serif';
      ctx.fillText(company.slice(0, 2).toUpperCase(), 108, 124);
    }
    ctx.restore();

    ctx.fillStyle = brand;
    ctx.font = '900 48px Arial, sans-serif';
    ctx.fillText(company.toUpperCase(), 230, 113);
    ctx.fillStyle = '#4b5563';
    ctx.font = '900 24px Arial, sans-serif';
    ctx.fillText('VOUCHER WIFI', 232, 151);

    ctx.save();
    ctx.globalAlpha = 1;
    ctx.fillStyle = mark;
    ctx.font = '900 150px Arial, sans-serif';
    ctx.textAlign = 'center';
    ctx.translate(845, 420);
    ctx.rotate(-0.18);
    ctx.fillText('MSS', 0, 0);
    ctx.restore();

    ctx.fillStyle = accent;
    ctx.font = '900 40px Arial, sans-serif';
    ctx.fillText('Rp', 888, 92);
    ctx.font = '900 86px Arial, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(price.replace(/^Rp\s*/i, ''), 1122, 155);
    ctx.textAlign = 'left';

    ctx.save();
    ctx.strokeStyle = '#111827';
    ctx.setLineDash([14, 14]);
    ctx.beginPath();
    ctx.moveTo(74, 194);
    ctx.lineTo(1126, 194);
    ctx.stroke();
    ctx.restore();

    ctx.save();
    ctx.strokeStyle = brand;
    ctx.lineWidth = 12;
    ctx.globalAlpha = 0.18;
    ctx.beginPath();
    ctx.arc(990, 398, 92, Math.PI * 1.13, Math.PI * 1.87);
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(990, 398, 146, Math.PI * 1.13, Math.PI * 1.87);
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(990, 398, 202, Math.PI * 1.13, Math.PI * 1.87);
    ctx.stroke();
    ctx.fillStyle = brand;
    ctx.beginPath();
    ctx.arc(990, 398, 16, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();

    ctx.fillStyle = '#0f172a';
    ctx.font = '900 30px Arial, sans-serif';
    ctx.fillText('Kode Voucher', 74, 275);
    const safeCode = code.length > 16 ? code.slice(0, 16) : code;
    agentDrawFitText(ctx, safeCode, 74, 395, 650, 118, '900', '#050816');

    if (password && password !== code) {
      ctx.fillStyle = '#111827';
      ctx.font = '900 32px Arial, sans-serif';
      ctx.fillText('Password: ' + password, 78, 442);
    }

    const chipY = 472;
    const chips = [
      ['Paket', profile, 74, 280],
      ['Masa aktif', validity, 374, 230],
      ['Login', 'User = Kode', 626, 210]
    ];
    chips.forEach(([label, value, x, w]) => {
      agentRoundRect(ctx, x, chipY, w, 74, 16);
      ctx.fillStyle = '#ffffff';
      ctx.fill();
      ctx.strokeStyle = '#e5e7eb';
      ctx.lineWidth = 2;
      ctx.stroke();
      ctx.fillStyle = '#4b5563';
      ctx.font = '900 17px Arial, sans-serif';
      ctx.fillText(label.toUpperCase(), x + 18, chipY + 26);
      agentDrawFitText(ctx, value, x + 18, chipY + 58, w - 34, 26, '900', '#050816');
    });

    agentRoundRect(ctx, 872, 470, 174, 78, 16);
    ctx.fillStyle = wash;
    ctx.fill();
    ctx.strokeStyle = accent;
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.fillStyle = brand;
    ctx.font = '900 24px Arial, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('WiFi', 959, 502);
    ctx.fillText('ACCESS', 959, 532);
    ctx.textAlign = 'left';

    ctx.fillStyle = accent;
    ctx.fillRect(34, 618, 1132, 62);
    ctx.fillStyle = '#ffffff';
    ctx.font = '900 30px Arial, sans-serif';
    ctx.fillText('Hubungkan ke WiFi, buka browser, lalu login memakai kode voucher.', 74, 658);

    return new Promise((resolve) => {
      try {
        canvas.toBlob(resolve, 'image/png', 0.95);
      } catch (e) {
        resolve(null);
      }
    });
  }

  async function agentShareVoucherImage(button) {
    const data = button.dataset || {};
    const blob = await agentBuildVoucherImageBlob(data);
    if (!blob) return agentShareText(agentBuildVoucherText(data));
    const fileName = 'voucher-' + String(data.code || 'wifi').replace(/[^\w.-]+/g, '-') + '.png';
    const file = new File([blob], fileName, { type: 'image/png' });
    if (navigator.canShare && navigator.canShare({ files: [file] }) && navigator.share) {
      try {
        await navigator.share({ files: [file], title: 'Voucher WiFi', text: 'Voucher WiFi ' + (data.code || '') });
        return;
      } catch (e) {}
    }
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = fileName;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 3000);
  }

  document.addEventListener('click', (event) => {
    const printConfirm = event.target.closest('[data-agent-print-confirm]');
    if (printConfirm) {
      const readyCount = Number(printConfirm.getAttribute('data-ready-count') || 0) || 0;
      const totalCount = Number(printConfirm.getAttribute('data-total-count') || 0) || 0;
      const countText = readyCount > 0 ? `${readyCount} voucher siap jual` : `${totalCount || 'semua'} voucher`;
      const message = [
        `Anda yakin mau mencetak ${countText}?`,
        '',
        'Voucher yang dicetak akan masuk ke daftar Sudah Dicetak dan tidak bisa dijual digital lewat tombol Bagikan lagi.'
      ].join('\n');
      if (!window.confirm(message)) {
        event.preventDefault();
        return;
      }
      return;
    }
    const markSold = event.target.closest('[data-agent-mark-sold]');
    if (markSold) {
      event.preventDefault();
      const old = markSold.innerHTML;
      markSold.disabled = true;
      markSold.innerHTML = '<i class="bi bi-hourglass-split"></i> Proses';
      agentMarkVoucherSold(markSold.getAttribute('data-voucher-id'), markSold).then((voucher) => {
        if (!voucher) {
          markSold.disabled = false;
          markSold.innerHTML = old;
        }
      });
      return;
    }
    const imageShare = event.target.closest('[data-agent-voucher-image]');
    if (imageShare) {
      event.preventDefault();
      agentShareVoucherImage(imageShare);
      return;
    }
    const copy = event.target.closest('[data-agent-copy]');
    if (copy) {
      event.preventDefault();
      agentCopyText(copy.getAttribute('data-agent-copy') || '', copy);
      return;
    }
    const share = event.target.closest('[data-agent-share]');
    if (share) {
      event.preventDefault();
      agentShareText(share.getAttribute('data-agent-share') || '');
    }
  });
</script>
