<div class="topbar">
  <div class="inner">
    <div class="brand">
      <div class="icon">
        <img src="<%= (typeof logoUrl !== 'undefined' && logoUrl) ? logoUrl : '/img/mss-logo.png' %>" alt="Logo <%= company %>" style="width:32px;height:32px;object-fit:contain" onerror="this.onerror=null;this.src='/img/mss-logo.png'">
      </div>
      <div class="agent-brand-copy">
        <p class="title">Agent: <%= agent?.name || '-' %></p>
        <div class="agent-brand-meta">
          <p class="sub"><%= company %></p>
          <%- include('../../partials/partner_brand_badge', { settings: (typeof settings !== 'undefined' ? settings : {}), variant: 'topbar' }) %>
        </div>
      </div>
    </div>
    <div class="top-actions">
      <button type="button" class="theme-toggle" id="agentThemeToggle" aria-label="Ganti tema portal agent">
        <i class="bi bi-sun"></i>
      </button>
      <a href="/agent/logout" class="icon-btn" aria-label="Logout"><i class="bi bi-box-arrow-right"></i></a>
    </div>
  </div>
</div>
