<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('agent.print_thermal', 'Print Thermal') %> Voucher #<%= tx.id %></title>
  <style>
    @page { margin: 0; }
    * { box-sizing: border-box; }
    body {
      font-family: 'Courier New', Courier, monospace;
      font-size: 12px;
      line-height: 1.3;
      color: #000;
      margin: 0 auto;
      padding: 5px 7px 8px;
      max-width: 58mm;
      background: #fff;
    }
    .text-center { text-align: center; }
    .bold { font-weight: bold; }
    .divider { border-bottom: 1px dashed #000; margin: 7px 0; }
    .row { display: flex; justify-content: space-between; gap: 10px; }
    .mono { font-family: inherit; }
    .small { font-size: 10px; }
    .tiny { font-size: 9px; }
    .title { font-size: 13px; letter-spacing: 0.4px; }
    .mt { margin-top: 6px; }
    .mb { margin-bottom: 5px; }
    .code-wrap{
      border: 1px dashed #000;
      padding: 8px 6px;
      margin-top: 6px;
    }
    .code { font-size: 24px; font-weight: 900; letter-spacing: 2px; line-height: 1.1; }
    .subcode { font-size: 10px; color:#222; margin-top: 4px; }
    .label{
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    .summary{
      border: 1px solid #000;
      padding: 6px 6px 4px;
    }
    .summary .row + .row{
      margin-top: 5px;
    }
    .foot-note{
      margin-top: 6px;
      text-align: center;
      font-size: 10px;
      line-height: 1.4;
    }
    .top-actions{
      position: fixed;
      top: 8px;
      right: 8px;
      display: flex;
      gap: 8px;
      z-index: 10;
    }
    .top-actions button{
      font: inherit;
      font-size: 11px;
      padding: 6px 8px;
      border: 1px solid #111;
      background: #fff;
      border-radius: 6px;
      cursor: pointer;
    }
    @media print {
      body { width: 100%; max-width: 100%; margin: 0; padding: 3mm 3mm 0 3mm; }
      .top-actions{ display:none; }
    }
  </style>
</head>
<body>
  <div class="top-actions">
    <button type="button" onclick="window.print()"><%= t('agent.print_thermal', 'Print Thermal') %></button>
    <button type="button" onclick="try{window.close()}catch(e){}">Close</button>
  </div>
  <div class="text-center">
    <div class="title bold"><%= company %></div>
    <% if (settings && settings.company_address) { %>
      <div class="small"><%= settings.company_address %></div>
    <% } %>
    <% const wa = (settings && settings.whatsapp_admin_numbers && settings.whatsapp_admin_numbers.length) ? settings.whatsapp_admin_numbers[0] : (settings && settings.company_phone ? settings.company_phone : ''); %>
    <% if (wa) { %>
      <div class="small">Telp/WA: <%= String(wa).startsWith('0') ? wa : ('+' + wa) %></div>
    <% } %>
  </div>

  <div class="divider"></div>

  <div class="text-center bold mb"><%= t('agent.receipt.voucher_title', 'STRUK VOUCHER HOTSPOT') %></div>
  <div class="text-center small"><%= tx.created_at ? new Date(tx.created_at).toLocaleString('id-ID') : new Date().toLocaleString('id-ID') %></div>
  <div class="text-center tiny">Ref: #<%= tx.id %></div>

  <div class="divider"></div>

  <div class="text-center mt">
    <% if (tx.profile_name) { %>
      <div class="label"><%= t('agent.package', 'Paket') %></div>
      <div class="small bold"><%= tx.profile_name %></div>
    <% } %>
    <div class="code-wrap">
      <div class="label"><%= t('agent.receipt.code', 'KODE VOUCHER') %></div>
      <div class="code"><%= tx.voucher_code || '-' %></div>
      <% if (tx.voucher_password && tx.voucher_password !== tx.voucher_code) { %>
        <div class="subcode"><%= t('agent.receipt.password', 'PASSWORD') %>: <%= tx.voucher_password %></div>
      <% } %>
    </div>
  </div>

  <div class="divider"></div>

  <div class="summary">
    <% if (tx.amount_sell) { %>
      <div class="row bold">
        <div><%= t('agent.price', 'HARGA') %></div>
        <div>Rp <%= Number(tx.amount_sell || 0).toLocaleString('id-ID') %></div>
      </div>
    <% } %>
    <% if (tx.validity_text || tx.validity) { %>
      <div class="row bold">
        <div><%= t('agent.validity', 'Masa Aktif') %></div>
        <div><%= tx.validity_text || tx.validity %></div>
      </div>
    <% } %>
    <% if (tx.router_name) { %>
      <div class="row">
        <div>Router</div>
        <div><%= tx.router_name %></div>
      </div>
    <% } %>
  </div>

  <div class="divider"></div>

  <div class="foot-note">
    Simpan kode voucher ini.<br>
    Tunjukkan struk ini bila dibutuhkan.
  </div>

  <script>
    window.onload = function () {
      setTimeout(function () { window.print(); }, 350);
    };
  </script>
</body>
</html>
