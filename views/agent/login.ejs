<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<%
  const logoSrc = logoUrl || '/img/logo.png';
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <%- include('../partials/pwa_portal', {
    portalKey: 'agent',
    manifestPath: '/pwa/agent.webmanifest',
    scope: '/agent/',
    themeColor: '#4f6ef7',
    appTitle: 'Portal Agent'
  }) %>
  <title><%= t('agent.login_title', 'Login Agent') %> - <%= company %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root{
      --page-bg:#eef3ff;
      --page-bg-2:#ffffff;
      --surface:rgba(255,255,255,.95);
      --surface-soft:#f8fbff;
      --line:rgba(170,186,215,.24);
      --text-main:#1b2740;
      --text-soft:#6b7b97;
      --text-faint:#8a98b3;
      --primary:#4f6ef7;
      --primary-2:#6f8dff;
      --accent:#1ca56f;
      --shadow:0 26px 60px rgba(85,104,148,.16);
      --shell-width:min(100vw, 430px);
    }
    *{box-sizing:border-box}
    html,body{
      min-height:100%;
      margin:0;
      color:var(--text-main);
      font-family:"Plus Jakarta Sans","Manrope",system-ui,-apple-system,sans-serif;
      background:
        radial-gradient(circle at top left, rgba(111,141,255,.22) 0%, rgba(111,141,255,0) 34%),
        radial-gradient(circle at top right, rgba(28,165,111,.10) 0%, rgba(28,165,111,0) 28%),
        linear-gradient(180deg, var(--page-bg-2) 0%, var(--page-bg) 100%);
      -webkit-tap-highlight-color:transparent;
    }
    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      opacity:.18;
      background-image:
        linear-gradient(rgba(79,110,247,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(79,110,247,.04) 1px, transparent 1px);
      background-size:30px 30px;
    }
    body{
      display:flex;
      justify-content:center;
      padding:14px;
    }
    .login-shell{
      width:var(--shell-width);
      min-height:calc(100vh - 28px);
      min-height:calc(100dvh - 28px);
      display:flex;
      align-items:center;
    }
    .login-main{width:100%;display:grid;gap:12px}
    .brand-panel{
      display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:24px;
      background:rgba(255,255,255,.82);border:1px solid rgba(255,255,255,.72);
      box-shadow:0 18px 38px rgba(85,104,148,.10);backdrop-filter:blur(18px);
    }
    .brand-logo{
      width:64px;height:64px;flex:0 0 64px;display:grid;place-items:center;border-radius:20px;
      background:linear-gradient(145deg, rgba(255,255,255,.98), rgba(238,243,255,.94));
      box-shadow:inset 0 1px 0 rgba(255,255,255,.92), 0 18px 34px rgba(79,110,247,.12);
    }
    .brand-logo img{width:48px;height:48px;object-fit:contain}
    .brand-copy{min-width:0;flex:1}
    .brand-copy strong{
      display:inline-flex;align-items:center;gap:7px;margin-bottom:7px;padding:7px 11px;border-radius:999px;
      background:rgba(79,110,247,.10);border:1px solid rgba(79,110,247,.14);color:var(--primary);
      font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;
    }
    .brand-copy h1{margin:0 0 4px;font-size:22px;line-height:1.04;font-weight:800;letter-spacing:-.04em}
    .brand-copy p{margin:0;color:var(--text-soft);font-size:12px;line-height:1.45}
    .login-card{
      background:var(--surface);border:1px solid rgba(255,255,255,.74);border-radius:28px;
      box-shadow:var(--shadow);backdrop-filter:blur(18px);overflow:hidden;
    }
    .login-card-head{padding:18px 18px 10px;text-align:center}
    .portal-icon{
      width:60px;height:60px;margin:0 auto 14px;display:grid;place-items:center;border-radius:20px;
      background:linear-gradient(135deg, rgba(79,110,247,.16), rgba(28,165,111,.18));
      border:1px solid rgba(79,110,247,.16);color:var(--accent);font-size:24px;
      box-shadow:0 18px 32px rgba(79,110,247,.14);
    }
    .login-card-head h2{margin:0 0 5px;font-size:20px;font-weight:800;letter-spacing:-.03em}
    .login-card-head p{margin:0;font-size:12px;line-height:1.5;color:var(--text-soft)}
    .form-container{padding:12px 18px 18px}
    .field{margin-bottom:12px}
    .field-label{
      display:block;margin-bottom:7px;font-size:11px;font-weight:800;color:var(--text-faint);
      letter-spacing:.08em;text-transform:uppercase;
    }
    .field-wrap{position:relative}
    .field-wrap i{
      position:absolute;left:14px;top:50%;transform:translateY(-50%);
      color:var(--text-soft);font-size:15px;pointer-events:none;
    }
    .fc{
      width:100%;min-height:54px;border-radius:18px;border:1px solid var(--line);background:var(--surface-soft);
      color:var(--text-main);padding:14px 14px 14px 42px;font-size:14px;outline:none;box-shadow:none;
      transition:border-color .2s ease, box-shadow .2s ease, background .2s ease;
    }
    .fc::placeholder{color:var(--text-soft)}
    .fc:focus{border-color:rgba(79,110,247,.38);background:#fff;box-shadow:0 0 0 4px rgba(79,110,247,.10)}
    .btn-login{
      width:100%;min-height:52px;border:none;border-radius:18px;color:#fff;font-size:14px;font-weight:800;
      display:inline-flex;align-items:center;justify-content:center;gap:10px;
      background:linear-gradient(135deg, var(--primary) 0%, var(--primary-2) 100%);
      box-shadow:0 20px 34px rgba(79,110,247,.22);
    }
    .alert-box{
      border-radius:16px;padding:12px 13px;margin-bottom:12px;font-size:12px;line-height:1.5;
      background:rgba(224,93,109,.10);border:1px solid rgba(224,93,109,.16);color:#b84657;
      display:flex;align-items:center;gap:9px;
    }
    .helper{
      margin-top:12px;padding:12px 13px;border-radius:18px;background:linear-gradient(180deg, rgba(79,110,247,.05), rgba(28,165,111,.03));
      border:1px solid rgba(79,110,247,.10);text-align:center;font-size:11px;color:var(--text-soft);line-height:1.55;
    }
    @media (max-width:576px){
      body{padding:12px}
      .login-shell{min-height:calc(100vh - 24px);min-height:calc(100dvh - 24px)}
      .brand-panel,.login-card-head,.form-container{padding-left:14px;padding-right:14px}
      .brand-logo{width:58px;height:58px;flex-basis:58px}
      .brand-logo img{width:44px;height:44px}
      .brand-copy h1{font-size:20px}
      .login-card-head h2{font-size:18px}
    }
  </style>
</head>
<body>
  <div class="login-shell">
    <main class="login-main">
      <section class="brand-panel">
        <div class="brand-logo">
          <img src="<%= logoSrc %>" alt="Logo <%= company %>">
        </div>
        <div class="brand-copy">
          <strong><i class="bi bi-shop-window"></i> Portal Agent</strong>
          <h1><%= company %></h1>
          <p>Akses agent.</p>
        </div>
      </section>

      <section class="login-card">
        <div class="login-card-head">
          <div class="portal-icon"><i class="bi bi-wallet2"></i></div>
          <h2>Masuk ke Akun Agent</h2>
          <p>Masuk dengan akun agent.</p>
        </div>

        <div class="form-container">
          <% if (error) { %>
            <div class="alert-box"><i class="bi bi-exclamation-octagon"></i><span><%= error %></span></div>
          <% } %>

          <form method="POST" action="/agent/login">
            <div class="field">
              <label class="field-label" for="agent-username"><%= t('agent.username', 'Username') %></label>
              <label class="field-wrap">
                <i class="bi bi-person-badge-fill"></i>
                <input id="agent-username" type="text" name="username" class="fc" required autocomplete="username" placeholder="<%= t('agent.username_placeholder', 'Masukkan username') %>" value="<%= (form && form.username) ? form.username : '' %>">
              </label>
            </div>
            <div class="field">
              <label class="field-label" for="agent-password"><%= t('agent.password', 'Password') %></label>
              <label class="field-wrap">
                <i class="bi bi-shield-lock-fill"></i>
                <input id="agent-password" type="password" name="password" class="fc" required autocomplete="current-password" placeholder="<%= t('agent.password_placeholder', 'Masukkan password') %>">
              </label>
            </div>
            <button type="submit" class="btn-login"><i class="bi bi-box-arrow-in-right"></i><span><%= t('agent.sign_in', 'Masuk') %></span></button>
          </form>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
