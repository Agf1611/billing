<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <%- include('partials/head', { title, company }) %>
</head>
<body>
  <%- include('partials/topbar', { agent, company }) %>
  <main class="wrap">
    <% if (msg) { %>
      <div class="alert-agent alert-<%= msg.type === 'error' ? 'danger' : msg.type === 'warning' ? 'warning' : 'success' %>"><%= msg.text %></div>
    <% } %>

    <section class="hero">
      <h1>Dashboard Agent</h1>
      <p>Kelola voucher, pembayaran tagihan, dan riwayat transaksi dari satu portal yang ringan untuk HP.</p>
    </section>

    <section class="cardx">
      <div class="hd">
        <h2><i class="bi bi-wallet2"></i> Ringkasan</h2>
        <span class="pill"><i class="bi bi-shield-check"></i> Aktif</span>
      </div>
      <div class="bd">
        <div class="grid grid-2">
          <div class="kpi">
            <div class="lbl">Saldo</div>
            <div class="val">Rp <%= Number(agent?.balance || 0).toLocaleString('id-ID') %></div>
          </div>
          <div class="kpi">
            <div class="lbl">Fee Tagihan</div>
            <div class="val">Rp <%= Number(agent?.billing_fee || 0).toLocaleString('id-ID') %></div>
          </div>
          <div class="kpi">
            <div class="lbl">Profit</div>
            <div class="val" style="color:var(--success)">Rp <%= Number(profit || 0).toLocaleString('id-ID') %></div>
          </div>
          <div class="kpi">
            <div class="lbl">Paket Voucher</div>
            <div class="val"><%= prices?.length || 0 %></div>
          </div>
        </div>
      </div>
    </section>

    <section class="cardx">
      <div class="hd">
        <h2><i class="bi bi-lightning-charge"></i> Aksi Cepat</h2>
      </div>
      <div class="bd">
        <div class="grid grid-2">
          <a class="btn-action" href="/agent/vouchers/single"><i class="bi bi-lightning-charge"></i> Voucher Satuan</a>
          <a class="btn-action" href="/agent/vouchers/batch"><i class="bi bi-grid-3x3-gap"></i> Voucher Banyak</a>
          <a class="btn-action" href="/agent/billing"><i class="bi bi-receipt"></i> Bayar Tagihan</a>
          <a class="btn-action" href="/agent/topup"><i class="bi bi-qr-code-scan"></i> Topup Saldo</a>
          <a class="btn-action" href="/agent/help"><i class="bi bi-headset"></i> Bantuan Admin</a>
        </div>
      </div>
    </section>

    <% if (Number(agent?.balance || 0) < 50000) { %>
      <section class="cardx soft-warning">
        <div class="bd">
          <div class="item-head">
            <div>
              <div class="t1">Saldo mulai rendah</div>
              <div class="t2">Topup dulu supaya generate voucher dan bayar tagihan pelanggan tetap lancar.</div>
            </div>
            <a class="btn-mini" href="/agent/topup"><i class="bi bi-qr-code"></i> Topup</a>
          </div>
        </div>
      </section>
    <% } %>

    <section class="cardx">
      <div class="hd">
        <h2><i class="bi bi-clock-history"></i> Transaksi Terakhir</h2>
        <a class="btn-mini" href="/agent/history">Semua</a>
      </div>
      <div class="bd">
        <% if (!txs || txs.length === 0) { %>
          <div class="empty">Belum ada transaksi.</div>
        <% } else { %>
          <div class="listx">
            <% txs.forEach(tx => { %>
              <div class="itemx">
                <div class="item-head">
                  <div>
                    <div class="t1"><%= String(tx.type || '').replace(/_/g, ' ').toUpperCase() %></div>
                    <div class="t2"><%= tx.created_at ? new Date(tx.created_at).toLocaleString('id-ID') : '-' %></div>
                  </div>
                  <div style="text-align:right">
                    <div class="t1">Rp <%= Number(tx.amount_sell || tx.amount_buy || 0).toLocaleString('id-ID') %></div>
                    <div class="t2">Saldo Rp <%= Number(tx.balance_after || 0).toLocaleString('id-ID') %></div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section class="cardx">
      <div class="hd">
        <h2><i class="bi bi-qr-code"></i> Topup Terbaru</h2>
        <a class="btn-mini" href="/agent/topup">Topup</a>
      </div>
      <div class="bd">
        <% if (!topups || topups.length === 0) { %>
          <div class="empty">Belum ada topup saldo.</div>
        <% } else { %>
          <div class="listx">
            <% topups.forEach(o => { %>
              <div class="itemx">
                <div class="item-head">
                  <div>
                    <div class="t1">Rp <%= Number(o.amount || 0).toLocaleString('id-ID') %></div>
                    <div class="t2">Bayar Rp <%= Number(o.pay_amount || 0).toLocaleString('id-ID') %></div>
                  </div>
                  <span class="badgey <%= String(o.status || '') === 'paid' ? 's' : 'w' %>"><%= o.status || '-' %></span>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>
  <%- include('partials/bottom_nav', { activeAgentPage: 'dashboard' }) %>
  <%- include('partials/scripts') %>
</body>
</html>
