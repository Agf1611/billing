<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">

<head>
  <% const logoSrc = (settings && settings.company_logo_url) ? settings.company_logo_url : '/img/logo.png'; %>
  <% const loginPushFeatureEnabled = Boolean(settings && settings.onesignal_enabled && settings.onesignal_app_id); %>
  <% const loginOneSignalAppId = String((settings && settings.onesignal_app_id) || '').trim(); %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title><%= t('customer.login_title', 'Login Pelanggan') %> | <%= settings.company_header || 'Portal ISP' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <%- include('partials/pwa_portal', {
    portalKey: 'customer',
    manifestPath: '/pwa/customer.webmanifest',
    scope: '/customer/',
    themeColor: '#f4f8ff',
    appTitle: 'Portal Pelanggan',
    installLabel: 'Install Pelanggan'
  }) %>
  <style>
    :root {
      --page-bg: #f4f8ff;
      --page-bg-2: #ffffff;
      --surface: rgba(255, 255, 255, 0.96);
      --surface-soft: #f8fbff;
      --line: rgba(107, 142, 195, 0.18);
      --line-strong: rgba(47, 107, 255, 0.22);
      --text-main: #18243d;
      --text-soft: #6c7b98;
      --text-faint: #8d98b1;
      --blue: #2c6bff;
      --blue-deep: #1f4fd8;
      --mint: #0ea5a4;
      --amber: #f59e0b;
      --shadow: 0 28px 70px rgba(40, 79, 144, 0.16);
      --shell-width: min(100vw, 448px);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
      margin: 0;
      color: var(--text-main);
      font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(72, 165, 255, 0.18) 0%, rgba(72, 165, 255, 0) 34%),
        radial-gradient(circle at top right, rgba(14, 165, 164, 0.14) 0%, rgba(14, 165, 164, 0) 28%),
        linear-gradient(180deg, var(--page-bg-2) 0%, var(--page-bg) 100%);
      -webkit-tap-highlight-color: transparent;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.18;
      background-image:
        linear-gradient(rgba(44, 107, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(44, 107, 255, 0.04) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    body.pwa-login {
      display: flex;
      justify-content: center;
    }

    .login-shell {
      position: relative;
      width: var(--shell-width);
      min-height: 100vh;
      min-height: 100dvh;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.76) 0%, rgba(247, 250, 255, 0.98) 100%);
      backdrop-filter: blur(20px);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .login-shell::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(320px 180px at 15% 0%, rgba(44, 107, 255, 0.14), transparent 70%),
        radial-gradient(280px 180px at 85% 14%, rgba(14, 165, 164, 0.1), transparent 72%);
    }

    .login-main {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: calc(env(safe-area-inset-top) + 14px) 18px calc(14px + env(safe-area-inset-bottom));
      gap: 10px;
    }

    .brand-bar {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 14px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.7);
      box-shadow: 0 16px 34px rgba(42, 78, 140, 0.08);
    }

    .brand-logo {
      width: 62px;
      height: 62px;
      flex: 0 0 62px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(236, 244, 255, 0.96));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.88), 0 18px 34px rgba(44, 107, 255, 0.12);
    }

    .brand-logo img {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }

    .brand-copy {
      min-width: 0;
      flex: 1;
    }

    .brand-copy strong {
      display: block;
      margin-bottom: 3px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-faint);
    }

    .brand-copy h1 {
      margin: 0 0 3px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 21px;
      line-height: 1.04;
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .brand-copy p {
      margin: 0;
      color: var(--text-soft);
      font-size: 12px;
      line-height: 1.4;
    }

    .login-card {
      background: var(--surface);
      border: 1px solid rgba(255, 255, 255, 0.74);
      border-radius: 26px;
      box-shadow: 0 22px 44px rgba(42, 78, 140, 0.1);
      overflow: hidden;
    }

    .login-card-head {
      padding: 16px 18px 8px;
    }

    .login-card-head h2 {
      margin: 0 0 4px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 19px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .login-card-head p {
      margin: 0;
      font-size: 12px;
      line-height: 1.45;
      color: var(--text-soft);
    }

    .form-container {
      padding: 12px 18px 18px;
    }

    .form-floating {
      margin-bottom: 12px;
    }

    .form-control {
      min-height: 54px;
      background: #f7faff;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px 16px 8px;
      color: var(--text-main);
      font-size: 15px;
      box-shadow: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .form-control:focus {
      background: #ffffff;
      border-color: rgba(44, 107, 255, 0.42);
      box-shadow: 0 0 0 4px rgba(44, 107, 255, 0.11);
      color: var(--text-main);
    }

    .form-floating > label {
      color: var(--text-soft);
      padding: 14px 16px;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
      color: var(--blue);
    }

    .remember-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: 2px 0 12px;
    }

    .remember-check {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      margin: 0;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-main);
      cursor: pointer;
      user-select: none;
    }

    .remember-check input {
      width: 16px;
      height: 16px;
      margin: 0;
      accent-color: var(--blue);
    }

    .remember-hint {
      font-size: 11px;
      color: var(--text-soft);
      text-align: right;
    }

    .btn-login {
      min-height: 50px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--blue) 0%, #4f8cff 100%);
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -0.02em;
      box-shadow: 0 18px 34px rgba(44, 107, 255, 0.2);
    }

    .btn-login:hover,
    .btn-login:focus {
      background: linear-gradient(135deg, #225bdf 0%, #437ef0 100%);
    }

    .action-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .btn-soft-action {
      min-height: 46px;
      border-radius: 15px;
      border: 1px solid rgba(44, 107, 255, 0.16);
      background: rgba(44, 107, 255, 0.06);
      color: var(--blue-deep);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 800;
      text-decoration: none;
      transition: 0.2s ease;
    }

    .btn-soft-action:hover,
    .btn-soft-action:focus {
      background: rgba(44, 107, 255, 0.1);
      border-color: rgba(44, 107, 255, 0.24);
      color: var(--blue-deep);
    }

    .alert {
      margin: 12px 0 0;
      border-radius: 16px;
      border: 1px solid rgba(239, 68, 68, 0.16);
      font-size: 12px;
    }

    .support-compact {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(247, 250, 255, 0.96), rgba(241, 246, 255, 0.94));
      border: 1px solid var(--line);
    }

    .support-copy {
      min-width: 0;
    }

    .support-copy strong {
      display: block;
      margin: 0;
      font-size: 13px;
      font-weight: 800;
      color: var(--text-main);
    }

    .support-copy span {
      display: block;
      margin-top: 3px;
      font-size: 11px;
      line-height: 1.4;
      color: var(--text-soft);
    }

    .wa-mini-link {
      width: 48px;
      height: 48px;
      flex: 0 0 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 16px;
      background: linear-gradient(135deg, #1ecb67 0%, #13a34f 100%);
      color: #ffffff;
      text-decoration: none;
      box-shadow: 0 16px 28px rgba(30, 203, 103, 0.22);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .wa-mini-link:hover,
    .wa-mini-link:focus {
      color: #ffffff;
      transform: translateY(-1px);
      box-shadow: 0 18px 30px rgba(30, 203, 103, 0.28);
    }

    .wa-mini-link i {
      font-size: 22px;
    }

    .footer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: 12px;
      font-size: 11px;
      color: var(--text-soft);
    }

    .footer-row a {
      color: var(--blue);
      font-weight: 800;
      text-decoration: none;
    }

    body.pwa-login-gated {
      overflow: hidden;
    }

    body.pwa-login-gated .login-shell {
      filter: blur(8px);
      pointer-events: none;
      user-select: none;
    }

    .login-pwa-gate {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: grid;
      place-items: center;
      padding: 18px;
      background:
        radial-gradient(circle at 18% 10%, rgba(44, 107, 255, 0.22), transparent 34%),
        radial-gradient(circle at 88% 82%, rgba(14, 165, 164, 0.18), transparent 36%),
        linear-gradient(145deg, #f8fbff 0%, #eaf2ff 100%);
    }

    .login-pwa-gate[hidden] {
      display: none !important;
    }

    .login-pwa-card {
      width: min(100%, 430px);
      border-radius: 28px;
      padding: 24px;
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(107, 142, 195, 0.2);
      box-shadow: 0 28px 70px rgba(40, 79, 144, 0.2);
    }

    .login-pwa-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 32px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(44, 107, 255, 0.1);
      color: var(--blue);
      font-size: 12px;
      font-weight: 900;
    }

    .login-pwa-card h2 {
      margin: 16px 0 8px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 28px;
      line-height: 1.08;
      font-weight: 900;
      letter-spacing: 0;
      color: var(--text-main);
    }

    .login-pwa-card p {
      margin: 0 0 16px;
      color: var(--text-soft);
      font-size: 13px;
      line-height: 1.5;
      font-weight: 700;
    }

    .login-pwa-status {
      display: grid;
      gap: 9px;
      margin: 14px 0;
    }

    .login-pwa-status-item {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 48px;
      padding: 10px 12px;
      border-radius: 16px;
      background: #f5f8ff;
      border: 1px solid rgba(107, 142, 195, 0.16);
      color: var(--text-main);
      font-size: 13px;
      font-weight: 850;
    }

    .login-pwa-status-item i {
      width: 30px;
      height: 30px;
      flex: 0 0 30px;
      display: inline-grid;
      place-items: center;
      border-radius: 12px;
      background: rgba(245, 158, 11, 0.14);
      color: #c47a00;
    }

    .login-pwa-status-item.is-ok i {
      background: rgba(16, 185, 129, 0.14);
      color: #059669;
    }

    .login-pwa-actions {
      display: grid;
      gap: 10px;
    }

    .login-pwa-actions button {
      min-height: 48px;
      border: 0;
      border-radius: 16px;
      padding: 0 14px;
      font-weight: 900;
    }

    .login-pwa-actions .primary {
      background: linear-gradient(135deg, #2c6bff, #0ea5a4);
      color: #fff;
    }

    .login-pwa-actions .secondary {
      background: #edf3ff;
      color: var(--blue);
    }

    .login-pwa-actions button[hidden] {
      display: none !important;
    }

    .login-pwa-help {
      margin-top: 12px;
      padding: 11px 12px;
      border-radius: 15px;
      background: rgba(245, 158, 11, 0.1);
      color: #8a5a00;
      font-size: 12px;
      line-height: 1.45;
      font-weight: 800;
    }

    @media (max-width: 576px) {
      .login-main {
        padding-left: 14px;
        padding-right: 14px;
      }

      .brand-bar {
        padding: 12px;
      }

      .brand-logo {
        width: 56px;
        height: 56px;
        flex-basis: 56px;
      }

      .brand-logo img {
        width: 42px;
        height: 42px;
      }

      .brand-copy h1 {
        font-size: 20px;
      }

      .login-card-head,
      .form-container {
        padding-left: 14px;
        padding-right: 14px;
      }

      .remember-row {
        grid-template-columns: 1fr;
        display: grid;
      }

      .remember-row {
        align-items: stretch;
      }

      .remember-hint {
        text-align: left;
      }

      .footer-row {
        flex-direction: column;
        align-items: flex-start;
      }

      .support-compact {
        align-items: center;
      }
    }

    @media (max-width: 640px) {
      body.android-webview {
        display: block;
      }

      body.android-webview .login-shell {
        width: 100vw;
        min-height: 100vh;
        min-height: 100dvh;
        box-shadow: none;
      }
    }
  </style>
</head>

<body class="pwa-login">
  <div class="login-pwa-gate" id="loginPwaGate" role="dialog" aria-modal="true" hidden>
    <section class="login-pwa-card">
      <span class="login-pwa-pill"><i class="bi bi-phone"></i> Install Wajib</span>
      <h2>Install aplikasi pelanggan</h2>
      <p>Portal pelanggan dibuka dari aplikasi terinstall dan notifikasi aktif.</p>
      <div class="login-pwa-status">
        <div class="login-pwa-status-item" id="loginPwaInstallStatus">
          <i class="bi bi-phone"></i>
          <span>Belum terinstall</span>
        </div>
        <div class="login-pwa-status-item" id="loginPwaNotifyStatus">
          <i class="bi bi-bell"></i>
          <span>Notifikasi belum aktif</span>
        </div>
      </div>
      <div class="login-pwa-actions">
        <button type="button" class="primary" id="loginPwaInstallButton">
          <i class="bi bi-download me-2"></i>Install Sekarang
        </button>
        <button type="button" class="primary" id="loginPwaNotifyButton">
          <i class="bi bi-bell me-2"></i>Izinkan Notifikasi
        </button>
        <button type="button" class="secondary" id="loginPwaRetryButton">
          <i class="bi bi-arrow-clockwise me-2"></i>Cek Lagi
        </button>
      </div>
      <div class="login-pwa-help" id="loginPwaHelp">Jika tombol install belum muncul, buka menu browser lalu pilih Install app atau Tambahkan ke layar utama.</div>
    </section>
  </div>

  <div class="login-shell">
    <main class="login-main">
      <% const supportWhatsapp = settings.company_phone || ((settings.whatsapp_admin_numbers && settings.whatsapp_admin_numbers[0]) ? settings.whatsapp_admin_numbers[0] : ''); %>
      <% const supportWhatsappLink = supportWhatsapp ? buildWhatsAppLink(supportWhatsapp) : '/customer/contact'; %>
      <% const supportEmail = settings.company_email || ''; %>
      <% const supportHours = settings.operational_hours || 'Setiap Hari 08.00 - 22.00 WIB'; %>

      <section class="brand-bar">
        <div class="brand-logo">
          <img src="<%= logoSrc %>" alt="Logo <%= settings.company_header || 'Portal ISP' %>">
        </div>
        <div class="brand-copy">
          <strong><i class="bi bi-person-vcard-fill"></i> Portal Pelanggan</strong>
          <h1><%= settings.company_header || 'Portal ISP' %></h1>
          <p>Akses layanan pelanggan.</p>
        </div>
      </section>

      <section class="login-card">
        <div class="login-card-head">
          <h2>Masuk ke Portal Pelanggan</h2>
          <p>Masuk dengan ID pelanggan, username PPPoE, atau nomor HP.</p>
        </div>

        <div class="form-container">
          <form method="POST" action="/customer/login">
            <div class="form-floating">
              <input type="text" class="form-control" id="phone" name="phone" placeholder="<%= t('customer.id_tag_placeholder', 'Masukkan ID/Tag Pelanggan') %>" required autofocus autocomplete="username" enterkeyhint="go" value="<%= (form && form.phone) ? form.phone : '' %>">
              <label for="phone">
                <i class="bi bi-person-vcard-fill me-2"></i><%= t('customer.id_tag', 'ID/Tag Pelanggan') %>
              </label>
            </div>

            <div class="remember-row">
              <label class="remember-check">
                <input type="hidden" name="remember_me" value="1">
                <input type="checkbox" checked disabled>
                <span>Tetap masuk otomatis</span>
              </label>
              <div class="remember-hint">Keluar hanya saat logout manual.</div>
            </div>

            <button type="submit" class="btn btn-primary btn-login w-100">
              <i class="bi bi-door-open-fill me-2"></i><%= t('customer.sign_in', 'Masuk') %>
            </button>
          </form>

          <div class="action-row">
            <a href="/customer/check-billing" class="btn-soft-action w-100">
              <i class="bi bi-credit-card-2-front-fill"></i>
              <span>Cek Pembayaran & Tagihan</span>
            </a>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger text-center">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <%= error==='Nomor HP tidak valid atau belum terdaftar.' ? 'ID/Tag tidak valid atau belum terdaftar.' : error %>
            </div>
          <% } %>

          <div class="support-compact">
            <div class="support-copy">
              <strong>Bantuan pelanggan</strong>
              <span><%= supportHours %></span>
            </div>
            <a href="<%= supportWhatsappLink %>" class="wa-mini-link" aria-label="WhatsApp Support">
              <i class="bi bi-whatsapp"></i>
            </a>
          </div>

          <div class="footer-row">
            <span><%= t('customer.not_subscribed', 'Belum berlangganan?') %> <a href="/customer/register"><%= t('customer.register_new', 'Daftar Pemasangan Baru') %></a></span>
            <span>&copy; <%= new Date().getFullYear() %> <%= settings.company_header || 'Portal ISP' %></span>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    const LOGIN_ONESIGNAL_ENABLED = <%- JSON.stringify(loginPushFeatureEnabled) %>;
    const LOGIN_ONESIGNAL_APP_ID = <%- JSON.stringify(loginOneSignalAppId) %>;
    const LOGIN_ONESIGNAL_SDK_URL = 'https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js';
    const LOGIN_PWA_GATE_DELAY_MS = 1400;
    const loginPwaGateStartedAt = Date.now();
    let deferredLoginInstallPrompt = null;
    let loginOneSignalPromise = null;

    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', {
          scope: '/customer/',
          updateViaCache: 'none'
        }).then((registration) => {
          registration.update().catch(() => {});
        }).catch(() => {});
      });
    }

    const isAndroidShell = /android/i.test(navigator.userAgent || '') || window.matchMedia('(display-mode: standalone)').matches;
    if (isAndroidShell) {
      document.body.classList.add('android-webview');
    }

    function isLoginPwaInstalled() {
      const modes = ['standalone', 'fullscreen', 'minimal-ui', 'window-controls-overlay'];
      const displayModeInstalled = modes.some((mode) => {
        try {
          return window.matchMedia(`(display-mode: ${mode})`).matches;
        } catch (_) {
          return false;
        }
      });
      const standalone = Boolean(displayModeInstalled || window.navigator.standalone === true || String(document.referrer || '').startsWith('android-app://'));
      if (!standalone) return false;
      try {
        localStorage.setItem('pwa-installed-customer', '1');
        localStorage.setItem('pwa-installed-scope-customer', '/customer/');
      } catch (_) {
      }
      return true;
    }

    function loginNotificationPermission() {
      if (!LOGIN_ONESIGNAL_ENABLED) return 'granted';
      if (!('Notification' in window)) return 'unsupported';
      return Notification.permission || 'default';
    }

    function loadLoginOneSignalSdk() {
      if (!LOGIN_ONESIGNAL_ENABLED || !LOGIN_ONESIGNAL_APP_ID) return Promise.resolve(null);
      if (window.OneSignal || document.querySelector('script[data-onesignal-login-sdk="true"],script[data-onesignal-web-sdk="true"]')) {
        return Promise.resolve(window.OneSignal || null);
      }
      return new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = LOGIN_ONESIGNAL_SDK_URL;
        script.async = true;
        script.defer = true;
        script.dataset.onesignalLoginSdk = 'true';
        script.onload = () => resolve(window.OneSignal || null);
        script.onerror = () => reject(new Error('Gagal memuat OneSignal'));
        document.head.appendChild(script);
      });
    }

    async function ensureLoginOneSignal() {
      if (!LOGIN_ONESIGNAL_ENABLED || !LOGIN_ONESIGNAL_APP_ID) return null;
      if (loginOneSignalPromise) return loginOneSignalPromise;
      loginOneSignalPromise = (async () => {
        window.OneSignalDeferred = window.OneSignalDeferred || [];
        await loadLoginOneSignalSdk();
        return await new Promise((resolve, reject) => {
          window.OneSignalDeferred.push(async (OneSignal) => {
            try {
              if (!window.__CUSTOMER_LOGIN_ONESIGNAL_READY) {
                await OneSignal.init({
                  appId: LOGIN_ONESIGNAL_APP_ID,
                  notifyButton: { enable: false },
                  allowLocalhostAsSecureOrigin: true,
                  serviceWorkerPath: '/OneSignalSDKWorker.js',
                  serviceWorkerUpdaterPath: '/OneSignalSDKUpdaterWorker.js',
                  serviceWorkerParam: { scope: '/' },
                  autoResubscribe: true
                });
                window.__CUSTOMER_LOGIN_ONESIGNAL_READY = true;
              }
              resolve(OneSignal);
            } catch (error) {
              reject(error);
            }
          });
        });
      })().catch((error) => {
        console.warn('OneSignal login gate gagal:', error);
        loginOneSignalPromise = null;
        return null;
      });
      return loginOneSignalPromise;
    }

    async function isLoginNotificationAllowed() {
      if (!LOGIN_ONESIGNAL_ENABLED) return true;
      if (loginNotificationPermission() !== 'granted') return false;
      const OneSignal = await ensureLoginOneSignal();
      if (!OneSignal) return loginNotificationPermission() === 'granted';
      try {
        if (OneSignal?.User?.PushSubscription?.optIn) {
          await OneSignal.User.PushSubscription.optIn();
        }
        return Boolean(
          OneSignal?.User?.PushSubscription?.optedIn === true ||
          OneSignal?.Notifications?.permission === true ||
          OneSignal?.Notifications?.permission === 'granted' ||
          loginNotificationPermission() === 'granted'
        );
      } catch (_) {
        return loginNotificationPermission() === 'granted';
      }
    }

    function setLoginGateStatus(id, ok, icon, text) {
      const node = document.getElementById(id);
      if (!node) return;
      node.classList.toggle('is-ok', Boolean(ok));
      const iconNode = node.querySelector('i');
      const label = node.querySelector('span');
      if (iconNode) iconNode.className = icon;
      if (label) label.textContent = text;
    }

    function getLoginInstallPrompt() {
      return deferredLoginInstallPrompt || window.__deferredInstallPrompt || null;
    }

    async function updateLoginPwaGate() {
      const gate = document.getElementById('loginPwaGate');
      if (!gate) return;
      const installed = isLoginPwaInstalled();
      const permission = loginNotificationPermission();
      const notifyAllowed = await isLoginNotificationAllowed();
      const canInstallNow = Boolean(getLoginInstallPrompt());
      const canFixNotification = installed && LOGIN_ONESIGNAL_ENABLED && permission !== 'denied' && permission !== 'unsupported';
      const shouldBlock = (!installed && canInstallNow) || (!notifyAllowed && canFixNotification);
      const canShowGateNow = Date.now() - loginPwaGateStartedAt >= LOGIN_PWA_GATE_DELAY_MS;
      const showGate = shouldBlock && canShowGateNow;

      setLoginGateStatus('loginPwaInstallStatus', installed, `bi ${installed ? 'bi-check-circle-fill' : 'bi-phone'}`, installed ? 'Aplikasi sudah terinstall' : 'Belum terinstall');
      setLoginGateStatus('loginPwaNotifyStatus', notifyAllowed, `bi ${notifyAllowed ? 'bi-bell-fill' : 'bi-bell'}`, notifyAllowed ? 'Notifikasi aktif' : 'Notifikasi belum aktif');

      const installButton = document.getElementById('loginPwaInstallButton');
      const notifyButton = document.getElementById('loginPwaNotifyButton');
      const retryButton = document.getElementById('loginPwaRetryButton');
      const help = document.getElementById('loginPwaHelp');
      if (installButton) installButton.hidden = installed || !canInstallNow;
      if (notifyButton) notifyButton.hidden = !canFixNotification || notifyAllowed;
      if (retryButton) retryButton.hidden = !shouldBlock;
      if (help) {
        if (!installed && canInstallNow) help.textContent = 'Tekan Install Sekarang, lalu buka aplikasi dari layar utama HP.';
        else if (!installed && isAndroidShell) help.textContent = 'Buka halaman ini dari Chrome/browser biasa, lalu install aplikasi pelanggan.';
        else if (!installed) help.textContent = 'Jika tombol install belum muncul, buka menu browser lalu pilih Install app atau Tambahkan ke layar utama.';
        else if (permission === 'denied') help.textContent = 'Notifikasi diblokir. Aktifkan lagi dari pengaturan situs/aplikasi browser, lalu tekan Cek Lagi.';
        else if (!notifyAllowed) help.textContent = 'Izinkan notifikasi sebelum masuk portal pelanggan.';
        else help.textContent = 'Aplikasi siap dipakai.';
      }

      gate.hidden = !showGate;
      document.body.classList.toggle('pwa-login-gated', showGate);
    }

    async function installLoginPwa() {
      const promptEvent = getLoginInstallPrompt();
      if (promptEvent) {
        try {
          promptEvent.prompt();
          await promptEvent.userChoice;
        } catch (_) {
        } finally {
          deferredLoginInstallPrompt = null;
          window.__deferredInstallPrompt = null;
        }
      }
      updateLoginPwaGate();
    }

    async function requestLoginNotification() {
      const button = document.getElementById('loginPwaNotifyButton');
      if (button) button.disabled = true;
      try {
        const OneSignal = await ensureLoginOneSignal();
        if (OneSignal?.Notifications?.requestPermission) {
          await OneSignal.Notifications.requestPermission();
        } else if ('Notification' in window && Notification.permission === 'default') {
          await Notification.requestPermission();
        }
        if (OneSignal?.User?.PushSubscription?.optIn) {
          await OneSignal.User.PushSubscription.optIn();
        }
      } catch (error) {
        console.warn('Izin notifikasi login gagal:', error);
      } finally {
        if (button) button.disabled = false;
        updateLoginPwaGate();
      }
    }

    window.addEventListener('beforeinstallprompt', (event) => {
      event.preventDefault();
      deferredLoginInstallPrompt = event;
      updateLoginPwaGate();
    });
    window.addEventListener('pwa-install-ready', () => {
      deferredLoginInstallPrompt = window.__deferredInstallPrompt || deferredLoginInstallPrompt;
      updateLoginPwaGate();
    });
    window.addEventListener('appinstalled', () => {
      deferredLoginInstallPrompt = null;
      window.__deferredInstallPrompt = null;
      updateLoginPwaGate();
    });
    document.getElementById('loginPwaInstallButton')?.addEventListener('click', installLoginPwa);
    document.getElementById('loginPwaNotifyButton')?.addEventListener('click', requestLoginNotification);
    document.getElementById('loginPwaRetryButton')?.addEventListener('click', updateLoginPwaGate);
    updateLoginPwaGate();
    window.setTimeout(updateLoginPwaGate, 900);
    window.setTimeout(updateLoginPwaGate, 2200);
  </script>
</body>

</html>
