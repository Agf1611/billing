<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">

<head>
  <% const logoSrc = (settings && settings.company_logo_url) ? settings.company_logo_url : '/img/logo.png'; %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title><%= t('customer.login_title', 'Login Pelanggan') %> | <%= settings.company_header || 'Portal ISP' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#f4f8ff">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="apple-touch-icon" href="<%= logoSrc %>">
  <link rel="icon" href="<%= logoSrc %>">
  <style>
    :root {
      --page-bg: #f4f8ff;
      --page-bg-2: #ffffff;
      --surface: rgba(255, 255, 255, 0.96);
      --surface-soft: #f8fbff;
      --line: rgba(107, 142, 195, 0.18);
      --line-strong: rgba(47, 107, 255, 0.22);
      --text-main: #18243d;
      --text-soft: #6c7b98;
      --text-faint: #8d98b1;
      --blue: #2c6bff;
      --blue-deep: #1f4fd8;
      --mint: #0ea5a4;
      --amber: #f59e0b;
      --shadow: 0 28px 70px rgba(40, 79, 144, 0.16);
      --shell-width: min(100vw, 448px);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
      margin: 0;
      color: var(--text-main);
      font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(72, 165, 255, 0.18) 0%, rgba(72, 165, 255, 0) 34%),
        radial-gradient(circle at top right, rgba(14, 165, 164, 0.14) 0%, rgba(14, 165, 164, 0) 28%),
        linear-gradient(180deg, var(--page-bg-2) 0%, var(--page-bg) 100%);
      -webkit-tap-highlight-color: transparent;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.18;
      background-image:
        linear-gradient(rgba(44, 107, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(44, 107, 255, 0.04) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    body.pwa-login {
      display: flex;
      justify-content: center;
    }

    .login-shell {
      position: relative;
      width: var(--shell-width);
      min-height: 100vh;
      min-height: 100dvh;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.76) 0%, rgba(247, 250, 255, 0.98) 100%);
      backdrop-filter: blur(20px);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .login-shell::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(320px 180px at 15% 0%, rgba(44, 107, 255, 0.14), transparent 70%),
        radial-gradient(280px 180px at 85% 14%, rgba(14, 165, 164, 0.1), transparent 72%);
    }

    .login-main {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: calc(env(safe-area-inset-top) + 14px) 18px calc(14px + env(safe-area-inset-bottom));
      gap: 10px;
    }

    .brand-bar {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 14px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.7);
      box-shadow: 0 16px 34px rgba(42, 78, 140, 0.08);
    }

    .brand-logo {
      width: 62px;
      height: 62px;
      flex: 0 0 62px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(236, 244, 255, 0.96));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.88), 0 18px 34px rgba(44, 107, 255, 0.12);
    }

    .brand-logo img {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }

    .brand-copy {
      min-width: 0;
      flex: 1;
    }

    .brand-copy strong {
      display: block;
      margin-bottom: 3px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-faint);
    }

    .brand-copy h1 {
      margin: 0 0 3px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 21px;
      line-height: 1.04;
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .brand-copy p {
      margin: 0;
      color: var(--text-soft);
      font-size: 12px;
      line-height: 1.4;
    }

    .login-card {
      background: var(--surface);
      border: 1px solid rgba(255, 255, 255, 0.74);
      border-radius: 26px;
      box-shadow: 0 22px 44px rgba(42, 78, 140, 0.1);
      overflow: hidden;
    }

    .login-card-head {
      padding: 16px 18px 8px;
    }

    .login-card-head h2 {
      margin: 0 0 4px;
      font-family: "Plus Jakarta Sans", "DM Sans", sans-serif;
      font-size: 19px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .login-card-head p {
      margin: 0;
      font-size: 12px;
      line-height: 1.45;
      color: var(--text-soft);
    }

    .form-container {
      padding: 12px 18px 18px;
    }

    .form-floating {
      margin-bottom: 12px;
    }

    .form-control {
      min-height: 54px;
      background: #f7faff;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px 16px 8px;
      color: var(--text-main);
      font-size: 15px;
      box-shadow: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .form-control:focus {
      background: #ffffff;
      border-color: rgba(44, 107, 255, 0.42);
      box-shadow: 0 0 0 4px rgba(44, 107, 255, 0.11);
      color: var(--text-main);
    }

    .form-floating > label {
      color: var(--text-soft);
      padding: 14px 16px;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
      color: var(--blue);
    }

    .remember-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: 2px 0 12px;
    }

    .remember-check {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      margin: 0;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-main);
      cursor: pointer;
      user-select: none;
    }

    .remember-check input {
      width: 16px;
      height: 16px;
      margin: 0;
      accent-color: var(--blue);
    }

    .remember-hint {
      font-size: 11px;
      color: var(--text-soft);
      text-align: right;
    }

    .btn-login {
      min-height: 50px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--blue) 0%, #4f8cff 100%);
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -0.02em;
      box-shadow: 0 18px 34px rgba(44, 107, 255, 0.2);
    }

    .btn-login:hover,
    .btn-login:focus {
      background: linear-gradient(135deg, #225bdf 0%, #437ef0 100%);
    }

    .action-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .btn-soft-action {
      min-height: 46px;
      border-radius: 15px;
      border: 1px solid rgba(44, 107, 255, 0.16);
      background: rgba(44, 107, 255, 0.06);
      color: var(--blue-deep);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 800;
      text-decoration: none;
      transition: 0.2s ease;
    }

    .btn-soft-action:hover,
    .btn-soft-action:focus {
      background: rgba(44, 107, 255, 0.1);
      border-color: rgba(44, 107, 255, 0.24);
      color: var(--blue-deep);
    }

    .alert {
      margin: 12px 0 0;
      border-radius: 16px;
      border: 1px solid rgba(239, 68, 68, 0.16);
      font-size: 12px;
    }

    .support-compact {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(247, 250, 255, 0.96), rgba(241, 246, 255, 0.94));
      border: 1px solid var(--line);
    }

    .support-copy {
      min-width: 0;
    }

    .support-copy strong {
      display: block;
      margin: 0;
      font-size: 13px;
      font-weight: 800;
      color: var(--text-main);
    }

    .support-copy span {
      display: block;
      margin-top: 3px;
      font-size: 11px;
      line-height: 1.4;
      color: var(--text-soft);
    }

    .wa-mini-link {
      width: 48px;
      height: 48px;
      flex: 0 0 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 16px;
      background: linear-gradient(135deg, #1ecb67 0%, #13a34f 100%);
      color: #ffffff;
      text-decoration: none;
      box-shadow: 0 16px 28px rgba(30, 203, 103, 0.22);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .wa-mini-link:hover,
    .wa-mini-link:focus {
      color: #ffffff;
      transform: translateY(-1px);
      box-shadow: 0 18px 30px rgba(30, 203, 103, 0.28);
    }

    .wa-mini-link i {
      font-size: 22px;
    }

    .footer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: 12px;
      font-size: 11px;
      color: var(--text-soft);
    }

    .footer-row a {
      color: var(--blue);
      font-weight: 800;
      text-decoration: none;
    }

    @media (max-width: 576px) {
      .login-main {
        padding-left: 14px;
        padding-right: 14px;
      }

      .brand-bar {
        padding: 12px;
      }

      .brand-logo {
        width: 56px;
        height: 56px;
        flex-basis: 56px;
      }

      .brand-logo img {
        width: 42px;
        height: 42px;
      }

      .brand-copy h1 {
        font-size: 20px;
      }

      .login-card-head,
      .form-container {
        padding-left: 14px;
        padding-right: 14px;
      }

      .remember-row {
        grid-template-columns: 1fr;
        display: grid;
      }

      .remember-row {
        align-items: stretch;
      }

      .remember-hint {
        text-align: left;
      }

      .footer-row {
        flex-direction: column;
        align-items: flex-start;
      }

      .support-compact {
        align-items: center;
      }
    }

    @media (max-width: 640px) {
      body.android-webview {
        display: block;
      }

      body.android-webview .login-shell {
        width: 100vw;
        min-height: 100vh;
        min-height: 100dvh;
        box-shadow: none;
      }
    }
  </style>
</head>

<body class="pwa-login">
  <div class="login-shell">
    <main class="login-main">
      <% const supportWhatsapp = settings.company_phone || ((settings.whatsapp_admin_numbers && settings.whatsapp_admin_numbers[0]) ? settings.whatsapp_admin_numbers[0] : ''); %>
      <% const supportWhatsappLink = supportWhatsapp ? `https://wa.me/${supportWhatsapp.replace(/\D/g, '')}` : '/customer/contact'; %>
      <% const supportEmail = settings.company_email || ''; %>
      <% const supportHours = settings.operational_hours || 'Setiap Hari 08.00 - 22.00 WIB'; %>

      <section class="brand-bar">
        <div class="brand-logo">
          <img src="<%= logoSrc %>" alt="Logo <%= settings.company_header || 'Portal ISP' %>">
        </div>
        <div class="brand-copy">
          <strong>Portal Pelanggan</strong>
          <h1><%= settings.company_header || 'Portal ISP' %></h1>
          <p>Login cepat untuk portal pelanggan dan cek pembayaran.</p>
        </div>
      </section>

      <section class="login-card">
        <div class="login-card-head">
          <h2>Masuk ke akun Anda</h2>
          <p>Gunakan ID pelanggan, tag ONU, username PPPoE, atau nomor HP yang terdaftar.</p>
        </div>

        <div class="form-container">
          <form method="POST" action="/customer/login">
            <div class="form-floating">
              <input type="text" class="form-control" id="phone" name="phone" placeholder="<%= t('customer.id_tag_placeholder', 'Masukkan ID/Tag Pelanggan') %>" required autofocus autocomplete="username" enterkeyhint="go" value="<%= (form && form.phone) ? form.phone : '' %>">
              <label for="phone">
                <i class="bi bi-person-badge me-2"></i><%= t('customer.id_tag', 'ID/Tag Pelanggan') %>
              </label>
            </div>

            <div class="remember-row">
              <label class="remember-check">
                <input type="checkbox" name="remember_me" <%= (form && form.rememberMe) ? 'checked' : '' %>>
                <span>Tetap ingat saya</span>
              </label>
              <div class="remember-hint">Proses login aman dan tersimpan hanya di perangkat ini.</div>
            </div>

            <button type="submit" class="btn btn-primary btn-login w-100">
              <i class="bi bi-box-arrow-in-right me-2"></i><%= t('customer.sign_in', 'Masuk') %>
            </button>
          </form>

          <div class="action-row">
            <a href="/customer/check-billing" class="btn-soft-action w-100">
              <i class="bi bi-receipt-cutoff"></i>
              <span>Cek Pembayaran & Tagihan</span>
            </a>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger text-center">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <%= error==='Nomor HP tidak valid atau belum terdaftar.' ? 'ID/Tag tidak valid atau belum terdaftar.' : error %>
            </div>
          <% } %>

          <div class="support-compact">
            <div class="support-copy">
              <strong>Bantuan pelanggan</strong>
              <span><%= supportHours %></span>
            </div>
            <a href="<%= supportWhatsappLink %>" class="wa-mini-link" aria-label="WhatsApp Support">
              <i class="bi bi-whatsapp"></i>
            </a>
          </div>

          <div class="footer-row">
            <span><%= t('customer.not_subscribed', 'Belum berlangganan?') %> <a href="/customer/register"><%= t('customer.register_new', 'Daftar Pemasangan Baru') %></a></span>
            <span>&copy; <%= new Date().getFullYear() %> <%= settings.company_header || 'Portal ISP' %></span>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/customer/' }).catch(() => {});
      });
    }

    const isAndroidShell = /android/i.test(navigator.userAgent || '') || window.matchMedia('(display-mode: standalone)').matches;
    if (isAndroidShell) {
      document.body.classList.add('android-webview');
    }
  </script>
</body>

</html>
