<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Pilih Metode Pembayaran - <%= settings.company_header || settings.company || 'Portal Pelanggan' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <%- include('partials/pwa_portal', {
    portalKey: 'customer',
    manifestPath: '/pwa/customer.webmanifest',
    scope: '/customer/',
    themeColor: '#2563eb',
    appTitle: 'Portal Pelanggan',
    installLabel: 'Install Pelanggan'
  }) %>
  <style>
    :root{
      --bg:#f5f8ff;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --line:#dbe4f0;
      --accent:#2563eb;
      --accent-2:#4f46e5;
      --shadow:0 24px 70px rgba(37,99,235,.12);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      min-height:100vh;
      font-family:"DM Sans",sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top left, rgba(96,165,250,.22), transparent 28%),
        radial-gradient(circle at top right, rgba(129,140,248,.18), transparent 24%),
        linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
      padding:20px 16px 32px;
    }
    .shell{max-width:520px;margin:0 auto}
    .back-link{
      display:inline-flex;align-items:center;gap:10px;text-decoration:none;color:#1e3a8a;
      font-weight:700;margin-bottom:16px
    }
    .hero{
      background:linear-gradient(145deg, #1d4ed8 0%, #2563eb 45%, #4f46e5 100%);
      color:#fff;border-radius:28px;padding:24px 22px;box-shadow:var(--shadow);position:relative;overflow:hidden
    }
    .hero::after{
      content:"";position:absolute;right:-40px;top:-40px;width:150px;height:150px;border-radius:50%;
      background:rgba(255,255,255,.12)
    }
    .eyebrow{font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;opacity:.82}
    .hero h1{font-family:"Outfit",sans-serif;font-size:28px;line-height:1.05;margin:10px 0 0}
    .summary{
      margin-top:16px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.18);
      border-radius:20px;padding:15px 16px;display:grid;grid-template-columns:1fr auto;gap:14px;position:relative;z-index:1
    }
    .summary strong{display:block;font-size:26px;font-family:"Outfit",sans-serif;line-height:1.1}
    .summary small{display:block;color:rgba(255,255,255,.8);margin-top:5px}
    .summary .code{
      align-self:start;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.22);
      padding:9px 12px;border-radius:999px;font-size:12px;font-weight:700
    }
    .panel{
      margin-top:16px;background:var(--card);border-radius:28px;padding:18px;box-shadow:0 18px 45px rgba(15,23,42,.06)
    }
    .auto-note{
      margin-top:14px;
      padding:14px 15px;
      border-radius:18px;
      background:rgba(255,255,255,.16);
      border:1px solid rgba(255,255,255,.22);
      font-size:13px;
      line-height:1.55;
      color:#f8fbff;
    }
    .auto-note strong{display:block;margin-bottom:4px;font-size:13px}
    .auto-note code{
      display:inline-flex;align-items:center;gap:6px;margin-top:7px;padding:5px 10px;border-radius:999px;
      background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.24);color:#fff;font-family:inherit;font-size:12px;font-weight:800
    }
    .panel-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:12px}
    .panel-head h2{margin:0;font-family:"Outfit",sans-serif;font-size:22px}
    .grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .method{
      text-decoration:none;color:inherit;background:#f8fbff;border:1px solid var(--line);border-radius:20px;
      padding:14px 13px;display:grid;grid-template-columns:46px minmax(0,1fr);grid-template-areas:
      "icon badge"
      "icon title"
      "meta meta";column-gap:12px;row-gap:7px;min-height:112px;position:relative;align-items:start;overflow:hidden;
      transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease
    }
    .method:hover{transform:translateY(-2px);border-color:#93c5fd;box-shadow:0 18px 32px rgba(37,99,235,.12)}
    .method > *{min-width:0}
    .icon{
      width:46px;height:46px;border-radius:16px;display:flex;align-items:center;justify-content:center;
      font-size:21px;font-weight:800;background:#dbeafe;color:#1d4ed8;overflow:hidden;flex:0 0 auto;grid-area:icon
    }
    .icon img{width:100%;height:100%;object-fit:contain;background:#fff;padding:8px}
    .badge{
      font-size:10px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;border-radius:999px;
      padding:5px 9px;background:#e0e7ff;color:#4338ca;grid-area:badge;justify-self:end;max-width:84px;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;align-self:start
    }
    .badge.internal{background:#dcfce7;color:#15803d}
    .badge.va{background:#e2e8f0;color:#334155}
    .badge.wallet{background:#fef3c7;color:#b45309}
    .badge.online{background:#dbeafe;color:#1d4ed8}
    .method h3{
      margin:0;font-size:17px;font-family:"Outfit",sans-serif;grid-area:title;line-height:1.15;align-self:center;max-width:100%;
      overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;word-break:break-word
    }
    .meta{
      display:flex;align-items:center;justify-content:space-between;gap:8px;grid-area:meta;align-self:end;min-width:0;
      width:100%;padding-top:2px;border-top:1px solid rgba(37,99,235,.08)
    }
    .meta span{
      font-size:11px;color:#1d4ed8;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0;
      flex:1 1 auto
    }
    .meta i{font-size:14px;color:#1e3a8a}
    @media (max-width:560px){
      body{padding:14px 12px 28px}
      .hero{padding:20px 18px;border-radius:24px}
      .hero h1{font-size:24px}
      .panel{padding:16px 14px;border-radius:24px}
      .panel-head h2{font-size:20px}
      .summary{grid-template-columns:1fr}
      .method{padding:12px 11px;grid-template-columns:42px minmax(0,1fr);column-gap:10px;row-gap:5px;min-height:100px;border-radius:18px}
      .icon{width:42px;height:42px;border-radius:14px;font-size:19px}
      .method h3{font-size:15px}
      .meta span{font-size:10px}
      .badge{font-size:9px;padding:5px 8px;max-width:76px}
    }
    @media (max-width:380px){
      .grid{gap:10px}
      .method{padding:11px 10px;grid-template-columns:38px minmax(0,1fr);min-height:96px}
      .icon{width:38px;height:38px;border-radius:12px}
      .method h3{font-size:14px}
      .meta{gap:6px}
      .meta span{font-size:9px}
      .meta i{font-size:13px}
    }
  </style>
</head>
<body>
  <%
    const paymentBaseAmount = Number(invoice.amount || 0) || 0;
    const paymentExactAmount = Number(invoice.qris_amount_unique || invoice.amount || 0) || 0;
    const paymentUniqueCode = Number(invoice.qris_unique_code || 0) || 0;
    const paymentUniqueDelta = paymentExactAmount > paymentBaseAmount ? (paymentExactAmount - paymentBaseAmount) : paymentUniqueCode;
    const includePpn = Number(customer?.package_include_ppn || customer?.include_ppn || 0) === 1;
    const ppnPercent = includePpn ? Math.max(0, Number(customer?.package_ppn_percent || customer?.ppn_percent || 0)) : 0;
    const baseBeforeTax = includePpn && ppnPercent > 0 ? Math.round(paymentBaseAmount / (1 + (ppnPercent / 100))) : paymentBaseAmount;
    const ppnAmount = includePpn && ppnPercent > 0 ? Math.max(0, paymentBaseAmount - baseBeforeTax) : 0;
  %>
  <div class="shell">
    <a class="back-link" href="/customer/dashboard#billing"><i class="bi bi-arrow-left"></i> Kembali ke tagihan</a>

    <section class="hero">
      <div class="eyebrow">Pembayaran Pelanggan</div>
      <h1>Bayar Online Otomatis</h1>

      <div class="summary">
        <div>
          <div><strong><%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(paymentExactAmount) %></strong></div>
          <small>INV-<%= invoice.id %> • <%= customer?.name || invoice.customer_name || 'Pelanggan' %></small>
        </div>
        <div class="code">Belum Lunas</div>
      </div>

      <div class="auto-note">
        <strong>Disarankan pakai payment gateway</strong>
        Pilih Bayar Online, Virtual Account, atau kanal payment gateway lain agar pembayaran otomatis masuk sistem. Transfer manual seperti BRI/BRImo tetap bisa dipakai sebagai cadangan, tetapi perlu dicek admin jika tidak terbaca otomatis.
        <% if (ppnAmount > 0) { %>
          <br>Harga dasar Rp <%= baseBeforeTax.toLocaleString('id-ID') %> + PPN <%= ppnPercent.toLocaleString('id-ID') %>% Rp <%= ppnAmount.toLocaleString('id-ID') %> = Rp <%= paymentBaseAmount.toLocaleString('id-ID') %>.
        <% } %>
        <% if (paymentExactAmount > 0 && paymentUniqueDelta > 0) { %>
          <br><code><i class="bi bi-check2-circle"></i> Rp <%= paymentBaseAmount.toLocaleString('id-ID') %> + kode unik <%= String(paymentUniqueCode || paymentUniqueDelta).padStart(3, '0') %> = Rp <%= paymentExactAmount.toLocaleString('id-ID') %></code>
        <% } %>
      </div>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <h2>Pilih Pembayaran Online</h2>
          <div style="font-size:12px;color:#64748b;margin-top:4px">Metode online membantu tagihan cepat terbaca lunas tanpa konfirmasi manual.</div>
        </div>
      </div>

      <div class="grid">
        <%
          const brandMap = {
            DANA: { badge: 'wallet', note: 'Bayar cepat via saldo DANA atau scan dari aplikasi.' },
            OVO: { badge: 'wallet', note: 'Cocok untuk pelanggan yang sering pakai OVO.' },
            SHOPEEPAY: { badge: 'wallet', note: 'Praktis lewat ShopeePay dan scan langsung.' },
            LINKAJA: { badge: 'wallet', note: 'Bayar lewat LinkAja dengan proses instan.' },
            GOPAY: { badge: 'wallet', note: 'Bisa dibayar memakai GoPay atau QR pendukung.' },
            BRIVA: { badge: 'va', note: 'Transfer dari BRI Virtual Account dengan nominal otomatis.' },
            BCAVA: { badge: 'va', note: 'Transfer dari BCA Virtual Account dengan nominal otomatis.' },
            BNIVA: { badge: 'va', note: 'Transfer dari BNI Virtual Account dengan nominal otomatis.' },
            MANDIRIVA: { badge: 'va', note: 'Transfer dari Mandiri Virtual Account dengan nominal otomatis.' },
            PERMATAVA: { badge: 'va', note: 'Transfer dari Permata Virtual Account dengan nominal otomatis.' }
          };
          paymentChannels.forEach((channel) => {
            const code = String(channel.code || '').toUpperCase();
            const iconUrl = channel.icon_url || channel.iconUrl || '';
            const group = String(channel.group || '').trim();
            const brand = brandMap[code] || null;
            const isInternal = code === 'STATICQRIS' || channel.source === 'internal';
            const isQrisTripay = !isInternal && code.startsWith('QRIS');
            const groupClass = isInternal ? 'internal' : isQrisTripay ? 'online' : group === 'Virtual Account' ? 'va' : group === 'E-Wallet' ? 'wallet' : 'online';
            const title = isInternal
              ? 'Bayar Online Cadangan'
              : isQrisTripay
                ? 'Bayar Online'
              : String(channel.name || code)
                  .replace(/virtual account/ig, 'VA')
                  .replace(/QRIS/ig, 'Bayar Online')
                  .replace(/^bank\s+/ig, '')
                  .replace(/\s+/g, ' ')
                  .trim();
            const iconClass = isQrisTripay ? 'bi-credit-card-2-front' : group === 'Virtual Account' ? 'bi-bank2' : group === 'E-Wallet' ? 'bi-wallet2' : 'bi-credit-card-2-front';
        %>
          <a class="method" href="/customer/payment/create/<%= invoice.id %>?method=<%= encodeURIComponent(code) %>">
            <div class="icon">
              <% if (iconUrl) { %>
                <img src="<%= iconUrl %>" alt="<%= title %>" loading="lazy" referrerpolicy="no-referrer">
              <% } else { %>
                <i class="bi <%= iconClass %>"></i>
              <% } %>
            </div>
            <span class="badge <%= groupClass %>"><%= isInternal ? 'Opsional' : isQrisTripay ? 'Online' : (group === 'Virtual Account' ? 'VA' : String(group || 'Bayar').replace(/QRIS/ig, 'Online')) %></span>
            <h3><%= title %></h3>
            <div class="meta">
              <span><%= isInternal ? 'Cadangan manual' : isQrisTripay ? 'Payment gateway otomatis' : String(code || '').replace(/QRIS/ig, 'ONLINE') %></span>
              <i class="bi bi-arrow-right-circle-fill"></i>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  </div>
</body>
</html>
