<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
  <%- include('../admin/partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    :root{
      --bg:#08111f;
      --surface:rgba(16,26,46,.94);
      --surface-soft:#16243d;
      --border:rgba(148,163,184,.16);
      --text:#e7eefb;
      --muted:#99a9c4;
      --primary:#5b6dfb;
      --primary-2:#3b82f6;
      --danger:#ef4444;
      --danger-soft:rgba(239,68,68,.12);
      --shadow:0 28px 64px rgba(1,7,18,.28);
    }
    *{box-sizing:border-box}
    html,body{
      margin:0;
      min-height:100%;
      background:
        radial-gradient(820px 400px at 0% 0%, rgba(91,109,251,.18), rgba(8,17,31,0) 58%),
        radial-gradient(760px 360px at 100% 0%, rgba(59,130,246,.14), rgba(8,17,31,0) 52%),
        linear-gradient(180deg, #0b1526 0%, var(--bg) 100%);
      color:var(--text);
      font-family:Inter, system-ui, -apple-system, "Segoe UI", sans-serif;
    }
    body[data-theme="light"]{
      --bg:#eef4ff;
      --surface:rgba(255,255,255,.96);
      --surface-soft:#f7faff;
      --border:rgba(110,140,198,.16);
      --text:#13233f;
      --muted:#6f819b;
      --danger-soft:rgba(239,68,68,.10);
      --shadow:0 24px 58px rgba(44,72,122,.14);
    }
    body{
      padding:18px 14px;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .login-shell{
      width:min(100%, 388px);
      display:grid;
      gap:12px;
    }
    .login-topbar{
      display:flex;
      justify-content:flex-end;
    }
    .icon-btn{
      width:38px;
      height:38px;
      border-radius:13px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.04);
      color:var(--text);
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }
    body[data-theme="light"] .icon-btn{background:rgba(91,109,251,.04)}
    .login-card{
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:28px;
      padding:22px 18px 18px;
      box-shadow:var(--shadow);
      backdrop-filter:blur(12px);
    }
    .brand{
      width:56px;
      height:56px;
      margin:0 auto 14px;
      border-radius:20px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:24px;
      color:#dce8ff;
      background:linear-gradient(135deg, rgba(91,109,251,.22), rgba(59,130,246,.18));
      border:1px solid rgba(91,109,251,.28);
      box-shadow:0 14px 30px rgba(59,130,246,.18);
    }
    .title{
      text-align:center;
      font-size:24px;
      font-weight:900;
      letter-spacing:-.04em;
      line-height:1.05;
    }
    .subtitle{
      margin:6px auto 18px;
      max-width:260px;
      text-align:center;
      font-size:12px;
      color:var(--muted);
      line-height:1.55;
    }
    .field{display:grid;gap:7px;margin-bottom:11px}
    .label{
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.08em;
      color:var(--muted);
    }
    .fc{
      width:100%;
      border-radius:16px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      padding:12px 13px;
      font-size:14px;
      outline:none;
    }
    .fc:focus{border-color:rgba(91,109,251,.48)}
    .btn-login{
      width:100%;
      margin-top:4px;
      min-height:46px;
      border:0;
      border-radius:16px;
      color:#fff;
      font-size:14px;
      font-weight:900;
      background:linear-gradient(135deg, var(--primary), var(--primary-2));
      box-shadow:0 18px 34px rgba(59,130,246,.22);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
    }
    .alert-box{
      border-radius:16px;
      padding:11px 12px;
      margin-bottom:12px;
      font-size:12px;
      line-height:1.5;
      background:var(--danger-soft);
      border:1px solid rgba(239,68,68,.18);
      color:var(--danger);
    }
    .helper{
      margin-top:14px;
      text-align:center;
      font-size:11px;
      color:var(--muted);
      line-height:1.6;
    }
  </style>
</head>
<body>
  <div class="login-shell">
    <div class="login-topbar">
      <button class="icon-btn" type="button" data-theme-toggle aria-label="Ganti tema">
        <i class="bi bi-sun"></i>
      </button>
    </div>

    <div class="login-card">
      <div class="brand"><i class="bi bi-person-lines-fill"></i></div>
      <div class="title">Portal Kolektor</div>
      <div class="subtitle">Masuk cepat untuk cek tagihan, cari pelanggan, dan kirim pengajuan pembayaran dari HP.</div>

      <% if (error) { %>
        <div class="alert-box"><%= error %></div>
      <% } %>

      <form method="POST" action="/collector/login">
        <div class="field">
          <label class="label" for="collector-username">Username</label>
          <input id="collector-username" class="fc" name="username" autocomplete="username" required placeholder="Masukkan username kolektor">
        </div>
        <div class="field">
          <label class="label" for="collector-password">Password</label>
          <input id="collector-password" type="password" class="fc" name="password" autocomplete="current-password" required placeholder="Masukkan password">
        </div>
        <button class="btn-login" type="submit">
          <i class="bi bi-box-arrow-in-right"></i>
          <span>Masuk ke Portal</span>
        </button>
      </form>

      <div class="helper"><%= company %> · tampilan dibuat lebih ringkas untuk operasional lapangan dan layar mobile.</div>
    </div>
  </div>

  <script>
    (function() {
      const savedTheme = localStorage.getItem('admin-theme')
        || document.documentElement.dataset.adminTheme
        || 'dark';

      function syncTheme(theme) {
        document.documentElement.dataset.adminTheme = theme;
        document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
        if (document.body) document.body.dataset.theme = theme;
        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          const icon = button.querySelector('i');
          if (icon) icon.className = theme === 'light' ? 'bi bi-moon-stars' : 'bi bi-sun';
        });
      }

      syncTheme(savedTheme);
      document.addEventListener('click', (event) => {
        const toggle = event.target.closest('[data-theme-toggle]');
        if (!toggle) return;
        event.preventDefault();
        const currentTheme = document.body?.dataset.theme || document.documentElement.dataset.adminTheme || 'dark';
        const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
        localStorage.setItem('admin-theme', nextTheme);
        syncTheme(nextTheme);
      });
      window.addEventListener('storage', (event) => {
        if (event.key === 'admin-theme') syncTheme(event.newValue || 'dark');
      });
    })();
  </script>
</body>
</html>
