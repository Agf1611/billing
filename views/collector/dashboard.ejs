<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
  <%- include('../admin/partials/theme_init') %>
  <%- include('../partials/pwa_portal', {
    portalKey: 'collector',
    manifestPath: '/pwa/collector.webmanifest',
    scope: '/collector/',
    themeColor: '#073dcc',
    appTitle: 'Portal Kolektor'
  }) %>
  <title><%= title %> | <%= company %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    :root{
      --bg:#f5f8ff;
      --bg-soft:#ffffff;
      --surface:#ffffff;
      --surface-soft:#f7faff;
      --surface-elevated:rgba(255,255,255,.96);
      --border:rgba(28,54,102,.14);
      --text:#07163f;
      --muted:#62708c;
      --primary:#073dcc;
      --primary-2:#0b55f4;
      --primary-soft:rgba(7,61,204,.10);
      --success:#22c55e;
      --success-soft:rgba(34,197,94,.14);
      --warn:#f59e0b;
      --warn-soft:rgba(245,158,11,.15);
      --danger:#ef4444;
      --danger-soft:rgba(239,68,68,.14);
      --shadow:0 18px 44px rgba(18,47,102,.12);
      --radius-lg:22px;
      --radius-md:16px;
      --radius-sm:12px;
    }

    *{box-sizing:border-box}
    html,body{
      margin:0;
      min-height:100%;
      background:linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
      color:var(--text);
      font-family:Inter, system-ui, -apple-system, "Segoe UI", sans-serif;
    }
    body{
      padding:0 0 28px;
      -webkit-tap-highlight-color:transparent;
    }
    body[data-theme="light"]{
      --bg:#f5f8ff;
      --bg-soft:#ffffff;
      --surface:#ffffff;
      --surface-soft:#f7faff;
      --surface-elevated:rgba(255,255,255,.96);
      --border:rgba(110,140,198,.16);
      --text:#13233f;
      --muted:#6f819b;
      --primary-soft:rgba(7,61,204,.08);
      --success-soft:rgba(34,197,94,.12);
      --warn-soft:rgba(245,158,11,.12);
      --danger-soft:rgba(239,68,68,.10);
      --shadow:0 18px 44px rgba(44,72,122,.12);
    }
    a{text-decoration:none;color:inherit}
    button,input,select,textarea{font:inherit}

    .collector-shell{
      width:min(100%, 760px);
      margin:0 auto;
      padding:0 12px;
    }

    .collector-topbar{
      position:sticky;
      top:0;
      z-index:1200;
      backdrop-filter:blur(14px);
      background:rgba(255,255,255,.92);
      border-bottom:1px solid rgba(28,54,102,.12);
    }
    body[data-theme="light"] .collector-topbar{
      background:rgba(255,255,255,.94);
      border-bottom-color:rgba(110,140,198,.14);
    }
    .collector-topbar-inner{
      width:min(100%, 760px);
      margin:0 auto;
      padding:10px 12px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }
    .collector-brand{
      min-width:0;
      display:flex;
      align-items:center;
      gap:10px;
    }
    .collector-brand-badge{
      width:38px;
      height:38px;
      border-radius:14px;
      display:flex;
      align-items:center;
      justify-content:center;
      flex:0 0 auto;
      color:#073dcc;
      background:#ffffff;
      border:1px solid rgba(7,61,204,.18);
      box-shadow:0 12px 26px rgba(7,61,204,.14);
      font-size:16px;
    }
    .collector-brand-badge img{width:30px;height:30px;object-fit:contain}
    .collector-brand-title{
      font-size:14px;
      font-weight:900;
      letter-spacing:0;
      line-height:1.05;
    }
    .collector-brand-sub{
      margin-top:3px;
      font-size:11px;
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .collector-topbar-actions{
      display:flex;
      align-items:center;
      gap:8px;
      flex:0 0 auto;
    }
    .icon-btn{
      width:36px;
      height:36px;
      border-radius:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.04);
      color:var(--text);
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }
    body[data-theme="light"] .icon-btn{background:rgba(91,109,251,.04)}

    .sticky-tools{
      position:sticky;
      top:59px;
      z-index:1150;
      padding:10px 0 8px;
      background:linear-gradient(180deg, rgba(8,17,31,.96) 0%, rgba(8,17,31,.90) 84%, rgba(8,17,31,0) 100%);
      backdrop-filter:blur(16px);
    }
    body[data-theme="light"] .sticky-tools{
      background:linear-gradient(180deg, rgba(244,247,255,.97) 0%, rgba(244,247,255,.91) 84%, rgba(244,247,255,0) 100%);
    }

    .tool-card,.section-card,.summary-strip,.history-card{
      background:var(--surface-elevated);
      border:1px solid var(--border);
      box-shadow:var(--shadow);
    }
    .tool-card{
      border-radius:20px;
      padding:10px;
      display:grid;
      gap:10px;
    }
    .tool-search{
      display:flex;
      align-items:center;
      gap:8px;
      padding:8px 10px;
      border-radius:16px;
      background:var(--surface-soft);
      border:1px solid var(--border);
    }
    .tool-search i{font-size:14px;color:var(--muted)}
    .tool-search input{
      flex:1 1 auto;
      min-width:0;
      border:0;
      outline:none;
      background:transparent;
      color:var(--text);
      font-size:13px;
      padding:0;
    }
    .tool-search input::placeholder{color:var(--muted)}
    .tool-submit{
      border:0;
      border-radius:12px;
      background:linear-gradient(135deg, var(--primary), var(--primary-2));
      color:#fff;
      padding:9px 11px;
      font-size:12px;
      font-weight:800;
      display:inline-flex;
      align-items:center;
      gap:6px;
      box-shadow:0 12px 24px rgba(59,130,246,.22);
    }
    .tool-meta{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:8px;
    }
    .tool-select{
      width:100%;
      border-radius:12px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      padding:9px 10px;
      font-size:12px;
      outline:none;
    }
    .filter-strip{
      display:flex;
      gap:8px;
      overflow:auto;
      padding-bottom:2px;
      scrollbar-width:none;
    }
    .filter-strip::-webkit-scrollbar{display:none}
    .filter-chip{
      flex:0 0 auto;
      display:inline-flex;
      align-items:center;
      gap:6px;
      min-height:36px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      white-space:nowrap;
    }
    .filter-chip.active{
      background:rgba(91,109,251,.16);
      border-color:rgba(91,109,251,.36);
      color:#dce8ff;
      box-shadow:0 10px 22px rgba(59,130,246,.18);
    }
    body[data-theme="light"] .filter-chip.active{color:#2f4ca8}

    .summary-strip{
      margin:12px 0 10px;
      border-radius:20px;
      padding:10px;
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:8px;
    }
    .summary-pill{
      min-width:0;
      border-radius:16px;
      padding:10px 10px 9px;
      background:var(--surface-soft);
      border:1px solid var(--border);
      display:grid;
      gap:4px;
    }
    .summary-pill span{
      font-size:10px;
      color:var(--muted);
      font-weight:700;
      line-height:1.25;
    }
    .summary-pill strong{
      font-size:18px;
      font-weight:900;
      line-height:1;
      letter-spacing:0;
    }
    .summary-pill small{
      font-size:10px;
      color:var(--muted);
      font-weight:700;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .section-card,.history-card{
      border-radius:22px;
      overflow:hidden;
      margin-top:10px;
    }
    .section-head{
      padding:12px 14px 10px;
      border-bottom:1px solid rgba(148,163,184,.08);
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:8px;
    }
    .section-title{
      font-size:14px;
      font-weight:900;
      letter-spacing:0;
      display:flex;
      align-items:center;
      gap:8px;
    }
    .section-note{
      margin-top:4px;
      font-size:11px;
      color:var(--muted);
      line-height:1.4;
    }
    .section-body{padding:12px}

    .collector-list{
      display:grid;
      gap:10px;
    }
    .empty-state{
      padding:24px 14px;
      border-radius:18px;
      background:var(--surface-soft);
      border:1px dashed var(--border);
      color:var(--muted);
      text-align:center;
      font-size:12px;
      line-height:1.5;
    }

    .history-card details{padding:0}
    .history-card summary{
      list-style:none;
      cursor:pointer;
      padding:12px 14px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      font-size:14px;
      font-weight:900;
    }
    .history-card summary::-webkit-details-marker{display:none}
    .history-card summary small{
      font-size:11px;
      color:var(--muted);
      font-weight:700;
    }
    .history-list{
      display:grid;
      gap:8px;
      padding:0 12px 12px;
    }
    .history-row{
      border:1px solid var(--border);
      background:var(--surface-soft);
      border-radius:16px;
      padding:10px 11px;
      display:grid;
      gap:5px;
    }
    .history-top{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:flex-start;
    }
    .history-name{
      font-size:13px;
      font-weight:900;
      line-height:1.25;
    }
    .history-sub{
      font-size:11px;
      color:var(--muted);
      line-height:1.4;
    }

    .sheet-backdrop{
      position:fixed;
      inset:0;
      z-index:1600;
      background:rgba(2,8,23,.54);
      backdrop-filter:blur(6px);
      opacity:0;
      visibility:hidden;
      transition:opacity .2s ease, visibility .2s ease;
    }
    .sheet-backdrop.is-open{
      opacity:1;
      visibility:visible;
    }
    .action-sheet{
      position:fixed;
      left:0;
      right:0;
      bottom:0;
      z-index:1700;
      transform:translateY(104%);
      transition:transform .24s ease;
      pointer-events:none;
    }
    .action-sheet.is-open{
      transform:translateY(0);
      pointer-events:auto;
    }
    .action-sheet-inner{
      width:min(100%, 760px);
      margin:0 auto;
      border-radius:26px 26px 0 0;
      background:var(--surface);
      border:1px solid var(--border);
      box-shadow:0 -18px 44px rgba(1,7,18,.38);
      padding:10px 12px calc(16px + env(safe-area-inset-bottom));
      max-height:min(78vh, 720px);
      overflow:auto;
    }
    .sheet-handle{
      width:44px;
      height:5px;
      border-radius:999px;
      background:rgba(148,163,184,.32);
      margin:0 auto 10px;
    }
    .sheet-head{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
    }
    .sheet-title{
      font-size:15px;
      font-weight:900;
      letter-spacing:0;
      line-height:1.15;
    }
    .sheet-sub{
      margin-top:4px;
      font-size:12px;
      color:var(--muted);
      line-height:1.45;
    }
    .sheet-close{
      width:34px;
      height:34px;
      border-radius:12px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      flex:0 0 auto;
    }
    .sheet-status{
      margin-top:12px;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }
    .sheet-grid{
      margin-top:12px;
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
    }
    .sheet-cell{
      padding:10px 11px;
      border-radius:14px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      min-width:0;
    }
    .sheet-cell span{
      display:block;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.08em;
      color:var(--muted);
      font-weight:800;
      margin-bottom:5px;
    }
    .sheet-cell strong{
      display:block;
      font-size:12px;
      line-height:1.45;
      word-break:break-word;
    }
    .sheet-actions{
      margin-top:12px;
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
    }
    .sheet-btn{
      min-height:42px;
      border-radius:14px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:7px;
      font-size:12px;
      font-weight:800;
    }
    .sheet-btn.primary{
      border:0;
      background:linear-gradient(135deg, var(--primary), var(--primary-2));
      color:#fff;
      box-shadow:0 14px 28px rgba(59,130,246,.22);
    }
    .sheet-note-wrap{
      margin-top:12px;
      display:none;
      gap:8px;
    }
    .sheet-note-wrap.is-visible{display:grid}
    .sheet-textarea{
      width:100%;
      min-height:88px;
      resize:vertical;
      border-radius:16px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      padding:11px 12px;
      outline:none;
      font-size:13px;
    }
    .sheet-submit-row{
      display:grid;
      grid-template-columns:minmax(0,1fr) auto;
      gap:8px;
      align-items:center;
    }
    .sheet-help{
      font-size:11px;
      color:var(--muted);
      line-height:1.5;
    }
    .status-pill{
      display:inline-flex;
      align-items:center;
      gap:6px;
      min-height:28px;
      padding:0 10px;
      border-radius:999px;
      border:1px solid var(--border);
      font-size:10px;
      font-weight:900;
      letter-spacing:.02em;
    }
    .status-pill.success{background:var(--success-soft);color:#bbf7d0;border-color:rgba(34,197,94,.26)}
    .status-pill.warn{background:var(--warn-soft);color:#fde68a;border-color:rgba(245,158,11,.26)}
    .status-pill.danger{background:var(--danger-soft);color:#fecaca;border-color:rgba(239,68,68,.24)}
    body[data-theme="light"] .status-pill.success{color:#1d7a4b}
    body[data-theme="light"] .status-pill.warn{color:#b66f04}
    body[data-theme="light"] .status-pill.danger{color:#c43b4e}

    @media (max-width: 430px){
      .collector-shell{padding:0 10px}
      .collector-topbar-inner{padding:9px 10px}
      .tool-card{padding:9px}
      .tool-search{padding:7px 9px}
      .tool-meta{grid-template-columns:repeat(3,minmax(0,1fr))}
      .summary-strip{
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:7px;
        padding:8px;
      }
      .summary-pill{padding:9px}
      .summary-pill strong{font-size:16px}
      .section-head{padding:11px 12px 9px}
      .section-body{padding:10px}
      .sheet-grid,.sheet-actions{grid-template-columns:1fr}
      .sheet-submit-row{grid-template-columns:1fr}
    }

    @media (min-width: 700px){
      .tool-card{
        grid-template-columns:minmax(0,1fr) auto;
        align-items:center;
      }
      .tool-card > *:first-child{grid-column:1 / -1}
      .tool-meta{grid-template-columns:repeat(3,130px)}
      .summary-strip{grid-template-columns:repeat(4,minmax(0,1fr))}
    }
  </style>
</head>
<body>
<%
  const qsBase = { month: String(month), year: String(year), search: String(search || ''), status: String(status || 'unpaid') };
  const chipAll = new URLSearchParams({ ...qsBase, scope: '' }).toString();
  const chipToday = new URLSearchParams({ ...qsBase, status: 'unpaid', scope: 'today' }).toString();
  const chipUnpaid = new URLSearchParams({ ...qsBase, status: 'unpaid', scope: 'unpaid' }).toString();
  const chipIsolir = new URLSearchParams({ ...qsBase, status: 'unpaid', scope: 'isolir' }).toString();
  const chipMulti = new URLSearchParams({ ...qsBase, status: 'unpaid', scope: 'multi' }).toString();
  const currentScope = String(scope || '');
  const historyCount = Array.isArray(myReqs) ? myReqs.length : 0;
  const collectorDisplayName = typeof collectorName !== 'undefined' && collectorName ? collectorName : 'Kolektor';
%>

<header class="collector-topbar">
  <div class="collector-topbar-inner">
    <div class="collector-brand">
      <div class="collector-brand-badge">
        <img src="<%= (typeof logoUrl !== 'undefined' && logoUrl) ? logoUrl : '/img/mss-logo.png' %>" alt="Logo <%= company %>" onerror="this.onerror=null;this.src='/img/mss-logo.png'">
      </div>
      <div style="min-width:0">
        <div class="collector-brand-title">Portal Kolektor</div>
        <div class="collector-brand-sub"><%= collectorDisplayName %> - <%= company %></div>
      </div>
    </div>
    <div class="collector-topbar-actions">
      <button class="icon-btn" type="button" data-theme-toggle aria-label="Ganti tema">
        <i class="bi bi-sun"></i>
      </button>
      <a class="icon-btn" href="/collector/logout" aria-label="Logout">
        <i class="bi bi-box-arrow-right"></i>
      </a>
    </div>
  </div>
</header>

<main class="collector-shell">
  <% if (msg) { %>
    <div class="section-card" style="margin-top:12px;border-color:<%= msg.type === 'error' ? 'rgba(239,68,68,.28)' : 'rgba(34,197,94,.28)' %>;">
      <div class="section-body" style="padding:11px 12px;font-size:12px;line-height:1.5;color:<%= msg.type === 'error' ? 'var(--danger)' : 'var(--success)' %>;">
        <%= msg.text %>
      </div>
    </div>
  <% } %>

  <div class="sticky-tools">
    <%- include('partials/search_bar', { month, year, status, scope, search }) %>
    <%- include('partials/filter_chips', { chipAll, chipToday, chipUnpaid, chipIsolir, chipMulti, currentScope }) %>
  </div>

  <section class="summary-strip" aria-label="Ringkasan koleksi">
    <a class="summary-pill" href="/collector?<%= chipToday %>#collector-list">
      <span>Hari ini</span>
      <strong><%= Number(summary?.today_count || 0) %></strong>
      <small>Rp <%= Number(summary?.today_total || 0).toLocaleString('id-ID') %></small>
    </a>
    <a class="summary-pill" href="/collector?<%= chipUnpaid %>#collector-list">
      <span>Belum bayar</span>
      <strong><%= Number(summary?.unpaid_count || 0) %></strong>
      <small>Rp <%= Number(summary?.unpaid_total || 0).toLocaleString('id-ID') %></small>
    </a>
    <a class="summary-pill" href="/collector?<%= chipIsolir %>#collector-list">
      <span>Isolir</span>
      <strong><%= Number(summary?.isolir_count || 0) %></strong>
      <small>Rp <%= Number(summary?.isolir_total || 0).toLocaleString('id-ID') %></small>
    </a>
    <a class="summary-pill" href="/collector?<%= chipMulti %>#collector-list">
      <span>&gt; 1 bulan</span>
      <strong><%= Number(summary?.multi_customer_count || 0) %></strong>
      <small>Rp <%= Number(summary?.multi_total || 0).toLocaleString('id-ID') %></small>
    </a>
  </section>

  <section class="section-card" id="collector-list">
    <div class="section-head">
      <div>
        <div class="section-title"><i class="bi bi-receipt-cutoff"></i> Daftar Tagihan</div>
        <div class="section-note">Kartu dipadatkan untuk layar 360px-430px. Detail lengkap dan catatan dipindah ke action sheet.</div>
      </div>
      <div class="section-note"><strong><%= (invoices || []).length %></strong> data</div>
    </div>
    <div class="section-body">
      <% if (!invoices || invoices.length === 0) { %>
        <div class="empty-state">Tidak ada tagihan untuk filter ini. Coba ubah periode, status, atau pencarian.</div>
      <% } else { %>
        <div class="collector-list">
          <% invoices.forEach((inv) => { %>
            <%- include('partials/customer_card', { inv, pendingMap, month, year, status, search, scope }) %>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="history-card" style="margin-top:12px;">
    <details <%= historyCount > 0 ? '' : 'open' %>>
      <summary>
        <span><i class="bi bi-clock-history"></i> Riwayat Pengajuan Saya</span>
        <small><%= historyCount %> data</small>
      </summary>
      <div class="history-list">
        <% if (!myReqs || myReqs.length === 0) { %>
          <div class="empty-state">Belum ada pengajuan pembayaran dari kolektor ini.</div>
        <% } else { %>
          <% myReqs.slice(0, 24).forEach((r) => { 
            const st = String(r.status || '').toLowerCase();
          %>
            <div class="history-row">
              <div class="history-top">
                <div>
                  <div class="history-name"><%= r.customer_name || '-' %></div>
                  <div class="history-sub">Invoice #<%= r.invoice_id %> - <%= r.period_month %>/<%= r.period_year %></div>
                </div>
                <span class="status-pill <%= st === 'approved' ? 'success' : (st === 'rejected' ? 'danger' : 'warn') %>">
                  <%= st === 'approved' ? 'APPROVED' : (st === 'rejected' ? 'REJECTED' : 'PENDING') %>
                </span>
              </div>
              <div class="history-sub">
                Rp <%= Number(r.amount || 0).toLocaleString('id-ID') %>
                <% if (r.customer_phone) { %> - <%= r.customer_phone %><% } %>
                <% if (r.created_at) { %> - <%= new Date(r.created_at).toLocaleString('id-ID') %><% } %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </details>
  </section>
</main>

<%- include('partials/customer_action_sheet', { month, year, status, search, scope }) %>

<script>
  (function() {
    const savedTheme = localStorage.getItem('admin-theme')
      || document.documentElement.dataset.adminTheme
      || 'dark';

    function syncThemeButtons(theme) {
      document.documentElement.dataset.adminTheme = theme;
      document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
      if (document.body) document.body.dataset.theme = theme;
      document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
        const icon = button.querySelector('i');
        if (icon) icon.className = theme === 'light' ? 'bi bi-moon-stars' : 'bi bi-sun';
      });
    }

    syncThemeButtons(savedTheme);
    document.addEventListener('click', (event) => {
      const toggle = event.target.closest('[data-theme-toggle]');
      if (!toggle) return;
      event.preventDefault();
      const currentTheme = document.body?.dataset.theme || document.documentElement.dataset.adminTheme || 'dark';
      const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
      localStorage.setItem('admin-theme', nextTheme);
      syncThemeButtons(nextTheme);
    });
    window.addEventListener('storage', (event) => {
      if (event.key === 'admin-theme') syncThemeButtons(event.newValue || 'dark');
    });
  })();

  (function() {
    const sheet = document.getElementById('collectorActionSheet');
    const backdrop = document.getElementById('collectorSheetBackdrop');
    if (!sheet || !backdrop) return;

    const titleEl = document.getElementById('sheetCustomerName');
    const subEl = document.getElementById('sheetCustomerSub');
    const statusWrap = document.getElementById('sheetStatusWrap');
    const detailFields = {
      amount: document.getElementById('sheetAmount'),
      package: document.getElementById('sheetPackage'),
      due: document.getElementById('sheetDue'),
      invoice: document.getElementById('sheetInvoice'),
      period: document.getElementById('sheetPeriod'),
      customerId: document.getElementById('sheetCustomerId'),
      pppoe: document.getElementById('sheetPppoe'),
      tag: document.getElementById('sheetTag'),
      address: document.getElementById('sheetAddress')
    };
    const waBtn = document.getElementById('sheetWaBtn');
    const mapBtn = document.getElementById('sheetMapBtn');
    const noteWrap = document.getElementById('sheetNoteWrap');
    const noteField = document.getElementById('sheetNote');
    const submitBtn = document.getElementById('sheetSubmitBtn');
    const modeLabel = document.getElementById('sheetModeHelp');
    const hiddenInvoice = document.getElementById('sheetInvoiceId');

    function closeSheet() {
      sheet.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    function createStatusPill(tone, iconClass, text) {
      const pill = document.createElement('span');
      pill.className = `status-pill ${tone || 'warn'}`;
      const icon = document.createElement('i');
      icon.className = `bi ${iconClass || 'bi-info-circle'}`;
      const label = document.createElement('span');
      label.textContent = text || '-';
      pill.append(icon, label);
      return pill;
    }

    function openSheet(trigger, mode) {
      const data = trigger.dataset || {};
      titleEl.textContent = data.customerName || 'Pelanggan';
      subEl.textContent = data.subtitle || '';
      detailFields.amount.textContent = data.amount || '-';
      detailFields.package.textContent = data.package || '-';
      detailFields.due.textContent = data.due || '-';
      detailFields.invoice.textContent = data.invoice || '-';
      detailFields.period.textContent = data.period || '-';
      detailFields.customerId.textContent = data.customerId || '-';
      detailFields.pppoe.textContent = data.pppoe || '-';
      detailFields.tag.textContent = data.tag || '-';
      detailFields.address.textContent = data.address || '-';
      hiddenInvoice.value = data.invoiceId || '';
      noteField.value = '';

      statusWrap.replaceChildren();
      statusWrap.appendChild(createStatusPill(data.statusTone || 'warn', data.statusIcon || 'bi-info-circle', data.statusText || '-'));

      if (data.pendingText) {
        statusWrap.appendChild(createStatusPill('warn', 'bi-hourglass-split', data.pendingText));
      }

      if (data.waHref) {
        waBtn.href = data.waHref;
        waBtn.style.display = '';
      } else {
        waBtn.removeAttribute('href');
        waBtn.style.display = 'none';
      }

      if (data.mapHref) {
        mapBtn.href = data.mapHref;
        mapBtn.style.display = '';
      } else {
        mapBtn.removeAttribute('href');
        mapBtn.style.display = 'none';
      }

      const allowSubmit = data.allowSubmit === 'true';
      if (mode === 'payment' && allowSubmit) {
        noteWrap.classList.add('is-visible');
        submitBtn.disabled = false;
        submitBtn.style.display = '';
        modeLabel.textContent = 'Tambahkan catatan bila perlu, lalu kirim pengajuan pembayaran ke admin/kasir.';
      } else {
        noteWrap.classList.remove('is-visible');
        submitBtn.disabled = true;
        submitBtn.style.display = 'none';
        modeLabel.textContent = allowSubmit
          ? 'Buka aksi "Tandai Bayar" untuk mengirim catatan dan pengajuan pembayaran.'
          : (data.pendingText || 'Invoice ini tidak bisa diajukan lagi dari kartu ini.');
      }

      sheet.classList.add('is-open');
      backdrop.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    document.addEventListener('click', (event) => {
      const openDetail = event.target.closest('[data-open-sheet="detail"]');
      if (openDetail) {
        event.preventDefault();
        openSheet(openDetail, 'detail');
        return;
      }
      const openPayment = event.target.closest('[data-open-sheet="payment"]');
      if (openPayment) {
        event.preventDefault();
        openSheet(openPayment, 'payment');
        return;
      }
      if (event.target.closest('[data-close-sheet]') || event.target === backdrop) {
        event.preventDefault();
        closeSheet();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeSheet();
    });
  })();
</script>
<%- include('../partials/employee_location_tracker', {
  enabled: true,
  endpoint: '/collector/api/location',
  roleLabel: 'Kolektor'
}) %>
</body>
</html>
