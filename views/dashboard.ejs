    .business-info-card i {
      color: var(--app-blue);
      font-size: 17px;
      margin-top: 2px;
    }

    .business-info-card strong {
      display: block;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--app-text-soft);
      margin-bottom: 5px;
    }

    .business-info-card span {
      display: block;
      font-size: 13px;
      line-height: 1.45;
      font-weight: 700;
      color: var(--app-text);
      word-break: break-word;
