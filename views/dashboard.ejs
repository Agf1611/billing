  <% if (oneSignalDirectEmbedEnabled) { %>
  <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer data-onesignal-web-sdk="true"></script>
  <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    window.__CUSTOMER_ONESIGNAL_DIRECT_APP_ID = <%- JSON.stringify(oneSignalAppId) %>;
    window.__CUSTOMER_ONESIGNAL_EXTERNAL_ID = <%- JSON.stringify(customerPushExternalId) %>;
    OneSignalDeferred.push(async function(OneSignal) {
      try {
        window.__CUSTOMER_ONESIGNAL_INIT_PROMISE = window.__CUSTOMER_ONESIGNAL_INIT_PROMISE || (async function () {
          await OneSignal.init({
            appId: window.__CUSTOMER_ONESIGNAL_DIRECT_APP_ID,
            notifyButton: { enable: false },
            allowLocalhostAsSecureOrigin: true,
            serviceWorkerPath: '/OneSignalSDKWorker.js',
            serviceWorkerUpdaterPath: '/OneSignalSDKUpdaterWorker.js',
            serviceWorkerParam: { scope: '/' },
            autoResubscribe: true
          });
          window.__CUSTOMER_ONESIGNAL_DIRECT_INITIALIZED = true;
          return OneSignal;
        })();
        await window.__CUSTOMER_ONESIGNAL_INIT_PROMISE;
        if (window.__CUSTOMER_ONESIGNAL_EXTERNAL_ID && typeof OneSignal.login === 'function') {
          await OneSignal.login(window.__CUSTOMER_ONESIGNAL_EXTERNAL_ID);
        }
      } catch (error) {
        console.warn('OneSignal pelanggan gagal dipasang:', error);
      }
    });
  </script>
  <% } %>
