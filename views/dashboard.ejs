    .traffic-gauge-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      align-items: stretch;
    }

    .traffic-gauge-card {
      --gauge-face-bg: radial-gradient(circle at 50% 38%, #ffffff 0%, #f4f8ff 62%, #d9e6fb 100%);
      --gauge-face-shadow: inset 0 0 0 1px rgba(86, 116, 170, 0.08), inset 0 16px 24px rgba(255,255,255,0.75);
      --gauge-ring-muted: rgba(126, 146, 186, 0.18);
      --gauge-dash-color: rgba(124, 146, 192, 0.22);
      --gauge-center-bg: transparent;
      --gauge-center-shadow: none;
      --gauge-needle-base: #f7fbff;
      --gauge-needle-shadow: rgba(47, 107, 255, 0.18);
      --gauge-needle-ring: rgba(18, 30, 56, 0.14);
      --gauge-value-color: #0d1a30;
      --gauge-unit-color: #5f6f89;
      --gauge-label-color: #6f7f98;
      display: grid;
      gap: 12px;
      padding: 16px 14px 14px;
      border-radius: 24px;
      border: 1px solid rgba(104, 129, 182, 0.14);
      background:
        radial-gradient(circle at top, rgba(255, 255, 255, 0.78) 0%, rgba(246, 249, 255, 0.92) 58%, rgba(235, 241, 252, 0.98) 100%);
      min-width: 0;
      overflow: hidden;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.6);
    }

    .traffic-gauge-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      min-width: 0;
    }

    .traffic-gauge-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .traffic-gauge-label i {
      font-size: 18px;
    }

    .traffic-gauge-label h5 {
      margin: 0;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .traffic-gauge-cap {
      font-size: 11px;
      font-weight: 700;
      color: var(--app-text-soft);
      white-space: nowrap;
    }

    .traffic-gauge-meter {
      display: grid;
      justify-items: center;
      gap: 8px;
      width: 100%;
    }

    .traffic-gauge-dial {
      position: relative;
      width: 156px;
      height: 156px;
      display: grid;
      place-items: center;
    }

    .traffic-gauge-arc {
      --gauge-fill: 8;
      --gauge-color: #073dcc;
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background:
        conic-gradient(from 220deg,
          var(--gauge-color) 0deg,
          var(--gauge-color) calc(var(--gauge-fill) * 1deg),
          var(--gauge-ring-muted) calc(var(--gauge-fill) * 1deg),
          var(--gauge-ring-muted) 280deg,
          transparent 280deg 360deg);
      filter: drop-shadow(0 6px 12px var(--gauge-needle-shadow));
    }

    .traffic-gauge-arc::before {
      content: "";
      position: absolute;
      inset: 12px;
      border-radius: 50%;
      background: var(--gauge-face-bg);
      box-shadow: var(--gauge-face-shadow);
    }

    .traffic-gauge-arc::after {
      content: "";
      position: absolute;
      inset: 22px;
      border-radius: 50%;
      border: 2px dashed var(--gauge-dash-color);
    }

    .traffic-gauge-needle {
      --needle-angle: -130deg;
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      pointer-events: none;
      transform: rotate(var(--needle-angle));
      transition: transform 0.35s ease;
    }

    .traffic-gauge-needle::before {
      content: "";
      width: 76px;
      height: 12px;
      background: linear-gradient(90deg, var(--gauge-needle-base) 0%, var(--gauge-color) 88%);
      clip-path: polygon(0 50%, 12% 0, 100% 50%, 12% 100%);
      transform-origin: 6px center;
      transform: translateX(24px);
      box-shadow:
        0 3px 10px rgba(8, 18, 35, 0.18);
    }

    .traffic-gauge-needle::after {
      content: "";
      position: absolute;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: var(--gauge-color);
      box-shadow:
        0 0 0 6px var(--gauge-needle-ring),
        0 0 0 1px rgba(255,255,255,0.16);
    }

    .traffic-gauge-center {
      position: relative;
      z-index: 2;
      min-width: 88px;
      padding: 0;
      border-radius: 0;
      background: var(--gauge-center-bg);
      box-shadow: var(--gauge-center-shadow);
      display: grid;
      gap: 3px;
      justify-items: center;
      text-align: center;
    }

    .traffic-gauge-center strong {
      font-size: 22px;
      line-height: 1;
      letter-spacing:0;
      font-weight: 800;
      color: var(--gauge-value-color);
      text-shadow: 0 1px 0 rgba(255,255,255,0.22);
    }

    .traffic-gauge-center span {
      font-size: 12px;
      font-weight: 800;
      color: var(--gauge-unit-color);
    }

    .traffic-gauge-center small {
      font-size: 10px;
      font-weight: 700;
      color: var(--gauge-label-color);
    }

    .traffic-gauge-readout {
      display: grid;
      justify-items: center;
      gap: 2px;
      margin-top: -2px;
      text-align: center;
    }

    .traffic-gauge-readout strong {
      display: inline-flex;
      align-items: baseline;
      justify-content: center;
      gap: 4px;
      margin: 0;
      color: var(--gauge-value-color);
      line-height: 1;
      font-weight: 800;
      letter-spacing:0;
    }

    .traffic-gauge-readout strong span {
      font-size: 20px;
    }

    .traffic-gauge-readout strong small {
      font-size: 10px;
      font-weight: 800;
      color: var(--gauge-unit-color);
      letter-spacing: 0;
    }

    .traffic-gauge-readout > span {
      font-size: 10px;
      font-weight: 700;
      color: var(--gauge-label-color);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .traffic-gauge-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      color: var(--app-text-soft);
      width: 100%;
    }

    .traffic-gauge-meta span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 26px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(47, 107, 255, 0.07);
      border: 1px solid rgba(104, 129, 182, 0.12);
      white-space: nowrap;
    }

    .traffic-gauge-card.upload-tone .traffic-gauge-label i,
    .traffic-gauge-card.upload-tone .traffic-gauge-label h5,
    .traffic-gauge-card.upload-tone .traffic-gauge-center strong {
      color: #20b26b;
