        manualPaymentAccountNumber,
        manualPaymentAccountName,
        manualPaymentNotes,
        hasManualPayment,
        companyLegalName,
        companyAddressText,
        companyPhoneText,
        companyEmailText
      }) %>

      <section class="app-screen" data-tab="ticketing">
        <div class="ticket-card">
          <div class="ticket-card-top">
            <div>
              <h4>Keluhan & Bantuan</h4>
              <div class="soft-muted">Pantau status tiket dan kirim keluhan baru.</div>
            </div>
            <button class="ticket-trigger" type="button" onclick="openTicketModal()">
              <i class="bi bi-plus-circle"></i> Tiket Baru
            </button>
          </div>

          <% if (!tickets || tickets.length === 0) { %>
            <div class="empty-card">
              <i class="bi bi-life-preserver"></i>
              <strong>Belum ada tiket</strong>
              <div>Kalau koneksi bermasalah atau butuh bantuan, Anda bisa buat tiket dari sini.</div>
            </div>
          <% } else { %>
            <div class="ticket-list">
              <% tickets.forEach((ticket) => { const ticketStatus = String(ticket.status || 'open').toLowerCase(); %>
                <div class="ticket-item">
                  <div class="item-icon"><i class="bi bi-life-preserver"></i></div>
                  <div class="item-text">
                    <div class="ticket-card-top" style="margin:0 0 10px;">
                      <strong><%= ticket.subject || `Tiket #${ticket.id}` %></strong>
                      <span class="ticket-status <%= ticketStatus === 'closed' || ticketStatus === 'done' ? 'closed' : ticketStatus === 'pending' ? 'pending' : 'open' %>">
                        <i class="bi <%= ticketStatus === 'closed' || ticketStatus === 'done' ? 'bi-check-circle' : ticketStatus === 'pending' ? 'bi-hourglass-split' : 'bi-lightning-charge' %>"></i>
                        <%= String(ticket.status || 'open').toUpperCase() %>
                      </span>
                    </div>
                    <p><%= ticket.message || 'Tidak ada detail pesan.' %></p>
                    <div class="ticket-meta">
                      <span><i class="bi bi-hash"></i> #<%= ticket.id %></span>
                      <span><i class="bi bi-clock-history"></i> <%= formatDateTime(ticket.created_at) %></span>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>

      <section class="app-screen" data-tab="profile">
        <div class="profile-card">
          <div class="profile-highlight">
