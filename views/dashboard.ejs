    .router-detail-grid .detail-item span {
      word-break: break-word;
    }

    .detail-item,
    .device-item {
      padding: 14px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(47, 107, 255, 0.06);
    }

