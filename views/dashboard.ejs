<%
  const monthNames = [null, 'Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  const customerData = customer || {};
  const profileData = profile || {};
  const companyName = settings?.company_header || 'Portal Pelanggan';
  const companyLogoUrl = settings?.company_logo_url || '/img/logo.png';
  const companyLegalName = String(settings?.company_legal_name || '').trim();
  const upstreamProviderName = String(settings?.upstream_provider_name || '').trim();
  const companyAddressText = String(settings?.company_address || '').trim();
  const companyPhoneText = String(settings?.company_phone || '').trim();
  const companyEmailText = String(settings?.company_email || '').trim();
  const manualPaymentBank = String(settings?.manual_payment_bank || '').trim();
  const manualPaymentAccountNumber = String(settings?.manual_payment_account_number || '').trim();
  const manualPaymentAccountName = String(settings?.manual_payment_account_name || '').trim();
  const manualPaymentNotes = String(settings?.manual_payment_notes || '').trim();
  const hasManualPayment = Boolean(manualPaymentBank && manualPaymentAccountNumber);
  const customerCode = String(profileData.genieacs_tag || profileData.pppoe_username || profileData.phone || customerData.phone || profileData.id || '-').trim();
  const customerName = profileData.name || customerData.name || 'Pelanggan';
  const packageName = profileData.package_name || customerData.package_name || 'Paket Internet';
  const customerPhone = profileData.phone || customerData.phone || '-';
  const customerAddress = profileData.address || customerData.lokasi || '-';
  const customerOdp = profileData.odp_name || '-';
  const customerIdLabel = customerCode || String(profileData.id || '-');
  const routerDisplayName = profileData.router_name || customerData.model || customerData.productClass || '-';
  const monthlyPrice = Number(profileData.package_price || 0);
  const uploadBytes = Math.max(0, Number(profileData.bytes_out || 0));
  const downloadBytes = Math.max(0, Number(profileData.bytes_in || 0));
  const totalBytes = uploadBytes + downloadBytes;
  const useFup = Number(profileData.use_fup || 0) === 1 && Number(profileData.fup_limit_gb || 0) > 0;
  const quotaLimitBytes = useFup ? Number(profileData.fup_limit_gb || 0) * 1024 * 1024 * 1024 : 0;
  const quotaPercent = quotaLimitBytes > 0 ? Math.min(100, (totalBytes / quotaLimitBytes) * 100) : 0;
  const usageStartDate = new Date();
  usageStartDate.setDate(1);
  usageStartDate.setHours(0, 0, 0, 0);
  const usageEndDate = new Date();
  const liveDownloadCap = Number(trafficMaxDownMbps || Math.max(1, Math.round(Number(profileData.speed_down || 10000) / 1000) || 10));
  const liveUploadCap = Number(trafficMaxUpMbps || Math.max(1, Math.round(Number(profileData.speed_up || 10000) / 1000) || 10));
  const unpaidInvoices = (invoices || []).filter((inv) => String(inv.status || '').toLowerCase() !== 'paid');
  const paidInvoices = (invoices || []).filter((inv) => String(inv.status || '').toLowerCase() === 'paid');
  const latestInvoice = unpaidInvoices[0] || (invoices || [])[0] || null;
  const usersOnline = Array.isArray(connectedUsers) ? connectedUsers.filter((item) => String(item.status || '').toLowerCase() === 'online') : [];
  const connectedDeviceCount = Array.isArray(connectedUsers) ? connectedUsers.length : 0;
  const activeTickets = (tickets || []).filter((ticket) => !['resolved', 'closed', 'done'].includes(String(ticket.status || '').toLowerCase()));
  const pppoeStatusText = String(customerData.pppoeStatusText || profileData.pppoe_status || '').trim();
  const isPppoeOnline = /online|connected|aktif/i.test(pppoeStatusText);
  const hasRouterPortalAccess = Boolean(
    (customerData.ssid && customerData.ssid !== '-') ||
    (customerData.serialNumber && customerData.serialNumber !== '-') ||
    (customerData.rxPower && customerData.rxPower !== '-') ||
    (customerData.model && customerData.model !== '-') ||
    (customerData.productClass && customerData.productClass !== '-') ||
    (Array.isArray(connectedUsers) && connectedUsers.length > 0)
  );
  const supportPhone = String(settings?.whatsapp_admin || settings?.admin_phone || settings?.company_phone || '').replace(/\D/g, '');
  const supportUrl = supportPhone ? `https://wa.me/${supportPhone}` : '/customer/contact';
  const appNotif = (typeof notif !== 'undefined' ? notif : null) || null;
  const notificationItems = Array.isArray(typeof notifications !== 'undefined' ? notifications : []) ? (typeof notifications !== 'undefined' ? notifications : []) : [];
  const notificationUnread = Math.max(0, Number(typeof notificationUnreadCount !== 'undefined' ? notificationUnreadCount : 0) || 0);
  const pushFeatureEnabled = Boolean(settings?.onesignal_enabled && settings?.onesignal_app_id);
  const customerPushExternalId = profileData.id || customerData.id ? `customer-${profileData.id || customerData.id}` : '';
  const recentActivities = [];

  function formatCurrency(value) {
    return `Rp ${Number(value || 0).toLocaleString('id-ID')}`;
  }

  function formatBytes(bytes) {
    const num = Number(bytes || 0);
    if (!Number.isFinite(num) || num <= 0) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB', 'TB'];
    let value = num;
    let unitIndex = 0;
    while (value >= 1024 && unitIndex < units.length - 1) {
      value /= 1024;
      unitIndex += 1;
    }
    const digits = value >= 100 ? 0 : value >= 10 ? 1 : 2;
    return `${value.toFixed(digits)} ${units[unitIndex]}`;
  }

  function formatUsageGb(bytes) {
    const num = Math.max(0, Number(bytes || 0));
    const gb = num / (1024 * 1024 * 1024);
    if (gb >= 1) return gb.toFixed(2);
    const mb = num / (1024 * 1024);
    return (mb / 1024).toFixed(2);
  }

  function formatDate(value) {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function formatDateTime(value) {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleString('id-ID', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  (unpaidInvoices || []).slice(0, 2).forEach((inv) => {
    recentActivities.push({
      type: 'invoice-unpaid',
      title: `Invoice INV-${inv.id}`,
      subtitle: `Tagihan ${monthNames[Number(inv.period_month)] || inv.period_month} ${inv.period_year}`,
      meta: formatCurrency(inv.amount),
      time: `${monthNames[Number(inv.period_month)] || inv.period_month} ${inv.period_year}`,
      ts: new Date(Number(inv.period_year), Number(inv.period_month) - 1, 1).getTime() || 0,
      icon: 'bi-receipt-cutoff'
    });
  });

  (paidInvoices || []).slice(0, 2).forEach((inv) => {
    recentActivities.push({
      type: 'invoice-paid',
      title: `Pembayaran INV-${inv.id}`,
      subtitle: `Tagihan lunas ${monthNames[Number(inv.period_month)] || inv.period_month} ${inv.period_year}`,
      meta: formatCurrency(inv.amount),
      time: formatDateTime(inv.paid_at),
      ts: inv.paid_at ? new Date(inv.paid_at).getTime() : 0,
      icon: 'bi-patch-check'
    });
  });

  (tickets || []).slice(0, 3).forEach((ticket) => {
    recentActivities.push({
      type: 'ticket',
      title: ticket.subject || `Tiket #${ticket.id}`,
      subtitle: ticket.message || 'Keluhan pelanggan',
      meta: String(ticket.status || 'open').toUpperCase(),
      time: formatDateTime(ticket.created_at),
      ts: ticket.created_at ? new Date(ticket.created_at).getTime() : 0,
      icon: 'bi-life-preserver'
    });
  });

  recentActivities.sort((a, b) => (b.ts || 0) - (a.ts || 0));
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Dashboard Pelanggan | <%= companyName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#2f6bff">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="apple-touch-icon" href="<%= companyLogoUrl %>">
  <link rel="icon" href="<%= companyLogoUrl %>">
  <style>
    :root {
      --app-bg: #eef4ff;
      --app-surface: rgba(255, 255, 255, 0.92);
      --app-surface-strong: #ffffff;
      --app-line: rgba(104, 129, 182, 0.16);
      --app-text: #17223b;
      --app-text-soft: #6a7897;
      --app-blue: #2f6bff;
      --app-blue-deep: #1d53dc;
      --app-blue-soft: rgba(47, 107, 255, 0.12);
      --app-danger: #f2485b;
      --app-success: #20b26b;
      --app-warning: #ff9e45;
      --app-shadow: 0 24px 64px rgba(42, 74, 140, 0.16);
      --shell-width: min(100vw, 430px);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top left, rgba(130, 180, 255, 0.38) 0%, rgba(130, 180, 255, 0) 34%),
        radial-gradient(circle at top right, rgba(100, 216, 255, 0.28) 0%, rgba(100, 216, 255, 0) 30%),
        linear-gradient(180deg, #f8fbff 0%, #edf3ff 100%);
      font-family: 'Plus Jakarta Sans', 'Manrope', sans-serif;
      color: var(--app-text);
      -webkit-tap-highlight-color: transparent;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(47, 107, 255, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(47, 107, 255, 0.035) 1px, transparent 1px);
      background-size: 26px 26px;
      pointer-events: none;
      opacity: 0.45;
    }

    body.pwa-body {
      display: flex;
      justify-content: center;
      padding: 0;
      overscroll-behavior-y: none;
      touch-action: manipulation;
    }

    body.android-webview {
      background:
        linear-gradient(180deg, #f6faff 0%, #edf4ff 100%);
    }

    body.android-webview::before {
      opacity: 0.24;
    }

    .app-shell {
      position: relative;
      width: var(--shell-width);
      min-height: 100vh;
      min-height: 100dvh;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.78) 0%, rgba(248, 251, 255, 0.92) 100%);
      backdrop-filter: blur(18px);
      overflow: hidden;
      box-shadow: var(--app-shadow);
    }

    .app-shell::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(380px 180px at 50% -20%, rgba(47, 107, 255, 0.18), transparent 72%),
        radial-gradient(280px 180px at 90% 18%, rgba(80, 180, 255, 0.12), transparent 70%);
      pointer-events: none;
    }

    .app-splash {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at 50% 22%, rgba(176, 214, 255, 0.7), rgba(176, 214, 255, 0) 42%),
        linear-gradient(180deg, #f8fbff 0%, #e9f1ff 100%);
      z-index: 1400;
      transition: opacity 0.35s ease, visibility 0.35s ease;
    }

    .app-splash.is-hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .splash-card {
      width: min(82vw, 280px);
      padding: 22px 20px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(47, 107, 255, 0.12);
      box-shadow: 0 22px 44px rgba(44, 79, 146, 0.16);
      text-align: center;
    }

    .splash-logo {
      width: 60px;
      height: 60px;
      margin: 0 auto 14px;
      border-radius: 20px;
      background: linear-gradient(135deg, #2f6bff 0%, #72a6ff 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 14px 24px rgba(47, 107, 255, 0.24);
    }

    .splash-logo img {
      width: 36px;
      height: 36px;
      object-fit: contain;
    }

    .splash-card h1 {
      margin: 0;
      font-size: 18px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .splash-card p {
      margin: 6px 0 14px;
      color: var(--app-text-soft);
      font-size: 12px;
    }

    .splash-progress {
      height: 8px;
      border-radius: 999px;
      background: rgba(47, 107, 255, 0.1);
      overflow: hidden;
    }

    .splash-progress span {
      display: block;
      height: 100%;
      width: 42%;
      border-radius: inherit;
      background: linear-gradient(90deg, #2f6bff 0%, #7bb3ff 100%);
      animation: splashLoad 1.2s ease-in-out infinite;
    }

    @keyframes splashLoad {
      0% { transform: translateX(-115%); }
      100% { transform: translateX(250%); }
    }

    .app-topbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      padding: calc(env(safe-area-inset-top) + 4px) 14px 8px;
      background: linear-gradient(180deg, rgba(248, 251, 255, 0.94) 0%, rgba(248, 251, 255, 0.78) 100%);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(110, 140, 198, 0.12);
    }

    .topbar-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .header-menu,
    .brand-chip,
    .header-action {
      border: 0;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: 0 10px 22px rgba(54, 86, 152, 0.1);
      color: var(--app-text);
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
    }

    .topbar-left,
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .header-menu,
    .header-action {
      width: 38px;
      height: 38px;
      padding: 0;
      justify-content: center;
      font-size: 16px;
      flex: 0 0 auto;
    }

    .header-icon-wrap {
      position: relative;
      display: inline-flex;
    }

    .notif-badge {
      position: absolute;
      top: -3px;
      right: -3px;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #ff4d5f;
      color: #fff;
      font-size: 10px;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 18px rgba(242, 72, 91, 0.3);
      border: 2px solid #f8fbff;
    }

    .account-menu {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: min(220px, calc(100vw - 40px));
      padding: 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.97);
      border: 1px solid rgba(110, 140, 198, 0.16);
      box-shadow: 0 22px 40px rgba(44, 79, 146, 0.18);
      display: none;
      z-index: 1100;
    }

    .account-menu.is-open {
      display: block;
    }

    .account-menu-head {
      padding: 6px 8px 10px;
      border-bottom: 1px solid rgba(110, 140, 198, 0.12);
      margin-bottom: 8px;
    }

    .account-menu-head strong {
      display: block;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .account-menu-head span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      color: var(--app-text-soft);
      font-weight: 700;
    }

    .account-menu button,
    .account-menu a {
      width: 100%;
      border: 0;
      background: transparent;
      color: var(--app-text);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 10px;
      border-radius: 14px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
    }

    .account-menu button:hover,
    .account-menu a:hover {
      background: rgba(47, 107, 255, 0.08);
    }

    .account-menu .danger-action {
      color: var(--app-danger);
    }

    .brand-chip img {
      width: 18px;
      height: 18px;
      object-fit: contain;
    }

    .brand-meta {
      display: flex;
      flex-direction: column;
      line-height: 1.05;
    }

    .brand-meta strong {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .brand-meta span {
      font-size: 10px;
      color: var(--app-text-soft);
      font-weight: 700;
    }

    .page-title {
      display: none;
    }

    .app-menu-backdrop {
      position: fixed;
      inset: 0;
      z-index: 1080;
      background: rgba(19, 31, 63, 0.22);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s ease;
      backdrop-filter: blur(4px);
    }

    .app-menu-backdrop.is-open {
      opacity: 1;
      visibility: visible;
    }

    .app-menu-sheet {
      position: absolute;
      top: calc(env(safe-area-inset-top) + 56px);
      left: 14px;
      right: 14px;
      z-index: 1090;
      padding: 12px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.98);
      border: 1px solid rgba(110, 140, 198, 0.14);
      box-shadow: 0 22px 46px rgba(44, 79, 146, 0.18);
      display: grid;
      gap: 10px;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px) scale(0.98);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .app-menu-sheet.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .app-menu-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      padding: 2px 2px 4px;
    }

    .app-menu-head strong {
      display: block;
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .app-menu-head span {
      display: block;
      margin-top: 4px;
      color: var(--app-text-soft);
      font-size: 11px;
      line-height: 1.45;
      font-weight: 700;
    }

    .app-menu-close {
      width: 34px;
      height: 34px;
      border: 0;
      border-radius: 12px;
      background: rgba(47, 107, 255, 0.08);
      color: var(--app-blue);
      font-size: 15px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .app-menu-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .app-menu-tile {
      border: 0;
      border-radius: 18px;
      padding: 12px;
      background: linear-gradient(180deg, rgba(246, 250, 255, 0.95) 0%, rgba(236, 244, 255, 0.9) 100%);
      border: 1px solid rgba(47, 107, 255, 0.08);
      display: flex;
      align-items: center;
      gap: 10px;
      text-align: left;
      color: var(--app-text);
    }

    .app-menu-tile i {
      width: 34px;
      height: 34px;
      border-radius: 12px;
      background: rgba(47, 107, 255, 0.12);
      color: var(--app-blue);
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
    }

    .app-menu-tile strong {
      display: block;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .app-menu-tile span {
      display: block;
      margin-top: 2px;
      color: var(--app-text-soft);
      font-size: 10px;
      font-weight: 700;
      line-height: 1.35;
    }

    .page-title small {
      display: block;
      color: var(--app-text-soft);
      font-weight: 700;
      font-size: 10px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .page-title h2 {
      margin: 4px 0 0;
      font-size: 18px;
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .app-main {
      position: relative;
      padding: 12px 16px 136px;
    }

    .app-screen {
      display: none;
      animation: screenFade 0.22s ease;
    }

    .app-screen.is-active {
      display: block;
    }

    @keyframes screenFade {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-card {
      position: relative;
      padding: 13px 13px 12px;
      border-radius: 24px;
      color: #ffffff;
      background: linear-gradient(135deg, #2f6bff 0%, #4d8cff 50%, #2c66ea 100%);
      box-shadow: 0 20px 40px rgba(47, 107, 255, 0.24);
      overflow: hidden;
    }

    .hero-card::before,
    .hero-card::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      pointer-events: none;
    }

    .hero-card::before {
      width: 240px;
      height: 240px;
      top: -120px;
      right: -110px;
    }

    .hero-card::after {
      width: 170px;
      height: 170px;
      bottom: -88px;
      left: -72px;
    }

    .hero-top,
    .hero-bottom {
      position: relative;
      z-index: 1;
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 8px;
    }

    .hero-eyebrow {
      font-size: 10px;
      font-weight: 700;
      opacity: 0.84;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .hero-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.16);
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .hero-package {
      margin: 5px 0 0;
      font-size: 19px;
      font-weight: 800;
      line-height: 1.02;
      letter-spacing: -0.05em;
    }

    .hero-sub {
      margin-top: 4px;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
