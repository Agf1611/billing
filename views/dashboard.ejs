                  <i class="bi <%= item.kind === 'invoice' ? 'bi-receipt-cutoff' : item.kind === 'ticket' ? 'bi-life-preserver' : 'bi-info-circle' %>"></i>
                  <div>
                    <strong><%= item.title %></strong>
