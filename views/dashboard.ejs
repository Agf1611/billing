      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .portal-package-price {
      text-align: right;
      white-space: nowrap;
    }

    .portal-package-price strong {
      display: block;
      font-size: 18px;
      color: var(--app-blue-deep);
      font-weight: 900;
    }

    .portal-package-price span {
      display: block;
      margin-top: 4px;
      color: var(--app-text-soft);
      font-size: 11px;
      font-weight: 700;
    }

    .portal-package-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }

    .portal-package-meta .status-detail {
      margin: 0;
      min-height: auto;
      padding: 8px 11px;
      border-radius: 14px;
      font-size: 10.5px;
      font-weight: 800;
      box-shadow: none;
    }

    .portal-package-form {
      display: block;
    }

    .portal-package-form .settings-submit {
      min-height: 42px;
      padding: 10px 14px;
      font-size: 12px;
      white-space: nowrap;
      width: 100%;
    }

    .package-request-state {
      display: grid;
      gap: 8px;
      padding: 12px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(47, 107, 255, 0.06) 0%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(47, 107, 255, 0.12);
    }

    .package-request-top {
      display: grid;
      gap: 8px;
    }

    .package-request-copy {
      display: grid;
      gap: 4px;
      min-width: 0;
    }

    .package-request-copy strong {
      font-size: 14px;
      font-weight: 800;
      letter-spacing:0;
      color: var(--app-text);
    }

    .package-request-copy span {
      color: var(--app-text-soft);
      font-size: 11px;
      line-height: 1.35;
      font-weight: 700;
    }

    .package-request-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .package-request-cell {
      display: grid;
      gap: 4px;
      padding: 10px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid rgba(104, 129, 182, 0.14);
    }

    .package-request-label {
      font-size: 9px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--app-text-soft);
    }

    .package-request-value {
      color: var(--app-text);
      font-size: 11px;
      font-weight: 800;
      line-height: 1.3;
    }

    .package-request-note {
