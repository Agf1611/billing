      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(47, 107, 255, 0.08);
      color: var(--app-blue);
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .portal-package-list {
      display: grid;
      gap: 12px;
    }

    .portal-package-item {
      padding: 14px;
      border-radius: 18px;
      border: 1px solid rgba(47, 107, 255, 0.12);
      background: linear-gradient(180deg, rgba(47, 107, 255, 0.05) 0%, rgba(255, 255, 255, 0.96) 100%);
      box-shadow: 0 12px 24px rgba(42, 74, 140, 0.08);
      display: grid;
      gap: 12px;
    }

    .portal-package-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .portal-package-top strong {
      display: block;
      font-size: 16px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .portal-package-desc {
      margin-top: 5px;
      color: var(--app-text-soft);
      font-size: 12px;
      line-height: 1.55;
      font-weight: 600;
    }

    .portal-package-price {
      text-align: right;
      white-space: nowrap;
    }

    .portal-package-price strong {
      display: block;
      font-size: 17px;
      color: var(--app-blue-deep);
      font-weight: 800;
    }

    .portal-package-price span {
      display: block;
      margin-top: 4px;
      color: var(--app-text-soft);
      font-size: 11px;
      font-weight: 700;
    }

    .portal-package-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .portal-package-meta .status-detail {
      margin: 0;
      min-height: auto;
      padding: 8px 11px;
      border-radius: 14px;
      font-size: 11px;
      font-weight: 800;
      box-shadow: none;
    }

    .portal-package-form {
      display: flex;
      justify-content: flex-end;
    }

    .portal-package-form .settings-submit {
      min-height: 42px;
      padding: 10px 14px;
      font-size: 12px;
      white-space: nowrap;
    }

    .android-nav-wrap {
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: calc(8px + env(safe-area-inset-bottom));
      width: min(calc(100vw - 18px), 398px);
      z-index: 1100;
      transition: transform 0.24s ease, opacity 0.24s ease, visibility 0.24s ease;
    }

    body.modal-open .android-nav-wrap {
      opacity: 0;
      visibility: hidden;
      transform: translate(-50%, 24px);
      pointer-events: none;
    }

    .android-nav {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 4px;
      padding: 7px 8px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(47, 107, 255, 0.08);
      box-shadow: 0 16px 34px rgba(54, 86, 152, 0.15);
      backdrop-filter: blur(16px);
    }

    .android-nav button {
      border: 0;
      min-width: 0;
      background: transparent;
      padding: 5px 3px;
      border-radius: 14px;
      color: var(--app-text-soft);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-size: 10px;
      font-weight: 800;
    }

    .android-nav button i {
      font-size: 17px;
      line-height: 1;
    }

    .android-nav button.is-active {
      color: var(--app-blue);
      background: rgba(47, 107, 255, 0.1);
    }

    .modal-content.app-modal {
      border: 0;
      border-radius: 28px;
      overflow: hidden;
      background: linear-gradient(180deg, #fbfdff 0%, #edf4ff 100%);
      box-shadow: 0 28px 60px rgba(54, 86, 152, 0.18);
    }

    .app-modal .modal-header,
    .app-modal .modal-footer {
      border: 0;
      padding: 18px 18px 0;
      background: transparent;
    }

    .app-modal .modal-body {
      padding: 18px 18px 24px;
    }

    .app-modal .btn-close {
      background-size: 12px;
      opacity: 0.65;
    }

    .payment-modal-list {
      display: grid;
      gap: 12px;
    }

    .payment-method-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .payment-method-chip {
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(47, 107, 255, 0.08);
      color: var(--app-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .business-card {
      margin-top: 16px;
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(104, 129, 182, 0.14);
      box-shadow: 0 16px 36px rgba(42, 74, 140, 0.1);
      display: grid;
      gap: 14px;
    }

    .business-head {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .business-head img {
      width: 46px;
      height: 46px;
      border-radius: 16px;
      object-fit: cover;
      background: rgba(47, 107, 255, 0.08);
      border: 1px solid rgba(47, 107, 255, 0.08);
      padding: 6px;
      flex: 0 0 auto;
    }

    .business-head strong {
      display: block;
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .business-head span {
      display: block;
      margin-top: 2px;
      color: var(--app-text-soft);
      font-size: 11px;
      line-height: 1.45;
      font-weight: 700;
    }

    .manual-payment-box {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(47, 107, 255, 0.08) 0%, rgba(47, 107, 255, 0.04) 100%);
      border: 1px solid rgba(47, 107, 255, 0.14);
      display: grid;
      gap: 10px;
    }

    .manual-payment-box h5 {
      margin: 0;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .manual-payment-bank {
      font-size: 16px;
      font-weight: 800;
      color: var(--app-blue-deep);
    }

    .manual-payment-line {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      color: var(--app-text-soft);
      font-size: 12px;
      line-height: 1.5;
      font-weight: 700;
    }

    .manual-payment-line strong {
      color: var(--app-text);
      min-width: 84px;
      font-weight: 800;
    }

    @media (min-width: 600px) {
      body.pwa-body {
        padding: 16px 0;
      }

      .app-shell {
        min-height: calc(100vh - 32px);
        border-radius: 36px;
        border: 1px solid rgba(47, 107, 255, 0.08);
      }
    }

    @media (max-width: 399.98px) {
      .app-topbar { padding-left: 15px; padding-right: 15px; }
      .app-main { padding-left: 15px; padding-right: 15px; padding-bottom: 144px; }
      .topbar-left,
      .topbar-right { gap: 8px; }
      .home-intro h1 { font-size: 14px; }
      .home-intro-line strong { font-size: 20px; }
      .home-code { font-size: 13px; }
      .hero-card { padding: 10px 10px; border-radius: 18px; }
      .hero-package { font-size: 18px; }
      .home-hero-grid { grid-template-columns: 1fr; }
      .home-hero-side { justify-items: start; text-align: left; }
      .home-amount-row { width: 100%; justify-content: space-between; }
      .home-amount-wrap strong { font-size: 14px; white-space: nowrap; }
      .home-pay-button { width: auto; min-width: 0; }
      .customer-focus-grid { grid-template-columns: 1fr; }
      .focus-card { padding: 13px 12px; }
      .detail-grid { grid-template-columns: 1fr; }
      .router-detail-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
      .router-detail-grid .detail-item {
        grid-template-columns: 1fr;
        gap: 8px;
        padding: 12px;
        border-radius: 18px;
      }
      .router-detail-grid .detail-item i {
        margin-top: 0;
        font-size: 16px;
      }
      .router-detail-grid .detail-item strong {
        font-size: 12px;
        margin-bottom: 3px;
      }
      .router-detail-grid .detail-item span {
        font-size: 11px;
        line-height: 1.38;
      }
      .profile-highlight,
      .settings-card,
      .profile-card { border-radius: 20px; }
      .profile-highlight { padding: 14px; }
      .billing-card-head { gap: 10px; }
      .billing-card-head h4,
      .profile-card h4,
      .settings-card h4 { font-size: 16px; }
      .soft-muted { font-size: 11px; }
      .quick-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
      .quick-card { padding: 12px 8px 13px; border-radius: 18px; }
      .quick-card .quick-icon { width: 40px; height: 40px; border-radius: 13px; font-size: 17px; }
      .quick-card h4 { font-size: 11px; }
      .quick-card p { font-size: 8.5px; }
      .android-nav button { font-size: 8.5px; }
      .android-nav button i { font-size: 15px; }
      .speed-meter-grid { grid-template-columns: 1fr; }
      .speed-meter { grid-template-columns: minmax(0, 1fr) 94px; }
      .sparkline { width: 94px; height: 42px; }
      .status-detail { padding: 10px 13px; font-size: 11px; }
      .package-upgrade-card { padding: 14px; border-radius: 20px; }
      .package-upgrade-head { display: grid; gap: 8px; }
      .portal-package-top { display: grid; gap: 8px; }
      .portal-package-price { text-align: left; }
      .portal-package-form { justify-content: stretch; }
      .portal-package-form .settings-submit { width: 100%; }
      .traffic-gauge-grid { grid-template-columns: 1fr; }
      .traffic-gauge { width: 146px; height: 88px; }
      .traffic-period-grid { grid-template-columns: 1fr; }
      .speedtest-panel { border-radius: 24px; padding: 16px; }
      .speedtest-head { flex-direction: column; }
      .speedtest-frame-wrap { min-height: 460px; }
      .speedtest-notes { grid-template-columns: 1fr; }
      .speedtest-action-row { display: grid; grid-template-columns: 1fr; }
      .speedtest-inline-btn { width: 100%; }
    }

    @media (max-width: 640px) {
      body.android-webview {
        display: block;
      }

      .billing-item {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .billing-amount {
        font-size: 18px;
      }

      .item-meta {
        min-width: 0;
        text-align: left;
      }

      .billing-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        justify-content: stretch;
      }

      .pay-action {
        width: 100%;
        min-height: 38px;
        padding: 9px 12px;
        font-size: 11px;
      }

      body.android-webview .app-shell {
        width: 100vw;
        min-height: 100vh;
        min-height: 100dvh;
        border-radius: 0;
        border: 0;
        box-shadow: none;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(244, 249, 255, 0.98) 100%);
      }

      body.android-webview .app-topbar {
        padding-top: calc(env(safe-area-inset-top) + 4px);
      }

      body.android-webview .app-main {
        padding-bottom: calc(142px + env(safe-area-inset-bottom));
      }

      body.android-webview .app-menu-sheet {
        top: calc(env(safe-area-inset-top) + 54px);
      }

      body.android-webview .modal.fade .modal-dialog {
        margin: 0;
        min-height: 100%;
        display: flex;
        align-items: flex-end;
      }

      body.android-webview .modal-content.app-modal {
        width: 100%;
        border-radius: 26px 26px 0 0;
        box-shadow: 0 -18px 44px rgba(54, 86, 152, 0.18);
      }
    }
  </style>
</head>
<body class="pwa-body">
  <div class="app-splash" id="appSplash" aria-hidden="true">
    <div class="splash-card">
      <div class="splash-logo">
        <img src="<%= companyLogoUrl %>" alt="Logo" onerror="this.onerror=null;this.src='/img/logo.png'">
      </div>
      <h1><%= companyName %></h1>
      <p>Menyiapkan dashboard pelanggan yang lebih ringan dan nyaman di HP.</p>
      <div class="splash-progress"><span></span></div>
    </div>
  </div>

  <div class="app-shell">
    <%- include('partials/customer/dashboard_topbar', {
      companyLogoUrl,
      companyName,
      customerName,
      customerCode,
      hasRouterPortalAccess,
      notificationUnread,
      notificationUnreadCount,
      notifications,
      profileData,
      customerData,
      settings
    }) %>

    <main class="app-main">
      <%- include('partials/customer/dashboard_home_screen', {
        customerName,
        customerCode,
        profileData,
        customerData,
        packageName,
        liveDownloadCap,
        liveUploadCap,
        isPppoeOnline,
        pppoeStatusText,
        latestInvoice,
        monthlyPrice,
        uploadBytes,
        downloadBytes,
        appNotif,
        hasRouterPortalAccess,
        formatDate,
        formatCurrency,
        formatBytes,
        connectedUsers
      }) %>

      <section class="app-screen" data-tab="traffic">
        <div class="traffic-stack">
          <div class="traffic-panel">
            <div class="traffic-panel-head">
              <div class="traffic-panel-title">
                <span class="traffic-panel-icon"><i class="bi bi-cpu"></i></span>
                <div>
                  <h4>Penggunaan Bandwidth</h4>
                  <p>Statistik pemakaian bulan berjalan yang disimpan dari PPPoE pelanggan.</p>
                </div>
              </div>
            </div>
            <div class="usage-bandwidth-label">Total Penggunaan</div>
            <div class="usage-bandwidth-total">
              <strong id="usageTotalDisplay"><%= formatUsageGb(totalBytes) %></strong>
              <span>GB</span>
            </div>
            <div class="usage-breakdown">
              <div class="usage-breakdown-item upload">
                <small>Download</small>
                <strong id="usageUploadDisplay"><%= formatUsageGb(uploadBytes) %> GB</strong>
              </div>
              <div class="usage-breakdown-item download">
                <small>Upload</small>
                <strong id="usageDownloadDisplay"><%= formatUsageGb(downloadBytes) %> GB</strong>
              </div>
            </div>
          </div>

          <div class="traffic-panel">
            <div class="traffic-panel-head">
              <div class="traffic-panel-title">
                <span class="traffic-panel-icon warning"><i class="bi bi-lightning-charge"></i></span>
                <div>
                  <h4>Penggunaan Traffic</h4>
                  <p>Kecepatan realtime mengikuti pembacaan PPPoE aktif di MikroTik.</p>
                </div>
              </div>
              <span class="live-pill"><i class="bi bi-circle-fill"></i> Live</span>
            </div>
            <div class="traffic-gauge-grid">
              <div class="traffic-gauge-card upload-tone">
                <div class="traffic-gauge" id="downloadGauge" style="--gauge-rotate:-90deg;">
                  <div class="traffic-gauge-arc"></div>
                  <div class="traffic-gauge-needle"></div>
                  <div class="traffic-gauge-center">
                    <strong id="liveRxValue">0.00</strong>
                    <span>Mbps</span>
                  </div>
                </div>
                <h5>UPLOAD</h5>
              </div>
              <div class="traffic-gauge-card download-tone">
                <div class="traffic-gauge" id="uploadGauge" style="--gauge-rotate:-90deg;">
                  <div class="traffic-gauge-arc"></div>
                  <div class="traffic-gauge-needle"></div>
                  <div class="traffic-gauge-center">
                    <strong id="liveTxValue">0.00</strong>
                    <span>Mbps</span>
                  </div>
                </div>
                <h5>DOWNLOAD</h5>
              </div>
            </div>
            <div class="soft-muted" id="trafficStatusText" style="margin-top:10px;">Menyiapkan pembacaan traffic live...</div>
          </div>

          <div class="traffic-panel">
            <div class="traffic-panel-head">
              <div class="traffic-panel-title">
                <span class="traffic-panel-icon purple"><i class="bi bi-calendar-range"></i></span>
                <div>
                  <h4>Riwayat Traffic</h4>
                  <p>Periode pemakaian yang sedang dihitung pada aplikasi pelanggan.</p>
                </div>
              </div>
            </div>
            <div class="traffic-period-grid">
              <div class="traffic-period-item">
                <small>Dari</small>
                <strong><i class="bi bi-calendar-event"></i> <%= formatDateTime(usageStartDate) %></strong>
              </div>
              <div class="traffic-period-item">
                <small>Sampai</small>
                <strong><i class="bi bi-calendar-check"></i> <%= formatDateTime(usageEndDate) %></strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <%- include('partials/customer/dashboard_speedtest_screen') %>

      <%- include('partials/customer/dashboard_billing_screen', {
        companyName,
        companyLogoUrl,
        packageName,
        profileData,
        customerData,
        settings,
        notifications,
        notificationUnreadCount,
        unpaidInvoices,
        paidInvoices,
        monthNames,
        formatCurrency,
        formatDateTime,
        paymentChannels,
        manualPaymentBank,
        manualPaymentAccountNumber,
        manualPaymentAccountName,
        manualPaymentNotes,
        hasManualPayment,
        companyLegalName,
        companyAddressText,
        companyPhoneText,
        companyEmailText
      }) %>

      <section class="app-screen" data-tab="ticketing">
        <div class="ticket-card">
          <div class="ticket-card-top">
            <div>
              <h4>Keluhan & Bantuan</h4>
              <div class="soft-muted">Pantau status tiket dan kirim keluhan baru.</div>
            </div>
            <button class="ticket-trigger" type="button" onclick="openTicketModal()">
              <i class="bi bi-plus-circle"></i> Tiket Baru
            </button>
          </div>

          <% if (!tickets || tickets.length === 0) { %>
            <div class="empty-card">
              <i class="bi bi-life-preserver"></i>
              <strong>Belum ada tiket</strong>
              <div>Kalau koneksi bermasalah atau butuh bantuan, Anda bisa buat tiket dari sini.</div>
            </div>
          <% } else { %>
            <div class="ticket-list">
              <% tickets.forEach((ticket) => { const ticketStatus = String(ticket.status || 'open').toLowerCase(); %>
                <div class="ticket-item">
                  <div class="item-icon"><i class="bi bi-life-preserver"></i></div>
                  <div class="item-text">
                    <div class="ticket-card-top" style="margin:0 0 10px;">
                      <strong><%= ticket.subject || `Tiket #${ticket.id}` %></strong>
                      <span class="ticket-status <%= ticketStatus === 'closed' || ticketStatus === 'done' ? 'closed' : ticketStatus === 'pending' ? 'pending' : 'open' %>">
                        <i class="bi <%= ticketStatus === 'closed' || ticketStatus === 'done' ? 'bi-check-circle' : ticketStatus === 'pending' ? 'bi-hourglass-split' : 'bi-lightning-charge' %>"></i>
                        <%= String(ticket.status || 'open').toUpperCase() %>
                      </span>
                    </div>
                    <p><%= ticket.message || 'Tidak ada detail pesan.' %></p>
                    <div class="ticket-meta">
                      <span><i class="bi bi-hash"></i> #<%= ticket.id %></span>
                      <span><i class="bi bi-clock-history"></i> <%= formatDateTime(ticket.created_at) %></span>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>

      <section class="app-screen" data-tab="profile">
        <div class="profile-card">
          <div class="profile-highlight">
            <h4>Profil Pelanggan</h4>
          </div>

          <div class="section-head" style="margin-top:18px;">
            <h3>Info Identitas</h3>
            <span>Data utama</span>
          </div>

          <div class="detail-grid">
            <div class="detail-item">
              <i class="bi bi-person"></i>
              <div>
                <strong>Nama Pelanggan</strong>
                <span><%= customerName %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-phone"></i>
              <div>
                <strong>Nomor HP</strong>
                <span><%= customerPhone %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-credit-card-2-front"></i>
              <div>
                <strong>ID Pelanggan</strong>
                <span><%= customerIdLabel %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-box-seam"></i>
              <div>
                <strong>Paket Layanan</strong>
                <span><%= packageName %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-diagram-3"></i>
              <div>
                <strong>ODP</strong>
                <span><%= customerOdp %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-calendar-check"></i>
              <div>
                <strong>Tanggal Pasang</strong>
                <span><%= formatDate(profileData.install_date) %></span>
              </div>
            </div>
            <div class="detail-item" style="grid-column:1 / -1;">
              <i class="bi bi-geo-alt"></i>
              <div>
                <strong>Alamat</strong>
                <span><%= customerAddress %></span>
              </div>
            </div>
          </div>

          <div class="settings-card" style="margin-top:16px;">
            <div class="billing-card-head">
              <div>
                <h4>Notifikasi Aplikasi</h4>
                <div class="soft-muted">Aktifkan agar pelanggan menerima push saat ada tagihan baru dan pengumuman.</div>
              </div>
            </div>
            <% if (!pushFeatureEnabled) { %>
              <div class="empty-card" style="margin:0;">
                <i class="bi bi-bell-slash"></i>
                <strong>Notifikasi belum diaktifkan admin</strong>
                <div>Admin perlu mengisi App ID dan REST API Key OneSignal di pengaturan aplikasi.</div>
              </div>
            <% } else { %>
              <div class="stack-actions">
                <div class="detail-item" style="margin-bottom:0;">
                  <i class="bi bi-app-indicator"></i>
                  <div>
                    <strong>Status Push</strong>
                    <span id="pushStatusText">Belum dicek</span>
                  </div>
                </div>
                <button class="settings-submit" type="button" onclick="enableCustomerPushNotifications()">
                  <i class="bi bi-bell"></i> Aktifkan Notifikasi
                </button>
              </div>
            <% } %>
          </div>

        </div>
      </section>

      <section class="app-screen" data-tab="packages">
        <div class="package-upgrade-card" style="margin-top:0;">
          <div class="package-upgrade-head">
            <div>
              <h4>Pilihan Paket WiFi</h4>
              <p>Pilih paket yang tersedia untuk pelanggan. Perubahan paket langsung diproses sistem dan tagihan aktif yang belum lunas ikut menyesuaikan.</p>
            </div>
            <div class="current-package-chip">
              <i class="bi bi-check2-circle"></i>
              Paket sekarang: <%= packageName %>
            </div>
          </div>

          <% if (!portalPackages || portalPackages.length === 0) { %>
            <div class="empty-card" style="margin:0;">
              <i class="bi bi-box-seam"></i>
              <strong>Belum ada paket lain yang dibuka</strong>
              <div>Admin belum menampilkan pilihan paket upgrade di portal pelanggan.</div>
            </div>
          <% } else { %>
            <div class="portal-package-list">
              <% portalPackages.forEach((pkg) => { %>
                <div class="portal-package-item">
                  <div class="portal-package-top">
                    <div>
                      <strong><%= pkg.name %></strong>
                      <div class="portal-package-desc"><%= pkg.description || 'Paket internet pelanggan dengan kecepatan stabil untuk kebutuhan harian.' %></div>
                    </div>
                    <div class="portal-package-price">
                      <strong><%= formatCurrency(pkg.price || 0) %></strong>
                      <span>/ bulan</span>
                    </div>
                  </div>
                  <div class="portal-package-meta">
                    <% if (Number(pkg.speed_down || 0) > 0 || Number(pkg.speed_up || 0) > 0) { %>
                      <span class="status-detail success">
                        <i class="bi bi-speedometer2"></i>
                        <%= Number(pkg.speed_down || 0) > 0 ? `${Math.round(Number(pkg.speed_down || 0) / 1000)} Mbps` : '-' %><%= Number(pkg.speed_up || 0) > 0 ? ` / ${Math.round(Number(pkg.speed_up || 0) / 1000)} Mbps` : '' %>
                      </span>
                    <% } %>
                    <% if (Number(pkg.include_ppn || 0) === 1 && Number(pkg.ppn_percent || 0) > 0) { %>
                      <span class="status-detail info">
                        <i class="bi bi-receipt-cutoff"></i>
                        Termasuk PPN <%= Number(pkg.ppn_percent || 0).toLocaleString('id-ID') %>%
                      </span>
                    <% } %>
                  </div>
                  <form class="portal-package-form" method="POST" action="/customer/packages/change" onsubmit="return confirm('Ganti paket ini? Tagihan aktif yang belum lunas akan ikut diperbarui.');">
                    <input type="hidden" name="package_id" value="<%= pkg.id %>">
                    <button class="settings-submit" type="submit">
                      <i class="bi bi-arrow-up-circle"></i> Pilih Paket Ini
                    </button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>

      <% if (hasRouterPortalAccess) { %>
      <section class="app-screen" data-tab="settings">
        <div class="settings-card">
          <div class="billing-card-head">
            <div>
              <h4>Router & WiFi</h4>
              <div class="soft-muted">WiFi, status internet, dan perangkat yang terhubung.</div>
            </div>
          </div>

          <div class="detail-grid router-detail-grid" style="margin-bottom:16px;">
            <div class="detail-item">
              <i class="bi bi-wifi"></i>
              <div>
                <strong>Status Internet</strong>
                <span><%= isPppoeOnline ? 'Online' : (customerData.pppoeStatusText || customerData.status || 'Belum terbaca') %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-router"></i>
              <div>
                <strong>Router / ONU</strong>
                <span><%= routerDisplayName %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-broadcast-pin"></i>
              <div>
                <strong>Nama WiFi (SSID)</strong>
                <span><%= customerData.ssid || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-globe2"></i>
              <div>
                <strong>PPPoE Username</strong>
                <span><%= customerData.pppoeUsername || profileData.pppoe_username || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-hdd-network"></i>
              <div>
                <strong>IP Internet</strong>
                <span><%= customerData.pppoeIP || profileData.static_ip || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-upc-scan"></i>
              <div>
                <strong>Serial Number</strong>
                <span><%= customerData.serialNumber || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-reception-4"></i>
              <div>
                <strong>RX Power</strong>
                <span><%= customerData.rxPower || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-phone"></i>
              <div>
                <strong>Perangkat Terdeteksi</strong>
                <span><%= usersOnline.length %> online dari <%= connectedDeviceCount %> perangkat</span>
              </div>
            </div>
          </div>

          <div class="settings-grid">
            <form class="settings-form" method="POST" action="/customer/change-ssid">
              <div class="settings-field">
                <label for="ssidField">Nama WiFi (SSID)</label>
                <input id="ssidField" type="text" name="ssid" value="<%= customerData.ssid && customerData.ssid !== '-' ? customerData.ssid : '' %>" placeholder="Contoh: Rumah-Huda-WiFi" required>
              </div>
              <button class="settings-submit" type="submit">
                <i class="bi bi-broadcast-pin"></i> Simpan SSID
              </button>
