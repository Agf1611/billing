  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const NOTIFICATION_UNREAD = <%- JSON.stringify(notificationUnread) %>;
    const PUSH_FEATURE_ENABLED = <%- JSON.stringify(pushFeatureEnabled) %>;
    const CUSTOMER_PUSH_EXTERNAL_ID = <%- JSON.stringify(customerPushExternalId) %>;
    const TAB_META = {
      home: { eyebrow: 'Halaman Utama', title: 'Dashboard Pelanggan' },
      billing: { eyebrow: 'Pembayaran', title: 'Tagihan & Riwayat' },
      traffic: { eyebrow: 'Statistik', title: 'Statistik Penggunaan' },
      packages: { eyebrow: 'Paket WiFi', title: 'Pilih Paket Internet' },
      speedtest: { eyebrow: 'Tes Speed', title: 'Tes Speed Internet' },
      ticketing: { eyebrow: 'Bantuan', title: 'Bantuan & Tiket' },
      profile: { eyebrow: 'Profil', title: 'Profil Pelanggan' },
      settings: { eyebrow: 'Router', title: 'Router & WiFi' }
    };

    const HAS_ROUTER_PORTAL_ACCESS = <%- JSON.stringify(hasRouterPortalAccess) %>;

    const LEGACY_HASH_MAP = {
      '#home-section': 'home',
      '#traffic-section': 'traffic',
      '#speedtest-section': 'speedtest',
      '#ticket-section': 'ticketing',
      '#profile-section': 'profile',
      '#activity-section': 'home',
      '#settings-section': 'settings',
      '#router-section': 'settings'
    };

    let paymentModal = null;
    let ticketModal = null;
    let notificationModal = null;
    let trafficTimer = null;
    const trafficHistory = {
      rx: Array(8).fill(0),
      tx: Array(8).fill(0)
    };
    const LIVE_CAPS = {
      rx: <%- JSON.stringify(liveDownloadCap) %>,
      tx: <%- JSON.stringify(liveUploadCap) %>
    };

    function setPushStatus(message) {
      const node = document.getElementById('pushStatusText');
      if (node) node.textContent = message;
    }

    async function syncCustomerPushIdentity() {
      if (!PUSH_FEATURE_ENABLED || !CUSTOMER_PUSH_EXTERNAL_ID || !window.median?.onesignal?.login) return null;
      try {
        await window.median.onesignal.login(CUSTOMER_PUSH_EXTERNAL_ID);
        if (window.median.onesignal.info) {
          return await window.median.onesignal.info();
        }
      } catch (error) {
        console.warn('OneSignal sync gagal:', error);
      }
      return null;
    }

    async function refreshCustomerPushStatus() {
      if (!PUSH_FEATURE_ENABLED) {
        setPushStatus('Belum diaktifkan oleh admin');
        return null;
      }
      if (!window.median?.onesignal) {
        setPushStatus('Aktif jika dibuka lewat aplikasi');
        return null;
      }
      const info = await syncCustomerPushIdentity();
      const optedIn = Boolean(info?.subscription?.optedIn);
      setPushStatus(optedIn ? 'Sudah aktif di aplikasi ini' : 'Belum diizinkan di aplikasi ini');
      return info;
    }

    async function enableCustomerPushNotifications() {
      if (!PUSH_FEATURE_ENABLED) {
        alert('Notifikasi aplikasi belum diaktifkan oleh admin.');
        return;
      }
      if (!window.median?.onesignal) {
        alert('Aktifkan dari aplikasi Median yang sudah di-install di HP Anda.');
        return;
      }
      setPushStatus('Meminta izin notifikasi...');
      try {
        if (window.median.onesignal.userPrivacyConsent?.grant) {
          await window.median.onesignal.userPrivacyConsent.grant();
        }
      } catch (_) {}
      try {
        await syncCustomerPushIdentity();
        if (window.median.onesignal.register) {
          await window.median.onesignal.register();
        }
        const info = await refreshCustomerPushStatus();
        if (info?.subscription?.optedIn) {
          alert('Notifikasi aplikasi berhasil diaktifkan.');
        } else {
          alert('Izin notifikasi belum aktif. Silakan cek pengaturan aplikasi di HP.');
        }
      } catch (error) {
        setPushStatus('Gagal mengaktifkan notifikasi');
        alert('Gagal mengaktifkan notifikasi: ' + (error?.message || error));
      }
    }

    function getTabFromHash() {
      const rawHash = String(window.location.hash || '').trim().toLowerCase();
      if (!rawHash) return 'home';
      if (LEGACY_HASH_MAP[rawHash]) return LEGACY_HASH_MAP[rawHash];
      const clean = rawHash.replace('#', '');
      return TAB_META[clean] ? clean : 'home';
    }

    function updateHeader(tabName) {
      const meta = TAB_META[tabName] || TAB_META.home;
      const eyebrow = document.getElementById('appHeaderEyebrow');
      const title = document.getElementById('appHeaderTitle');
      if (eyebrow) eyebrow.textContent = meta.eyebrow;
      if (title) title.textContent = meta.title;
    }

    function openAppTab(tabName, updateHash = true) {
      let nextTab = TAB_META[tabName] ? tabName : 'home';
      if (nextTab === 'settings' && !HAS_ROUTER_PORTAL_ACCESS) {
        nextTab = 'home';
      }
      closeAppMenu();
      closeAccountMenu();
      document.querySelectorAll('.app-screen').forEach((screen) => {
        screen.classList.toggle('is-active', screen.dataset.tab === nextTab);
      });
      document.querySelectorAll('[data-nav-tab]').forEach((button) => {
        button.classList.toggle('is-active', button.dataset.navTab === nextTab);
      });
      updateHeader(nextTab);
      if (updateHash) {
        const nextHash = `#${nextTab}`;
        if (window.location.hash !== nextHash) {
          history.replaceState(null, '', nextHash);
        }
      }
      scheduleTrafficRefresh(nextTab);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function openPaymentModal() {
      if (!paymentModal) return;
      paymentModal.show();
    }

    function openTicketModal() {
      if (!ticketModal) return;
      ticketModal.show();
    }

    function toggleAccountMenu(forceOpen = null) {
      closeAppMenu();
      const menu = document.getElementById('accountMenu');
      if (!menu) return;
      const shouldOpen = forceOpen === null ? !menu.classList.contains('is-open') : Boolean(forceOpen);
      menu.classList.toggle('is-open', shouldOpen);
    }

    function closeAccountMenu() {
      toggleAccountMenu(false);
    }

    function toggleAppMenu(forceOpen = null) {
      closeAccountMenu();
      const backdrop = document.getElementById('appMenuBackdrop');
      const sheet = document.getElementById('appMenuSheet');
      if (!backdrop || !sheet) return;
      const shouldOpen = forceOpen === null ? !sheet.classList.contains('is-open') : Boolean(forceOpen);
      backdrop.classList.toggle('is-open', shouldOpen);
      sheet.classList.toggle('is-open', shouldOpen);
      sheet.setAttribute('aria-hidden', shouldOpen ? 'false' : 'true');
    }

    function closeAppMenu() {
      const backdrop = document.getElementById('appMenuBackdrop');
      const sheet = document.getElementById('appMenuSheet');
      backdrop?.classList.remove('is-open');
      sheet?.classList.remove('is-open');
      sheet?.setAttribute('aria-hidden', 'true');
    }

    async function markNotificationsRead() {
      if (!NOTIFICATION_UNREAD) return;
      try {
        await fetch('/customer/notifications/read', {
          method: 'POST',
          headers: { 'x-requested-with': 'fetch' }
        });
        const badge = document.getElementById('notificationBadge');
        if (badge) badge.remove();
      } catch {}
    }

    async function openNotificationsPanel() {
      closeAccountMenu();
      await markNotificationsRead();
      if (notificationModal) {
        notificationModal.show();
        return;
      }
      openAppTab('billing');
    }

    function goToNotification(tabName) {
      if (notificationModal) notificationModal.hide();
      openAppTab(tabName || 'home');
    }

    function copyCustomerCode() {
      const code = <%- JSON.stringify(customerCode) %>;
      if (!code || code === '-') return;
      navigator.clipboard?.writeText(code).then(() => {
        const statusText = document.getElementById('trafficStatusText');
        if (statusText) statusText.textContent = 'Kode pelanggan berhasil disalin.';
      }).catch(() => {});
    }

    function quickReboot() {
      const ok = window.confirm('Reboot perangkat pelanggan sekarang? Koneksi akan terputus beberapa menit.');
      if (!ok) return;
      const form = document.getElementById('quickRebootForm');
      if (form) form.submit();
    }

    function reloadPortalSpeedtest() {
      const frame = document.getElementById('portalSpeedtestFrame');
      if (!frame) return;
      frame.src = `https://openspeedtest.com/speedtest?Run=3&ts=${Date.now()}`;
    }

    function setSpeedMeter(kind, rawValue) {
      const valueNode = document.getElementById(kind === 'rx' ? 'liveRxValue' : 'liveTxValue');
      const polyline = document.getElementById(kind === 'rx' ? 'rxSparklinePath' : 'txSparklinePath');
      const dot = document.getElementById(kind === 'rx' ? 'rxSparklineDot' : 'txSparklineDot');
      const gauge = document.getElementById(kind === 'rx' ? 'downloadGauge' : 'uploadGauge');
      const cap = Math.max(1, Number(kind === 'rx' ? LIVE_CAPS.rx : LIVE_CAPS.tx) || 1);
      const mbps = Math.max(0, Number(rawValue || 0));
      const ratio = Math.max(0, Math.min(1, mbps / cap));
      const degree = -90 + (ratio * 180);

      if (valueNode) {
        valueNode.textContent = mbps.toFixed(2);
      }

      if (gauge) {
        gauge.style.setProperty('--gauge-rotate', `${degree}deg`);
      }

      const nextHistory = [...(trafficHistory[kind] || []), mbps].slice(-8);
      trafficHistory[kind] = nextHistory;

      if (polyline && dot) {
        const maxValue = Math.max(cap, ...nextHistory, 0.1);
        const points = nextHistory.map((value, index) => {
          const x = Math.round((112 / (nextHistory.length - 1 || 1)) * index);
          const ratio = Math.max(0, Math.min(1, value / maxValue));
          const y = Math.round(42 - (ratio * 28));
          return { x, y };
        });
        polyline.setAttribute('points', points.map((point) => `${point.x},${point.y}`).join(' '));
        const lastPoint = points[points.length - 1] || { x: 112, y: 42 };
        dot.setAttribute('cx', String(lastPoint.x));
        dot.setAttribute('cy', String(lastPoint.y));
      }
    }

    async function refreshTrafficNow() {
      const statusText = document.getElementById('trafficStatusText');
      const rxNode = document.getElementById('liveRxValue');
      const txNode = document.getElementById('liveTxValue');
      if (!rxNode || !txNode) return;

      try {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 4500);
        const response = await fetch('/customer/api/pppoe-traffic', {
          headers: { 'x-requested-with': 'fetch' },
          signal: controller.signal
        });
        clearTimeout(timeout);
        const data = await response.json();

        if (!data || data.ok === false) {
          setSpeedMeter('rx', 0);
          setSpeedMeter('tx', 0);
          if (statusText) statusText.textContent = data?.error ? `Traffic live belum tersedia: ${data.error}` : 'Traffic live belum tersedia.';
          return;
        }

        const customerDownloadMbps = Number(data.downloadMbps ?? data.rxMbps ?? data.txMbps ?? 0) || 0;
        const customerUploadMbps = Number(data.uploadMbps ?? data.txMbps ?? data.rxMbps ?? 0) || 0;
        setSpeedMeter('rx', customerDownloadMbps);
        setSpeedMeter('tx', customerUploadMbps);

        const usageTotalNode = document.getElementById('usageTotalDisplay');
        const usageDownloadNode = document.getElementById('usageDownloadDisplay');
        const usageUploadNode = document.getElementById('usageUploadDisplay');
        const usageDownBytes = Number(data.usageDownloadBytes ?? data.usageBytesIn ?? data.usageBytesOut ?? 0) || 0;
        const usageUpBytes = Number(data.usageUploadBytes ?? data.usageBytesOut ?? data.usageBytesIn ?? 0) || 0;
        const usageTotalBytes = usageDownBytes + usageUpBytes;
        const formatUsageGb = (bytes) => ((Math.max(0, Number(bytes || 0)) / (1024 * 1024 * 1024))).toFixed(2);
        if (usageTotalNode) usageTotalNode.textContent = formatUsageGb(usageTotalBytes);
        if (usageDownloadNode) usageDownloadNode.textContent = `${formatUsageGb(usageDownBytes)} GB`;
        if (usageUploadNode) usageUploadNode.textContent = `${formatUsageGb(usageUpBytes)} GB`;

        if (data.available === false) {
          if (statusText) statusText.textContent = 'PPPoE belum terdeteksi untuk akun ini.';
          return;
        }

        if (data.online === false) {
          if (statusText) statusText.textContent = 'PPPoE sedang offline.';
          return;
        }

        if (data.warmup) {
          if (statusText) statusText.textContent = 'Traffic live sedang kalibrasi. Coba lagi beberapa detik.';
          return;
        }

        const ifaceInfo = data.iface ? ` • ${data.iface}` : '';
        if (statusText) statusText.textContent = `Traffic live aktif${ifaceInfo}${data.uptime ? ` • uptime ${data.uptime}` : ''}`;
      } catch (error) {
        setSpeedMeter('rx', 0);
        setSpeedMeter('tx', 0);
        if (statusText) statusText.textContent = 'Gagal mengambil traffic live. Dashboard tetap bisa dipakai.';
      }
    }

    function scheduleTrafficRefresh(tabName) {
      if (trafficTimer) {
        clearInterval(trafficTimer);
        trafficTimer = null;
      }

      if (tabName !== 'traffic') return;
      refreshTrafficNow();
      trafficTimer = window.setInterval(() => {
        if (document.hidden) return;
        refreshTrafficNow();
      }, 12000);
    }

    document.addEventListener('DOMContentLoaded', () => {
      paymentModal = new bootstrap.Modal(document.getElementById('paymentModal'));
      ticketModal = new bootstrap.Modal(document.getElementById('ticketModal'));
      notificationModal = new bootstrap.Modal(document.getElementById('notificationModal'));

      ['paymentModal', 'ticketModal', 'notificationModal'].forEach((modalId) => {
        const modalEl = document.getElementById(modalId);
        if (!modalEl) return;
        modalEl.addEventListener('shown.bs.modal', () => document.body.classList.add('modal-open'));
        modalEl.addEventListener('hidden.bs.modal', () => {
          const anyOpen = Array.from(document.querySelectorAll('.modal.show')).length > 0;
          document.body.classList.toggle('modal-open', anyOpen);
        });
      });

      document.querySelectorAll('[data-nav-tab]').forEach((button) => {
        button.addEventListener('click', () => openAppTab(button.dataset.navTab));
      });

      document.addEventListener('click', (event) => {
        const menu = document.getElementById('accountMenu');
        if (!menu) return;
        const wrap = event.target.closest('.header-icon-wrap');
        if (!wrap || !wrap.contains(menu)) {
          if (!event.target.closest('[aria-label="Akun"]')) closeAccountMenu();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeAccountMenu();
          closeAppMenu();
        }
      });

      const isAndroidLike = /android/i.test(navigator.userAgent || '') || window.matchMedia('(display-mode: standalone)').matches;
      if (isAndroidLike) {
        document.body.classList.add('android-webview');
      }

      setSpeedMeter('rx', 0);
      setSpeedMeter('tx', 0);

      const initialTab = getTabFromHash();
      openAppTab(initialTab, true);

      const splash = document.getElementById('appSplash');
      const seenBefore = sessionStorage.getItem('customer-pwa-splash') === '1';
      window.setTimeout(() => {
        splash?.classList.add('is-hidden');
        sessionStorage.setItem('customer-pwa-splash', '1');
      }, seenBefore ? 120 : 420);

      window.addEventListener('hashchange', () => {
        openAppTab(getTabFromHash(), false);
      });

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/customer/' }).catch(() => {});
        });
      }

      document.querySelectorAll('form[action="/customer/logout"]').forEach((form) => {
        form.addEventListener('submit', () => {
          try {
            if (window.median?.onesignal?.logout) window.median.onesignal.logout();
          } catch (_) {}
        });
      });

      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) {
          const active = document.querySelector('.app-screen.is-active');
          if (active) scheduleTrafficRefresh(active.dataset.tab);
        }
      });

      refreshCustomerPushStatus();
    });
  </script>
</body>
</html>
