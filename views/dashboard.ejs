<body class="pwa-body">
  <div class="app-splash" id="appSplash" aria-hidden="true">
    <div class="splash-card">
      <div class="splash-logo">
        <img src="<%= companyLogoUrl %>" alt="Logo" onerror="this.onerror=null;this.src='/img/mss-logo.png'">
      </div>
      <h1><%= companyName %></h1>
      <p>Menyiapkan dashboard pelanggan yang lebih ringan dan nyaman di HP.</p>
      <div class="splash-progress"><span></span></div>
    </div>
  </div>

  <div class="app-shell">
    <%- include('partials/customer/dashboard_topbar', {
      companyLogoUrl,
      companyName,
      customerName,
      customerCode,
      hasRouterPortalAccess,
      notificationUnread,
      notificationUnreadCount,
      notifications,
      profileData,
      customerData,
      settings
    }) %>

    <main class="app-main">
      <%- include('partials/customer/dashboard_home_screen', {
        customerName,
        customerCode,
        profileData,
        customerData,
        packageName,
        liveDownloadCap,
        liveUploadCap,
        isPppoeOnline,
        pppoeStatusText,
        portalAccountLabel,
        latestInvoice,
        primaryUnpaidInvoice,
        latestPaidInvoice,
        hasUnpaidInvoice,
        totalUnpaidAmount,
        unpaidInvoices,
        monthlyPrice,
        uploadBytes,
        downloadBytes,
        appNotif,
        portalBannerSlides,
        pushFeatureEnabled,
        hasRouterPortalAccess,
        formatDate,
        formatCurrency,
        formatBytes,
        connectedUsers
      }) %>

      <section class="app-screen" data-tab="traffic">
        <div class="traffic-stack">
          <div class="traffic-panel">
            <div class="traffic-panel-head">
              <div class="traffic-panel-title">
                <span class="traffic-panel-icon"><i class="bi bi-cpu"></i></span>
                <div>
                  <h4>Penggunaan Bandwidth</h4>
                  <p>Statistik pemakaian bulan berjalan yang disimpan dari PPPoE pelanggan.</p>
                </div>
              </div>
            </div>
            <div class="usage-bandwidth-label">Total Penggunaan</div>
            <div class="usage-bandwidth-total">
              <strong id="usageTotalDisplay"><%= formatUsageGb(totalBytes) %></strong>
              <span>GB</span>
            </div>
            <div class="usage-breakdown">
              <div class="usage-breakdown-item upload">
                <small>Upload</small>
                <strong id="usageUploadDisplay"><%= formatUsageGb(uploadBytes) %> GB</strong>
              </div>
              <div class="usage-breakdown-item download">
                <small>Download</small>
                <strong id="usageDownloadDisplay"><%= formatUsageGb(downloadBytes) %> GB</strong>
              </div>
            </div>
          </div>

          <div class="traffic-panel">
            <div class="traffic-panel-head">
              <div class="traffic-panel-title">
                <span class="traffic-panel-icon warning"><i class="bi bi-lightning-charge"></i></span>
                <div>
                  <h4>Penggunaan Traffic</h4>
                </div>
              </div>
              <span class="live-pill"><i class="bi bi-circle-fill"></i> Live</span>
            </div>
            <div class="traffic-gauge-grid">
              <div class="traffic-gauge-card upload-tone">
                <div class="traffic-gauge-top">
                  <div class="traffic-gauge-label">
                    <i class="bi bi-arrow-up-circle-fill"></i>
                    <h5>Upload</h5>
                  </div>
                  <span class="traffic-gauge-cap">Live</span>
                </div>
                <div class="traffic-gauge-meter">
                  <div class="traffic-gauge-dial">
                    <div class="traffic-gauge-arc" id="uploadGaugeFill"></div>
                    <div class="traffic-gauge-needle" id="uploadGaugeNeedle"></div>
                  </div>
                  <div class="traffic-gauge-readout">
                    <strong><span id="liveTxValue">0.00</span><small>Mbps</small></strong>
                    <span>Upload</span>
                  </div>
                  <div class="traffic-gauge-meta">
                    <span id="uploadGaugeCap">Max <%= liveUploadCap %> Mbps</span>
                  </div>
                </div>
              </div>
              <div class="traffic-gauge-card download-tone">
                <div class="traffic-gauge-top">
                  <div class="traffic-gauge-label">
                    <i class="bi bi-arrow-down-circle-fill"></i>
                    <h5>Download</h5>
                  </div>
                  <span class="traffic-gauge-cap">Live</span>
                </div>
                <div class="traffic-gauge-meter">
                  <div class="traffic-gauge-dial">
                    <div class="traffic-gauge-arc" id="downloadGaugeFill"></div>
                    <div class="traffic-gauge-needle" id="downloadGaugeNeedle"></div>
                  </div>
                  <div class="traffic-gauge-readout">
                    <strong><span id="liveRxValue">0.00</span><small>Mbps</small></strong>
                    <span>Download</span>
                  </div>
                  <div class="traffic-gauge-meta">
                    <span id="downloadGaugeCap">Max <%= liveDownloadCap %> Mbps</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="soft-muted" id="trafficStatusText" style="display:none;margin-top:10px;"></div>
          </div>

          <div class="traffic-panel">
            <div class="traffic-panel-head">
              <div class="traffic-panel-title">
                <span class="traffic-panel-icon purple"><i class="bi bi-calendar-range"></i></span>
                <div>
                  <h4>Riwayat Traffic</h4>
                  <p>Periode pemakaian yang sedang dihitung pada aplikasi pelanggan.</p>
                </div>
              </div>
            </div>
            <div class="traffic-period-grid">
              <div class="traffic-period-item">
                <small>Dari</small>
                <strong><i class="bi bi-calendar-event"></i> <%= formatDateTime(usageStartDate) %></strong>
              </div>
              <div class="traffic-period-item">
                <small>Sampai</small>
                <strong><i class="bi bi-calendar-check"></i> <%= formatDateTime(usageEndDate) %></strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <%- include('partials/customer/dashboard_speedtest_screen') %>

      <%- include('partials/customer/dashboard_billing_screen', {
