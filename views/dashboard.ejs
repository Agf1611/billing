  const monthNames = [null, 'Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  const customerData = customer || {};
  const profileData = profile || {};
  const companyName = settings?.company_header || 'Portal Pelanggan';
  const companyLogoUrl = settings?.company_logo_url || '/img/mss-logo.png';
  const companyLegalName = String(settings?.company_legal_name || '').trim();
  const upstreamProviderName = String(settings?.upstream_provider_name || '').trim();
  const companyAddressText = String(settings?.company_address || '').trim();
  const companyPhoneText = String(settings?.company_phone || '').trim();
  const companyEmailText = String(settings?.company_email || '').trim();
  const manualPaymentBank = String(settings?.manual_payment_bank || '').trim();
  const manualPaymentAccountNumber = String(settings?.manual_payment_account_number || '').trim();
  const manualPaymentAccountName = String(settings?.manual_payment_account_name || '').trim();
  const manualPaymentNotes = String(settings?.manual_payment_notes || '').trim();
  const hasManualPayment = Boolean(manualPaymentBank && manualPaymentAccountNumber);
  function isSafePortalIdentity(value) {
    const raw = String(value || '').trim();
    if (!raw || raw === '-') return false;
    if (/@/.test(raw)) return false;
    if (/pppoe/i.test(raw)) return false;
    return true;
  }
  const customerIdPrefix = String(settings?.customer_id_prefix || 'SCK').trim().toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10) || 'SCK';
  const generatedCustomerCode = profileData.id ? `${customerIdPrefix}${profileData.id}` : '';
  const customerCode = String(
    [
      profileData.customer_code,
      customerData.customer_code,
      generatedCustomerCode
    ].find((value) => isSafePortalIdentity(value)) || '-'
  ).trim();
  const portalBannerSlides = [1, 2, 3]
    .map((idx) => String(settings?.[`customer_portal_banner_${idx}_url`] || '').trim())
    .filter(Boolean)
    .slice(0, 3);
  const customerName = profileData.name || customerData.name || 'Pelanggan';
  const packageName = profileData.package_name || customerData.package_name || 'Paket Internet';
  const customerPhone = profileData.phone || customerData.phone || '-';
  const customerNik = String(profileData.nik || customerData.nik || '').trim();
  const customerAddress = profileData.address || customerData.lokasi || '-';
  const customerOdp = profileData.odp_name || '-';
  const customerIdLabel = customerCode || String(profileData.id || '-');
  const routerDisplayName = profileData.router_name || customerData.model || customerData.productClass || '-';
  const monthlyPrice = Number(profileData.package_price || 0);
  const downloadBytes = Math.max(0, Number(profileData.bytes_out || 0));
  const uploadBytes = Math.max(0, Number(profileData.bytes_in || 0));
  const totalBytes = uploadBytes + downloadBytes;
  const useFup = Number(profileData.use_fup || 0) === 1 && Number(profileData.fup_limit_gb || 0) > 0;
  const quotaLimitBytes = useFup ? Number(profileData.fup_limit_gb || 0) * 1024 * 1024 * 1024 : 0;
  const quotaPercent = quotaLimitBytes > 0 ? Math.min(100, (totalBytes / quotaLimitBytes) * 100) : 0;
  const usageStartDate = new Date();
  usageStartDate.setDate(1);
  usageStartDate.setHours(0, 0, 0, 0);
  const usageEndDate = new Date();
  const liveDownloadCap = Number(trafficMaxDownMbps || Math.max(1, Math.round(Number(profileData.speed_down || 10000) / 1000) || 10));
  const liveUploadCap = Number(trafficMaxUpMbps || Math.max(1, Math.round(Number(profileData.speed_up || 10000) / 1000) || 10));
  const unpaidInvoices = (invoices || []).filter((inv) => String(inv.status || '').toLowerCase() === 'unpaid');
  const paidInvoices = (invoices || []).filter((inv) => String(inv.status || '').toLowerCase() === 'paid');
  const primaryUnpaidInvoice = unpaidInvoices[0] || null;
  const latestPaidInvoice = paidInvoices[0] || null;
  const latestInvoice = primaryUnpaidInvoice || latestPaidInvoice || null;
  const hasUnpaidInvoice = unpaidInvoices.length > 0;
  const totalUnpaidAmount = unpaidInvoices.reduce((sum, inv) => sum + (Number(inv.amount || 0) || 0), 0);
  const usersOnline = Array.isArray(connectedUsers) ? connectedUsers.filter((item) => String(item.status || '').toLowerCase() === 'online') : [];
  const connectedDeviceCount = Array.isArray(connectedUsers) ? connectedUsers.length : 0;
  const activeTickets = (tickets || []).filter((ticket) => !['resolved', 'closed', 'done'].includes(String(ticket.status || '').toLowerCase()));
  const pppoeStatusText = String(customerData.pppoeStatusText || profileData.pppoe_status || '').trim();
  const isPppoeOnline = /online|connected|aktif/i.test(pppoeStatusText);
  const portalAccountStatus = String(profileData.status || customerData.status || 'active').trim().toLowerCase();
  const portalAccountLabel = portalAccountStatus === 'suspended' ? 'Isolir' : portalAccountStatus === 'inactive' ? 'Nonaktif' : 'Aktif';
  const portalServiceActionLocked = portalAccountStatus === 'suspended' || portalAccountStatus === 'inactive';
  const portalServiceLockText = portalAccountStatus === 'inactive'
    ? 'Akun nonaktif. Pembayaran dan info tagihan tetap bisa dibuka, tetapi perubahan layanan perlu aktivasi admin.'
    : portalAccountStatus === 'suspended'
      ? 'Akun sedang isolir. Bayar tagihan untuk membuka kembali perubahan layanan.'
      : '';
  const hasRouterPortalAccess = Boolean(
    (customerData.ssid && customerData.ssid !== '-') ||
    (customerData.serialNumber && customerData.serialNumber !== '-') ||
    (customerData.rxPower && customerData.rxPower !== '-') ||
    (customerData.model && customerData.model !== '-') ||
    (customerData.productClass && customerData.productClass !== '-') ||
    (Array.isArray(connectedUsers) && connectedUsers.length > 0)
  );
  const supportPhone = String(settings?.whatsapp_admin || settings?.admin_phone || settings?.company_phone || '').trim();
  const supportUrl = supportPhone ? buildWhatsAppLink(supportPhone) : '/customer/contact';
  const appNotif = (typeof notif !== 'undefined' ? notif : null) || null;
  const settingsLocalNotif = (typeof settingsActionNotif !== 'undefined' && settingsActionNotif) ? settingsActionNotif : null;
  const profileLocalNotif = (typeof profileActionNotif !== 'undefined' && profileActionNotif) ? profileActionNotif : null;
  const notificationItems = Array.isArray(typeof notifications !== 'undefined' ? notifications : []) ? (typeof notifications !== 'undefined' ? notifications : []) : [];
  const notificationUnread = Math.max(0, Number(typeof notificationUnreadCount !== 'undefined' ? notificationUnreadCount : 0) || 0);
  const pushFeatureEnabled = Boolean(settings?.onesignal_enabled && settings?.onesignal_app_id);
  const oneSignalAppId = String(settings?.onesignal_app_id || '').trim();
  const customerPushExternalId = profileData.id || customerData.id ? `customer-${profileData.id || customerData.id}` : '';
  const oneSignalDirectEmbedEnabled = Boolean(pushFeatureEnabled && oneSignalAppId && customerPushExternalId);
  const profileChangeViewState = (typeof profileChangeState !== 'undefined' && profileChangeState) ? profileChangeState : {};
  const activeProfileChangeRequest = profileChangeViewState.activeRequest || null;
  const latestProfileChangeRequest = profileChangeViewState.latestRequest || null;
  const recentActivities = [];

  function formatCurrency(value) {
    return `Rp ${Number(value || 0).toLocaleString('id-ID')}`;
  }

  function formatBytes(bytes) {
    const num = Number(bytes || 0);
    if (!Number.isFinite(num) || num <= 0) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB', 'TB'];
    let value = num;
    let unitIndex = 0;
    while (value >= 1024 && unitIndex < units.length - 1) {
      value /= 1024;
      unitIndex += 1;
    }
    const digits = value >= 100 ? 0 : value >= 10 ? 1 : 2;
    return `${value.toFixed(digits)} ${units[unitIndex]}`;
  }

  function formatUsageGb(bytes) {
    const num = Math.max(0, Number(bytes || 0));
    const gb = num / (1024 * 1024 * 1024);
    if (gb >= 1) return gb.toFixed(2);
    const mb = num / (1024 * 1024);
    return (mb / 1024).toFixed(2);
  }

  function formatDate(value) {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function formatDateTime(value) {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleString('id-ID', {
      timeZone: 'Asia/Jakarta',
      day: 'numeric',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  (unpaidInvoices || []).slice(0, 2).forEach((inv) => {
    recentActivities.push({
      type: 'invoice-unpaid',
      title: `Invoice INV-${inv.id}`,
      subtitle: `Tagihan ${monthNames[Number(inv.period_month)] || inv.period_month} ${inv.period_year}`,
      meta: formatCurrency(inv.amount),
      time: `${monthNames[Number(inv.period_month)] || inv.period_month} ${inv.period_year}`,
      ts: new Date(Number(inv.period_year), Number(inv.period_month) - 1, 1).getTime() || 0,
      icon: 'bi-receipt-cutoff'
    });
  });

  (paidInvoices || []).slice(0, 2).forEach((inv) => {
    recentActivities.push({
      type: 'invoice-paid',
      title: `Pembayaran INV-${inv.id}`,
      subtitle: `Tagihan lunas ${monthNames[Number(inv.period_month)] || inv.period_month} ${inv.period_year}`,
      meta: formatCurrency(inv.amount),
      time: formatDateTime(inv.paid_at),
      ts: inv.paid_at ? new Date(inv.paid_at).getTime() : 0,
      icon: 'bi-patch-check'
    });
  });

  (tickets || []).slice(0, 3).forEach((ticket) => {
    recentActivities.push({
      type: 'ticket',
      title: ticket.subject || `Tiket #${ticket.id}`,
      subtitle: ticket.message || 'Keluhan pelanggan',
      meta: String(ticket.status || 'open').toUpperCase(),
      time: formatDateTime(ticket.created_at),
      ts: ticket.created_at ? new Date(ticket.created_at).getTime() : 0,
      icon: 'bi-life-preserver'
    });
  });

  recentActivities.sort((a, b) => (b.ts || 0) - (a.ts || 0));
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Dashboard Pelanggan | <%= companyName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <%- include('partials/pwa_portal', {
    portalKey: 'customer',
    manifestPath: '/pwa/customer.webmanifest',
    scope: '/customer/',
    themeColor: '#073dcc',
    appTitle: 'Portal Pelanggan',
    installLabel: 'Install Pelanggan'
  }) %>
  <script>
    (function () {
      try {
        var savedTheme = localStorage.getItem('customer-portal-theme');
        var theme = savedTheme === 'dark' || savedTheme === 'light'
          ? savedTheme
          : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        document.body && document.body.setAttribute('data-theme', theme);
      } catch (_) {}
    })();
  </script>
  <style>
    :root {
      --app-bg: #f5f8ff;
      --app-surface: rgba(255, 255, 255, 0.94);
      --app-surface-strong: #ffffff;
      --app-line: rgba(170, 186, 215, 0.22);
      --app-text: #1b2740;
      --app-text-soft: #6b7b97;
      --app-blue: #073dcc;
      --app-blue-deep: #073dcc;
      --app-blue-soft: rgba(7, 61, 204, 0.12);
      --app-danger: #e05d6d;
      --app-success: #1ca56f;
      --app-warning: #ec9a36;
      --app-shadow: 0 24px 64px rgba(85, 104, 148, 0.16);
      --shell-width: min(100vw, 430px);
    }

    html[data-theme="dark"],
    body[data-theme="dark"] {
      --app-bg: #09111d;
      --app-surface: rgba(17, 24, 39, 0.94);
      --app-surface-strong: #111827;
      --app-line: rgba(148, 163, 184, 0.16);
      --app-text: #edf2ff;
      --app-text-soft: #96a3bf;
      --app-blue: #0b55f4;
      --app-blue-deep: #073dcc;
      --app-blue-soft: rgba(111, 141, 255, 0.16);
      --app-danger: #ff7286;
      --app-success: #35c98a;
      --app-warning: #ffb34d;
      --app-shadow: 0 30px 70px rgba(0, 0, 0, 0.38);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      background: linear-gradient(180deg, #ffffff 0%, #f5f8ff 100%);
      font-family: 'Plus Jakarta Sans', 'Manrope', sans-serif;
      color: var(--app-text);
      -webkit-tap-highlight-color: transparent;
    }

    html[data-theme="dark"],
    body[data-theme="dark"] {
      background: linear-gradient(180deg, #06153a 0%, #0b1f56 100%);
      color: var(--app-text);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(47, 107, 255, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(47, 107, 255, 0.035) 1px, transparent 1px);
      background-size: 26px 26px;
      pointer-events: none;
      opacity: 0.45;
    }

    html[data-theme="dark"] body::before,
    body[data-theme="dark"]::before {
      background-image:
        linear-gradient(rgba(105, 165, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(105, 165, 255, 0.05) 1px, transparent 1px);
      opacity: 0.22;
    }

    body.pwa-body {
      display: flex;
      justify-content: center;
      padding: 0;
      overscroll-behavior-y: none;
      touch-action: manipulation;
    }

    body.android-webview {
      background:
        linear-gradient(180deg, #f6faff 0%, #edf4ff 100%);
    }

    html[data-theme="dark"] body.android-webview,
    body[data-theme="dark"].android-webview {
      background:
        linear-gradient(180deg, #06111f 0%, #0c1628 100%);
      color: var(--app-text);
    }

    body.android-webview::before {
      opacity: 0.24;
    }

    .app-shell {
      position: relative;
      width: var(--shell-width);
      min-height: 100vh;
      min-height: 100dvh;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.78) 0%, rgba(248, 251, 255, 0.92) 100%);
      backdrop-filter: blur(18px);
      overflow: hidden;
      box-shadow: var(--app-shadow);
    }

    html[data-theme="dark"] .app-shell,
    body[data-theme="dark"] .app-shell {
      background: linear-gradient(180deg, rgba(7, 17, 31, 0.9) 0%, rgba(11, 23, 41, 0.96) 100%);
    }

    .app-shell::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(380px 180px at 50% -20%, rgba(47, 107, 255, 0.18), transparent 72%),
        radial-gradient(280px 180px at 90% 18%, rgba(80, 180, 255, 0.12), transparent 70%);
      pointer-events: none;
    }

    html[data-theme="dark"] .app-shell::before,
    body[data-theme="dark"] .app-shell::before {
      background:
        radial-gradient(380px 180px at 50% -20%, rgba(56, 126, 255, 0.2), transparent 72%),
        radial-gradient(280px 180px at 90% 18%, rgba(43, 177, 255, 0.12), transparent 70%);
    }

    .app-splash {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at 50% 22%, rgba(176, 214, 255, 0.7), rgba(176, 214, 255, 0) 42%),
        linear-gradient(180deg, #f8fbff 0%, #e9f1ff 100%);
      z-index: 1400;
      transition: opacity 0.35s ease, visibility 0.35s ease;
    }

    html[data-theme="dark"] .app-splash,
    body[data-theme="dark"] .app-splash {
      background:
        radial-gradient(circle at 50% 22%, rgba(74, 131, 255, 0.34), rgba(74, 131, 255, 0) 42%),
        linear-gradient(180deg, #081120 0%, #0d1729 100%);
    }

    .app-splash.is-hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .splash-card {
      width: min(82vw, 280px);
      padding: 22px 20px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(47, 107, 255, 0.12);
      box-shadow: 0 22px 44px rgba(44, 79, 146, 0.16);
      text-align: center;
    }

    .splash-logo {
      width: 60px;
      height: 60px;
      margin: 0 auto 14px;
      border-radius: 20px;
      background: linear-gradient(135deg, #073dcc 0%, #72a6ff 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 14px 24px rgba(47, 107, 255, 0.24);
    }

    .splash-logo img {
      width: 36px;
      height: 36px;
      object-fit: contain;
    }

    .splash-card h1 {
      margin: 0;
      font-size: 18px;
      font-weight: 800;
      letter-spacing:0;
    }

    .splash-card p {
      margin: 6px 0 14px;
      color: var(--app-text-soft);
      font-size: 12px;
    }

    .splash-progress {
      height: 8px;
      border-radius: 999px;
      background: rgba(47, 107, 255, 0.1);
      overflow: hidden;
    }

    .splash-progress span {
      display: block;
      height: 100%;
      width: 42%;
      border-radius: inherit;
      background: linear-gradient(90deg, #073dcc 0%, #7bb3ff 100%);
      animation: splashLoad 1.2s ease-in-out infinite;
    }

    @keyframes splashLoad {
      0% { transform: translateX(-115%); }
      100% { transform: translateX(250%); }
    }

    .app-topbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      padding: calc(env(safe-area-inset-top) + 4px) 14px 8px;
      background: linear-gradient(180deg, rgba(248, 251, 255, 0.94) 0%, rgba(248, 251, 255, 0.78) 100%);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(110, 140, 198, 0.12);
    }

    .topbar-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .header-menu,
    .brand-chip,
    .header-action {
      border: 0;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: 0 10px 22px rgba(54, 86, 152, 0.1);
      color: var(--app-text);
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
    }

    .brand-chip {
      flex: 1 1 auto;
      min-width: 0;
      max-width: 100%;
      min-height: 46px;
      padding: 7px 10px;
      gap: 9px;
    }

    .topbar-left,
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .topbar-left {
      flex: 1 1 auto;
      min-width: 0;
    }

    .topbar-right {
      flex: 0 0 auto;
    }

    .header-menu,
    .header-action {
      width: 38px;
      height: 38px;
      padding: 0;
      justify-content: center;
      font-size: 16px;
      flex: 0 0 auto;
    }

    .header-icon-wrap {
      position: relative;
      display: inline-flex;
    }

    .notif-badge {
      position: absolute;
      top: -3px;
      right: -3px;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #ff4d5f;
      color: #fff;
      font-size: 10px;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 18px rgba(242, 72, 91, 0.3);
      border: 2px solid #f8fbff;
    }

    .account-menu {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: min(220px, calc(100vw - 40px));
      padding: 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.97);
      border: 1px solid rgba(110, 140, 198, 0.16);
      box-shadow: 0 22px 40px rgba(44, 79, 146, 0.18);
      display: none;
      z-index: 1100;
    }

    html[data-theme="dark"] .app-topbar,
    body[data-theme="dark"] .app-topbar,
    html[data-theme="dark"] .brand-chip,
    body[data-theme="dark"] .brand-chip,
    html[data-theme="dark"] .header-action,
    body[data-theme="dark"] .header-action,
    html[data-theme="dark"] .page-title,
    body[data-theme="dark"] .page-title,
    html[data-theme="dark"] .account-menu,
    body[data-theme="dark"] .account-menu,
    html[data-theme="dark"] .app-menu-sheet,
    body[data-theme="dark"] .app-menu-sheet,
    html[data-theme="dark"] .app-menu-tile,
    body[data-theme="dark"] .app-menu-tile,
    html[data-theme="dark"] .quick-card,
    body[data-theme="dark"] .quick-card,
    html[data-theme="dark"] .content-card,
    body[data-theme="dark"] .content-card,
    html[data-theme="dark"] .traffic-panel,
    body[data-theme="dark"] .traffic-panel,
    html[data-theme="dark"] .traffic-period-item,
    body[data-theme="dark"] .traffic-period-item,
    html[data-theme="dark"] .app-bottom-nav,
    body[data-theme="dark"] .app-bottom-nav,
    html[data-theme="dark"] .modal-content.app-modal,
    body[data-theme="dark"] .modal-content.app-modal,
    html[data-theme="dark"] .billing-item,
    body[data-theme="dark"] .billing-item,
    html[data-theme="dark"] .profile-highlight,
    body[data-theme="dark"] .profile-highlight,
    html[data-theme="dark"] .portal-package-item,
    body[data-theme="dark"] .portal-package-item,
    html[data-theme="dark"] .notification-item,
    body[data-theme="dark"] .notification-item,
    html[data-theme="dark"] .notification-detail,
    body[data-theme="dark"] .notification-detail,
    html[data-theme="dark"] .speedtest-frame.light-embed,
    body[data-theme="dark"] .speedtest-frame.light-embed {
      background: var(--app-surface) !important;
      color: var(--app-text);
      border-color: var(--app-line) !important;
      box-shadow: none;
    }

    html[data-theme="dark"] .soft-muted,
    body[data-theme="dark"] .soft-muted,
    html[data-theme="dark"] .page-title small,
    body[data-theme="dark"] .page-title small,
    html[data-theme="dark"] .brand-meta span,
    body[data-theme="dark"] .brand-meta span,
    html[data-theme="dark"] .traffic-panel-title p,
    body[data-theme="dark"] .traffic-panel-title p,
    html[data-theme="dark"] .portal-package-desc,
    body[data-theme="dark"] .portal-package-desc,
    html[data-theme="dark"] .item-meta,
    body[data-theme="dark"] .item-meta,
    html[data-theme="dark"] .account-menu-head span,
    body[data-theme="dark"] .account-menu-head span {
      color: var(--app-text-soft) !important;
