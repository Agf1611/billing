    .settings-submit.secondary {
      background: rgba(47, 107, 255, 0.08);
      color: var(--app-blue);
      box-shadow: none;
    }

    .settings-submit.danger {
      background: rgba(242, 72, 91, 0.14);
      color: #c73345;
      box-shadow: none;
    }

    .settings-submit[disabled],
    .password-toggle-btn[disabled],
    .settings-field input[disabled],
    .settings-field textarea[disabled] {
      cursor: not-allowed;
      opacity: 0.58;
      filter: grayscale(0.15);
    }

    .stack-actions {
      display: grid;
      gap: 10px;
    }

    .package-upgrade-card {
      margin-top: 16px;
      padding: 14px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(104, 129, 182, 0.14);
      box-shadow: 0 16px 36px rgba(42, 74, 140, 0.1);
      display: grid;
      gap: 14px;
    }

    .package-upgrade-head {
      display: grid;
      gap: 10px;
    }

    .package-upgrade-head h4 {
      margin: 0;
      font-size: 17px;
      font-weight: 800;
      letter-spacing:0;
    }

    .package-upgrade-head p {
