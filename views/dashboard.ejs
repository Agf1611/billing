    .manual-payment-box {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(47, 107, 255, 0.08) 0%, rgba(47, 107, 255, 0.04) 100%);
      border: 1px solid rgba(47, 107, 255, 0.14);
      display: grid;
      gap: 10px;
    }

    .manual-payment-box h5 {
      margin: 0;
      font-size: 14px;
      font-weight: 800;
      letter-spacing:0;
    }

    .manual-payment-bank {
      font-size: 16px;
      font-weight: 800;
      color: var(--app-blue-deep);
    }

    .manual-payment-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .manual-payment-line {
      display: grid;
      gap: 4px;
      color: var(--app-text-soft);
      font-size: 12px;
      line-height: 1.5;
      font-weight: 700;
      min-width: 0;
