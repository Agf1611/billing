    }

    .settings-form-alert.danger {
      background: rgba(242, 72, 91, 0.1);
      border-color: rgba(242, 72, 91, 0.18);
      color: #c73345;
    }

    .settings-form-alert.warning {
      background: rgba(245, 158, 11, 0.12);
      border-color: rgba(245, 158, 11, 0.18);
      color: #a7660b;
    }

    .settings-inline-note {
