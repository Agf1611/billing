    .traffic-gauge {
      position: relative;
      width: 154px;
      height: 92px;
      overflow: hidden;
    }

    .traffic-gauge-arc {
      position: absolute;
      inset: 0;
      border: 12px solid #e8edf6;
      border-bottom: 0;
      border-radius: 154px 154px 0 0;
    }

    .traffic-gauge-needle {
      position: absolute;
      left: 50%;
      bottom: 0;
      width: 4px;
      height: 74px;
      transform-origin: center bottom;
      transform: translateX(-50%) rotate(var(--gauge-rotate, -90deg));
      transition: transform 0.35s ease;
    }

    .traffic-gauge-needle::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 10px;
      width: 3px;
      height: 58px;
      border-radius: 999px;
      background: #243042;
      transform: translateX(-50%);
      box-shadow: 0 0 0 1px rgba(36, 48, 66, 0.02);
    }

    .traffic-gauge-needle::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -1px;
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: #243042;
      transform: translateX(-50%);
    }

    .traffic-gauge-center {
      position: absolute;
      left: 50%;
      bottom: 8px;
      transform: translateX(-50%);
      min-width: 96px;
      padding: 12px 10px 10px;
