    async function fetchNotificationState() {
      try {
        const response = await fetch('/customer/api/notifications', {
          headers: { 'x-requested-with': 'fetch' }
        });
        const data = await response.json();
        if (!data || data.ok === false) return false;
        const incomingItems = Array.isArray(data.items) ? data.items : [];
        const incomingSignatures = incomingItems.map((item) => `${item.kind || 'system'}|${item.title || ''}|${item.body || ''}|${item.time || ''}`);
        const freshItems = incomingItems.filter((item) => {
          const signature = `${item.kind || 'system'}|${item.title || ''}|${item.body || ''}|${item.time || ''}`;
          return !knownNotificationSignatures.has(signature);
        });
        notificationState = {
          unreadCount: Math.max(0, Number(data.unreadCount || 0) || 0),
          items: incomingItems
        };
        knownNotificationSignatures = new Set(incomingSignatures);
        renderNotificationUI();
        if (freshItems.length) {
          showNotificationToast(freshItems);
          window.setTimeout(() => maybeAutoOpenLatestNotification('poll'), 150);
        }
        return true;
      } catch {
        return false;
      }
    }

    function scheduleNotificationPolling() {
      if (notificationPollTimer) {
        clearInterval(notificationPollTimer);
        notificationPollTimer = null;
      }
      fetchNotificationState();
      notificationPollTimer = window.setInterval(() => {
        if (document.hidden) return;
        fetchNotificationState();
      }, 45000);
    }

    async function markNotificationsRead() {
      if (!(Number(notificationState.unreadCount || 0) > 0)) return;
      try {
        await fetch('/customer/notifications/read', {
          method: 'POST',
          headers: { 'x-requested-with': 'fetch' }
        });
        notificationState = {
          ...notificationState,
          unreadCount: 0,
          items: (notificationState.items || []).map((item) => ({ ...item, unread: false }))
        };
        renderNotificationUI();
      } catch {}
    }

    async function deleteNotificationItem(notificationId, trigger = null) {
      const id = Number(notificationId || 0);
      if (!Number.isFinite(id) || id <= 0) return false;
      if (trigger) trigger.disabled = true;
      try {
        const response = await fetch(`/customer/notifications/${id}/delete`, {
          method: 'POST',
          headers: { 'x-requested-with': 'fetch' }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.error || 'Gagal menghapus pesan');
        notificationState = {
          unreadCount: 0,
          items: (notificationState.items || []).filter((item) => Number(item.sourceId || 0) !== id)
        };
        notificationState.unreadCount = notificationState.items.filter((item) => item.unread === true).length;
        knownNotificationSignatures = new Set((notificationState.items || []).map((item) => `${item.kind || 'system'}|${item.title || ''}|${item.body || ''}|${item.time || ''}`));
        renderNotificationUI();
        return true;
      } catch (error) {
        if (trigger) trigger.disabled = false;
        showNotificationToast([{ title: 'Gagal hapus pesan', body: error.message || 'Silakan coba lagi.' }]);
        return false;
      }
    }

