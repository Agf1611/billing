    .manual-payment-line strong {
      color: var(--app-text);
      min-width: 0;
      font-weight: 800;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .manual-payment-line span {
      word-break: break-word;
    }

    .manual-payment-line.full {
      grid-column: 1 / -1;
    }

    html[data-theme="dark"] :is(.business-card, .business-info-card, .manual-payment-box),
    body[data-theme="dark"] :is(.business-card, .business-info-card, .manual-payment-box) {
      background: rgba(17, 24, 39, 0.94) !important;
      border-color: var(--app-line) !important;
      color: var(--app-text) !important;
