      opacity: 0.7;
      filter: saturate(0.7);
    }

    .android-nav-wrap {
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: calc(8px + env(safe-area-inset-bottom));
      width: min(calc(100vw - 18px), 398px);
      z-index: 1100;
      transition: transform 0.24s ease, opacity 0.24s ease, visibility 0.24s ease;
    }

    body.modal-open .android-nav-wrap {
      opacity: 0;
      visibility: hidden;
      transform: translate(-50%, 24px);
      pointer-events: none;
    }

    .android-nav {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(64px, 1.18fr) minmax(0, 1fr) minmax(0, 1fr);
      gap: 5px;
      padding: 8px 9px 7px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(47, 107, 255, 0.08);
      box-shadow: 0 16px 34px rgba(54, 86, 152, 0.15);
      backdrop-filter: blur(16px);
    }

    .android-nav button {
      border: 0;
      min-width: 0;
      background: transparent;
      padding: 6px 3px 5px;
      border-radius: 17px;
      color: var(--app-text-soft);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      font-size: 9.5px;
      font-weight: 800;
      line-height: 1;
      transition: transform .18s ease, background .18s ease, color .18s ease;
    }

    .android-nav button i {
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: rgba(47, 107, 255, 0.06);
      font-size: 17px;
      line-height: 1;
    }

    .android-nav button.is-active {
      color: var(--app-blue);
      background: rgba(47, 107, 255, 0.1);
    }

    .android-nav button.is-main {
      margin-top: -18px;
      color: #fff;
      background: transparent;
    }

    .android-nav button.is-main i {
      width: 54px;
      height: 54px;
      border-radius: 22px;
      color: #fff;
      background: linear-gradient(135deg, #073dcc 0%, #5b8dff 58%, #1bb3a6 100%);
      box-shadow: 0 14px 28px rgba(47, 107, 255, 0.34);
      font-size: 25px;
    }

    .android-nav button.is-main span {
      margin-top: -1px;
      color: var(--app-blue-deep);
      font-size: 10px;
      font-weight: 900;
    }

    .android-nav button.is-main.is-active {
      background: transparent;
    }

    .modal-content.app-modal {
      border: 0;
      border-radius: 28px;
      overflow: hidden;
      background: linear-gradient(180deg, rgba(255,255,255,.98) 0%, rgba(238,243,255,.95) 100%);
      box-shadow: 0 28px 60px rgba(54, 86, 152, 0.20);
      border: 1px solid rgba(79, 110, 247, 0.10);
    }

    .app-modal .modal-header,
    .app-modal .modal-footer {
      border: 0;
      padding: 18px 18px 0;
      background: transparent;
    }

    .app-modal .modal-body {
      padding: 18px 18px 24px;
    }

    .app-modal .modal-title {
      font-weight: 900;
      letter-spacing:0;
    }

    .app-modal .btn-close {
      background-size: 12px;
      opacity: 0.65;
    }

    html[data-theme="dark"] .modal-content.app-modal,
    body[data-theme="dark"] .modal-content.app-modal {
      background: linear-gradient(180deg, rgba(17, 24, 39, 0.98) 0%, rgba(15, 23, 42, 0.96) 100%) !important;
      border-color: var(--app-line) !important;
      color: var(--app-text) !important;
      box-shadow: none;
    }

    .payment-modal-list {
      display: grid;
      gap: 12px;
    }

    .payment-method-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .payment-method-chip {
      padding: 7px 11px;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(79, 110, 247, 0.12), rgba(79, 110, 247, 0.07));
      border: 1px solid rgba(79, 110, 247, 0.14);
      color: var(--app-blue);
      font-size: 11px;
      font-weight: 800;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
    }

    .business-card {
      margin-top: 16px;
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(104, 129, 182, 0.14);
      box-shadow: 0 16px 36px rgba(42, 74, 140, 0.1);
      display: grid;
      gap: 14px;
    }

    .business-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .business-title {
      margin: 0;
      font-size: 18px;
      font-weight: 800;
      letter-spacing:0;
    }

    .business-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(47, 107, 255, 0.08);
      color: var(--app-blue);
      font-size: 11px;
      font-weight: 800;
