      color: var(--app-text-soft);
      font-size: 11px;
      line-height: 1.35;
      font-weight: 700;
    }

    .current-package-chip {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 9px 12px;
      border-radius: 16px;
      background: rgba(47, 107, 255, 0.08);
      color: var(--app-blue);
      font-size: 11px;
      font-weight: 800;
      width: 100%;
    }

    .portal-package-list {
      display: grid;
      gap: 12px;
    }

    .portal-package-item {
      padding: 13px;
      border-radius: 20px;
      border: 1px solid rgba(47, 107, 255, 0.12);
      background: linear-gradient(180deg, rgba(47, 107, 255, 0.06) 0%, rgba(255, 255, 255, 0.98) 100%);
      box-shadow: 0 12px 24px rgba(42, 74, 140, 0.08);
      display: grid;
      gap: 10px;
    }

