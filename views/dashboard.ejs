    function initPortalBannerSlider() {
      const slider = document.querySelector('[data-portal-banner-slider]');
      if (!slider) return;
      const track = slider.querySelector('.portal-banner-track');
      const slides = Array.from(slider.querySelectorAll('.portal-banner-slide'));
      const dots = Array.from(slider.querySelectorAll('[data-portal-banner-dot]'));
      if (!track || slides.length <= 1) return;
      let index = 0;
      const render = () => {
        track.style.transform = `translate3d(-${index * (100 / slides.length)}%, 0, 0)`;
        dots.forEach((dot, dotIndex) => dot.classList.toggle('active', dotIndex === index));
      };
      window.setInterval(() => {
        if (document.hidden) return;
        index = (index + 1) % slides.length;
        render();
      }, 4200);
    }

