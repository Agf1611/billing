    .profile-highlight {
      padding: 16px;
      border-radius: 22px;
      background: linear-gradient(135deg, rgba(47, 107, 255, 0.1), rgba(121, 179, 255, 0.08));
      border: 1px solid rgba(47, 107, 255, 0.1);
    }

    .profile-headline {
