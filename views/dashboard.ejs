              </div>
              <button class="profile-edit-toggle" type="button" id="profileEditToggle" aria-expanded="false" aria-controls="profileEditPanel" title="Ubah data">
                <i class="bi bi-pencil-square"></i>
              </button>
            </div>
            <div class="profile-data-note">
              <i class="bi bi-shield-check"></i> Perubahan data perlu approval admin
            </div>
          </div>

          <div class="section-head" style="margin-top:18px;">
            <h3>Data Pelanggan</h3>
            <span><%= customerIdLabel %></span>
          </div>

          <div class="detail-grid">
            <div class="detail-item">
              <i class="bi bi-person"></i>
              <div>
                <strong>Nama Pelanggan</strong>
                <span><%= customerName %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-phone"></i>
              <div>
                <strong>Nomor HP</strong>
                <span><%= customerPhone %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-person-vcard"></i>
              <div>
                <strong>NIK</strong>
                <span><%= customerNik || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-credit-card-2-front"></i>
              <div>
                <strong>ID Pelanggan</strong>
                <span><%= customerIdLabel %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-box-seam"></i>
              <div>
                <strong>Paket Layanan</strong>
                <span><%= packageName %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-diagram-3"></i>
              <div>
                <strong>ODP</strong>
                <span><%= customerOdp %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-calendar-check"></i>
              <div>
                <strong>Tanggal Pasang</strong>
                <span><%= formatDate(profileData.install_date) %></span>
              </div>
            </div>
            <div class="detail-item" style="grid-column:1 / -1;">
              <i class="bi bi-geo-alt"></i>
              <div>
                <strong>Alamat</strong>
                <span><%= customerAddress %></span>
              </div>
            </div>
          </div>

          <div class="settings-card profile-edit-panel" id="profileEditPanel" <%= (profileLocalNotif || activeProfileChangeRequest) ? '' : 'hidden' %>>
            <div class="billing-card-head">
              <div>
                <h4>Ubah Data Profil</h4>
                <div class="soft-muted">Nama, nomor HP, NIK, dan alamat.</div>
              </div>
            </div>
            <% if (activeProfileChangeRequest) { %>
              <div class="settings-form-alert warning" style="margin-bottom:12px;">
                <i class="bi bi-hourglass-split"></i>
                <span>Menunggu approval admin sejak <%= formatDateTime(activeProfileChangeRequest.requested_at || activeProfileChangeRequest.created_at) %>.</span>
              </div>
            <% } else if (latestProfileChangeRequest && ['approved','rejected'].includes(String(latestProfileChangeRequest.status || '').toLowerCase())) { %>
              <div class="settings-form-alert <%= String(latestProfileChangeRequest.status).toLowerCase() === 'approved' ? '' : 'danger' %>" style="margin-bottom:12px;">
                <i class="bi <%= String(latestProfileChangeRequest.status).toLowerCase() === 'approved' ? 'bi-check-circle-fill' : 'bi-x-circle-fill' %>"></i>
                <span><%= String(latestProfileChangeRequest.status).toLowerCase() === 'approved' ? 'Perubahan profil terakhir sudah disetujui.' : 'Perubahan profil terakhir ditolak.' %></span>
              </div>
            <% } %>
            <form class="settings-form" method="POST" action="/customer/profile/change">
              <div class="settings-field">
                <label for="profileNameField">Nama</label>
                <input id="profileNameField" type="text" name="name" value="<%= customerName %>" maxlength="120" required <%= activeProfileChangeRequest ? 'disabled' : '' %>>
              </div>
              <div class="settings-field">
                <label for="profilePhoneField">No HP</label>
                <input id="profilePhoneField" type="tel" name="phone" value="<%= customerPhone %>" maxlength="24" required <%= activeProfileChangeRequest ? 'disabled' : '' %>>
              </div>
              <div class="settings-field">
                <label for="profileNikField">NIK</label>
                <input id="profileNikField" type="text" name="nik" value="<%= customerNik %>" maxlength="32" inputmode="numeric" <%= activeProfileChangeRequest ? 'disabled' : '' %>>
              </div>
              <div class="settings-field">
                <label for="profileAddressField">Alamat</label>
                <textarea id="profileAddressField" name="address" rows="3" maxlength="260" required <%= activeProfileChangeRequest ? 'disabled' : '' %>><%= customerAddress %></textarea>
              </div>
              <button class="settings-submit" type="submit" <%= activeProfileChangeRequest ? 'disabled' : '' %>>
                <i class="bi bi-send-check"></i> Ajukan Perubahan
              </button>
              <% if (profileLocalNotif) { %>
                <div class="settings-form-alert <%= profileLocalNotif.type === 'danger' ? 'danger' : profileLocalNotif.type === 'warning' ? 'warning' : '' %>">
                  <i class="bi <%= profileLocalNotif.type === 'danger' ? 'bi-x-circle-fill' : profileLocalNotif.type === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-check-circle-fill' %>"></i>
                  <span><%= profileLocalNotif.text %></span>
                </div>
              <% } %>
            </form>
          </div>

        </div>
      </section>

      <section class="app-screen" data-tab="packages">
        <% 
          const packageRequestState = packageChangeState || {};
          const activePackageRequest = packageRequestState.activeRequest || null;
          const latestPackageRequest = packageRequestState.latestRequest || null;
          const canRequestPackageNow = Boolean(packageRequestState.canRequestNow) && !portalServiceActionLocked;
          const nextPackageEligibleText = packageRequestState.nextEligibleAtText || '';
          const packageRequestReason = portalServiceActionLocked ? portalServiceLockText : String(packageRequestState.reason || '').trim();
          const currentPortalPackageId = Number((packageRequestState.customer && packageRequestState.customer.package_id) || profileData.package_id || customerData.package_id || 0);
          const packageRequestStatusMap = {
            pending: 'Menunggu review admin',
            approved: 'Disetujui admin',
            scheduled: 'Terjadwal siklus berikutnya',
            processing: 'Sedang diproses sistem',
            completed: 'Selesai diterapkan',
            rejected: 'Ditolak admin',
            cancelled: 'Dibatalkan'
          };
          const packageRequestBadgeClass = (status) => {
            if (status === 'completed' || status === 'approved') return 'success';
            if (status === 'scheduled' || status === 'processing' || status === 'pending') return 'info';
            if (status === 'rejected' || status === 'cancelled') return 'danger';
            return 'warning';
          };
          const statusSourceRequest = activePackageRequest || latestPackageRequest || null;
          const statusTitle = portalServiceActionLocked
            ? 'Perubahan paket dikunci'
            : activePackageRequest
            ? 'Pengajuan perubahan paket sedang berjalan'
            : latestPackageRequest
              ? 'Status pengajuan paket terakhir'
              : 'Belum ada pengajuan aktif';
          const statusCopy = portalServiceActionLocked
            ? portalServiceLockText
            : activePackageRequest
            ? `Ke ${activePackageRequest.target_package_name || 'paket tujuan'}`
            : latestPackageRequest
              ? (canRequestPackageNow ? 'Bisa pilih paket baru' : `Bisa lagi ${nextPackageEligibleText || 'nanti'}`)
              : 'Pilih paket yang cocok.';
        %>
        <div class="package-upgrade-card" style="margin-top:0;">
          <div class="package-upgrade-head">
            <div>
              <h4>Pilihan Paket WiFi</h4>
              <p>Pilih paket baru, admin akan memproses pengajuannya.</p>
            </div>
            <div class="current-package-chip">
              <i class="bi bi-check2-circle"></i>
              Paket sekarang: <%= packageName %>
            </div>
          </div>

          <% if (portalServiceActionLocked || activePackageRequest || !canRequestPackageNow) { %>
          <div class="package-request-state">
            <div class="package-request-top">
              <div class="package-request-copy">
                <strong><%= statusTitle %></strong>
                <span><%= statusCopy %></span>
              </div>
              <% if (portalServiceActionLocked) { %>
                <span class="status-detail warning">
                  <i class="bi bi-lock"></i>
                  <%= portalAccountLabel %>
                </span>
              <% } else if (statusSourceRequest) { %>
                <span class="status-detail <%= packageRequestBadgeClass(String(statusSourceRequest.status || '').toLowerCase()) %>">
                  <i class="bi bi-arrow-repeat"></i>
                  <%= packageRequestStatusMap[String(statusSourceRequest.status || '').toLowerCase()] || String(statusSourceRequest.status || '').toUpperCase() %>
                </span>
              <% } else if (canRequestPackageNow) { %>
                <span class="status-detail success">
                  <i class="bi bi-check2-circle"></i>
                  Siap request
                </span>
              <% } else { %>
                <span class="status-detail warning">
                  <i class="bi bi-clock-history"></i>
                  Masa tunggu aktif
                </span>
              <% } %>
            </div>

            <% if (!portalServiceActionLocked && (activePackageRequest || !canRequestPackageNow)) { %>
            <div class="package-request-grid">
              <div class="package-request-cell">
                <span class="package-request-label">Paket Saat Ini</span>
                <span class="package-request-value"><%= packageName || '-' %></span>
              </div>
              <div class="package-request-cell">
                <span class="package-request-label">Bisa Request Lagi</span>
                <span class="package-request-value"><%= nextPackageEligibleText || (canRequestPackageNow ? 'Sekarang' : '-') %></span>
              </div>
              <div class="package-request-cell">
                <span class="package-request-label">Target Aktif / Terakhir</span>
                <span class="package-request-value"><%= statusSourceRequest?.target_package_name || '-' %></span>
              </div>
              <div class="package-request-cell">
                <span class="package-request-label">Mulai Berlaku</span>
                <span class="package-request-value"><%= statusSourceRequest?.effective_at ? new Date(statusSourceRequest.effective_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) : (activePackageRequest ? 'Menunggu penjadwalan' : '-') %></span>
              </div>
            </div>
            <% } %>

            <% if (packageRequestReason) { %>
              <div class="package-request-note">
                <strong>Catatan:</strong> <%= packageRequestReason %>
              </div>
            <% } %>
          </div>
          <% } %>

          <% if (!portalPackages || portalPackages.length === 0) { %>
            <div class="empty-card" style="margin:0;">
              <i class="bi bi-box-seam"></i>
              <strong>Belum ada paket lain yang dibuka</strong>
              <div>Admin belum menampilkan pilihan paket upgrade di portal pelanggan.</div>
            </div>
          <% } else { %>
            <div class="portal-package-list">
              <% portalPackages.forEach((pkg) => { %>
                <% 
                  const pkgId = Number(pkg.id || 0);
                  const isCurrentPackage = pkgId === currentPortalPackageId;
                  const isRequestedTarget = activePackageRequest && Number(activePackageRequest.target_package_id || 0) === pkgId;
                  const disableRequestButton = portalServiceActionLocked || isCurrentPackage || isRequestedTarget || !canRequestPackageNow;
                  const buttonLabel = isCurrentPackage
                    ? 'Paket Aktif'
                    : portalServiceActionLocked
                      ? 'Terkunci'
                    : isRequestedTarget
                      ? 'Menunggu'
                      : canRequestPackageNow
                        ? 'Pilih Paket'
                        : (nextPackageEligibleText ? `Tunggu ${nextPackageEligibleText}` : 'Belum Bisa');
                %>
                <div class="portal-package-item <%= disableRequestButton ? 'is-disabled' : '' %>">
                  <div class="portal-package-top">
                    <div>
                      <strong><%= pkg.name %></strong>
                      <div class="portal-package-desc"><%= pkg.description || 'Paket internet pelanggan dengan kecepatan stabil untuk kebutuhan harian.' %></div>
                    </div>
                    <div class="portal-package-price">
                      <strong><%= formatCurrency(pkg.price || 0) %></strong>
                      <span>/ bulan</span>
                    </div>
                  </div>
                  <div class="portal-package-meta">
                    <% if (Number(pkg.speed_down || 0) > 0 || Number(pkg.speed_up || 0) > 0) { %>
                      <span class="status-detail success">
                        <i class="bi bi-speedometer2"></i>
                        <%= Number(pkg.speed_down || 0) > 0 ? `${Math.round(Number(pkg.speed_down || 0) / 1000)} Mbps` : '-' %><%= Number(pkg.speed_up || 0) > 0 ? ` / ${Math.round(Number(pkg.speed_up || 0) / 1000)} Mbps` : '' %>
                      </span>
                    <% } %>
                    <% if (Number(pkg.include_ppn || 0) === 1 && Number(pkg.ppn_percent || 0) > 0) { %>
                      <span class="status-detail info">
                        <i class="bi bi-receipt-cutoff"></i>
                        Termasuk PPN <%= Number(pkg.ppn_percent || 0).toLocaleString('id-ID') %>%
                      </span>
                    <% } %>
                  </div>
                  <form class="portal-package-form" method="POST" action="/customer/packages/change" onsubmit="return confirm('Kirim pengajuan perubahan paket ini?');">
                    <input type="hidden" name="package_id" value="<%= pkgId %>">
                    <button class="settings-submit" type="submit" <%= disableRequestButton ? 'disabled' : '' %>>
                      <i class="bi bi-arrow-repeat"></i> <%= buttonLabel %>
                    </button>
                  </form>
                  <% if (disableRequestButton && !isCurrentPackage) { %>
                    <div class="portal-package-action-note">
                      <%= isRequestedTarget ? 'Request ke paket ini masih aktif.' : (packageRequestReason || 'Anda belum bisa membuat request baru saat ini.') %>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>

      <section class="app-screen" data-tab="settings">
        <div class="settings-card">
          <div class="billing-card-head">
            <div>
              <h4>Router & WiFi</h4>
              <div class="soft-muted">Informasi penting WiFi pelanggan dan perangkat yang sedang terhubung.</div>
            </div>
          </div>

          <div class="detail-grid router-detail-grid" style="margin-bottom:16px;">
            <div class="detail-item">
              <i class="bi bi-wifi"></i>
              <div>
                <strong>Status Internet</strong>
                <span><%= isPppoeOnline ? 'Online' : (customerData.pppoeStatusText || customerData.status || 'Belum terbaca') %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-router"></i>
              <div>
                <strong>Router / ONU</strong>
                <span><%= routerDisplayName %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-broadcast-pin"></i>
              <div>
                <strong>Nama WiFi (SSID)</strong>
                <span><%= customerData.ssid || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-reception-4"></i>
              <div>
                <strong>RX Power</strong>
                <span><%= customerData.rxPower || '-' %></span>
              </div>
            </div>
            <div class="detail-item">
              <i class="bi bi-phone"></i>
              <div>
                <strong>Perangkat Terdeteksi</strong>
                <span><%= usersOnline.length %> online dari <%= connectedDeviceCount %> perangkat</span>
              </div>
            </div>
          </div>

          <div class="settings-grid">
            <form class="settings-form" method="POST" action="/customer/change-ssid">
              <div class="settings-field">
                <label for="ssidField">Nama WiFi (SSID)</label>
                <input id="ssidField" type="text" name="ssid" value="<%= customerData.ssid && customerData.ssid !== '-' ? customerData.ssid : '' %>" placeholder="Contoh: Rumah-Huda-WiFi" required <%= portalServiceActionLocked ? 'disabled' : '' %>>
              </div>
              <button class="settings-submit" type="submit" <%= portalServiceActionLocked ? 'disabled' : '' %>>
                <i class="bi bi-broadcast-pin"></i> Simpan SSID
              </button>
              <% if (settingsLocalNotif && settingsLocalNotif.target === 'ssid') { %>
                <div class="settings-form-alert <%= settingsLocalNotif.type === 'danger' ? 'danger' : settingsLocalNotif.type === 'warning' ? 'warning' : '' %>">
                  <i class="bi <%= settingsLocalNotif.type === 'danger' ? 'bi-x-circle-fill' : settingsLocalNotif.type === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-check-circle-fill' %>"></i>
                  <span><%= settingsLocalNotif.text %></span>
                </div>
              <% } %>
            </form>

            <form class="settings-form" method="POST" action="/customer/change-password">
              <div class="settings-field">
                <label for="wifiPasswordField">Password WiFi Baru</label>
                <div class="password-input-wrap">
                  <input id="wifiPasswordField" type="password" name="password" placeholder="Minimal 8 karakter" minlength="8" required <%= portalServiceActionLocked ? 'disabled' : '' %>>
                  <button class="password-toggle-btn" type="button" aria-label="Lihat password" onclick="togglePasswordVisibility('wifiPasswordField', this)" <%= portalServiceActionLocked ? 'disabled' : '' %>>
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                <div class="settings-field-note">Jika password belum berubah di perangkat setelah disimpan, coba restart modem / router Anda.</div>
              </div>
              <button class="settings-submit" type="submit" <%= portalServiceActionLocked ? 'disabled' : '' %>>
                <i class="bi bi-shield-lock"></i> Update Password
              </button>
              <% if (settingsLocalNotif && settingsLocalNotif.target === 'password') { %>
                <div class="settings-form-alert <%= settingsLocalNotif.type === 'danger' ? 'danger' : settingsLocalNotif.type === 'warning' ? 'warning' : '' %>">
                  <i class="bi <%= settingsLocalNotif.type === 'danger' ? 'bi-x-circle-fill' : settingsLocalNotif.type === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-check-circle-fill' %>"></i>
                  <span><%= settingsLocalNotif.text %></span>
                </div>
              <% } %>
            </form>
          </div>

          <div class="stack-actions" style="margin-top:14px;">
            <form method="POST" action="/customer/reboot" onsubmit="return confirm('Reboot perangkat pelanggan sekarang?')">
              <button class="settings-submit secondary" type="submit" style="width:100%;" <%= portalServiceActionLocked ? 'disabled' : '' %>>
                <i class="bi bi-arrow-repeat"></i> Reboot Perangkat
              </button>
            </form>
          </div>

          <div class="settings-inline-note">
            <%= portalServiceActionLocked ? portalServiceLockText : 'Untuk keamanan, akun PPPoE, IP internet, dan serial perangkat tidak ditampilkan di aplikasi pelanggan.' %>
          </div>
        </div>

        <div class="settings-card" style="margin-top:16px;">
          <div class="billing-card-head">
            <div>
              <h4>Perangkat Terkoneksi</h4>
              <div class="soft-muted">Perangkat yang terbaca dari router / ONU.</div>
            </div>
          </div>

          <% if (!connectedUsers || connectedUsers.length === 0) { %>
            <div class="empty-card">
              <i class="bi bi-router"></i>
              <strong>Belum ada perangkat terbaca</strong>
              <div>Jika GenieACS / ONU belum mengirim inform lengkap, daftar perangkat akan muncul setelah sinkron.</div>
            </div>
          <% } else { %>
            <div class="device-list">
              <% connectedUsers.forEach((user) => { %>
                <div class="device-item">
                  <i class="bi bi-phone"></i>
                  <div>
                    <strong><%= user.hostname || 'Unknown Device' %></strong>
                    <span><%= user.iface || 'Perangkat WiFi pelanggan' %></span>
                    <div class="ticket-meta">
                      <span class="status-dot <%= String(user.status || '').toLowerCase() === 'online' ? 'closed' : 'pending' %>">
                        <i class="bi <%= String(user.status || '').toLowerCase() === 'online' ? 'bi-wifi' : 'bi-wifi-off' %>"></i>
                        <%= user.status || 'Unknown' %>
                      </span>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="settings-card" style="margin-top:16px;">
          <div class="billing-card-head">
            <div>
              <h4>Aksi Router</h4>
              <div class="soft-muted">Bantuan cepat untuk akun pelanggan dan akses kontak admin.</div>
            </div>
          </div>

          <div class="stack-actions">
            <a class="settings-submit secondary" href="<%= supportUrl %>" target="_blank" rel="noopener" style="text-decoration:none;">
              <i class="bi bi-headset"></i> Hubungi Admin
            </a>

            <form method="POST" action="/customer/logout">
              <button class="settings-submit danger" type="submit" style="width:100%;">
                <i class="bi bi-box-arrow-right"></i> Keluar dari Aplikasi
              </button>
            </form>
          </div>
        </div>
      </section>
    </main>
  </div>

  <nav class="android-nav-wrap" aria-label="Navigasi bawah">
    <div class="android-nav">
      <button type="button" data-nav-tab="billing">
        <i class="bi bi-wallet2"></i>
        <span>Tagihan</span>
      </button>
      <button type="button" data-nav-tab="settings">
        <i class="bi bi-router"></i>
        <span>Router</span>
      </button>
      <button type="button" data-nav-tab="home" class="is-active is-main">
        <i class="bi bi-house-heart-fill"></i>
        <span>Dashboard</span>
      </button>
      <button type="button" data-nav-tab="ticketing">
        <i class="bi bi-headset"></i>
        <span>Bantuan</span>
      </button>
      <button type="button" data-nav-tab="profile">
        <i class="bi bi-person"></i>
        <span>Akun</span>
      </button>
    </div>
  </nav>

  <form id="quickRebootForm" method="POST" action="/customer/reboot" class="d-none"></form>

  <div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content app-modal">
        <div class="modal-header">
          <div>
            <h5 class="modal-title mb-1">Bayar Tagihan</h5>
            <div class="soft-muted">Pilih invoice yang ingin dibayar sekarang.</div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
        </div>
        <div class="modal-body">
          <% if (unpaidInvoices.length === 0) { %>
            <div class="empty-card">
              <i class="bi bi-check-circle"></i>
              <strong>Tidak ada tagihan aktif</strong>
              <div>Semua tagihan pelanggan sudah lunas.</div>
            </div>
          <% } else { %>
            <div class="payment-modal-list">
              <% unpaidInvoices.forEach((inv) => { %>
                <div class="billing-item">
                  <div class="item-text">
                    <strong>INV-<%= inv.id %></strong>
                    <p><%= monthNames[Number(inv.period_month)] || inv.period_month %> <%= inv.period_year %> • <%= formatCurrency(inv.amount) %></p>
                  </div>
                  <div class="item-meta">
                    <a class="pay-action" href="/customer/payment/select/<%= inv.id %>">
                      <i class="bi bi-wallet2"></i> Pilih Metode
                    </a>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="ticketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content app-modal">
        <div class="modal-header">
          <div>
            <h5 class="modal-title mb-1">Buat Tiket Baru</h5>
            <div class="soft-muted">Jelaskan kendala dengan singkat dan jelas.</div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
        </div>
        <div class="modal-body">
          <form class="settings-form" method="POST" action="/customer/tickets/create">
            <input type="hidden" name="customerId" value="<%= profileData.id || '' %>">
            <div class="settings-field">
              <label for="ticketSubject">Judul Keluhan</label>
              <input id="ticketSubject" type="text" name="subject" placeholder="Contoh: Internet putus sejak pagi" required>
            </div>
            <div class="settings-field">
              <label for="ticketMessage">Detail Keluhan</label>
              <textarea id="ticketMessage" name="message" rows="5" placeholder="Tuliskan kronologi, jam kejadian, dan gejala yang Anda rasakan." required></textarea>
            </div>
            <button class="settings-submit" type="submit">
              <i class="bi bi-send"></i> Kirim Tiket
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="notificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content app-modal">
        <div class="modal-header">
          <div>
            <h5 class="modal-title mb-1">Inbox</h5>
            <div class="soft-muted" id="notificationModalHint"><%= notificationUnread %> pesan perlu dibaca</div>
          </div>
          <button type="button" class="notification-header-action" id="markAllNotificationsBtn" onclick="markNotificationsRead()">
            <i class="bi bi-check2-all"></i> Tandai dibaca
          </button>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
        </div>
        <div class="modal-body">
          <div id="notificationModalBodyContent">
          <% if (!notificationItems.length) { %>
            <div class="empty-card">
              <i class="bi bi-bell-slash"></i>
              <strong>Belum ada pesan</strong>
              <div>Info tagihan dan update tiket akan muncul di sini.</div>
            </div>
          <% } else { %>
            <%
              const notificationGroups = {
                announcement: notificationItems.filter((item) => item.kind === 'announcement').length,
                offline: notificationItems.filter((item) => item.kind === 'wifi-offline' || item.kind === 'suspension').length,
                password: notificationItems.filter((item) => item.kind === 'password').length,
                billing: notificationItems.filter((item) => item.kind === 'invoice' || item.kind === 'ticket').length
              };
              function notificationKindLabel(kind) {
                if (kind === 'announcement') return 'Pengumuman';
                if (kind === 'password') return 'Password';
                if (kind === 'wifi-offline') return 'Offline';
                if (kind === 'suspension') return 'Isolir';
                if (kind === 'reactivation') return 'Aktif';
                if (kind === 'invoice' || kind === 'due-reminder') return 'Tagihan';
                if (kind === 'ticket') return 'Tiket';
                return 'Info';
              }
            %>
            <div class="notification-filter-row" id="notificationFilterRow">
              <button type="button" class="notification-filter-chip is-active" data-notification-filter="all"><i class="bi bi-grid"></i> Semua</button>
              <button type="button" class="notification-filter-chip" data-notification-filter="billing"><i class="bi bi-receipt-cutoff"></i> Tagihan</button>
              <button type="button" class="notification-filter-chip" data-notification-filter="ticket"><i class="bi bi-life-preserver"></i> Tiket</button>
              <button type="button" class="notification-filter-chip" data-notification-filter="offline"><i class="bi bi-wifi-off"></i> Status</button>
              <button type="button" class="notification-filter-chip" data-notification-filter="announcement"><i class="bi bi-megaphone"></i> Info</button>
            </div>
            <div class="notification-summary-grid">
              <div class="notification-summary-card kind-announcement">
                <small>Pengumuman</small>
                <strong><%= notificationGroups.announcement %></strong>
                <span>Update dan info terbaru dari admin.</span>
              </div>
              <div class="notification-summary-card kind-offline">
                <small>Offline / Isolir</small>
                <strong><%= notificationGroups.offline %></strong>
                <span>Perlu cek koneksi atau status layanan.</span>
              </div>
              <div class="notification-summary-card kind-password">
                <small>Password</small>
                <strong><%= notificationGroups.password %></strong>
                <span>Riwayat perubahan password WiFi.</span>
              </div>
              <div class="notification-summary-card kind-billing">
                <small>Tagihan / Tiket</small>
                <strong><%= notificationGroups.billing %></strong>
                <span>Tagihan jatuh tempo dan update bantuan.</span>
              </div>
            </div>
            <div class="notification-list">
              <% notificationItems.forEach((item) => { %>
                <button type="button" class="notification-item kind-<%= item.kind || 'system' %> <%= item.unread ? 'unread' : '' %>" onclick='goToNotification(<%- JSON.stringify(item.tab || "home") %>)'>
                  <span class="notification-icon">
                    <i class="bi <%= item.kind === 'invoice' || item.kind === 'due-reminder' ? 'bi-receipt-cutoff' : item.kind === 'ticket' ? 'bi-life-preserver' : item.kind === 'announcement' ? 'bi-megaphone' : item.kind === 'password' ? 'bi-shield-lock' : item.kind === 'wifi-offline' ? 'bi-wifi-off' : item.kind === 'suspension' ? 'bi-pause-circle' : item.kind === 'reactivation' ? 'bi-check-circle' : 'bi-info-circle' %>"></i>
                  </span>
                  <div class="notification-content">
                    <div class="notification-topline">
                      <span class="notification-kind-badge kind-<%= item.kind || 'system' %>"><%= notificationKindLabel(item.kind) %></span>
                      <span class="notification-time"><%= formatDateTime(item.time) %></span>
                    </div>
                    <strong><%= item.title %></strong>
                    <p><%= item.body %></p>
                  </div>
                  <span class="notification-arrow"><i class="bi bi-chevron-right"></i></span>
                </button>
              <% }) %>
            </div>
          <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="app-notification-toast-wrap" aria-live="polite" aria-atomic="true">
    <div class="app-notification-toast" id="appNotificationToast">
      <i class="bi bi-bell-fill"></i>
      <div>
        <strong id="appNotificationToastTitle">Notifikasi baru</strong>
        <span id="appNotificationToastBody">Info terbaru akan tampil di sini.</span>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const INITIAL_NOTIFICATION_UNREAD = <%- JSON.stringify(notificationUnread) %>;
    const INITIAL_NOTIFICATION_ITEMS = <%- JSON.stringify(notificationItems) %>;
    const CUSTOMER_PORTAL_ID = <%- JSON.stringify(profileData.id || '') %>;
    const NOTIFICATION_AUTO_POPUP_KEY = `customer-latest-inbox-popup:${CUSTOMER_PORTAL_ID || 'guest'}`;
    let notificationState = {
      unreadCount: Number(INITIAL_NOTIFICATION_UNREAD || 0) || 0,
      items: Array.isArray(INITIAL_NOTIFICATION_ITEMS) ? INITIAL_NOTIFICATION_ITEMS : []
    };
    let notificationFilter = 'all';
    let notificationAutoPopupBusy = false;
    let notificationPollTimer = null;
    let notificationToastTimer = null;
    let knownNotificationSignatures = new Set((notificationState.items || []).map((item) => `${item.kind || 'system'}|${item.title || ''}|${item.body || ''}|${item.time || ''}`));
    const PUSH_FEATURE_ENABLED = <%- JSON.stringify(pushFeatureEnabled) %>;
    const ONESIGNAL_APP_ID = <%- JSON.stringify(oneSignalAppId) %>;
    const CUSTOMER_PUSH_EXTERNAL_ID = <%- JSON.stringify(customerPushExternalId) %>;
    const ONESIGNAL_WEB_SDK_URL = 'https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js';
    const TAB_META = {
      home: { eyebrow: 'Halaman Utama', title: 'Dashboard Pelanggan' },
      billing: { eyebrow: 'Pembayaran', title: 'Tagihan & Riwayat' },
      traffic: { eyebrow: 'Statistik', title: 'Statistik Penggunaan' },
      packages: { eyebrow: 'Paket WiFi', title: 'Pilih Paket Internet' },
      speedtest: { eyebrow: 'Tes Speed', title: 'Tes Speed Internet' },
      ticketing: { eyebrow: 'Bantuan', title: 'Bantuan & Tiket' },
      profile: { eyebrow: 'Profil', title: 'Profil Pelanggan' },
      settings: { eyebrow: 'Router', title: 'Router & WiFi' }
    };

    const LEGACY_HASH_MAP = {
      '#home-section': 'home',
      '#traffic-section': 'traffic',
      '#speedtest-section': 'speedtest',
      '#ticket-section': 'ticketing',
      '#profile-section': 'profile',
      '#activity-section': 'home',
      '#settings-section': 'settings',
      '#router-section': 'settings'
    };

    let paymentModal = null;
    let ticketModal = null;
    let notificationModal = null;
    let trafficTimer = null;
    const trafficHistory = {
      rx: Array(8).fill(0),
      tx: Array(8).fill(0)
    };
    const LIVE_CAPS = {
      rx: <%- JSON.stringify(liveDownloadCap) %>,
      tx: <%- JSON.stringify(liveUploadCap) %>
    };

    function applyPortalTheme(theme, persist = true) {
      const nextTheme = theme === 'dark' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', nextTheme);
      document.body?.setAttribute('data-theme', nextTheme);
      const themeMeta = document.querySelector('meta[name="theme-color"]');
      if (themeMeta) {
        themeMeta.setAttribute('content', nextTheme === 'dark' ? '#0b1628' : '#073dcc');
      }
      const themeIcon = document.getElementById('portalThemeToggleIcon');
      const themeButton = document.getElementById('portalThemeToggle');
      if (themeIcon) {
        themeIcon.className = `bi ${nextTheme === 'dark' ? 'bi-sun-fill' : 'bi-moon-stars'}`;
      }
      if (themeButton) {
        const label = nextTheme === 'dark' ? 'Pakai mode terang' : 'Pakai mode gelap';
        themeButton.setAttribute('title', label);
        themeButton.setAttribute('aria-label', label);
      }
      if (persist) {
        try {
          localStorage.setItem('customer-portal-theme', nextTheme);
        } catch (_) {}
      }
      return nextTheme;
    }

    function getPortalTheme() {
      return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    }

    function togglePortalTheme() {
      const nextTheme = getPortalTheme() === 'dark' ? 'light' : 'dark';
      applyPortalTheme(nextTheme, true);
    }

    function initProfileEditPanel() {
      const toggle = document.getElementById('profileEditToggle');
      const panel = document.getElementById('profileEditPanel');
      if (!toggle || !panel) return;
      const sync = () => {
        const open = !panel.hasAttribute('hidden');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        const icon = toggle.querySelector('i');
        if (icon) icon.className = `bi ${open ? 'bi-x-lg' : 'bi-pencil-square'}`;
      };
      toggle.addEventListener('click', () => {
        if (panel.hasAttribute('hidden')) {
          panel.removeAttribute('hidden');
          window.setTimeout(() => {
            const firstInput = panel.querySelector('input:not([disabled]), textarea:not([disabled])');
            firstInput?.focus({ preventScroll: true });
          }, 60);
        } else {
          panel.setAttribute('hidden', '');
        }
        sync();
      });
      sync();
    }

    function setPushStatus(message) {
      document.querySelectorAll('[data-push-status-text]').forEach((node) => {
        node.textContent = message;
      });
    }

    function setPushActionState(isActive) {
      document.querySelectorAll('[data-push-subscribe-button]').forEach((button) => {
        button.classList.toggle('is-active', Boolean(isActive));
        button.disabled = Boolean(isActive);
        const label = button.querySelector('[data-push-subscribe-label]');
        const icon = button.querySelector('i');
        if (label) label.textContent = isActive ? 'Notifikasi Aktif' : 'Aktifkan Notifikasi';
        if (icon) icon.className = `bi ${isActive ? 'bi-bell-fill' : 'bi-bell'}`;
      });
    }

    function isSecurePushOrigin() {
      if (window.isSecureContext) return true;
      return ['localhost', '127.0.0.1', '::1'].includes(String(window.location.hostname || '').trim().toLowerCase());
    }

    function isOneSignalOptedIn(OneSignal) {
      const permission = OneSignal?.Notifications?.permission;
      const browserPermission = ('Notification' in window) ? (Notification.permission || 'default') : 'unsupported';
      return Boolean(
        OneSignal?.User?.PushSubscription?.optedIn === true ||
        permission === true ||
        permission === 'granted' ||
        browserPermission === 'granted'
      );
    }

    function buildOneSignalInfo(OneSignal) {
      return {
        subscription: {
          optedIn: isOneSignalOptedIn(OneSignal),
          id: OneSignal?.User?.PushSubscription?.id || '',
          token: OneSignal?.User?.PushSubscription?.token || ''
        }
      };
    }

    function loadOneSignalPageSdk() {
      if (window.OneSignal || document.querySelector('script[data-onesignal-web-sdk="true"]')) {
        return Promise.resolve();
      }
      return new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = ONESIGNAL_WEB_SDK_URL;
        script.async = true;
        script.defer = true;
        script.dataset.onesignalWebSdk = 'true';
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Gagal memuat SDK OneSignal'));
        document.head.appendChild(script);
      });
    }

    let oneSignalBridgePromise = null;
    async function ensureCustomerPushBridge() {
      if (!PUSH_FEATURE_ENABLED || !ONESIGNAL_APP_ID) return null;
      if (window.median?.onesignal) return window.median.onesignal;
      if (!isSecurePushOrigin()) return null;
      if (oneSignalBridgePromise) return oneSignalBridgePromise;

      oneSignalBridgePromise = (async () => {
        window.OneSignalDeferred = window.OneSignalDeferred || [];
        await loadOneSignalPageSdk();

        const OneSignal = await new Promise((resolve, reject) => {
          window.OneSignalDeferred.push(async (OneSignalInstance) => {
            try {
              if (!window.__CUSTOMER_ONESIGNAL_DIRECT_INITIALIZED) {
                window.__CUSTOMER_ONESIGNAL_INIT_PROMISE = window.__CUSTOMER_ONESIGNAL_INIT_PROMISE || (async function () {
                  await OneSignalInstance.init({
                    appId: ONESIGNAL_APP_ID,
                    notifyButton: { enable: false },
                    allowLocalhostAsSecureOrigin: true,
                    serviceWorkerPath: '/OneSignalSDKWorker.js',
                    serviceWorkerUpdaterPath: '/OneSignalSDKUpdaterWorker.js',
                    serviceWorkerParam: { scope: '/' },
                    autoResubscribe: true
                  });
                  window.__CUSTOMER_ONESIGNAL_DIRECT_INITIALIZED = true;
                  return OneSignalInstance;
                })();
              }
              if (window.__CUSTOMER_ONESIGNAL_INIT_PROMISE) {
                await window.__CUSTOMER_ONESIGNAL_INIT_PROMISE;
              }
              resolve(OneSignalInstance);
            } catch (error) {
              reject(error);
            }
          });
        });

        const bridge = {
          async login(externalId) {
            if (externalId && typeof OneSignal.login === 'function') {
              await OneSignal.login(String(externalId));
            }
            return buildOneSignalInfo(OneSignal);
          },
          async info() {
            return buildOneSignalInfo(OneSignal);
          },
          async register() {
            if (OneSignal?.Notifications?.requestPermission) {
              await OneSignal.Notifications.requestPermission();
            }
            if (OneSignal?.User?.PushSubscription?.optIn) {
              await OneSignal.User.PushSubscription.optIn();
            }
            return buildOneSignalInfo(OneSignal);
          },
          async logout() {
            if (typeof OneSignal.logout === 'function') {
              await OneSignal.logout();
            }
            return true;
          },
          userPrivacyConsent: {
            async grant() {
              if (typeof OneSignal.setConsentGiven === 'function') {
                OneSignal.setConsentGiven(true);
              }
              return true;
            }
          }
        };

        window.median = window.median || {};
        window.median.onesignal = bridge;
        return bridge;
      })().catch((error) => {
        console.warn('OneSignal web bridge gagal dipasang:', error);
        oneSignalBridgePromise = null;
        return null;
      });

      return oneSignalBridgePromise;
    }

    async function syncCustomerPushIdentity() {
      if (!PUSH_FEATURE_ENABLED || !CUSTOMER_PUSH_EXTERNAL_ID) return null;
      const pushBridge = await ensureCustomerPushBridge();
      if (!pushBridge?.login) return null;
      try {
        await pushBridge.login(CUSTOMER_PUSH_EXTERNAL_ID);
        if (pushBridge.info) {
          return await pushBridge.info();
        }
      } catch (error) {
        console.warn('OneSignal sync gagal:', error);
      }
      return null;
    }

    async function refreshCustomerPushStatus() {
      if (!PUSH_FEATURE_ENABLED) {
        setPushStatus('Belum diaktifkan oleh admin');
        return null;
      }
      const pushBridge = await ensureCustomerPushBridge();
      if (!pushBridge) {
        setPushStatus('Aktif jika dibuka lewat browser HTTPS / aplikasi');
        return null;
      }
      const info = await syncCustomerPushIdentity();
      const optedIn = Boolean(info?.subscription?.optedIn);
      setPushStatus(optedIn ? 'Sudah aktif di aplikasi ini' : 'Belum diizinkan di aplikasi ini');
      setPushActionState(optedIn);
      return info;
    }

    async function enableCustomerPushNotifications() {
      if (!PUSH_FEATURE_ENABLED) {
        alert('Notifikasi aplikasi belum diaktifkan oleh admin.');
        return;
      }
      const pushBridge = await ensureCustomerPushBridge();
      if (!pushBridge) {
        alert('Push notifikasi hanya bisa diaktifkan dari browser HTTPS, PWA, atau aplikasi yang mendukung OneSignal.');
        return;
      }
      setPushStatus('Meminta izin notifikasi...');
      setPushActionState(false);
      try {
        if (pushBridge.userPrivacyConsent?.grant) {
          await pushBridge.userPrivacyConsent.grant();
        }
      } catch (_) {}
      try {
        await syncCustomerPushIdentity();
        if (pushBridge.register) {
          await pushBridge.register();
        }
        const info = await refreshCustomerPushStatus();
        if (info?.subscription?.optedIn) {
          alert('Notifikasi aplikasi berhasil diaktifkan.');
        } else {
          alert('Izin notifikasi belum aktif. Silakan cek pengaturan aplikasi di HP.');
        }
      } catch (error) {
        setPushStatus('Gagal mengaktifkan notifikasi');
        alert('Gagal mengaktifkan notifikasi: ' + (error?.message || error));
      }
    }

    function getTabFromHash() {
      const rawHash = String(window.location.hash || '').trim().toLowerCase();
      if (!rawHash) return 'home';
      if (LEGACY_HASH_MAP[rawHash]) return LEGACY_HASH_MAP[rawHash];
      const clean = rawHash.replace('#', '');
      return TAB_META[clean] ? clean : 'home';
    }

    function updateHeader(tabName) {
      const meta = TAB_META[tabName] || TAB_META.home;
      const eyebrow = document.getElementById('appHeaderEyebrow');
      const title = document.getElementById('appHeaderTitle');
      if (eyebrow) eyebrow.textContent = meta.eyebrow;
      if (title) title.textContent = meta.title;
    }

    function openAppTab(tabName, updateHash = true) {
      let nextTab = TAB_META[tabName] ? tabName : 'home';
      closeAppMenu();
      closeAccountMenu();
      document.querySelectorAll('.app-screen').forEach((screen) => {
        screen.classList.toggle('is-active', screen.dataset.tab === nextTab);
      });
      document.querySelectorAll('[data-nav-tab]').forEach((button) => {
        button.classList.toggle('is-active', button.dataset.navTab === nextTab);
      });
      updateHeader(nextTab);
      if (updateHash) {
        const nextHash = `#${nextTab}`;
        if (window.location.hash !== nextHash) {
          history.replaceState(null, '', nextHash);
        }
      }
      scheduleTrafficRefresh(nextTab);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function openPaymentModal() {
      if (!paymentModal) return;
      paymentModal.show();
    }

    function openTicketModal() {
      if (!ticketModal) return;
      ticketModal.show();
    }

    function toggleAccountMenu(forceOpen = null) {
      closeAppMenu();
      const menu = document.getElementById('accountMenu');
      if (!menu) return;
      const shouldOpen = forceOpen === null ? !menu.classList.contains('is-open') : Boolean(forceOpen);
      menu.classList.toggle('is-open', shouldOpen);
    }

    function closeAccountMenu() {
      toggleAccountMenu(false);
    }

    function toggleAppMenu(forceOpen = null) {
      closeAccountMenu();
      const backdrop = document.getElementById('appMenuBackdrop');
      const sheet = document.getElementById('appMenuSheet');
      if (!backdrop || !sheet) return;
      const shouldOpen = forceOpen === null ? !sheet.classList.contains('is-open') : Boolean(forceOpen);
      backdrop.classList.toggle('is-open', shouldOpen);
      sheet.classList.toggle('is-open', shouldOpen);
      sheet.setAttribute('aria-hidden', shouldOpen ? 'false' : 'true');
    }

    function closeAppMenu() {
      const backdrop = document.getElementById('appMenuBackdrop');
      const sheet = document.getElementById('appMenuSheet');
      backdrop?.classList.remove('is-open');
      sheet?.classList.remove('is-open');
      sheet?.setAttribute('aria-hidden', 'true');
    }

    function escapeNotificationHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatDateTime(value) {
      if (!value) return '-';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return String(value);
      return date.toLocaleString('id-ID', {
        timeZone: 'Asia/Jakarta',
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    function notificationKindLabel(kind) {
      if (kind === 'announcement') return 'Pengumuman';
      if (kind === 'password') return 'Password';
      if (kind === 'wifi-offline') return 'Offline';
      if (kind === 'suspension') return 'Isolir';
      if (kind === 'reactivation') return 'Aktif';
      if (kind === 'invoice' || kind === 'due-reminder') return 'Tagihan';
      if (kind === 'ticket') return 'Tiket';
      return 'Info';
    }

    function notificationKindIcon(kind) {
      if (kind === 'invoice' || kind === 'due-reminder') return 'bi-receipt-cutoff';
      if (kind === 'ticket') return 'bi-life-preserver';
      if (kind === 'announcement') return 'bi-megaphone';
      if (kind === 'password') return 'bi-shield-lock';
      if (kind === 'wifi-offline') return 'bi-wifi-off';
      if (kind === 'suspension') return 'bi-pause-circle';
      if (kind === 'reactivation') return 'bi-check-circle';
      return 'bi-info-circle';
    }

    function mapNotificationFilter(kind) {
      if (kind === 'invoice' || kind === 'due-reminder') return 'billing';
      if (kind === 'ticket') return 'ticket';
      if (kind === 'wifi-offline' || kind === 'suspension' || kind === 'reactivation' || kind === 'password') return 'status';
      return 'info';
    }

    function buildNotificationGroups(items) {
      const list = Array.isArray(items) ? items : [];
      return {
        announcement: list.filter((item) => item.kind === 'announcement').length,
        offline: list.filter((item) => item.kind === 'wifi-offline' || item.kind === 'suspension' || item.kind === 'reactivation').length,
        password: list.filter((item) => item.kind === 'password').length,
        billing: list.filter((item) => item.kind === 'invoice' || item.kind === 'ticket' || item.kind === 'due-reminder').length
      };
    }

    function defaultNotificationSender(kind) {
      if (kind === 'announcement') return { name: 'Admin', role: 'Pengumuman' };
      if (kind === 'invoice' || kind === 'due-reminder') return { name: 'Billing', role: 'Tagihan' };
      if (kind === 'ticket') return { name: 'Bantuan Pelanggan', role: 'Tiket' };
      if (kind === 'password') return { name: 'Sistem Router', role: 'Router WiFi' };
      if (kind === 'suspension' || kind === 'reactivation') return { name: 'Sistem Layanan', role: 'Status Layanan' };
      return { name: 'Sistem', role: 'Info Pelanggan' };
    }

    function getNotificationSender(item) {
      const payload = item && typeof item.payload === 'object' ? item.payload : {};
      const fallback = defaultNotificationSender(item?.kind);
      return {
        name: String(item?.senderName || payload.sender_name || payload.senderName || payload.sender || fallback.name || 'Sistem').trim() || fallback.name,
        role: String(item?.senderRole || payload.sender_role || payload.senderRole || fallback.role || 'Info Pelanggan').trim() || fallback.role
      };
    }

    function getNotificationImageUrl(item) {
      const payload = item && typeof item.payload === 'object' ? item.payload : {};
      const raw = String(item?.imageUrl || payload.image_url || payload.imageUrl || payload.image || payload.media_url || payload.mediaUrl || '').trim();
      if (!raw) return '';
      if (raw.startsWith('/') || raw.startsWith('http://') || raw.startsWith('https://') || raw.startsWith('data:image/')) return raw;
      return '';
    }

    function getSenderInitials(name) {
      const words = String(name || 'Sistem').trim().split(/\s+/).filter(Boolean);
      return words.slice(0, 2).map((word) => word.charAt(0).toUpperCase()).join('') || 'S';
    }

    function stripTrailingUrlPunctuation(url) {
      let clean = String(url || '');
      let trailing = '';
      while (/[.,!?;:)]$/.test(clean)) {
        trailing = clean.slice(-1) + trailing;
        clean = clean.slice(0, -1);
      }
      return { clean, trailing };
    }

    function linkifyNotificationText(value) {
      const escaped = escapeNotificationHtml(value || '');
      return escaped.replace(/https?:\/\/[^\s<]+/gi, (url) => {
        const { clean, trailing } = stripTrailingUrlPunctuation(url);
        return `<a href="${clean}" target="_blank" rel="noopener noreferrer">${clean}</a>${trailing}`;
      });
    }

    function getNotificationPopupKey(item) {
      if (!item) return '';
      return String(item.sourceId || item.id || `${item.kind || 'system'}|${item.title || ''}|${item.time || ''}`).trim();
    }

    function getLatestUnreadNotificationIndex() {
      const items = Array.isArray(notificationState.items) ? notificationState.items : [];
      let latest = { index: -1, time: -1 };
      items.forEach((item, index) => {
        if (!item || item.unread !== true) return;
        const itemTime = Number(new Date(item.time || 0).getTime()) || Number(item.time || 0) || 0;
        if (itemTime >= latest.time) latest = { index, time: itemTime };
      });
      return latest.index;
    }

    function shouldAutoOpenNotification(item) {
      const key = getNotificationPopupKey(item);
      if (!key) return false;
      try {
        return localStorage.getItem(NOTIFICATION_AUTO_POPUP_KEY) !== key;
      } catch {
        return true;
      }
    }

    function rememberAutoOpenedNotification(item) {
      const key = getNotificationPopupKey(item);
      if (!key) return;
      try {
        localStorage.setItem(NOTIFICATION_AUTO_POPUP_KEY, key);
      } catch {}
    }

    function maybeAutoOpenLatestNotification(reason = 'load') {
      if (notificationAutoPopupBusy || !notificationModal) return false;
      const items = Array.isArray(notificationState.items) ? notificationState.items : [];
      const latestIndex = getLatestUnreadNotificationIndex();
      if (latestIndex < 0) return false;
      const latestItem = items[latestIndex];
      if (!latestItem || !shouldAutoOpenNotification(latestItem)) return false;
      notificationAutoPopupBusy = true;
      rememberAutoOpenedNotification(latestItem);
      renderNotificationDetail(latestIndex, { auto: true, reason });
      notificationModal.show();
      window.setTimeout(() => {
        notificationAutoPopupBusy = false;
      }, 500);
      return true;
    }

