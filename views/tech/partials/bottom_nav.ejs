  </div> <!-- End container -->

  <% const safeTechNav = (typeof techNav !== 'undefined' && techNav) ? techNav : { openTickets: 0, myTickets: 0, assignedTasks: 0, inProgress: 0, resolved: 0 }; %>

  <nav class="bottom-nav">
    <a href="/tech" class="nav-item <%= activePage === 'dashboard' ? 'active' : '' %>">
      <i class="bi bi-briefcase-fill"></i>
      <span>Beranda</span>
    </a>
    <a href="/tech/tasks" class="nav-item <%= activePage === 'tasks' ? 'active' : '' %>">
      <i class="bi bi-clipboard-check-fill"></i>
      <% if (safeTechNav.assignedTasks > 0) { %><span class="nav-count"><%= safeTechNav.assignedTasks > 99 ? '99+' : safeTechNav.assignedTasks %></span><% } %>
      <span>Job</span>
    </a>
    <a href="/tech/pool" class="nav-item <%= activePage === 'pool' ? 'active' : '' %>">
      <i class="bi bi-inbox-fill"></i>
      <% if (safeTechNav.openTickets > 0) { %><span class="nav-count"><%= safeTechNav.openTickets > 99 ? '99+' : safeTechNav.openTickets %></span><% } %>
      <span><%= t('tech.nav.new_tickets', 'Tiket') %></span>
    </a>
    <a href="/tech/map" class="nav-item <%= activePage === 'map' ? 'active' : '' %>">
      <i class="bi bi-map-fill"></i>
      <span><%= t('tech.nav.map', 'Peta') %></span>
    </a>
    <a href="/tech/monitoring" class="nav-item <%= activePage === 'monitoring' ? 'active' : '' %>">
      <i class="bi bi-display-fill"></i>
      <span><%= t('tech.nav.monitor', 'Monitor') %></span>
    </a>
    <a href="/tech/history" class="nav-item <%= activePage === 'history' ? 'active' : '' %>">
      <i class="bi bi-clock-history"></i>
      <span><%= t('tech.nav.history', 'Riwayat') %></span>
    </a>
  </nav>

  <script>
    (function () {
      const html = document.documentElement;
      const btn = document.getElementById('themeToggleBtn');
      const meta = document.querySelector('meta[name="theme-color"]');
      const syncThemeButton = () => {
        const isLight = html.getAttribute('data-theme') === 'light';
        if (btn) {
          btn.replaceChildren();
          const icon = document.createElement('i');
          icon.className = isLight ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
          const label = document.createElement('span');
          label.textContent = isLight ? 'Terang' : 'Gelap';
          btn.appendChild(icon);
          btn.appendChild(label);
        }
        if (meta) meta.setAttribute('content', isLight ? '#f5f7fb' : '#0f172a');
      };

      syncThemeButton();
      btn?.addEventListener('click', () => {
        const nextTheme = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', nextTheme);
        localStorage.setItem('tech-portal-theme', nextTheme);
        syncThemeButton();
      });
    })();

    setTimeout(() => {
      document.querySelectorAll('.alert').forEach(a => {
        const bsAlert = new bootstrap.Alert(a);
        bsAlert.close();
      });
    }, 4000);
  </script>
</body>
</html>
