  </div> <!-- End container -->

  <% const safeTechNav = (typeof techNav !== 'undefined' && techNav) ? techNav : { openTickets: 0, myTickets: 0, assignedTasks: 0, inProgress: 0, resolved: 0 }; %>
  <% const currentTechPage = typeof activePage !== 'undefined' ? activePage : ''; %>
  <% const isMoreActive = ['create_customer', 'map', 'monitoring', 'pool'].includes(currentTechPage); %>

  <nav class="bottom-nav">
    <a href="/tech/customers" class="nav-item <%= currentTechPage === 'customers' ? 'active' : '' %>">
      <i class="bi bi-people"></i>
      <span class="nav-item-label">Pelanggan</span>
    </a>
    <a href="/tech/tasks" class="nav-item <%= currentTechPage === 'tasks' ? 'active' : '' %>">
      <i class="bi bi-clipboard2-check"></i>
      <% if (safeTechNav.assignedTasks > 0) { %><span class="nav-count"><%= safeTechNav.assignedTasks > 99 ? '99+' : safeTechNav.assignedTasks %></span><% } %>
      <span class="nav-item-label">Tugas</span>
    </a>
    <a href="/tech" class="nav-item nav-item--center <%= currentTechPage === 'dashboard' ? 'active' : '' %>">
      <i class="bi bi-grid-1x2"></i>
      <span class="nav-item-label">Dashboard</span>
    </a>
    <a href="/tech/history" class="nav-item <%= currentTechPage === 'history' ? 'active' : '' %>">
      <i class="bi bi-clock-history"></i>
      <span class="nav-item-label">Riwayat</span>
    </a>
    <button type="button" class="nav-item-trigger <%= isMoreActive ? 'active' : '' %>" data-bs-toggle="offcanvas" data-bs-target="#techMoreMenu" aria-controls="techMoreMenu">
      <i class="bi bi-headset"></i>
      <span class="nav-item-label">Bantuan</span>
    </button>
  </nav>

  <div class="offcanvas offcanvas-bottom tech-menu-sheet" tabindex="-1" id="techMoreMenu" aria-labelledby="techMoreMenuLabel" style="height:auto;">
    <div class="offcanvas-header pb-2">
      <div>
        <div class="tech-menu-title" id="techMoreMenuLabel">Menu Teknisi</div>
        <div class="tech-menu-subtitle">Akses cepat untuk halaman tambahan dan aksi lapangan.</div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body pt-1">
      <div class="tech-menu-grid">
        <a href="/tech/customers/new" class="tech-menu-link">
          <i class="bi bi-person-plus"></i>
          <div>
            <strong>Tambah Pelanggan</strong>
            <span>Input calon pelanggan baru dari lapangan.</span>
          </div>
        </a>
        <a href="/tech/monitoring" class="tech-menu-link">
          <i class="bi bi-display"></i>
          <div>
            <strong>Monitoring ONU</strong>
            <span>Lihat status perangkat dan jalur online.</span>
          </div>
        </a>
        <a href="/tech/map" class="tech-menu-link">
          <i class="bi bi-pin-map"></i>
          <div>
            <strong>Peta Pelanggan</strong>
            <span>Buka titik lokasi pelanggan di lapangan.</span>
          </div>
        </a>
        <a href="/tech/history" class="tech-menu-link">
          <i class="bi bi-clock-history"></i>
          <div>
            <strong>Riwayat Kerja</strong>
            <span>Cek pekerjaan yang pernah ditangani.</span>
          </div>
        </a>
        <a href="/tech/pool" class="tech-menu-link">
          <i class="bi bi-broadcast-pin"></i>
          <div>
            <strong>Gangguan</strong>
            <span>Lihat tiket baru yang perlu ditangani.</span>
          </div>
        </a>
      </div>

      <div class="tech-menu-secondary">
        <a href="/tech/customers">
          <span><i class="bi bi-people me-2"></i>Daftar Pelanggan</span>
          <i class="bi bi-chevron-right"></i>
        </a>
        <a href="/tech/logout" onclick="return confirm('<%= t('tech.logout_confirm', 'Apakah Anda yakin ingin logout?') %>')">
          <span><i class="bi bi-box-arrow-right me-2"></i>Logout</span>
          <i class="bi bi-chevron-right"></i>
        </a>
      </div>
    </div>
  </div>

  <%- include('../../partials/employee_location_tracker', {
    enabled: true,
    endpoint: '/tech/api/location',
    roleLabel: 'Teknisi'
  }) %>

  <script>
    (function () {
      const html = document.documentElement;
      const btn = document.getElementById('themeToggleBtn');
      const meta = document.querySelector('meta[name="theme-color"]');
      const syncThemeButton = () => {
        const isLight = html.getAttribute('data-theme') === 'light';
        if (btn) {
          btn.replaceChildren();
          const icon = document.createElement('i');
          icon.className = isLight ? 'bi bi-sun' : 'bi bi-moon-stars';
          const label = document.createElement('span');
          label.textContent = isLight ? 'Terang' : 'Gelap';
          btn.appendChild(icon);
          btn.appendChild(label);
        }
        if (meta) meta.setAttribute('content', isLight ? '#eef3ff' : '#09111d');
      };

      syncThemeButton();
      btn?.addEventListener('click', () => {
        const nextTheme = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', nextTheme);
        localStorage.setItem('tech-portal-theme', nextTheme);
        syncThemeButton();
      });
    })();

    setTimeout(() => {
      document.querySelectorAll('.alert').forEach(a => {
        const bsAlert = new bootstrap.Alert(a);
        bsAlert.close();
      });
    }, 4000);
  </script>
</body>
</html>
