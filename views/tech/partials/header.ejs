<!-- views/tech/partials/header.ejs -->
<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <script>
    (function () {
      const savedTheme = localStorage.getItem('tech-portal-theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
    })();
  </script>
  <meta name="theme-color" content="#eef3ff">
  <%- include('../../partials/pwa_portal', {
    portalKey: 'tech',
    manifestPath: '/pwa/tech.webmanifest',
    scope: '/tech/',
    themeColor: '#073dcc',
    appTitle: 'Portal Teknisi'
  }) %>
  <title><%= title %> - <%= company %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <% if (typeof techPushEnabled !== 'undefined' && techPushEnabled && techOneSignalAppId && techPushExternalId) { %>
  <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer data-onesignal-tech-sdk="true"></script>
  <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    window.__TECH_ONESIGNAL_APP_ID = <%- JSON.stringify(techOneSignalAppId) %>;
    window.__TECH_ONESIGNAL_EXTERNAL_ID = <%- JSON.stringify(techPushExternalId) %>;
    OneSignalDeferred.push(async function(OneSignal) {
      try {
        await OneSignal.init({
          appId: window.__TECH_ONESIGNAL_APP_ID,
          notifyButton: { enable: false },
          allowLocalhostAsSecureOrigin: true,
          serviceWorkerPath: '/OneSignalSDKWorker.js',
          serviceWorkerUpdaterPath: '/OneSignalSDKUpdaterWorker.js',
          serviceWorkerParam: { scope: '/' },
          autoResubscribe: true
        });
        if (window.__TECH_ONESIGNAL_EXTERNAL_ID && typeof OneSignal.login === 'function') {
          await OneSignal.login(window.__TECH_ONESIGNAL_EXTERNAL_ID);
        }
        window.__TECH_ONESIGNAL_READY = true;
      } catch (error) {
        console.warn('OneSignal teknisi gagal dipasang:', error);
      }
    });
  </script>
  <% } %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    :root,
    html[data-theme="light"] {
      --tech-bg: #f5f8ff;
      --tech-bg-alt: #ffffff;
      --tech-panel: rgba(255, 255, 255, .94);
      --tech-panel-soft: rgba(79, 110, 247, .06);
      --tech-panel-soft-2: rgba(79, 110, 247, .10);
      --tech-border: rgba(170, 186, 215, .30);
      --tech-text: #1b2740;
      --tech-muted: #6b7b97;
      --tech-primary: #073dcc;
      --tech-primary-soft: rgba(79, 110, 247, .12);
      --tech-success: #149b68;
      --tech-warning: #d98a18;
      --tech-danger: #d95363;
      --tech-shadow: 0 20px 40px rgba(148, 163, 184, .18);
      --tech-topbar: rgba(255, 255, 255, .88);
      --tech-nav-bg: rgba(255, 255, 255, .96);
      --tech-input-bg: rgba(255, 255, 255, .98);
      --tech-icon-bg: rgba(79, 110, 247, .06);
      --tech-btn-close-filter: none;
    }

    html[data-theme="dark"] {
      --tech-bg: #06153a;
      --tech-bg-alt: #0b1f56;
      --tech-panel: rgba(9, 28, 76, .94);
      --tech-panel-soft: rgba(125, 162, 255, .12);
      --tech-panel-soft-2: rgba(125, 162, 255, .18);
      --tech-border: rgba(195, 211, 244, .18);
      --tech-text: #f5f8ff;
      --tech-muted: #b7c5e6;
      --tech-primary: #7da2ff;
      --tech-primary-soft: rgba(125, 162, 255, .18);
      --tech-success: #35c98a;
      --tech-warning: #ffb34d;
      --tech-danger: #ff7286;
      --tech-shadow: 0 26px 54px rgba(2, 8, 23, .34);
      --tech-topbar: rgba(9, 28, 76, .88);
      --tech-nav-bg: rgba(9, 28, 76, .94);
      --tech-input-bg: rgba(15, 31, 76, .92);
      --tech-icon-bg: rgba(255, 255, 255, .055);
      --tech-btn-close-filter: invert(1) grayscale(1) brightness(200%);
    }

    html,
    body {
      min-height: 100%;
      background-color: var(--tech-bg);
      color: var(--tech-text);
    }

    body {
      font-family: "Plus Jakarta Sans", "Manrope", "Segoe UI", system-ui, -apple-system, sans-serif;
      padding-top: 72px;
      padding-bottom: 92px;
      -webkit-tap-highlight-color: transparent;
      transition: background-color .2s ease, color .2s ease;
      background: linear-gradient(180deg, var(--tech-bg-alt) 0%, var(--tech-bg) 100%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .tech-shell {
      max-width: 680px;
    }

    .top-nav {
      position: fixed;
      top: 10px;
      left: 12px;
      right: 12px;
      min-height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 12px;
      border: 1px solid var(--tech-border);
      border-radius: 24px;
      background: var(--tech-topbar);
      backdrop-filter: blur(18px);
      box-shadow: var(--tech-shadow);
      z-index: 1050;
    }

    .top-nav-brand {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .top-nav-kicker {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--tech-muted);
    }

    .top-nav-title {
      margin: 0;
      font-size: 18px;
      font-weight: 900;
      letter-spacing:0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .top-nav-mobile-title,
    .top-nav-mobile-meta {
      display: none;
    }

    .top-nav-mobile-meta {
      align-items: center;
      gap: 7px;
      color: var(--tech-muted);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .top-nav-status {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 7px;
      border-radius: 999px;
      background: rgba(20, 155, 104, .10);
      color: var(--tech-success);
      border: 1px solid rgba(20, 155, 104, .16);
      text-transform: none;
      letter-spacing: 0;
    }

    .top-nav-status::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: currentColor;
      box-shadow: 0 0 0 4px rgba(20, 155, 104, .10);
    }

    .mss-partner-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      max-width: 100%;
      margin-top: 5px;
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--tech-text);
      box-shadow: none;
    }

    .mss-partner-logo {
      width: 32px;
      height: 18px;
      object-fit: contain;
      flex: 0 0 auto;
      border-radius: 7px;
      background: #fff;
    }

    .mss-partner-copy {
      min-width: 0;
      display: flex;
      flex-direction: column;
      line-height: 1.12;
    }

    .mss-partner-copy span {
      color: var(--tech-muted);
      font-size: 8px;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .mss-partner-copy strong {
      color: var(--tech-primary);
      font-size: 10.5px;
      font-weight: 900;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .top-nav-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .top-nav-btn {
      width: 40px;
      height: 40px;
      border-radius: 15px;
      border: 1px solid var(--tech-border);
      background: var(--tech-icon-bg);
      color: var(--tech-text);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      position: relative;
      font-size: 18px;
    }

    .theme-switch-btn {
      width: auto;
      min-width: 40px;
      padding: 0 12px;
      gap: 7px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      background: var(--tech-panel-soft);
    }

    .nav-icon-badge,
    .nav-count {
      position: absolute;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: var(--tech-danger);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 800;
      line-height: 1;
      box-shadow: 0 10px 18px rgba(241, 96, 99, .26);
    }

    .nav-icon-badge {
      top: -4px;
      right: -4px;
    }

    .t-card {
      background: var(--tech-panel);
      border-radius: 24px;
      padding: 14px;
      margin-bottom: 12px;
      border: 1px solid var(--tech-border);
      box-shadow: var(--tech-shadow);
    }

    .surface-soft {
      background: linear-gradient(180deg, rgba(255, 255, 255, .06), rgba(255, 255, 255, .03)) !important;
      border-color: var(--tech-border) !important;
      color: var(--tech-text) !important;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .05);
    }

    html[data-theme="dark"] :is(.text-dark, .text-body, .text-black):not(.badge) {
      color: var(--tech-text) !important;
    }

    html[data-theme="dark"] :is(.bg-white, .bg-light, .card, .modal-content, .dropdown-menu, .offcanvas, .popover, .list-group-item) {
      background: var(--tech-panel) !important;
      color: var(--tech-text) !important;
      border-color: var(--tech-border) !important;
    }

    html[data-theme="dark"] :is(.dropdown-item, .modal-content, .offcanvas, .popover, .list-group-item, .card) :is(h1, h2, h3, h4, h5, h6, p, label, span, strong, small, div):not(.badge) {
      color: inherit;
    }

    html[data-theme="dark"] :is(.text-muted, .text-secondary, .small, small) {
      color: var(--tech-muted) !important;
    }

    html[data-theme="dark"] :is(.form-control, .form-select, textarea, input:not([type="checkbox"]):not([type="radio"]):not([type="range"]), select):not(.tech-field):not(.tech-select):not(.tech-textarea) {
      background-color: var(--tech-input-bg) !important;
      color: var(--tech-text) !important;
      border-color: var(--tech-border) !important;
    }

    html[data-theme="dark"] :is(.form-control, .form-select, textarea, input, select)::placeholder {
      color: var(--tech-muted) !important;
    }

    html[data-theme="dark"] option {
      background: var(--tech-bg-alt);
      color: var(--tech-text);
    }

    html[data-theme="light"] body,
    html[data-theme="light"] .top-nav-title,
    html[data-theme="light"] .top-nav-mobile-meta,
    html[data-theme="light"] .nav-item,
    html[data-theme="light"] .nav-item-trigger,
    html[data-theme="light"] .tech-menu-title,
    html[data-theme="light"] .tech-menu-link,
    html[data-theme="light"] .tech-menu-secondary a {
      color: #1b2740 !important;
    }

    html[data-theme="light"] .text-secondary,
    html[data-theme="light"] .text-muted,
    html[data-theme="light"] .muted-text,
    html[data-theme="light"] .field-hint {
      color: #6b7b97 !important;
    }

    html[data-theme="dark"] .btn-close {
      filter: var(--tech-btn-close-filter);
      opacity: .78;
    }

    .badge-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .01em;
      border: 1px solid transparent;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .04);
    }

    .badge-open {
      background: rgba(241, 96, 99, .12);
      color: var(--tech-danger);
      border: 1px solid rgba(241, 96, 99, .2);
    }

    .badge-in_progress {
      background: rgba(245, 165, 36, .14);
      color: var(--tech-warning);
      border: 1px solid rgba(245, 165, 36, .22);
    }

    .badge-resolved {
      background: rgba(39, 193, 131, .14);
      color: var(--tech-success);
      border: 1px solid rgba(39, 193, 131, .2);
    }

    .badge-neutral {
      background: rgba(148, 163, 184, .12);
      color: var(--tech-text);
      border: 1px solid rgba(148, 163, 184, .18);
    }

    .btn-action {
      width: 100%;
      min-height: 46px;
      border-radius: 16px;
      padding: 10px 12px;
      font-size: 13px;
      font-weight: 800;
      margin-top: 8px;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 14px;
    }

    .stat-box {
      position: relative;
      overflow: hidden;
      background: var(--tech-panel);
      border-radius: 20px;
      padding: 14px;
      border: 1px solid var(--tech-border);
      box-shadow: var(--tech-shadow);
    }

    .stat-box::after {
      content: "";
      position: absolute;
      inset: auto -26px -34px auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(111, 141, 255, .16) 0%, rgba(111, 141, 255, 0) 72%);
      pointer-events: none;
    }

    .stat-box .lbl,
    .text-secondary,
    .muted-text {
      color: var(--tech-muted) !important;
    }

    .stat-box .lbl {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .1em;
      font-weight: 800;
      margin-bottom: 10px;
      display: block;
    }

    .stat-box .val {
      font-size: 24px;
      font-weight: 900;
      line-height: 1;
      letter-spacing:0;
      margin: 0;
    }

    .stat-box .stat-icon {
      width: 42px;
      height: 42px;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      background: var(--tech-panel-soft);
      border: 1px solid var(--tech-border);
      color: var(--tech-primary);
      margin-bottom: 12px;
    }

    .tech-field,
    .tech-select,
    .tech-textarea,
    .tech-input-group .input-group-text {
      background: var(--tech-input-bg) !important;
      color: var(--tech-text) !important;
      border-color: var(--tech-border) !important;
      box-shadow: none !important;
    }

    .tech-field::placeholder,
    .tech-textarea::placeholder {
      color: var(--tech-muted) !important;
    }

    .field-hint {
      color: var(--tech-muted);
      font-size: 11px;
      line-height: 1.45;
      margin-top: 6px;
    }

    .tech-modal-card {
      border: 1px solid var(--tech-border);
      border-radius: 26px;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, .07) 0%, rgba(255, 255, 255, .03) 100%),
        var(--tech-panel) !important;
      box-shadow: var(--tech-shadow);
      color: var(--tech-text);
    }

    .tech-modal-card .modal-header,
    .tech-modal-card .modal-footer {
      border-color: var(--tech-border) !important;
      background: transparent;
      padding: 16px 18px;
    }

    .tech-modal-card .modal-body {
      padding: 4px 18px 18px;
    }

    .tech-modal-card .modal-title {
      font-weight: 900;
      letter-spacing:0;
    }

    .tech-modal-card .btn-close {
      filter: var(--tech-btn-close-filter);
      opacity: .78;
    }

    .bottom-nav {
      position: fixed;
      left: 12px;
      right: 12px;
      bottom: 10px;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 8px;
      padding: 10px;
      border-radius: 30px;
      border: 1px solid var(--tech-border);
      background: var(--tech-nav-bg);
      backdrop-filter: blur(20px);
      box-shadow: var(--tech-shadow);
      z-index: 1050;
    }

    .nav-item,
    .nav-item-trigger {
      min-height: 54px;
      padding: 8px 6px;
      border-radius: 18px;
      border: 1px solid transparent;
      color: var(--tech-muted);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      position: relative;
      font-size: 11px;
      font-weight: 800;
      line-height: 1;
      background: transparent;
      text-decoration: none;
    }

    .nav-item i,
    .nav-item-trigger i {
      font-size: 19px;
    }

    .nav-item-label {
      white-space: nowrap;
    }

    .nav-item.active,
    .nav-item-trigger.active {
      color: var(--tech-primary);
      border-color: rgba(111, 141, 255, .18);
      background: var(--tech-primary-soft);
    }

    .nav-item--center {
      transform: translateY(-16px);
      min-height: 68px;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(111, 141, 255, .98), rgba(79, 110, 247, .96));
      color: #fff !important;
      border-color: rgba(255, 255, 255, .18);
      box-shadow: 0 18px 28px rgba(79, 110, 247, .28);
    }

    .nav-item--center.active {
      background: linear-gradient(180deg, rgba(111, 141, 255, 1), rgba(79, 110, 247, .97));
      border-color: rgba(255, 255, 255, .24);
    }

    .nav-item--center i {
      font-size: 22px;
    }

    .nav-count {
      top: 3px;
      right: 10px;
    }

    .tech-menu-sheet {
      bottom: 96px;
      background: var(--tech-panel);
      color: var(--tech-text);
      border-top-left-radius: 28px;
      border-top-right-radius: 28px;
      border-top: 1px solid var(--tech-border);
      max-width: 680px;
      margin: 0 auto;
    }

    .tech-menu-sheet .offcanvas-header,
    .tech-menu-sheet .offcanvas-body {
      padding-left: 18px;
      padding-right: 18px;
    }

    .tech-menu-sheet .offcanvas-body {
      padding-bottom: 22px;
    }

    .tech-menu-sheet .btn-close {
      filter: var(--tech-btn-close-filter);
    }

    .tech-menu-title {
      font-size: 18px;
      font-weight: 900;
      letter-spacing:0;
    }

    .tech-menu-subtitle {
      color: var(--tech-muted);
      font-size: 12px;
      margin-top: 3px;
    }

    .tech-menu-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 14px;
    }

    .tech-menu-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
      border-radius: 20px;
      border: 1px solid var(--tech-border);
      background: var(--tech-panel-soft);
      color: var(--tech-text);
    }

    .tech-menu-link i {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--tech-primary-soft);
      color: var(--tech-primary);
      font-size: 18px;
      flex-shrink: 0;
    }

    .tech-menu-link strong {
      display: block;
      font-size: 13px;
      line-height: 1.2;
      margin-bottom: 3px;
    }

    .tech-menu-link span {
      display: block;
      font-size: 11px;
      color: var(--tech-muted);
      line-height: 1.45;
    }

    .tech-menu-secondary {
      display: grid;
      gap: 8px;
    }

    .tech-menu-secondary a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 13px 14px;
      border-radius: 18px;
      border: 1px solid var(--tech-border);
      background: var(--tech-panel-soft);
      font-size: 13px;
      font-weight: 700;
    }

    @media (max-width: 576px) {
      body {
        padding-top: 76px;
        padding-bottom: 98px;
        background:
          linear-gradient(180deg, var(--tech-bg-alt) 0%, var(--tech-bg) 100%);
      }

      .top-nav {
        left: 10px;
        right: 10px;
        top: 8px;
        min-height: 58px;
        padding: 8px 10px 8px 12px;
        border-radius: 18px;
      }

      .top-nav-kicker {
        display: none;
      }

      .top-nav-title {
        font-size: 18px;
        line-height: 1.08;
        max-width: 46vw;
      }

      .top-nav-desktop-title { display: none; }
      .top-nav-mobile-title { display: inline; }
      .top-nav-mobile-meta { display: flex; }

      .top-nav-actions {
        gap: 6px;
      }

      .top-nav-btn {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        font-size: 16px;
      }

      .theme-switch-btn {
        padding: 0 10px;
      }

      .theme-switch-btn span {
        display: none;
      }

      .t-card {
        padding: 11px;
        border-radius: 16px;
      }

      .stat-box {
        padding: 12px;
        border-radius: 18px;
      }

      .stat-box .val {
        font-size: 22px;
      }

      .stat-box .stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        font-size: 16px;
        margin-bottom: 10px;
      }

      .bottom-nav {
        left: 10px;
        right: 10px;
        bottom: 8px;
        gap: 4px;
        padding: 7px 6px calc(7px + env(safe-area-inset-bottom));
        border-radius: 22px;
      }

      .tech-menu-sheet {
        bottom: 92px;
      }

      .nav-item,
      .nav-item-trigger {
        min-height: 48px;
        padding: 6px 3px;
        border-radius: 15px;
        font-size: 10px;
        gap: 4px;
      }

      .nav-item i,
      .nav-item-trigger i {
        font-size: 17px;
      }

      .nav-item--center {
        min-height: 62px;
        transform: translateY(-14px);
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(111, 141, 255, .98), rgba(79, 110, 247, .96));
        color: #fff !important;
        border-color: rgba(255, 255, 255, .18);
        box-shadow: 0 16px 26px rgba(79, 110, 247, .26);
      }

      .nav-item--center.active {
        color: #fff !important;
        border-color: rgba(255, 255, 255, .24);
        background: linear-gradient(180deg, rgba(111, 141, 255, 1), rgba(79, 110, 247, .97));
      }

      .nav-item--center i {
        font-size: 21px;
      }

      .nav-count {
        top: -2px;
        right: 6px;
      }
    }
  </style>
</head>

<body>
  <% const safeTechNav = (typeof techNav !== 'undefined' && techNav) ? techNav : { openTickets: 0, myTickets: 0, assignedTasks: 0, inProgress: 0, resolved: 0 }; %>
  <% const techHeaderDate = new Date().toLocaleDateString('id-ID', { weekday: 'short', day: '2-digit', month: 'short' }); %>

  <div class="top-nav">
    <div class="top-nav-brand">
      <span class="top-nav-kicker">Portal Teknisi</span>
      <h1 class="top-nav-title"><span class="top-nav-desktop-title"><%= title %></span><span class="top-nav-mobile-title">Teknisi</span></h1>
      <div class="top-nav-mobile-meta"><span><%= techHeaderDate %></span><span class="top-nav-status">Online</span></div>
      <%- include('../../partials/partner_brand_badge', { settings: (typeof settings !== 'undefined' ? settings : {}), variant: 'topbar' }) %>
    </div>
    <div class="top-nav-actions">
      <button type="button" class="top-nav-btn theme-switch-btn" id="themeToggleBtn" aria-label="Ganti tema portal teknisi">
        <i class="bi bi-moon-stars"></i>
        <span>Gelap</span>
      </button>
      <a href="/tech/pool" class="top-nav-btn" title="Tiket gangguan baru">
        <i class="bi bi-bell"></i>
        <% if (safeTechNav.openTickets > 0) { %><span class="nav-icon-badge"><%= safeTechNav.openTickets > 99 ? '99+' : safeTechNav.openTickets %></span><% } %>
      </a>
      <a href="/tech/logout" class="top-nav-btn" title="Logout" onclick="return confirm('<%= t('tech.logout_confirm', 'Apakah Anda yakin ingin logout?') %>')">
        <i class="bi bi-box-arrow-right"></i>
      </a>
    </div>
  </div>

  <div class="container tech-shell py-3">
    <% if (typeof msg !== 'undefined' && msg) { %>
      <div class="alert alert-<%= msg.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show rounded-4" role="alert" style="font-size: 13px;">
        <i class="bi bi-<%= msg.type === 'error' ? 'exclamation-circle' : 'check-circle' %> me-2"></i>
        <%= msg.text %>
        <button type="button" class="btn-close" style="font-size: 10px;" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
