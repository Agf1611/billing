<%- include('partials/header') %>

<%
  const shouldResetTechDraft = Boolean(msg && msg.type === 'success');
  const safePackages = Array.isArray(packages) ? packages : [];
  const safeRouters = Array.isArray(routers) ? routers : [];
  const safeOdps = Array.isArray(odps) ? odps : [];
  const safeOlts = Array.isArray(olts) ? olts : [];
  const safeRequests = Array.isArray(requests) ? requests : [];
  const formatTechRequestTime = (value) => value ? new Date(value).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) : '-';
  const techRequestStatusLabel = (value) => {
    const status = String(value || '').toLowerCase();
    if (status === 'approved') return 'Disetujui';
    if (status === 'rejected') return 'Ditolak';
    return 'Menunggu';
  };
  const techRequestStatusClass = (value) => {
    const status = String(value || '').toLowerCase();
    if (status === 'approved') return 'text-bg-success';
    if (status === 'rejected') return 'text-bg-danger';
    return 'text-bg-warning';
  };
%>

<style>
  .tech-create-hero{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 13px;background:linear-gradient(145deg, rgba(91,140,255,.14), rgba(39,193,131,.05)), var(--tech-panel)}
  .tech-create-kicker{display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:16px;background:var(--tech-panel-soft);border:1px solid var(--tech-border);color:var(--tech-primary);font-size:20px;flex:0 0 auto}
  .tech-create-kicker span{display:none}
  .tech-create-title{font-size:16px;font-weight:900;letter-spacing:0;line-height:1.15;margin:0}
  .tech-create-desc{color:var(--tech-muted);font-size:11px;line-height:1.35}
  .tech-form-intro{padding:10px 12px}
  .tech-create-section{padding:0}
  .tech-create-section summary{list-style:none;cursor:pointer;padding:11px 12px 10px;display:flex;align-items:center;justify-content:space-between;gap:10px}
  .tech-create-section summary::-webkit-details-marker{display:none}
  .tech-create-section .chev{transition:transform .18s ease}
  .tech-create-section[open] .chev{transform:rotate(180deg)}
  .tech-create-section-body{padding:0 12px 12px}
  .tech-create-section-title{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:900}
  .tech-create-section-title i{width:26px;height:26px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;background:var(--tech-panel-soft);color:var(--tech-primary);font-size:14px}
  .tech-create-section-sub{font-size:10px;color:var(--tech-muted);margin-top:2px;line-height:1.35}
  .tech-create-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
  .tech-create-grid .full{grid-column:1 / -1}
  .tech-field-card{padding:8px;border-radius:14px;border:1px solid var(--tech-border);background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.02));box-shadow:inset 0 1px 0 rgba(255,255,255,.035)}
  .tech-field-card label{display:flex;align-items:center;gap:6px;margin-bottom:6px;font-size:10px;font-weight:900;color:var(--tech-muted)}
  .tech-field-card .field-hint{margin-top:5px;font-size:10px;line-height:1.35;color:var(--tech-muted)}
  .tech-field-card .form-control,
  .tech-field-card .form-select{min-height:40px;font-size:12px}
  .tech-field-card textarea.form-control{min-height:64px}
  .tech-mode-switch{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
  .tech-mode-btn{min-height:40px;border-radius:14px;border:1px solid var(--tech-border);background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));color:var(--tech-text);font-size:11px;font-weight:800;padding:8px 10px}
  .tech-mode-btn.active{border-color:rgba(111,141,255,.28);background:linear-gradient(180deg, rgba(111,141,255,.18), rgba(111,141,255,.08));color:var(--tech-primary)}
  .tech-sync-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:10px}
  .tech-sync-card{padding:10px 11px;border-radius:16px;border:1px solid var(--tech-border);background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.025))}
  .tech-sync-card .label{font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:var(--tech-muted);margin-bottom:4px}
  .tech-sync-card .value{font-size:11px;font-weight:800;line-height:1.35}
  .tech-sync-card.ok .value{color:var(--tech-success)}
  .tech-sync-card.warn .value{color:var(--tech-warning)}
  .tech-sync-card.neutral .value{color:var(--tech-text)}
  .tech-upload-actions{display:flex;gap:8px;flex-wrap:wrap}
  .tech-upload-actions .btn{border-radius:14px;min-height:40px;font-size:12px;font-weight:800}
  .tech-upload-preview-row{display:flex;align-items:flex-start;gap:10px;flex-wrap:wrap;margin-top:10px}
  .tech-upload-preview-card{width:96px;min-height:96px;border-radius:18px;border:1px dashed rgba(148,163,184,.3);background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center;overflow:hidden}
  .tech-upload-preview-card img{width:100%;height:96px;object-fit:cover;display:block}
  .tech-upload-preview-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:10px;color:#94a3b8;font-size:11px;text-align:center;line-height:1.35}
  .tech-upload-preview-empty i{font-size:20px;color:#7c8cff}
  .tech-upload-preview-meta{display:flex;flex-direction:column;gap:4px;max-width:190px}
  .tech-upload-preview-name{font-size:11px;color:var(--tech-text);line-height:1.4;word-break:break-word}
  .tech-upload-preview-state{font-size:10px;color:#94a3b8}
  .tech-form-actions{position:sticky;bottom:88px;z-index:20;margin-top:14px;padding:10px;border-radius:20px;border:1px solid var(--tech-border);background:rgba(15,23,42,.92);backdrop-filter:blur(18px);box-shadow:var(--tech-shadow)}
  .tech-form-actions-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .tech-form-actions .btn{min-height:48px;border-radius:16px;font-weight:800}
  .tech-optional-note{font-size:11px;color:var(--tech-muted);line-height:1.5}
  .tech-request-list{display:grid;gap:8px}
  .tech-request-item{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    align-items:center;
    gap:10px;
    padding:10px 11px;
    border-radius:16px;
    border:1px solid var(--tech-border);
    background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.02));
  }
  .tech-request-main{min-width:0;display:grid;gap:5px}
  .tech-request-title{font-size:13px;font-weight:900;line-height:1.25;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .tech-request-sub{font-size:11px;color:var(--tech-muted);line-height:1.35;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .tech-request-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
  .tech-request-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 7px;border-radius:999px;background:var(--tech-panel-soft);border:1px solid var(--tech-border);font-size:10px;font-weight:800;color:var(--tech-text)}
  .tech-request-side{display:flex;align-items:center;gap:6px}
  .tech-request-detail-btn{width:36px;height:36px;border-radius:13px;display:inline-flex;align-items:center;justify-content:center}
  .tech-request-detail-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
  .tech-request-detail-cell{padding:10px;border-radius:14px;border:1px solid var(--tech-border);background:var(--tech-panel-soft)}
  .tech-request-detail-label{display:block;margin-bottom:4px;font-size:9px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;color:var(--tech-muted)}
  .tech-request-detail-value{font-size:12px;font-weight:800;color:var(--tech-text);word-break:break-word}
  .tech-map-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
  .tech-map-actions .btn{border-radius:15px;min-height:44px;font-weight:800}
  .tech-hidden-file{position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none}
  @media (max-width:576px){
    .tech-create-hero{padding:10px 11px}
    .tech-create-title{font-size:15px}
    .tech-create-desc{display:none}
    .tech-form-intro{display:none}
    .tech-create-section-sub{display:none}
    .tech-field-card .field-hint{display:none}
    .tech-create-grid{grid-template-columns:1fr}
    .tech-sync-grid{grid-template-columns:1fr}
    .tech-request-item{padding:9px 10px;gap:8px}
    .tech-request-title{font-size:12px}
    .tech-request-sub{font-size:10px}
    .tech-request-pill:nth-child(n+3){display:none}
    .tech-request-detail-grid{grid-template-columns:1fr}
    .tech-form-actions{bottom:92px}
  }
</style>

<div class="t-card tech-create-hero">
  <span class="tech-create-kicker"><i class="bi bi-person-plus"></i><span>Tambah Pelanggan</span></span>
  <div style="min-width:0;flex:1">
    <h2 class="tech-create-title">Pengajuan pelanggan baru</h2>
    <div class="tech-create-desc">Isi data inti, detail tambahan tetap bisa dibuka.</div>
  </div>
  <span class="badge-status badge-open" style="white-space:nowrap">Approval</span>
</div>

<div class="t-card tech-form-intro">
  <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
    <div>
      <div class="fw-bold" style="font-size:13px;">Form Pengajuan</div>
      <div class="text-secondary small">Gunakan ikon section untuk lompat ke bagian yang diperlukan.</div>
    </div>
  </div>
</div>

<form id="techCustomerForm" method="POST" action="/tech/customers" enctype="multipart/form-data">
  <input class="form-check-input d-none" type="checkbox" role="switch" id="create_pppoe_secret" name="create_pppoe_secret" value="1">
  <input name="house_photo_file" id="tech_house_photo_file" type="file" accept="image/*" capture="environment" class="tech-hidden-file">
  <input name="ktp_photo_file" id="tech_ktp_photo_file" type="file" accept="image/*" capture="environment" class="tech-hidden-file">

  <details class="t-card tech-create-section" open>
    <summary>
      <div>
        <div class="tech-create-section-title"><i class="bi bi-person-vcard"></i>Data Pelanggan</div>
        <div class="tech-create-section-sub">Nama, nomor HP, paket, dan kontak dasar.</div>
      </div>
      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-create-grid">
        <div class="tech-field-card full">
          <label for="tech_name">Nama Pelanggan</label>
          <input id="tech_name" name="name" class="form-control rounded-4 tech-field" placeholder="Nama lengkap pelanggan" required>
        </div>
        <div class="tech-field-card">
          <label for="tech_phone">No. HP / WhatsApp</label>
          <input id="tech_phone" name="phone" class="form-control rounded-4 tech-field" placeholder="08xxxxxxxxxx">
        </div>
        <div class="tech-field-card">
          <label for="package_id">Paket</label>
          <select name="package_id" class="form-select rounded-4 tech-select" id="package_id">
            <option value="">-- Pilih Paket --</option>
            <% safePackages.forEach((p) => { %>
              <option value="<%= p.id %>" data-profile="<%= p.pppoe_profile || '' %>"><%= p.name %> (Rp <%= Number(p.price || 0).toLocaleString('id-ID') %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="tech-field-card full">
          <label for="tech_address">Alamat</label>
          <textarea id="tech_address" name="address" class="form-control rounded-4 tech-textarea" rows="2" placeholder="Nama jalan, patokan rumah, RT/RW, atau titik penting lainnya"></textarea>
        </div>
        <div class="tech-field-card full">
          <label for="tech_email">Email</label>
          <input id="tech_email" name="email" class="form-control rounded-4 tech-field" type="email" placeholder="Opsional">
        </div>
      </div>
    </div>
  </details>

  <details class="t-card tech-create-section" open>
    <summary>
      <div>
        <div class="tech-create-section-title"><i class="bi bi-calendar2-check"></i>Pemasangan & Tagihan</div>
        <div class="tech-create-section-sub">Wajib diisi agar riwayat pemasangan dan jadwal tagihan pelanggan jelas.</div>
      </div>
      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-create-grid">
        <div class="tech-field-card">
          <label for="install_date">Tanggal Pemasangan</label>
          <input id="install_date" name="install_date" type="date" class="form-control rounded-4 tech-field" required>
          <div class="field-hint">Tanggal teknisi memasang atau mengaktifkan layanan pelanggan.</div>
        </div>
        <div class="tech-field-card">
          <label for="tech_isolate_day">Tanggal Jatuh Tempo Tagihan</label>
          <input id="tech_isolate_day" name="isolate_day" type="number" inputmode="numeric" min="1" max="31" value="10" class="form-control rounded-4 tech-field" required>
          <div class="field-hint">Diulang setiap bulan. Jika isolir otomatis aktif, layanan juga diisolir pada tanggal ini saat belum lunas.</div>
        </div>
        <div class="tech-field-card full">
          <label for="tech_auto_isolate">Isolir Otomatis Jika Belum Lunas</label>
          <select id="tech_auto_isolate" name="auto_isolate" class="form-select rounded-4 tech-select">
            <option value="1">Aktif</option>
            <option value="0">Tidak Aktif</option>
          </select>
        </div>
      </div>
    </div>
  </details>

  <details class="t-card tech-create-section" open>
    <summary>
      <div>
        <div class="tech-create-section-title"><i class="bi bi-router"></i>Akun Internet</div>
        <div class="tech-create-section-sub">Pilih secret yang sudah ada atau ajukan secret baru.</div>
      </div>
      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-mode-switch">
        <button type="button" class="tech-mode-btn active" id="techModeExisting" onclick="setSecretMode(false)">Pakai akun yang ada</button>
        <button type="button" class="tech-mode-btn" id="techModeNew" onclick="setSecretMode(true)">Buat secret baru</button>
      </div>
      <div id="secretModeHint" class="field-hint">Pilih akun PPPoE yang sudah tersedia di MikroTik.</div>

      <div class="tech-create-grid" style="margin-top:10px">
        <div class="tech-field-card">
          <label for="router_id">Router (MikroTik)</label>
          <select id="router_id" name="router_id" class="form-select rounded-4 tech-select" onchange="loadPppoeUsers(); loadPppoeProfiles(); updateTechSyncState();">
            <option value="">Default Router</option>
            <% safeRouters.forEach((r) => { %>
              <option value="<%= r.id %>"><%= r.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="tech-field-card">
          <label for="pppoe_username">Akun PPPoE</label>
          <input id="pppoe_username" name="pppoe_username" class="form-control rounded-4 tech-field" list="pppoeList" placeholder="Pilih / cari akun internet">
          <datalist id="pppoeList"></datalist>
          <div id="pppoeHint" class="field-hint"></div>
        </div>
        <div class="tech-field-card">
          <label for="pppoe_password">Password PPPoE</label>
          <input id="pppoe_password" name="pppoe_password" class="form-control rounded-4 tech-field" placeholder="Kosongkan bila sama dengan username">
          <div class="field-hint">Jika kosong, sistem anggap password sama dengan username.</div>
        </div>
        <div class="tech-field-card">
          <label for="normal_pppoe_profile">Profile Normal</label>
          <select id="normal_pppoe_profile" name="normal_pppoe_profile" class="form-select rounded-4 tech-select">
            <option value="">Ikuti profile paket</option>
          </select>
        </div>
      </div>

      <div class="tech-sync-grid">
        <div class="tech-sync-card neutral" id="syncRouterCard">
          <div class="label">Router</div>
          <div class="value" id="syncRouterState">Mengambil dari router default</div>
        </div>
        <div class="tech-sync-card neutral" id="syncModeCard">
          <div class="label">Mode Akun</div>
          <div class="value" id="syncModeState">Pakai akun yang ada</div>
        </div>
        <div class="tech-sync-card neutral" id="syncPppoeCard">
          <div class="label">Sinkron Akun</div>
          <div class="value" id="syncPppoeState">Belum dipilih</div>
        </div>
        <div class="tech-sync-card neutral" id="syncProfileCard">
          <div class="label">Sinkron Profile</div>
          <div class="value" id="syncProfileState">Menunggu profile</div>
        </div>
      </div>
    </div>
  </details>

  <details class="t-card tech-create-section" open>
    <summary>
      <div>
        <div class="tech-create-section-title"><i class="bi bi-geo-alt"></i>Lokasi</div>
        <div class="tech-create-section-sub">Ambil lokasi dari HP atau buka peta cepat.</div>
      </div>
      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-create-grid">
        <div class="tech-field-card">
          <label for="lat">Latitude</label>
          <input id="lat" name="lat" class="form-control rounded-4 tech-field" placeholder="-6.2">
        </div>
        <div class="tech-field-card">
          <label for="lng">Longitude</label>
          <input id="lng" name="lng" class="form-control rounded-4 tech-field" placeholder="106.8">
        </div>
      </div>
      <div class="tech-map-actions">
        <button type="button" class="btn btn-primary" onclick="getLocation()"><i class="bi bi-crosshair me-2"></i>Ambil Lokasi</button>
        <button type="button" class="btn btn-outline-info" onclick="openMapPreview()"><i class="bi bi-map me-2"></i>Buka Peta</button>
      </div>
      <div class="tech-sync-grid">
        <div class="tech-sync-card neutral" id="syncLocationCard">
          <div class="label">Status Lokasi</div>
          <div class="value" id="syncLocationState">Belum diambil</div>
        </div>
      </div>
    </div>
  </details>

  <details class="t-card tech-create-section">
    <summary>
      <div>
        <div class="tech-create-section-title"><i class="bi bi-diagram-3"></i>ODP</div>
        <div class="tech-create-section-sub">ODP, port, dan update data ODP bila diperlukan.</div>
      </div>
      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-create-grid">
        <div class="tech-field-card full">
          <label for="odp_id">ODP</label>
          <select id="odp_id" name="odp_id" class="form-select rounded-4 tech-select" onchange="onOdpChanged()">
            <option value="">-- Pilih ODP --</option>
            <% safeOdps.forEach((o) => { %>
              <option value="<%= o.id %>" data-lat="<%= o.lat || '' %>" data-lng="<%= o.lng || '' %>" data-pon="<%= o.pon_port || '' %>" data-cap="<%= o.port_capacity || 16 %>"><%= o.name %></option>
            <% }) %>
          </select>
          <div id="odpInfo" class="field-hint"></div>
        </div>
        <div class="tech-field-card">
          <label for="pon_port">Port Pelanggan (ODP)</label>
          <input id="pon_port" name="pon_port" class="form-control rounded-4 tech-field" placeholder="Contoh: 1">
        </div>
        <div class="tech-field-card">
          <label for="update_odp">Update data ODP</label>
          <select name="update_odp" id="update_odp" class="form-select rounded-4 tech-select" onchange="toggleOdpEdit()">
            <option value="0">Tidak</option>
            <option value="1">Ya</option>
          </select>
        </div>
      </div>

      <div id="odpEdit" class="mt-3" style="display:none">
        <div class="tech-create-grid">
          <div class="tech-field-card">
            <label for="odp_lat">ODP Latitude</label>
            <input id="odp_lat" name="odp_lat" class="form-control rounded-4 tech-field">
          </div>
          <div class="tech-field-card">
            <label for="odp_lng">ODP Longitude</label>
            <input id="odp_lng" name="odp_lng" class="form-control rounded-4 tech-field">
          </div>
          <div class="tech-field-card">
            <label for="odp_pon_port">ODP PON Port (Trunk)</label>
            <input id="odp_pon_port" name="odp_pon_port" class="form-control rounded-4 tech-field" placeholder="Opsional">
          </div>
          <div class="tech-field-card">
            <label for="odp_port_capacity">Kapasitas Port ODP</label>
            <input id="odp_port_capacity" name="odp_port_capacity" type="number" min="1" class="form-control rounded-4 tech-field" value="16">
          </div>
        </div>
        <button type="button" class="btn btn-outline-warning btn-action" onclick="copyCustomerToOdp()">
          <i class="bi bi-arrow-down-circle me-2"></i>Samakan lokasi ODP dengan lokasi pelanggan
        </button>
      </div>
    </div>
  </details>

  <details class="t-card tech-create-section">
    <summary>
      <div>
        <div class="tech-create-section-title"><i class="bi bi-camera"></i>Dokumentasi</div>
        <div class="tech-create-section-sub">Foto rumah dan KTP dikompres otomatis maksimal 500 KB.</div>
      </div>
      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-create-grid">
        <div class="tech-field-card">
          <label>Foto Rumah</label>
          <div class="tech-upload-actions">
            <button type="button" class="btn btn-outline-primary" onclick="document.getElementById('tech_house_photo_file').click()"><i class="bi bi-camera me-2"></i>Foto Rumah</button>
          </div>
          <div class="tech-upload-preview-row">
            <div class="tech-upload-preview-card" id="tech_house_preview">
              <div class="tech-upload-preview-empty"><i class="bi bi-house-door"></i><span>Preview Rumah</span></div>
            </div>
            <div class="tech-upload-preview-meta">
              <div class="tech-upload-preview-name" id="tech_house_preview_name">Belum ada file dipilih</div>
              <div class="tech-upload-preview-state">Otomatis dikompres maksimal 500 KB</div>
            </div>
          </div>
        </div>
        <div class="tech-field-card">
          <label>Foto KTP</label>
          <div class="tech-upload-actions">
