      <i class="bi bi-chevron-down chev"></i>
    </summary>
    <div class="tech-create-section-body">
      <div class="tech-create-grid">
        <div class="tech-field-card">
          <label for="tech_nik">NIK</label>
          <input id="tech_nik" name="nik" class="form-control rounded-4 tech-field" placeholder="Nomor KTP pelanggan">
        </div>
        <div class="tech-field-card">
          <label for="tech_npwp">NPWP</label>
          <input id="tech_npwp" name="npwp" class="form-control rounded-4 tech-field" placeholder="Opsional">
