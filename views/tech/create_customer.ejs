<div class="t-card mt-3">
  <div class="fw-bold mb-2" style="font-size:14px"><i class="bi bi-clock-history text-info me-2"></i>Pengajuan Terakhir</div>
  <% if (safeRequests.length === 0) { %>
    <div class="text-secondary small">Belum ada pengajuan pelanggan.</div>
  <% } else { %>
    <div class="tech-request-list">
      <% safeRequests.forEach((r, index) => {
        const payload = JSON.parse(String(r.payload_json || '{}') || '{}');
        const statusText = techRequestStatusLabel(r.status);
        const reviewedText = r.reviewed_at ? formatTechRequestTime(r.reviewed_at) : 'Belum diproses';
        const detailId = `techRequestDetail${Number(r.id || index)}${index}`;
      %>
        <div class="tech-request-item">
          <div class="tech-request-main">
            <div class="tech-request-title"><%= r.customer_name %></div>
            <div class="tech-request-sub"><%= r.package_name || 'Tanpa paket' %> &bull; <%= r.customer_phone || '-' %></div>
            <div class="tech-request-meta">
              <span class="tech-request-pill"><i class="bi bi-calendar2-check"></i> Pasang <%= payload.install_date || '-' %></span>
              <span class="tech-request-pill"><i class="bi bi-check2-square"></i> <%= reviewedText %></span>
            </div>
          </div>
          <div class="tech-request-side">
            <span class="badge <%= techRequestStatusClass(r.status) %>"><%= statusText %></span>
            <button type="button" class="btn btn-outline-light tech-request-detail-btn" data-bs-toggle="modal" data-bs-target="#<%= detailId %>" aria-label="Detail pengajuan <%= r.customer_name %>">
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </div>

        <div class="modal fade" id="<%= detailId %>" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content rounded-4" style="background:var(--tech-panel);border:1px solid var(--tech-border);color:var(--tech-text)">
              <div class="modal-header border-0">
                <div>
                  <div class="fw-bold"><%= r.customer_name %></div>
                  <div class="text-secondary small"><%= statusText %> &bull; <%= r.package_name || 'Tanpa paket' %></div>
                </div>
                <button type="button" class="btn-close" style="filter:var(--tech-btn-close-filter)" data-bs-dismiss="modal" aria-label="Tutup"></button>
              </div>
              <div class="modal-body pt-0">
                <div class="tech-request-detail-grid">
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">No HP</span><span class="tech-request-detail-value"><%= r.customer_phone || '-' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Paket</span><span class="tech-request-detail-value"><%= r.package_name || '-' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Mode Secret</span><span class="tech-request-detail-value"><%= payload.create_pppoe_secret ? 'Buat baru saat approval admin' : 'Pakai secret yang sudah ada' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Akun PPPoE</span><span class="tech-request-detail-value"><%= r.pppoe_username || payload.pppoe_username || '-' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Password PPPoE</span><span class="tech-request-detail-value"><%= payload.pppoe_password || '(ikut username)' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Tanggal Pemasangan</span><span class="tech-request-detail-value"><%= payload.install_date || '-' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Jatuh Tempo</span><span class="tech-request-detail-value">Tanggal <%= payload.isolate_day || 10 %> setiap bulan</span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Isolir Otomatis</span><span class="tech-request-detail-value"><%= Number(payload.auto_isolate) === 0 ? 'Tidak aktif' : 'Aktif' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Diajukan</span><span class="tech-request-detail-value"><%= formatTechRequestTime(r.created_at) %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label"><%= r.status === 'approved' ? 'Tanggal Approve' : 'Tanggal Review' %></span><span class="tech-request-detail-value"><%= reviewedText %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Diproses Oleh</span><span class="tech-request-detail-value"><%= r.reviewed_by_name || '-' %></span></div>
                  <div class="tech-request-detail-cell"><span class="tech-request-detail-label">Alamat</span><span class="tech-request-detail-value"><%= payload.address || '-' %></span></div>
                </div>
                <% if (r.review_note) { %>
                  <div class="mt-3 text-secondary small">Catatan review: <%= r.review_note %></div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
  const TECH_CUSTOMER_DRAFT_KEY = 'tech-customer-draft-v2';
  const techDraftShouldReset = <%- JSON.stringify(shouldResetTechDraft) %>;

  function applyPackageProfileHint() {
    const packageSelect = document.getElementById('package_id');
    const profileSelect = document.getElementById('normal_pppoe_profile');
    if (!packageSelect || !profileSelect) return;
    const packageOption = packageSelect.options[packageSelect.selectedIndex];
    const suggestedProfile = String(packageOption?.dataset?.profile || '').trim();
    if (suggestedProfile && !profileSelect.value) {
      const hasOption = Array.from(profileSelect.options).some((opt) => opt.value === suggestedProfile);
      if (hasOption) profileSelect.value = suggestedProfile;
    }
  }

  function setTechUploadPreview(previewId, nameId, sourceUrl, emptyLabel, fileName = '') {
    const preview = document.getElementById(previewId);
    const nameEl = document.getElementById(nameId);
    if (!preview || !nameEl) return;
    preview.replaceChildren();
    if (sourceUrl) {
      const img = document.createElement('img');
      img.src = sourceUrl;
      img.alt = emptyLabel;
      preview.appendChild(img);
      nameEl.textContent = fileName || 'File siap diunggah';
      return;
    }
    const empty = document.createElement('div');
    empty.className = 'tech-upload-preview-empty';
    empty.innerHTML = `<i class="bi ${/rumah/i.test(emptyLabel) ? 'bi-house-door' : 'bi-card-image'}"></i><span>${emptyLabel}</span>`;
    preview.appendChild(empty);
    nameEl.textContent = 'Belum ada file dipilih';
  }

  function formatTechUploadSize(bytes) {
    const size = Math.max(0, Number(bytes || 0) || 0);
    if (size >= 1024 * 1024) return (size / (1024 * 1024)).toFixed(2) + ' MB';
    return Math.max(1, Math.round(size / 1024)) + ' KB';
  }

  function readTechImageDataUrl(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(String(reader.result || ''));
      reader.onerror = () => reject(new Error('Gagal membaca gambar.'));
      reader.readAsDataURL(file);
    });
  }

  function loadTechImageElement(src) {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = () => reject(new Error('Gagal memuat gambar.'));
      img.src = src;
    });
  }

  async function compressTechImageForUpload(file, maxBytes = 500 * 1024) {
    if (!file || !String(file.type || '').startsWith('image/')) return file;
    if (Number(file.size || 0) <= maxBytes) return file;
    const sourceUrl = await readTechImageDataUrl(file);
    const image = await loadTechImageElement(sourceUrl);
    let width = image.naturalWidth || image.width || 1600;
    let height = image.naturalHeight || image.height || 1600;
    const maxDimension = 1600;
    if (Math.max(width, height) > maxDimension) {
      const ratio = maxDimension / Math.max(width, height);
      width = Math.max(1, Math.round(width * ratio));
      height = Math.max(1, Math.round(height * ratio));
    }

    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    if (!ctx) return file;

    let attemptWidth = width;
    let attemptHeight = height;
    let bestBlob = null;

    while (Math.max(attemptWidth, attemptHeight) >= 720) {
      canvas.width = attemptWidth;
      canvas.height = attemptHeight;
      ctx.clearRect(0, 0, attemptWidth, attemptHeight);
      ctx.drawImage(image, 0, 0, attemptWidth, attemptHeight);

      for (const quality of [0.86, 0.8, 0.74, 0.68, 0.62, 0.56, 0.5, 0.44]) {
        const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', quality));
        if (!blob) continue;
        if (!bestBlob || blob.size < bestBlob.size) bestBlob = blob;
        if (blob.size <= maxBytes) {
          return new File([blob], String(file.name || 'upload').replace(/\.[^.]+$/, '') + '.jpg', {
            type: 'image/jpeg',
            lastModified: Date.now()
          });
        }
      }

      if (Math.max(attemptWidth, attemptHeight) <= 720) break;
      attemptWidth = Math.max(1, Math.round(attemptWidth * 0.84));
      attemptHeight = Math.max(1, Math.round(attemptHeight * 0.84));
    }

    if (bestBlob) {
      return new File([bestBlob], String(file.name || 'upload').replace(/\.[^.]+$/, '') + '.jpg', {
        type: 'image/jpeg',
        lastModified: Date.now()
      });
    }
    return file;
  }

  async function replaceTechInputFile(input, file) {
    const compressed = await compressTechImageForUpload(file);
    if (compressed && compressed !== file && typeof DataTransfer !== 'undefined') {
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(compressed);
      input.files = dataTransfer.files;
      return compressed;
    }
    return compressed || file;
  }

  function updateSyncCard(cardId, valueId, status, text) {
    const card = document.getElementById(cardId);
    const value = document.getElementById(valueId);
    if (card) card.className = `tech-sync-card ${status}`;
    if (value) value.textContent = text;
  }

  function updateTechSyncState() {
    const routerSelect = document.getElementById('router_id');
    const routerLabel = routerSelect?.value ? routerSelect.options[routerSelect.selectedIndex]?.textContent || 'Router dipilih' : 'Mengambil dari router default';
    updateSyncCard('syncRouterCard', 'syncRouterState', routerSelect?.value ? 'ok' : 'neutral', routerLabel);

    const isCreateMode = Boolean(document.getElementById('create_pppoe_secret')?.checked);
    updateSyncCard('syncModeCard', 'syncModeState', isCreateMode ? 'ok' : 'neutral', isCreateMode ? 'Buat secret baru' : 'Pakai akun yang ada');

    const pppoeUsername = String(document.getElementById('pppoe_username')?.value || '').trim();
    updateSyncCard('syncPppoeCard', 'syncPppoeState', pppoeUsername ? 'ok' : 'warn', pppoeUsername ? pppoeUsername : 'Belum dipilih');

    const profileValue = String(document.getElementById('normal_pppoe_profile')?.value || '').trim();
    updateSyncCard('syncProfileCard', 'syncProfileState', profileValue ? 'ok' : 'neutral', profileValue || 'Ikuti profile paket');

    const lat = String(document.getElementById('lat')?.value || '').trim();
    const lng = String(document.getElementById('lng')?.value || '').trim();
    updateSyncCard('syncLocationCard', 'syncLocationState', lat && lng ? 'ok' : 'warn', lat && lng ? `${lat}, ${lng}` : 'Belum diambil');
  }

  function updateDocSyncState(type, label) {
    updateSyncCard(
      type === 'house' ? 'syncHouseCard' : 'syncKtpCard',
      type === 'house' ? 'syncHouseState' : 'syncKtpState',
      label ? 'ok' : 'warn',
      label || 'Belum ada foto'
    );
  }

  function bindTechUploadPreview(inputId, previewId, nameId, emptyLabel, syncType) {
    const input = document.getElementById(inputId);
    if (!input) return;
    input.addEventListener('change', async () => {
      const file = input.files && input.files[0];
      if (!file) {
        setTechUploadPreview(previewId, nameId, '', emptyLabel);
        updateDocSyncState(syncType, '');
        saveTechDraft();
        return;
      }
      try {
        const optimizedFile = await replaceTechInputFile(input, file);
        const previewUrl = await readTechImageDataUrl(optimizedFile);
        const label = `${optimizedFile.name || 'File dipilih'} / ${formatTechUploadSize(optimizedFile.size)} / siap upload`;
        setTechUploadPreview(previewId, nameId, previewUrl, emptyLabel, label);
        updateDocSyncState(syncType, `${formatTechUploadSize(optimizedFile.size)} / siap upload`);
      } catch (_error) {
        const previewUrl = await readTechImageDataUrl(file);
        const label = `${file.name || 'File dipilih'} / ${formatTechUploadSize(file.size)}`;
        setTechUploadPreview(previewId, nameId, previewUrl, emptyLabel, label);
        updateDocSyncState(syncType, formatTechUploadSize(file.size));
      }
      saveTechDraft();
    });
  }

  function setSecretMode(isCreateMode) {
    const createSecret = document.getElementById('create_pppoe_secret');
    if (createSecret) createSecret.checked = Boolean(isCreateMode);
    toggleSecretMode();
  }

  function toggleSecretMode() {
    const createSecret = document.getElementById('create_pppoe_secret');
    const usernameInput = document.getElementById('pppoe_username');
    const passwordInput = document.getElementById('pppoe_password');
    const hint = document.getElementById('pppoeHint');
    const modeHint = document.getElementById('secretModeHint');
    const isCreateMode = Boolean(createSecret?.checked);
    document.getElementById('techModeExisting')?.classList.toggle('active', !isCreateMode);
    document.getElementById('techModeNew')?.classList.toggle('active', isCreateMode);

    if (usernameInput) {
      usernameInput.setAttribute('list', isCreateMode ? '' : 'pppoeList');
      usernameInput.placeholder = isCreateMode ? 'Masukkan username secret baru' : 'Pilih / cari akun internet';
    }
    if (passwordInput) {
      passwordInput.placeholder = isCreateMode ? 'Isi password secret baru atau kosongkan = sama dengan username' : 'Kosongkan bila sama dengan username';
    }
    if (hint) {
      hint.innerText = isCreateMode
        ? 'Isi username baru. Secret akan dibuat saat admin menyetujui pengajuan.'
        : 'Pilih akun PPPoE yang sudah tersedia di MikroTik.';
    }
    if (modeHint) {
      modeHint.innerText = isCreateMode
        ? 'Mode secret baru aktif.'
        : 'Mode memakai akun yang sudah ada.';
    }
    updateTechSyncState();
    saveTechDraft();
  }

  async function getLocation() {
    if (!navigator.geolocation) return alert('Geolocation tidak didukung di perangkat ini.');
    try {
      if (window.median?.android?.geoLocation?.promptLocationServices) {
        window.median.android.geoLocation.promptLocationServices();
        await new Promise((resolve) => setTimeout(resolve, 700));
      }
    } catch (_) {}
    navigator.geolocation.getCurrentPosition((pos) => {
      document.getElementById('lat').value = pos.coords.latitude;
      document.getElementById('lng').value = pos.coords.longitude;
      updateTechSyncState();
      saveTechDraft();
    }, (err) => {
      alert('Gagal mengambil lokasi: ' + (err.message || err));
    }, { enableHighAccuracy: true, timeout: 8000 });
  }

  function openMapPreview() {
    const lat = String(document.getElementById('lat')?.value || '').trim();
    const lng = String(document.getElementById('lng')?.value || '').trim();
    if (!lat || !lng) {
      alert('Ambil lokasi dulu sebelum membuka peta.');
      return;
    }
    window.open(`https://www.google.com/maps?q=${encodeURIComponent(`${lat},${lng}`)}`, '_blank', 'noopener');
  }

  function toggleOdpEdit() {
    const v = document.getElementById('update_odp').value;
    document.getElementById('odpEdit').style.display = v === '1' ? 'block' : 'none';
    saveTechDraft();
  }

  function copyCustomerToOdp() {
    document.getElementById('odp_lat').value = document.getElementById('lat').value;
    document.getElementById('odp_lng').value = document.getElementById('lng').value;
    saveTechDraft();
  }

  async function onOdpChanged() {
    const sel = document.getElementById('odp_id');
    const opt = sel.options[sel.selectedIndex];
    const odpId = sel.value;
    document.getElementById('odp_lat').value = opt?.dataset?.lat || '';
    document.getElementById('odp_lng').value = opt?.dataset?.lng || '';
    document.getElementById('odp_pon_port').value = opt?.dataset?.pon || '';
    document.getElementById('odp_port_capacity').value = opt?.dataset?.cap || 16;

    const infoEl = document.getElementById('odpInfo');
    infoEl.innerText = '';
    if (!odpId) {
      saveTechDraft();
      return;
    }
    try {
      const res = await fetch(`/tech/api/odps/${encodeURIComponent(odpId)}/ports`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Gagal ambil info ODP');
      const used = Array.isArray(data.usedPorts) ? data.usedPorts.join(', ') : '';
      infoEl.innerText = `Port terpakai: ${data.usedCount}/${data.capacity} / Sisa: ${data.remaining}${used ? ' / (' + used + ')' : ''}`;
    } catch (e) {
      infoEl.innerText = e.message;
    }
    saveTechDraft();
  }

  async function loadPppoeUsers() {
    const routerId = document.getElementById('router_id')?.value || '';
    const createSecret = document.getElementById('create_pppoe_secret');
    const hint = document.getElementById('pppoeHint');
    const list = document.getElementById('pppoeList');
    if (createSecret?.checked) {
      if (list) list.replaceChildren();
      if (hint) hint.innerText = 'Mode secret baru aktif. Tidak perlu mengambil daftar akun dari MikroTik.';
      updateTechSyncState();
      return;
    }
    if (hint) hint.innerText = routerId ? 'Memuat akun internet...' : 'Memuat akun internet dari router default...';
    if (list) list.replaceChildren();
    updateSyncCard('syncPppoeCard', 'syncPppoeState', 'neutral', 'Memuat akun...');
    try {
      const url = routerId ? `/tech/api/mikrotik/pppoe-users?routerId=${encodeURIComponent(routerId)}` : `/tech/api/mikrotik/pppoe-users`;
      const res = await fetch(url);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Gagal memuat akun PPPoE');
      const users = Array.isArray(data) ? data : [];
      if (list) {
        list.replaceChildren();
        users.filter((u) => u && u.name).forEach((u) => {
          const option = document.createElement('option');
          option.value = String(u.name);
          list.appendChild(option);
        });
      }
      if (hint) hint.innerText = users.length ? `Tersedia ${users.length} akun PPPoE yang belum dipakai.` : 'Tidak ada akun PPPoE tersedia.';
      updateTechSyncState();
    } catch (e) {
      if (hint) hint.innerText = e.message;
      updateSyncCard('syncPppoeCard', 'syncPppoeState', 'warn', 'Gagal memuat akun');
    }
  }

  async function loadPppoeProfiles() {
    const routerId = document.getElementById('router_id')?.value || '';
    const normalSel = document.getElementById('normal_pppoe_profile');
    const isolirSel = document.getElementById('isolir_profile');
    const previousNormal = normalSel?.value || '';
    const previousIsolir = isolirSel?.value || 'BEATISOLIR';

    if (normalSel) normalSel.replaceChildren();
    if (isolirSel) isolirSel.replaceChildren();
    updateSyncCard('syncProfileCard', 'syncProfileState', 'neutral', 'Memuat profile...');

    try {
      const url = routerId ? `/tech/api/mikrotik/pppoe-profiles?routerId=${encodeURIComponent(routerId)}` : `/tech/api/mikrotik/pppoe-profiles`;
      const res = await fetch(url);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Gagal memuat profile PPPoE');
      const profiles = (Array.isArray(data) ? data : []).filter((p) => p && p.name);

      if (normalSel) {
        const defaultNormal = document.createElement('option');
        defaultNormal.value = '';
        defaultNormal.textContent = 'Ikuti profile paket';
        normalSel.appendChild(defaultNormal);
      }

      if (isolirSel) {
        const defaultIsolir = document.createElement('option');
        defaultIsolir.value = 'BEATISOLIR';
        defaultIsolir.textContent = 'BEATISOLIR';
        isolirSel.appendChild(defaultIsolir);
      }

      profiles.forEach((p) => {
        const name = String(p.name);
        if (normalSel && name !== 'BEATISOLIR') {
          const option = document.createElement('option');
          option.value = name;
          option.textContent = name;
          normalSel.appendChild(option);
        }
        if (isolirSel && name !== 'BEATISOLIR') {
          const option = document.createElement('option');
          option.value = name;
          option.textContent = name;
          isolirSel.appendChild(option);
        }
      });

      if (normalSel) normalSel.value = previousNormal || '';
      if (isolirSel) isolirSel.value = previousIsolir || 'BEATISOLIR';
      applyPackageProfileHint();
      updateTechSyncState();
    } catch (_e) {
      if (normalSel) {
        const option = document.createElement('option');
        option.value = '';
        option.textContent = 'Ikuti profile paket';
        normalSel.appendChild(option);
      }
      if (isolirSel) {
        const option = document.createElement('option');
        option.value = 'BEATISOLIR';
        option.textContent = 'BEATISOLIR';
        isolirSel.appendChild(option);
      }
      updateSyncCard('syncProfileCard', 'syncProfileState', 'warn', 'Gagal memuat profile');
    }
  }

  function collectTechDraftPayload() {
    const form = document.getElementById('techCustomerForm');
    const payload = {};
    Array.from(form.querySelectorAll('input, select, textarea')).forEach((field) => {
      if (!field.name) return;
      if (field.type === 'file') return;
      if (field.type === 'checkbox') {
        payload[field.name] = field.checked ? field.value : '';
        return;
      }
      payload[field.name] = field.value;
    });
    return payload;
  }

  function saveTechDraft(showToast = false) {
    try {
      localStorage.setItem(TECH_CUSTOMER_DRAFT_KEY, JSON.stringify({
        savedAt: new Date().toISOString(),
        data: collectTechDraftPayload()
      }));
      if (showToast) alert('Draft tersimpan di perangkat ini.');
    } catch (_e) {}
  }

  function restoreTechDraft() {
    if (techDraftShouldReset) {
      localStorage.removeItem(TECH_CUSTOMER_DRAFT_KEY);
      return;
    }
    try {
      const raw = localStorage.getItem(TECH_CUSTOMER_DRAFT_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      const data = parsed && parsed.data ? parsed.data : {};
      Object.entries(data).forEach(([name, value]) => {
        const field = document.querySelector(`[name="${name}"]`);
        if (!field) return;
        if (field.type === 'checkbox') {
          field.checked = Boolean(value);
        } else {
          field.value = value == null ? '' : String(value);
        }
      });
    } catch (_e) {}
  }

  function setDefaultInstallDate() {
    const installDate = document.getElementById('install_date');
    if (!installDate || installDate.value) return;
    const now = new Date();
    const localDate = new Date(now.getTime() - (now.getTimezoneOffset() * 60000)).toISOString().slice(0, 10);
    installDate.value = localDate;
  }

  function bindTechDraftAutosave() {
    const form = document.getElementById('techCustomerForm');
    let timer = null;
    form.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(saveTechDraft, 250);
      updateTechSyncState();
    });
    form.addEventListener('change', () => {
      saveTechDraft();
      updateTechSyncState();
    });
  }

  document.getElementById('package_id')?.addEventListener('change', () => {
    applyPackageProfileHint();
    updateTechSyncState();
  });

  restoreTechDraft();
  setDefaultInstallDate();
  bindTechDraftAutosave();
  bindTechUploadPreview('tech_house_photo_file', 'tech_house_preview', 'tech_house_preview_name', 'Preview Rumah', 'house');
  bindTechUploadPreview('tech_ktp_photo_file', 'tech_ktp_preview', 'tech_ktp_preview_name', 'Preview KTP', 'ktp');
  toggleSecretMode();
  loadPppoeUsers();
  loadPppoeProfiles();
  toggleOdpEdit();
  updateTechSyncState();

  document.getElementById('techCustomerForm')?.addEventListener('submit', () => {
    localStorage.setItem('tech-customer-last-submit', String(Date.now()));
  });
</script>

