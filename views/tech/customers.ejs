<%- include('partials/header') %>

<style>
  .tech-customer-hero{display:grid;gap:14px;padding:16px;background:linear-gradient(145deg, rgba(111,141,255,.18), rgba(77,189,255,.08)), var(--tech-panel)}
  .tech-customer-hero-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}
  .tech-customer-hero-copy h2{font-size:22px;font-weight:900;letter-spacing:-.04em;line-height:1.05;margin:0 0 6px}
  .tech-customer-hero-copy p{margin:0;color:var(--tech-muted);font-size:13px;line-height:1.55}
  .tech-customer-kicker{display:inline-flex;align-items:center;gap:6px;padding:7px 11px;border-radius:999px;background:var(--tech-primary-soft);border:1px solid var(--tech-border);color:var(--tech-primary);font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}
  .tech-customer-add-btn{min-height:48px;padding:0 16px;border-radius:16px;font-weight:800;display:inline-flex;align-items:center;gap:8px;white-space:nowrap}
  .tech-customer-toolbar{display:grid;grid-template-columns:minmax(0,1fr) 132px 48px 48px;gap:8px;align-items:center;margin-bottom:12px}
  .tech-customer-toolbar .form-control,
  .tech-customer-toolbar .form-select{background:var(--tech-input-bg);color:var(--tech-text);border-color:var(--tech-border)}
  .tech-customer-toolbar .btn{height:48px;border-radius:16px}
  .tech-customer-list{display:grid;gap:8px}
  .tech-customer-card{display:grid;gap:8px;padding:12px;background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025));border-radius:22px;box-shadow:inset 0 1px 0 rgba(255,255,255,.04)}
  .tech-customer-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
  .tech-customer-name{font-size:15px;font-weight:900;line-height:1.15}
  .tech-customer-sub{font-size:11px;color:var(--tech-muted);margin-top:4px;line-height:1.4}
  .tech-customer-chip-row{display:flex;gap:6px;flex-wrap:wrap}
  .tech-customer-chip-row .badge-status{padding:7px 11px}
  .tech-customer-meta{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
  .tech-customer-cell{padding:10px;border-radius:17px;background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.025));border:1px solid var(--tech-border);min-height:64px;box-shadow:inset 0 1px 0 rgba(255,255,255,.04)}
  .tech-customer-cell .label{font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:var(--tech-muted);margin-bottom:3px}
  .tech-customer-cell .value{font-size:11px;font-weight:800;line-height:1.28;word-break:break-word}
  .tech-customer-address{display:flex;align-items:flex-start;gap:6px;font-size:10px;color:var(--tech-muted);line-height:1.28}
  .tech-customer-address span{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
  .tech-customer-actions{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:6px}
  .tech-customer-actions .btn{border-radius:16px;min-height:48px;font-weight:800;padding:6px 4px;border-width:1px;box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .tech-action-mini{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;line-height:1}
  .tech-action-mini i{font-size:14px}
  .tech-action-mini small{font-size:9px;font-weight:800;letter-spacing:.02em}
  html[data-theme="dark"] .tech-customer-card{
    background:linear-gradient(180deg, rgba(30,41,59,.82), rgba(15,23,42,.74));
    border:1px solid var(--tech-border);
    color:var(--tech-text);
  }
  html[data-theme="dark"] .tech-customer-name,
  html[data-theme="dark"] .tech-customer-cell .value{
    color:var(--tech-text) !important;
  }
  html[data-theme="dark"] .tech-customer-sub,
  html[data-theme="dark"] .tech-customer-address,
  html[data-theme="dark"] .tech-customer-cell .label{
    color:#b6c3d8 !important;
  }
  html[data-theme="dark"] .tech-customer-cell{
    background:rgba(15,23,42,.66);
    border-color:rgba(148,163,184,.20);
  }
  html[data-theme="dark"] .tech-customer-actions .btn .tech-action-mini small{
    color:inherit !important;
  }
  html[data-theme="dark"] .tech-customer-actions .btn-outline-secondary:not(:disabled){
    color:#d8e3f8;
    border-color:rgba(203,213,225,.34);
  }
  html[data-theme="dark"] .tech-customer-actions .btn:disabled{
    color:#aebbd0 !important;
    border-color:rgba(148,163,184,.22) !important;
    background:rgba(15,23,42,.54) !important;
    opacity:1;
  }
  @media (max-width: 576px){
    .tech-customer-hero{padding:14px}
    .tech-customer-hero-head{flex-direction:column;align-items:stretch}
    .tech-customer-hero-copy h2{font-size:20px}
    .tech-customer-add-btn{width:100%;justify-content:center}
    .tech-customer-toolbar{grid-template-columns:minmax(0,1fr) 112px 44px 44px}
    .tech-customer-meta{grid-template-columns:repeat(2,minmax(0,1fr));gap:6px}
    .tech-customer-card{padding:10px;gap:7px}
    .tech-customer-cell{padding:8px;min-height:58px}
    .tech-customer-cell .value{font-size:10.5px}
    .tech-customer-actions .btn{min-height:44px}
    .tech-customer-name{font-size:13px}
  }
</style>

<div class="t-card tech-customer-hero">
  <div class="tech-customer-hero-head">
    <div class="tech-customer-hero-copy">
      <span class="tech-customer-kicker"><i class="bi bi-people"></i>Menu Pelanggan</span>
      <h2>Data Pelanggan</h2>
      <p>Lihat status pelanggan, buka detail, langsung kirim WhatsApp, dan tambah pengajuan pelanggan baru dari satu layar mobile yang lebih simpel.</p>
    </div>
    <a href="/tech/customers/new" class="btn btn-primary tech-customer-add-btn">
      <i class="bi bi-plus-lg"></i>
      <span>Tambah Pelanggan</span>
    </a>
  </div>
</div>

<div class="t-card">
  <form class="tech-customer-toolbar" method="GET" action="/tech/customers">
    <input type="text" class="form-control rounded-4" name="search" value="<%= search || '' %>" placeholder="Cari nama, nomor, PPPoE, alamat">
    <select class="form-select rounded-4" name="status">
      <option value="" <%= !filterStatus ? 'selected' : '' %>>Semua Status</option>
      <option value="active" <%= filterStatus === 'active' ? 'selected' : '' %>>Aktif</option>
      <option value="suspended" <%= filterStatus === 'suspended' ? 'selected' : '' %>>Suspend</option>
      <option value="inactive" <%= filterStatus === 'inactive' ? 'selected' : '' %>>Nonaktif</option>
    </select>
    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
    <% if (search || filterStatus) { %>
      <a href="/tech/customers" class="btn btn-outline-secondary"><i class="bi bi-arrow-counterclockwise"></i></a>
    <% } %>
  </form>
</div>

<div class="tech-customer-list">
  <% if (!customers || customers.length === 0) { %>
    <div class="t-card text-center text-secondary">Belum ada pelanggan yang cocok.</div>
  <% } %>
  <% (customers || []).forEach((c) => { %>
    <% const techRouteHref = (c.lat && c.lng) ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${c.lat},${c.lng}`)}` : ''; %>
    <div class="t-card tech-customer-card">
      <div class="tech-customer-head">
        <div>
          <div class="tech-customer-name"><%= c.name %></div>
          <div class="tech-customer-sub"><%= c.phone || '-' %> &bull; <%= c.pppoe_username || c.genieacs_tag || '-' %></div>
        </div>
        <span class="badge-status <%= c.status === 'active' ? 'badge-resolved' : (c.status === 'suspended' ? 'badge-open' : 'badge-in_progress') %>">
          <%= c.status === 'active' ? 'Aktif' : (c.status === 'suspended' ? 'Suspend' : 'Nonaktif') %>
        </span>
      </div>

      <div class="tech-customer-chip-row">
        <span class="badge-status <%= c.unpaid_count > 0 ? 'badge-open' : 'badge-resolved' %>"><%= c.unpaid_count > 0 ? `${c.unpaid_count} tagihan` : 'Lunas' %></span>
        <span class="badge-status badge-neutral">Traffic <%= (((Number(c.bytes_in || 0) || 0) + (Number(c.bytes_out || 0) || 0)) / (1024 * 1024 * 1024)).toFixed(2) %> GB</span>
      </div>

      <div class="tech-customer-meta">
        <div class="tech-customer-cell">
          <div class="label">Paket</div>
          <div class="value"><%= c.package_name || '-' %><% if (c.package_name) { %><br><span style="font-size:10px;color:var(--tech-muted);font-weight:700"><%= (Number(c.speed_down || 0) / 1000).toFixed(0) %>/<%= (Number(c.speed_up || 0) / 1000).toFixed(0) %> Mbps</span><% } %></div>
        </div>
        <div class="tech-customer-cell">
          <div class="label">Tagihan</div>
          <div class="value"><%= c.unpaid_count > 0 ? `${c.unpaid_count} belum lunas` : 'Lunas' %></div>
        </div>
        <div class="tech-customer-cell">
          <div class="label">Status Bayar</div>
          <div class="value"><%= c.unpaid_count > 0 ? 'Belum lunas' : 'Sudah lunas' %></div>
        </div>
        <div class="tech-customer-cell">
          <div class="label">Tag ONU</div>
          <div class="value"><%= c.genieacs_tag || '-' %></div>
        </div>
      </div>

      <div class="tech-customer-address">
        <i class="bi bi-geo-alt"></i>
        <span><%= c.address || '-' %></span>
      </div>

      <div class="tech-customer-actions">
        <button type="button" class="btn btn-primary" onclick="openCustomerDetail(<%= c.id %>)" title="Detail">
          <span class="tech-action-mini"><i class="bi bi-eye"></i><small>Detail</small></span>
        </button>
        <% if (c.unpaid_count > 0) { %>
          <button type="button" class="btn btn-success" data-customer-name="<%= String(c.name || '').replace(/"/g, '&quot;') %>" data-unpaid-count="<%= Number(c.unpaid_count || 0) %>" onclick="techQuickMarkPaid(<%= c.id %>, this)" title="Lunas">
            <span class="tech-action-mini"><i class="bi bi-cash-coin"></i><small>Lunas</small></span>
          </button>
        <% } else { %>
          <button type="button" class="btn btn-outline-secondary" disabled title="Lunas">
            <span class="tech-action-mini"><i class="bi bi-check2-circle"></i><small>Lunas</small></span>
          </button>
        <% } %>
        <% if (c.phone) { %>
          <a class="btn btn-outline-success" href="https://wa.me/<%= encodeURIComponent(String(c.phone || '').replace(/\D/g, '')) %>" target="_blank" rel="noopener" title="WhatsApp"><span class="tech-action-mini"><i class="bi bi-whatsapp"></i><small>WA</small></span></a>
        <% } else { %>
          <button type="button" class="btn btn-outline-secondary" disabled title="WhatsApp"><span class="tech-action-mini"><i class="bi bi-whatsapp"></i><small>WA</small></span></button>
        <% } %>
        <% if (techRouteHref) { %>
          <a class="btn btn-outline-info" href="<%= techRouteHref %>" target="_blank" rel="noopener" title="Rute">
            <span class="tech-action-mini"><i class="bi bi-sign-turn-right"></i><small>Rute</small></span>
          </a>
        <% } else { %>
          <button type="button" class="btn btn-outline-secondary" disabled title="Rute">
            <span class="tech-action-mini"><i class="bi bi-sign-turn-right"></i><small>Rute</small></span>
          </button>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<%- include('../partials/customer_detail_modal', {
  scope: 'tech',
  allowPayment: true,
  allowDeviceActions: true,
  detailApiBase: '/tech/api/customers',
  deviceApiBase: '/tech/api/device',
  paymentApiBase: '/tech/api/customers'
}) %>

<script>
  async function techQuickMarkPaid(customerId, button) {
    const id = Number(customerId || 0) || 0;
    if (!id || !button) return;
    const customerName = String(button.dataset.customerName || 'pelanggan').trim() || 'pelanggan';
    const unpaidCount = Number(button.dataset.unpaidCount || 0) || 0;
    const message = unpaidCount > 1
      ? `Lunaskan tagihan paling awal untuk ${customerName}? Masih ada ${unpaidCount} tagihan belum lunas.`
      : `Lunaskan tagihan ${customerName}?`;
    if (!confirm(message)) return;

    const originalHtml = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="tech-action-mini"><i class="bi bi-hourglass-split"></i><small>Proses</small></span>';
    try {
      const res = await fetch(`/tech/api/customers/${encodeURIComponent(String(id))}/pay-unpaid-first`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'same-origin',
        cache: 'no-store',
        body: JSON.stringify({ notes: 'Lunas oleh teknisi' })
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || json?.success === false) throw new Error(json?.error || 'Gagal melunaskan tagihan');
      alert('Tagihan berhasil dilunasi.');
      window.location.reload();
    } catch (error) {
      alert(error.message || String(error));
      button.disabled = false;
      button.innerHTML = originalHtml;
    }
  }
</script>

<%- include('partials/bottom_nav') %>
