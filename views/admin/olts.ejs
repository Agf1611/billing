  document.getElementById('search-container').style.display = 'none';
  tbody.replaceChildren();
  tbody.insertAdjacentHTML('beforeend', `<tr><td colspan="9" class="table-empty-cell">
    <div class="empty-state">
      <i class="bi bi-exclamation-triangle"></i>
      <p>${stats.error || I18N.noOnuData}</p>
      ${stats.error ? '<button class="btn btn-sm btn-p mt-2" onclick="refreshCurrentOlt()">' + I18N.tryAgain + '</button>' : ''}
    </div>
  </td></tr>`);
  applyOnuFilters();
}

async function fetchOltStatsJson(id, options = {}) {
  const { full = false, timeoutMs = full ? 65000 : 30000, section = '' } = options;
  const controller = new AbortController();
  const timeoutLabel = full ? I18N.fullLoadTimeout : I18N.summaryLoadTimeout;
  let timer = null;
  try {
    const stats = await Promise.race([
      (async () => {
        const params = new URLSearchParams();
        if (full) params.set('full', 'true');
        if (section) params.set('section', section);
        const url = `/admin/olts/${id}/stats${params.toString() ? `?${params.toString()}` : ''}`;
        const res = await fetch(url, { signal: controller.signal });
        const payload = await res.json().catch(() => null);
        if (!res.ok) {
          throw new Error(payload?.error || I18N.serverConnectFailed);
        }
        return payload || {};
      })(),
      new Promise((_, reject) => {
        timer = setTimeout(() => {
          try { controller.abort(); } catch (_error) {}
          reject(new Error(timeoutLabel));
        }, timeoutMs);
      })
    ]);

    return stats;
  } catch (e) {
    if (e && e.name === 'AbortError') throw new Error(timeoutLabel);
    throw e;
  } finally {
    if (timer) clearTimeout(timer);
  }
}

async function loadOltDashboard(id) {
  if (!id) return;

  const overlay = document.getElementById('loading-overlay');
  const loadToken = ++activeOltLoadToken;
  overlay.style.display = 'flex';
  renderOnuLoadingState();

  try {
    const summaryStats = await fetchOltStatsJson(id, { full: false, timeoutMs: 30000 });
    if (loadToken !== activeOltLoadToken) return;
    updateOltSummary(summaryStats);
  } catch (e) {
    if (loadToken !== activeOltLoadToken) return;
    resetOltSummary(e.message || I18N.serverConnectFailed);
  }

  overlay.style.display = 'none';

  fetchOltStatsJson(id, { full: true, section: 'table', timeoutMs: 65000 })
    .then((fullStats) => {
      if (loadToken !== activeOltLoadToken) return;
      renderCardList();
      renderUnauthList({}, id);
      renderOnuTable(fullStats, id);
    })
    .catch((e) => {
      if (loadToken !== activeOltLoadToken) return;
      renderOnuError(`${I18N.errorPrefix}${e.message}`);
    });
}

function formatStatus(statusVal) {
  const v = String(statusVal || '').trim();
  if (!v) return '';
  if (v.toLowerCase() === 'online') return I18N.statusOnline;
  if (v.toLowerCase() === 'offline') return I18N.statusOffline;
  return v;
}

function handleOltChange() {
  const id = document.getElementById('olt-selector').value;
  setOnuFilter('all', { silent: true });
  if (id) loadOltDashboard(id);
}

function refreshCurrentOlt() {
  handleOltChange();
}

function filterOnuTable() {
  applyOnuFilters();
}

function setOnuFilter(filterName, options = {}) {
  activeOnuFilter = String(filterName || 'all').trim().toLowerCase() || 'all';
  document.querySelectorAll('[data-stat-filter]').forEach((card) => {
    const isActive = card.dataset.statFilter === activeOnuFilter;
    card.classList.toggle('active', isActive);
  });
  if (!options.silent) {
    applyOnuFilters();
  }
}

function applyOnuFilters() {
  const input = document.getElementById('onu-search');
  const searchTerm = String(input?.value || '').toLowerCase().trim();
  const rows = document.querySelectorAll('#onu-table-body tr');

  rows.forEach(row => {
    if (row.querySelector('.empty-state')) {
      row.style.display = '';
      return;
    }

    const text = row.innerText.toLowerCase();
    const filterCell = row.querySelector('[data-onu-filter]');
    const rowFilter = filterCell?.dataset?.onuFilter || '';
    const rowWeak = filterCell?.dataset?.onuWeak === 'true';

    const matchesSearch = !searchTerm || text.includes(searchTerm);
    const matchesStat =
      activeOnuFilter === 'all' ||
      (activeOnuFilter === 'online' && rowFilter === 'online') ||
      (activeOnuFilter === 'offline' && rowFilter === 'offline') ||
      (activeOnuFilter === 'weak' && rowWeak);

    row.style.display = matchesSearch && matchesStat ? '' : 'none';
  });
}

async function renameOnuPrompt(oltId, index, oldName) {
  const newName = prompt(I18N.renamePrompt, oldName);
  if (!newName || newName === oldName) return;
  try {
    const res = await fetch(`/admin/olts/${oltId}/onu/${index}/rename`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ name: newName })
    });
    const data = await res.json();
    if (data.success) { refreshCurrentOlt(); } else { alert(I18N.failedPrefix + data.error); }
  } catch (e) { alert(I18N.errorPrefix + e.message); }
}

async function rebootOnu(oltId, index) {
  if (!confirm(I18N.confirmReboot)) return;
  try {
    const res = await fetch(`/admin/olts/${oltId}/onu/${index}/reboot`, { method: 'POST' });
    const data = await res.json();
    if (data.success) { alert(I18N.rebootSent); } else { alert(I18N.failedPrefix + data.error); }
  } catch (e) { alert(I18N.errorPrefix + e.message); }
}

async function authorizeOnuPrompt(oltId, index, sn) {
  const name = prompt('Masukkan Nama Pelanggan:', '');
  if (!name) return;
  const vlan = prompt('Masukkan VLAN ID:', '100');
  if (!vlan) return;

  const overlay = document.getElementById('loading-overlay');
  overlay.style.display = 'flex';

  try {
    const res = await fetch(`/admin/olts/${oltId}/onu/authorize`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ index, sn, name, vlan })
    });
    const data = await res.json();
    if (data.success) {
      alert('ONU berhasil diotorisasi!');
      refreshCurrentOlt();
    } else {
      alert(I18N.failedPrefix + data.error);
    }
  } catch (e) {
    alert(I18N.errorPrefix + e.message);
  } finally {
    overlay.style.display = 'none';
  }
}

function pushVlanPrompt(oltId, index, name) {
  document.getElementById('vlan_olt_id').value = oltId;
  document.getElementById('vlan_onu_index').value = index;
  document.getElementById('vlan_onu_name').value = `${name || '-'} (${index})`;
  document.getElementById('vlan_dry_run').checked = true;
  const result = document.getElementById('vlan_push_result');
  result.style.display = 'none';
  result.textContent = '';
  openModal('vlanPushModal');
}

async function submitVlanPush(e) {
  e.preventDefault();
  const oltId = document.getElementById('vlan_olt_id').value;
  const dryRun = document.getElementById('vlan_dry_run').checked;
  const lans = Array.from(document.querySelectorAll('input[name="vlan_lan"]:checked')).map(cb => cb.value);
  const ssids = Array.from(document.querySelectorAll('input[name="vlan_ssid"]:checked')).map(cb => cb.value);
  const result = document.getElementById('vlan_push_result');

  if (!lans.length && !ssids.length) {
    alert('Pilih minimal 1 LAN atau SSID.');
    return;
  }
  if (!dryRun && !confirm('Kirim VLAN ke OLT sekarang? Pastikan command template sudah sesuai Hioso.')) {
    return;
  }

  const payload = {
    index: document.getElementById('vlan_onu_index').value,
    name: document.getElementById('vlan_onu_name').value,
    vlan: document.getElementById('vlan_id').value,
    vlan_mode: document.getElementById('vlan_mode').value,
    lans: lans.join(','),
    ssids: ssids.join(','),
    dry_run: dryRun ? 'true' : 'false',
    command_template: document.getElementById('vlan_command_template').value
  };

  const overlay = document.getElementById('loading-overlay');
  overlay.style.display = 'flex';
  result.style.display = 'none';
  result.textContent = '';

  try {
    const res = await fetch(`/admin/olts/${oltId}/onu/push-vlan`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(payload)
    });
    const data = await res.json().catch(() => null);
    if (!res.ok || !data?.success) {
      throw new Error(data?.error || I18N.serverConnectFailed);
    }

    const commands = Array.isArray(data.output?.commands) ? data.output.commands.join('\n') : '';
    result.textContent = `${data.message}\n\nCommand:\n${commands}\n\nOutput:\n${data.output?.output || '-'}`;
    result.style.display = 'block';
    if (!data.output?.dryRun) {
      setTimeout(() => {
        closeModal('vlanPushModal');
        refreshCurrentOlt();
      }, 900);
    }
  } catch (err) {
    result.textContent = `${I18N.failedPrefix}${err.message}`;
    result.style.display = 'block';
  } finally {
    overlay.style.display = 'none';
  }
}

function configureWanPrompt(oltId, index, name, sn) {
  document.getElementById('wan_olt_id').value = oltId;
  document.getElementById('wan_onu_index').value = index;
  document.getElementById('wan_onu_name').value = name;
  document.getElementById('wan_onu_sn').value = sn;
  document.getElementById('wan_method').value = 'telnet';
  document.getElementById('wan_bootstrap_acs').checked = true;
  document.getElementById('wan_reboot_after_apply').checked = true;
  document.getElementById('wan_acs_url').value = oltDefaults?.dataset?.tr069AcsUrl || '';
  document.getElementById('wan_acs_username').value = oltDefaults?.dataset?.tr069AcsUsername || '';
  document.getElementById('wan_acs_password').value = oltDefaults?.dataset?.tr069AcsPassword || '';
  document.getElementById('wan_periodic_enable').checked = (oltDefaults?.dataset?.tr069PeriodicEnable || 'true') !== 'false';
  document.getElementById('wan_periodic_interval').value = oltDefaults?.dataset?.tr069PeriodicInterval || '300';
  onWanMethodChange();
  openModal('wanConfigModal');
}

function onWanMethodChange() {
  const m = document.getElementById('wan_method').value;
  const hint = document.getElementById('wan_goapi_hint');
  const extra = document.getElementById('wan_goapi_extra');
  const tr069 = document.getElementById('wan_tr069_extra');
  const modeSel = document.getElementById('wan_mode');
  if (hint) hint.style.display = m === 'go-api' ? 'block' : 'none';
  if (extra) extra.style.display = m === 'go-api' ? 'block' : 'none';
  if (tr069) tr069.style.display = m === 'tr069' ? 'block' : 'none';
  if (m === 'go-api' && modeSel) {
    modeSel.value = 'Bridge';
    toggleWanFields();
  }
}

function toggleWanFields() {
  const mode = document.getElementById('wan_mode').value;
  document.getElementById('pppoe_fields').style.display = mode === 'PPPoE' ? 'block' : 'none';
}

async function submitWanConfig(e) {
  e.preventDefault();
  const oltId = document.getElementById('wan_olt_id').value;
  const method = document.getElementById('wan_method').value;
  const mode = document.getElementById('wan_mode').value;
  if (method === 'go-api' && mode !== 'Bridge') {
    alert('Metode go-api-c320 pada integrasi ini hanya untuk mode Bridge + VLAN. Pilih Bridge atau ganti metode.');
    return;
  }
  const lans = Array.from(document.querySelectorAll('input[name="wan_lan"]:checked')).map(cb => cb.value);
  const ssids = Array.from(document.querySelectorAll('input[name="wan_ssid"]:checked')).map(cb => cb.value);
  
  const payload = {
    index: document.getElementById('wan_onu_index').value,
    sn: document.getElementById('wan_onu_sn').value,
    method,
    mode,
    vlan: document.getElementById('wan_vlan').value,
    username: document.getElementById('wan_username').value,
    password: document.getElementById('wan_password').value,
    lans: lans.join(','),
    ssids: ssids.join(','),
    bootstrap_acs: document.getElementById('wan_bootstrap_acs').checked ? 'true' : 'false',
    acs_url: document.getElementById('wan_acs_url').value,
    acs_username: document.getElementById('wan_acs_username').value,
    acs_password: document.getElementById('wan_acs_password').value,
    periodic_enable: document.getElementById('wan_periodic_enable').checked ? 'true' : 'false',
    periodic_interval: document.getElementById('wan_periodic_interval').value,
    reboot_after_apply: document.getElementById('wan_reboot_after_apply').checked ? 'true' : 'false'
  };
  if (method === 'go-api') {
    payload.cvlan = document.getElementById('wan_cvlan').value;
    payload.vlan_mode = document.getElementById('wan_vlan_mode').value;
    payload.priority = document.getElementById('wan_priority').value;
  }

  const overlay = document.getElementById('loading-overlay');
  overlay.style.display = 'flex';

  try {
    const res = await fetch(`/admin/olts/${oltId}/onu/configure-wan`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(payload)
    });
    const data = await res.json();
    if (data.success) {
      let message = 'Konfigurasi WAN berhasil diterapkan!';
      if (data.output?.rebootQueued) message += '\n\nReboot modem berhasil diantrikan melalui GenieACS.';
      if (data.output?.warning) message += `\n\nCatatan: ${data.output.warning}`;
      alert(message);
      closeModal('wanConfigModal');
      refreshCurrentOlt();
    } else {
      alert(I18N.failedPrefix + data.error);
    }
  } catch (e) {
    alert(I18N.errorPrefix + e.message);
  } finally {
    overlay.style.display = 'none';
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const selector = document.getElementById('olt-selector');
  if (selector && selector.value) {
    handleOltChange();
  }
});
</script>
</body>
</html>
