function renderOnuTable(stats = {}, id) {
  const tbody = document.getElementById('onu-table-body');
  if (Array.isArray(stats.onus) && stats.onus.length > 0) {
    document.getElementById('search-container').style.display = 'block';
    tbody.replaceChildren();
    tbody.insertAdjacentHTML('beforeend', stats.onus.map((onu, index) => {
      const statusVal = String(onu.status || '');
      const isOnline = statusVal.toLowerCase() === 'online';
      const statusClass = isOnline ? 'pill-online' : 'pill-offline';
      const rxVal = parseFloat(onu.rx);
      let rxClass = 'power-good';
      const hasWeakSignal = Number.isFinite(rxVal) && rxVal < WEAK_SIGNAL_THRESHOLD_DBM;
      if (!Number.isFinite(rxVal)) rxClass = '';
      else if (rxVal < -27) rxClass = 'power-danger';
      else if (rxVal < WEAK_SIGNAL_THRESHOLD_DBM) rxClass = 'power-warning';
      const actionOltId = encodeURIComponent(id || '');
      const actionIndex = encodeURIComponent(onu.index || '');
      const actionName = encodeURIComponent(onu.name || '-');
      const actionSn = encodeURIComponent(onu.sn || '');
      return `<tr>
        <td data-label="<%= t('admin.olts.table.no', 'No') %>" data-onu-filter="${isOnline ? 'online' : 'offline'}" data-onu-weak="${hasWeakSignal ? 'true' : 'false'}">${index + 1}</td>
        <td data-label="ONU">
          <div class="onu-name-cell">
            <span class="onu-name-main">${onu.name || '-'}</span>
            <span class="onu-name-meta">${onu.id || '-'}${onu.firmware && onu.firmware !== '-' ? ` â€¢ FW ${onu.firmware}` : ''}</span>
          </div>
        </td>
        <td data-label="MAC ONU"><code class="sn-mac">${onu.mac || '-'}</code></td>
        <td data-label="<%= t('admin.olts.table.serial', 'Serial Number') %>"><code class="sn-mac">${onu.sn || '-'}</code></td>
        <td data-label="<%= t('admin.olts.table.status', 'Status') %>"><span class="status-pill-v2 ${statusClass}"><i class="bi bi-circle-fill" style="font-size:6px;"></i> ${formatStatus(statusVal) || '-'}</span></td>
        <td data-label="<%= t('admin.olts.table.tx', 'TxPower') %>"><span class="power-badge">${onu.tx || 'N/A'}</span></td>
        <td data-label="<%= t('admin.olts.table.rx', 'RxPower') %>"><span class="power-badge ${rxClass}">${onu.rx || 'N/A'}</span></td>
        <td data-label="<%= t('admin.olts.table.distance', 'Jarak') %>"><span class="small text-muted">${onu.distance != null ? onu.distance : '-'}</span></td>
        <td data-label="<%= t('common.actions', 'Aksi') %>" style="text-align:right">
          <div class="onu-actions">
            <button class="btn btn-sm btn-outline-primary py-0 px-2" onclick="pushVlanPrompt(decodeURIComponent('${actionOltId}'), decodeURIComponent('${actionIndex}'), decodeURIComponent('${actionName}'))" style="font-size: 11px;">
              <i class="bi bi-diagram-3"></i> VLAN
            </button>
            <button class="btn btn-sm btn-outline-primary py-0 px-2" onclick="configureWanPrompt(decodeURIComponent('${actionOltId}'), decodeURIComponent('${actionIndex}'), decodeURIComponent('${actionName}'), decodeURIComponent('${actionSn}'))" style="font-size: 11px;">
              <i class="bi bi-gear-fill"></i> WAN
            </button>
            <button class="btn-action-v2 btn-rename-v2" onclick="renameOnuPrompt(decodeURIComponent('${actionOltId}'), decodeURIComponent('${actionIndex}'), decodeURIComponent('${actionName}'))" title="${I18N.renameTitle}"><i class="bi bi-pencil-square"></i></button>
            <button class="btn-action-v2 btn-reboot-v2" onclick="rebootOnu(decodeURIComponent('${actionOltId}'), decodeURIComponent('${actionIndex}'))" title="${I18N.rebootTitle}"><i class="bi bi-arrow-clockwise"></i></button>
          </div>
        </td>
      </tr>`;
    }).join(''));
