      const statusClass = card.status === 'INSERVICE' || card.status === 'ONLINE' ? 'pill-online' : 'pill-offline';
      return `<tr>
        <td data-label="Slot"><strong>${card.index}</strong></td>
        <td data-label="Type"><span class="badge-v2">${card.type}</span></td>
        <td data-label="Status"><span class="status-pill-v2 ${statusClass}">${card.status}</span></td>
        <td data-label="Ports">${card.ports}</td>
        <td data-label="Serial"><code class="sn-mac">${card.serial}</code></td>
        <td data-label="CPU">${card.cpu}</td>
        <td data-label="RAM">${card.ram}</td>
      </tr>`;
    }).join(''));
  } else {
    cardBody.replaceChildren();
    cardContainer.style.display = 'none';
  }
}

