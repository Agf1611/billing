<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.nav.olt_management', 'Manajemen OLT') %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    /* OLT Dashboard */
    .olt-dashboard { display: flex; flex-direction: column; gap: 14px; }
    .olt-header-actions,
    .olt-selector-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .olt-selector-main {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      min-width: 0;
      flex: 1 1 420px;
    }

    .olt-section-table {
      width: 100%;
      overflow: auto;
      -webkit-overflow-scrolling: touch;
    }

    .mw,
    .page,
    .olt-dashboard,
    .olt-selector-container,
    .onu-main-card,
    .system-info-bar,
    .stat-card-v2,
    .details {
      min-width: 0;
    }

    .onu-card-shell {
      min-width: 100%;
    }
    
    .stats-row { 
      display: grid; 
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); 
      gap: 10px; 
    }
    
    .stat-card-v2 {
      background: var(--surface-strong);
      border-radius: 18px;
      padding: 14px 15px;
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: var(--shadow-soft);
      border: 1px solid var(--border);
    }

    .stat-card-v2.is-filter {
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .stat-card-v2.is-filter:hover {
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--primary) 32%, var(--border));
    }

    .stat-card-v2.is-filter.active {
      border-color: color-mix(in srgb, var(--primary) 45%, var(--border));
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--primary) 28%, transparent), var(--shadow-soft);
      background: color-mix(in srgb, var(--surface-strong) 82%, var(--primary) 18%);
    }
    
    .stat-card-v2 .icon-box {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 19px;
      color: white;
      flex: 0 0 auto;
    }
    
    .stat-card-v2 .details h3 { margin: 0; font-size: 22px; font-weight: 800; color: var(--text); line-height: 1; }
    .stat-card-v2 .details p { margin: 3px 0 0; font-size: 11px; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
    
    .bg-blue { background: linear-gradient(135deg, #0b55f4, #073dcc); }
    .bg-green { background: linear-gradient(135deg, #10b981, #059669); }
    .bg-red { background: linear-gradient(135deg, #ef4444, #dc2626); }
    .bg-orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
    
    .system-info-bar {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 10px 14px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px 16px;
      align-items: center;
      font-size: 12px;
      box-shadow: var(--shadow-soft);
    }
    
    .info-item { display: flex; align-items: center; gap: 7px; color: var(--muted); }
    .info-item strong { color: var(--text); font-weight: 700; }
    .info-item i { color: var(--primary-2); }
    
    .olt-selector-container {
      background: var(--surface-strong);
      padding: 12px 14px;
      border-radius: 18px;
      border: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      box-shadow: var(--shadow-soft);
    }
    
    .custom-select-v2 {
      padding: 8px 11px;
      border-radius: 12px;
      border: 1px solid var(--border);
      font-weight: 600;
      color: var(--text);
      min-width: 250px;
      max-width: 100%;
      outline: none;
      background: var(--bg3);
    }
    
    .custom-select-v2:focus { border-color: var(--primary-2); box-shadow: 0 0 0 3px var(--pdim); }

    .onu-main-card {
      background: var(--surface-strong);
      border-radius: 18px;
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: var(--shadow-soft);
    }
    
    .onu-main-card .card-header {
      padding: 12px 14px;
      background: var(--surface-soft);
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .onu-card-header-main {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      flex: 1 1 360px;
      min-width: 0;
    }

    .onu-search-field {
      width: min(100%, 250px);
      padding: 4px 12px;
      font-size: 12px;
    }
    
    .onu-table-v2 { width: 100%; border-collapse: collapse; }
    .onu-table-v2 th { 
      background: color-mix(in srgb, var(--bg3) 86%, transparent); 
      padding: 10px 12px; 
      text-align: left; 
      font-size: 11px; 
      font-weight: 800; 
      color: var(--muted); 
      text-transform: uppercase;
      border-bottom: 1px solid var(--border);
      letter-spacing: .06em;
      white-space: nowrap;
    }
    .onu-table-v2 td { padding: 9px 12px; border-bottom: 1px solid color-mix(in srgb, var(--border) 75%, transparent); font-size: 12px; color: var(--text); vertical-align: middle; }
    .onu-table-v2 tr:hover { background: color-mix(in srgb, var(--primary) 8%, transparent); }
    
    .status-pill-v2 {
      padding: 3px 9px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      letter-spacing: .04em;
    }
    .pill-online { background: #dcfce7; color: #15803d; }
    .pill-offline { background: #fee2e2; color: #b91c1c; }
    
    .power-badge {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      padding: 3px 6px;
      border-radius: 999px;
      font-size: 11px;
      display: inline-flex;
      min-width: 72px;
      justify-content: center;
    }
    .power-good { color: #059669; background: #ecfdf5; }
    .power-warning { color: #d97706; background: #fffbeb; }
    .power-danger { color: #dc2626; background: #fef2f2; font-weight: 800; }

    .brand-badge { font-weight: 700; text-transform: uppercase; font-size: 10px; padding: 2px 5px; border-radius: 4px; }
    .brand-zte { background: #eff6ff; color: #073dcc; }
    .brand-huawei { background: #fef2f2; color: #dc2626; }
    .brand-vsol { background: #f0fdf4; color: #16a34a; }
    .brand-cdata { background: #fff7ed; color: #ea580c; }
    .brand-hioso { background: #fffbeb; color: #d97706; }
    .brand-hsgq { background: #f5f3ff; color: #073dcc; }

    .spin { animation: rotate 2s linear infinite; display: inline-block; }
    @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    .btn-action-v2 {
      width: 30px;
      height: 30px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border);
      background: var(--bg3);
      color: var(--muted);
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-action-v2:hover { background: var(--surface-soft); color: var(--text); border-color: var(--panel-border); }
    .btn-reboot-v2:hover { color: #ef4444; background: #fef2f2; border-color: #fee2e2; }
    .btn-rename-v2:hover { color: #0b55f4; background: #eff6ff; border-color: #e6efff; }
    .btn-wan-v2:hover { color: #059669; background: #ecfdf5; border-color: #d1fae5; }

    .traffic-v2 { display: flex; gap: 10px; font-family: monospace; font-size: 11px; font-weight: 700; }
    .traffic-in-v2 { color: #10b981; }
    .traffic-out-v2 { color: #0b55f4; }

    .empty-state { padding: 42px 16px; text-align: center; color: var(--muted); }
    .empty-state i { font-size: 40px; display: block; margin-bottom: 12px; }

    .sn-mac {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--text);
      background: var(--surface-soft);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 3px 8px;
      white-space: nowrap;
    }

    .onu-name-cell {
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 0;
    }

    .onu-name-main {
      font-weight: 700;
      color: var(--text);
      line-height: 1.25;
    }

    .onu-name-meta {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.2;
    }

    .onu-actions {
      display: flex;
      justify-content: flex-end;
      gap: 6px;
      flex-wrap: wrap;
    }

    .table-empty-cell {
      padding: 0 !important;
    }

    .table-empty-cell::before {
      display: none !important;
    }

    .dtbl code,
    .onu-table-v2 code {
      word-break: break-word;
    }

    .btn-outline-primary.btn-sm.py-0.px-2 {
      border-radius: 10px;
      font-size: 11px !important;
      padding: 4px 9px !important;
      border-color: var(--border);
      color: var(--primary-2);
      background: var(--surface-soft);
    }

    .btn-outline-primary.btn-sm.py-0.px-2:hover {
      background: var(--pdim);
      border-color: color-mix(in srgb, var(--primary) 35%, var(--border));
      color: var(--text);
    }

    .loading-overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: color-mix(in srgb, var(--bg2) 72%, transparent);
      backdrop-filter: blur(2px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 10;
    }

    @media (max-width: 1200px) {
      .stats-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .tbl-wrap { max-height: 520px !important; }
    }

    @media (max-width: 768px) {
      .olt-dashboard { gap: 12px; }
      .stats-row { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; gap: 8px; }
      .stat-card-v2 {
        padding: 12px 11px;
        gap: 10px;
        min-height: 88px;
      }
      .stat-card-v2 .icon-box {
        width: 38px;
        height: 38px;
        font-size: 17px;
      }
      .stat-card-v2 .details h3 { font-size: 18px; }
      .stat-card-v2 .details p {
        font-size: 10px;
        letter-spacing: .05em;
      }
      .system-info-bar {
        padding: 10px 12px;
        display: grid;
        grid-template-columns: 1fr;
        align-items: stretch;
      }
      .info-item {
        justify-content: space-between;
        width: 100%;
      }
      .info-item.ms-auto {
        width: 100%;
      }
      .olt-selector-container {
        padding: 12px;
        align-items: stretch;
      }
      .olt-selector-main {
        flex-direction: column;
        align-items: stretch;
        flex-basis: 100%;
        gap: 8px;
      }
      .olt-selector-main label {
        width: 100%;
        line-height: 1.35;
      }
      .olt-selector-main,
      .olt-selector-actions,
      .olt-header-actions,
      .onu-card-header-main {
        width: 100%;
      }
      .olt-selector-actions,
      .olt-header-actions {
        justify-content: stretch;
      }
      .olt-selector-actions .btn,
      .olt-header-actions .btn {
        flex: 1 1 180px;
      }
      .custom-select-v2 { min-width: 100%; width: 100%; }
      .onu-main-card .card-header { padding: 11px 12px; }
      .onu-table-v2 th, .onu-table-v2 td { padding: 8px 10px; }
      .onu-search-field { width: 100%; }
      .btn-action-v2 { width: 28px; height: 28px; }
      .traffic-v2 { width: 100%; justify-content: flex-start; }
      .tbl-wrap,
      .table-responsive,
      .olt-section-table {
        overflow-x: auto !important;
        overflow-y: auto !important;
        max-height: none !important;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
      }

      .onu-table-v2,
      .dtbl {
        display: table;
        width: max-content;
        min-width: 100%;
      }

      .onu-table-v2 thead,
      .dtbl thead {
        display: table-header-group;
      }

      .onu-table-v2 tbody,
      .dtbl tbody {
        display: table-row-group;
      }

      .onu-table-v2 tr,
      .dtbl tr {
        display: table-row;
      }

      .onu-table-v2 thead,
      .dtbl thead {
        display: table-header-group;
      }

      .onu-table-v2 th,
      .onu-table-v2 td,
      .dtbl th,
      .dtbl td {
        display: table-cell;
        white-space: nowrap;
        vertical-align: middle;
      }

      .onu-table-v2 td::before,
      .dtbl td::before {
        display: none;
      }

      .onu-table-v2 td > *,
      .dtbl td > * {
        margin-left: 0;
      }

      .onu-actions {
        width: auto;
        justify-content: flex-end;
        flex-wrap: nowrap;
      }

      .onu-actions .btn,
      .onu-actions .btn-action-v2 {
        min-height: 32px;
      }

      .onu-name-cell {
        min-width: 180px;
      }

      .table-empty-cell {
        padding: 0 !important;
        white-space: normal !important;
      }

      #manageOltsModal .mb,
      #wanConfigModal .mb,
      #vlanPushModal .mb {
        max-width: min(100vw - 16px, 900px) !important;
      }
    }

    @media (max-width: 560px) {
      .stats-row {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      }

      .topbar {
        align-items: flex-start;
      }

      .tb-right,
      .tb-right .d-flex,
      .olt-header-actions,
      .olt-selector-actions {
        width: 100%;
      }

      .tb-right .btn,
      .olt-header-actions .btn,
      .olt-selector-actions .btn {
        width: 100%;
        justify-content: center;
      }

      .olt-selector-main label,
      .card-header .text-muted.small {
        width: 100%;
      }

      .onu-table-v2 th,
      .onu-table-v2 td,
      .dtbl th,
      .dtbl td {
        padding: 8px 10px;
      }

      .onu-name-cell {
        min-width: 160px;
      }

      .onu-actions {
        gap: 4px;
      }

      .sn-mac,
      .power-badge,
      .status-pill-v2,
      .brand-badge {
        max-width: 100%;
      }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'olts', company }) %>

<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-hdd-rack"></i>
      <span><%= t('admin.nav.olt_management', 'Manajemen OLT') %></span>
    </div>
    <div class="tb-right">
      <div class="olt-header-actions">
        <button class="btn btn-g btn-sm" onclick="openModal('manageOltsModal')"><i class="bi bi-gear"></i> <%= t('admin.olts.manage', 'Kelola OLT') %></button>
        <button class="btn btn-p btn-sm" onclick="openModal('addOltModal')"><i class="bi bi-plus-lg"></i> <%= t('admin.olts.add', 'Tambah OLT') %></button>
      </div>
    </div>
  </div>

  <div class="page">
    <% if (msg) { %>
      <div class="alert alert-<%= msg.type==='error'?'d':'s' %>"><%= msg.text %></div>
    <% } %>

    <div class="olt-dashboard">
      <!-- OLT Selector & Global Actions -->
      <div class="olt-selector-container">
        <div class="olt-selector-main">
          <label class="fw-bold text-muted small text-uppercase"><%= t('admin.olts.select_label', 'Pilih Perangkat OLT:') %></label>
          <select id="olt-selector" class="custom-select-v2" onchange="handleOltChange()">
            <% if (olts.length === 0) { %>
              <option value=""><%= t('admin.olts.no_data', 'Tidak ada data OLT') %></option>
            <% } else { %>
              <% olts.forEach(olt => { %>
                <option value="<%= olt.id %>" <%= olt.is_active ? '' : 'disabled' %>><%= olt.name %> (<%= olt.host %>)</option>
              <% }) %>
            <% } %>
          </select>
        </div>
        <div class="olt-selector-actions">
          <button class="btn btn-sm btn-p" onclick="refreshCurrentOlt()">
            <i class="bi bi-arrow-clockwise"></i> <%= t('admin.olts.refresh_data', 'Refresh Data') %>
          </button>
        </div>
      </div>

      <!-- Summary Cards -->
      <div class="stats-row">
        <div class="stat-card-v2 is-filter active" data-stat-filter="all" onclick="setOnuFilter('all')">
          <div class="icon-box bg-blue"><i class="bi bi-device-hdd"></i></div>
          <div class="details">
            <h3 id="stat-total-onu">-</h3>
            <p><%= t('admin.olts.stats.total_onu', 'Total ONU') %></p>
          </div>
        </div>
        <div class="stat-card-v2 is-filter" data-stat-filter="online" onclick="setOnuFilter('online')">
          <div class="icon-box bg-green"><i class="bi bi-wifi"></i></div>
          <div class="details">
            <h3 id="stat-online-onu">-</h3>
            <p><%= t('admin.olts.stats.online', 'Online') %></p>
          </div>
        </div>
        <div class="stat-card-v2 is-filter" data-stat-filter="offline" onclick="setOnuFilter('offline')">
          <div class="icon-box bg-red"><i class="bi bi-wifi-off"></i></div>
          <div class="details">
            <h3 id="stat-offline-onu">-</h3>
            <p><%= t('admin.olts.stats.offline', 'Offline') %></p>
          </div>
        </div>
        <div class="stat-card-v2 is-filter" data-stat-filter="weak" onclick="setOnuFilter('weak')">
          <div class="icon-box bg-orange"><i class="bi bi-exclamation-triangle"></i></div>
          <div class="details">
            <h3 id="stat-weak-onu">-</h3>
            <p><%= t('admin.olts.stats.weak_signal', 'Sinyal Lemah') %></p>
          </div>
        </div>
      </div>

      <!-- System Info Bar -->
      <div class="system-info-bar">
        <div class="info-item"><i class="bi bi-thermometer-half"></i> <%= t('admin.olts.system.temp', 'Suhu') %>: <strong id="stat-temp">-</strong></div>
        <div class="info-item"><i class="bi bi-cpu"></i> <%= t('admin.olts.system.cpu', 'CPU') %>: <strong id="stat-cpu">-</strong></div>
        <div class="info-item"><i class="bi bi-memory"></i> <%= t('admin.olts.system.ram', 'RAM') %>: <strong id="stat-ram">-</strong></div>
        <div class="info-item"><i class="bi bi-clock-history"></i> <%= t('admin.olts.system.uptime', 'Uptime') %>: <strong id="stat-uptime">-</strong></div>
        <div class="info-item ms-auto">
          <div class="traffic-v2">
            <span class="traffic-in-v2" title="<%= t('admin.olts.system.traffic_in', 'Traffic In') %>"><i class="bi bi-arrow-down"></i> <span id="stat-traffic-in">0 B</span></span>
            <span class="traffic-out-v2" title="<%= t('admin.olts.system.traffic_out', 'Traffic Out') %>"><i class="bi bi-arrow-up"></i> <span id="stat-traffic-out">0 B</span></span>
          </div>
        </div>
      </div>

      <!-- Card List Section -->
      <div id="card-list-container" style="display: none;">
        <div class="onu-main-card" style="margin-bottom: 20px;">
          <div class="card-header">
            <h4 class="fw-bold m-0 text-primary small text-uppercase"><i class="bi bi-grid-3x3-gap"></i> <%= t('admin.olts.card_list', 'Daftar Board / Card') %></h4>
          </div>
          <div class="olt-section-table">
            <table class="onu-table-v2">
              <thead>
                <tr>
                  <th>SLOT</th>
                  <th>TYPE</th>
                  <th>STATUS</th>
                  <th>PORTS</th>
                  <th>SERIAL</th>
                  <th>CPU</th>
                  <th>RAM</th>
                </tr>
              </thead>
              <tbody id="card-table-body">
                <!-- Cards rendered here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Unauth ONU Section -->
      <div id="unauth-list-container" style="display: none;">
        <div class="onu-main-card" style="margin-bottom: 20px; border-left: 4px solid #ffc107;">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="fw-bold m-0 text-warning small text-uppercase"><i class="bi bi-exclamation-triangle"></i> <%= t('admin.olts.unauth_onu', 'ONU Belum Terdaftar (Unauth)') %></h4>
          </div>
          <div class="olt-section-table">
            <table class="onu-table-v2">
              <thead>
                <tr>
                  <th>PORT/INDEX</th>
                  <th>SN / SERIAL NUMBER</th>
                  <th>TYPE</th>
                  <th>AKSI</th>
                </tr>
              </thead>
              <tbody id="unauth-table-body">
                <!-- Unauth ONUs rendered here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Main ONU Table Card -->
      <div class="onu-main-card position-relative">
        <div id="loading-overlay" class="loading-overlay">
          <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 fw-bold text-primary small"><%= t('admin.olts.loading', 'Mengambil Data OLT...') %></div>
          </div>
        </div>
        
        <div class="card-header">
          <div class="onu-card-header-main">
            <h6 class="mb-0 fw-bold"><i class="bi bi-list-check me-2"></i> <%= t('admin.olts.onu_list_title', 'Daftar Perangkat ONU Terdaftar') %></h6>
