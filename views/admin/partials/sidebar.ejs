  </div>
  <div class="sb-toolbar">
    <div class="sb-lang-group">
      <a href="/lang/id" class="sb-lang-btn <%= ((typeof lang !== 'undefined' ? lang : 'id') === 'id') ? 'active' : '' %>">ID</a>
      <a href="/lang/en" class="sb-lang-btn <%= ((typeof lang !== 'undefined' ? lang : 'id') === 'en') ? 'active' : '' %>">EN</a>
