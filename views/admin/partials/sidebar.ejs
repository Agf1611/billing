<!-- views/admin/partials/sidebar.ejs -->
<%
  const sidebarLogoSrc =
    (typeof settings !== 'undefined' && settings && String(settings.company_logo_url || '').trim())
      ? String(settings.company_logo_url || '').trim()
      : '/img/mss-logo.png';
%>
<style id="admin-sidebar-unified-style">
  .sidebar{
    width:var(--sw,248px)!important;
    height:calc(100vh - 28px)!important;
    left:14px!important;
    top:14px!important;
    padding-top:0!important;
    border-radius:28px!important;
    background-color:#073dcc!important;
    background-image:linear-gradient(180deg,#073dcc 0%,#0634b0 100%)!important;
    border:1px solid rgba(255,255,255,.18)!important;
    box-shadow:0 22px 52px rgba(7,61,204,.24)!important;
  }
  .sidebar .sb-brand{
    padding:18px 18px 14px!important;
    align-items:flex-start!important;
    justify-content:space-between!important;
    gap:12px!important;
    border-bottom:0!important;
  }
  .sidebar .sb-brand-main{display:flex!important;align-items:center!important;gap:12px!important;min-width:0!important}
  .sidebar .sb-brand-copy{min-width:0!important;flex:1 1 auto!important;overflow:hidden!important}
  .sidebar .sb-icon{
    width:42px!important;
    height:42px!important;
    border-radius:14px!important;
    display:flex!important;
    align-items:center!important;
    justify-content:center!important;
    flex-shrink:0!important;
    overflow:hidden!important;
    color:#fff!important;
    background:#fff!important;
    border:1px solid rgba(255,255,255,.80)!important;
    box-shadow:none!important;
  }
  .sidebar .sb-icon img,
  .sidebar#sidebar .sb-icon img{
    width:30px!important;
    min-width:30px!important;
    max-width:30px!important;
    height:30px!important;
    min-height:30px!important;
    max-height:30px!important;
    object-fit:contain!important;
    display:block!important;
    flex:0 0 30px!important;
  }
  .sidebar#sidebar img{
    max-width:100%!important;
    object-fit:contain!important;
  }
  body[data-theme="light"] .sidebar .sb-icon{
    background:#fff!important;
    border-color:rgba(255,255,255,.80)!important;
    box-shadow:none!important;
  }
  .sidebar .sb-name{
    font-size:14px!important;
    font-weight:800!important;
    line-height:1.2!important;
    letter-spacing:0!important;
    color:#fff!important;
    overflow:hidden!important;
    text-overflow:ellipsis!important;
    white-space:nowrap!important;
  }
  .sidebar .sb-sub{
    margin-top:3px!important;
    font-size:10px!important;
    color:rgba(232,240,255,.78)!important;
    text-transform:uppercase!important;
    letter-spacing:.12em!important;
  }
  .sidebar .sb-brand-partner{
    width:100%!important;
    max-width:172px!important;
    margin-top:7px!important;
    overflow:hidden!important;
  }
  .sidebar .sb-brand-partner .mss-partner-badge,
  .sidebar .sb-brand-partner .mss-partner-badge--sidebar-brand{
    display:inline-flex!important;
    align-items:center!important;
    width:100%!important;
    max-width:100%!important;
    min-width:0!important;
    margin:0!important;
    padding:4px 7px!important;
    gap:6px!important;
    border-radius:12px!important;
    border:1px solid rgba(255,255,255,.22)!important;
    background:rgba(255,255,255,.14)!important;
    box-shadow:none!important;
    overflow:hidden!important;
  }
  .sidebar .sb-brand-partner .mss-partner-logo{
    width:30px!important;
    min-width:30px!important;
    max-width:30px!important;
    height:19px!important;
    min-height:19px!important;
    max-height:19px!important;
    padding:2px!important;
    object-fit:contain!important;
    flex:0 0 30px!important;
    border-radius:6px!important;
    background:#fff!important;
  }
  .sidebar .sb-brand-partner .mss-partner-copy{
    min-width:0!important;
    overflow:hidden!important;
    line-height:1.05!important;
  }
  .sidebar .sb-brand-partner .mss-partner-copy span{
    color:rgba(232,240,255,.76)!important;
    font-size:6.8px!important;
    line-height:1!important;
    letter-spacing:.08em!important;
  }
  .sidebar .sb-brand-partner .mss-partner-copy strong{
    display:block!important;
    max-width:118px!important;
    color:#fff!important;
    font-size:9.5px!important;
    line-height:1.05!important;
    overflow:hidden!important;
    text-overflow:ellipsis!important;
    white-space:nowrap!important;
  }
  .sidebar .sb-toolbar{display:flex!important;align-items:center!important;gap:10px!important;padding:0 18px 14px!important}
  .sidebar .sb-lang-group{
    display:inline-flex!important;
    align-items:center!important;
    gap:6px!important;
    padding:5px!important;
    border-radius:999px!important;
    background:rgba(255,255,255,.12)!important;
    border:1px solid rgba(255,255,255,.18)!important;
  }
  .sidebar .sb-lang-btn{
    min-width:34px!important;
    height:30px!important;
    padding:0 10px!important;
    border-radius:999px!important;
    font-size:11px!important;
    font-weight:800!important;
    letter-spacing:.04em!important;
    color:rgba(232,240,255,.78)!important;
  }
  .sidebar .sb-lang-btn:hover,
  .sidebar .sb-lang-btn.active{
    color:#073dcc!important;
    background:#fff!important;
    box-shadow:inset 0 0 0 1px rgba(255,255,255,.24)!important;
  }
  .sidebar .sb-theme-toggle{
    flex:1!important;
    height:40px!important;
    padding:0 12px!important;
    border-radius:14px!important;
    border:1px solid rgba(255,255,255,.18)!important;
    background:rgba(255,255,255,.12)!important;
    color:#fff!important;
    display:inline-flex!important;
    align-items:center!important;
    justify-content:center!important;
    gap:8px!important;
    font-size:12px!important;
    font-weight:700!important;
    box-shadow:none!important;
  }
  .sidebar .sb-theme-toggle i{
    width:auto!important;
    height:auto!important;
    font-size:15px!important;
    color:#fff!important;
    background:transparent!important;
    border:0!important;
    box-shadow:none!important;
  }
  .sidebar .sb-nav{flex:1!important;padding:4px 10px 20px!important}
  .sidebar .sb-section{
    margin:0!important;
    padding:14px 10px 8px!important;
    font-size:10px!important;
    font-weight:800!important;
    color:rgba(232,240,255,.78)!important;
    letter-spacing:.14em!important;
    text-transform:uppercase!important;
  }
  .sidebar .sb-item{
    display:flex!important;
    align-items:center!important;
    gap:12px!important;
    margin:2px 0!important;
    padding:11px 12px!important;
    border-radius:16px!important;
    color:rgba(232,240,255,.78)!important;
    text-decoration:none!important;
    font-size:13px!important;
    font-weight:600!important;
    background:transparent!important;
    border:0!important;
    box-shadow:none!important;
  }
  .sidebar .sb-item i{
    width:22px!important;
    height:22px!important;
    border-radius:9px!important;
    display:inline-flex!important;
    align-items:center!important;
    justify-content:center!important;
    font-size:13px!important;
    color:inherit!important;
    background:rgba(255,255,255,.10)!important;
    border:0!important;
    box-shadow:none!important;
  }
  body[data-theme="light"] .sidebar .sb-item i{background:rgba(255,255,255,.10)!important;color:rgba(232,240,255,.78)!important}
  .sidebar .sb-item:hover{color:#fff!important;background:rgba(255,255,255,.12)!important}
  body[data-theme="light"] .sidebar .sb-item:hover{background:rgba(255,255,255,.12)!important;color:#fff!important}
  .sidebar .sb-item.active{
    color:#fff!important;
    background:rgba(255,255,255,.18)!important;
    box-shadow:inset 0 0 0 1px rgba(255,255,255,.20)!important;
  }
  .sidebar .sb-item.active i{
    color:#073dcc!important;
    background:#fff200!important;
    box-shadow:0 12px 24px rgba(0,0,0,.14)!important;
  }
  body[data-theme="light"] .sidebar .sb-item.active{background:rgba(255,255,255,.18)!important;color:#fff!important}
  .sidebar .sb-item.logout{color:var(--danger)!important}
  .sidebar .sb-item.logout:hover{background:var(--ddim)!important}
  .sidebar .sb-footer{
    margin:0!important;
    padding:14px 18px 20px!important;
    border-top:1px solid rgba(255,255,255,.16)!important;
    color:rgba(232,240,255,.78)!important;
    overflow:hidden!important;
  }
  .sidebar .sb-footer .mss-partner-badge,
  .sidebar .sb-footer .mss-partner-badge--sidebar{
    width:100%!important;
    max-width:100%!important;
    min-width:0!important;
    padding:7px 9px!important;
    gap:8px!important;
    overflow:hidden!important;
  }
  .sidebar .sb-footer .mss-partner-logo{
    width:42px!important;
    min-width:42px!important;
    max-width:42px!important;
    height:26px!important;
    min-height:26px!important;
    max-height:26px!important;
    padding:3px!important;
    object-fit:contain!important;
    flex:0 0 42px!important;
  }
  .sidebar .sb-footer .mss-partner-copy{
    min-width:0!important;
    overflow:hidden!important;
  }
  .sidebar .sb-footer .mss-partner-copy strong,
  .sidebar .sb-footer .mss-partner-copy span,
  .sidebar .sb-footer .mss-partner-copy small{
    overflow:hidden!important;
    text-overflow:ellipsis!important;
    white-space:nowrap!important;
  }
  .sidebar .sb-footer a,
  .sidebar .sb-footer div{
    display:inline-flex!important;
    align-items:center!important;
    gap:8px!important;
    color:rgba(232,240,255,.78)!important;
    font-size:11px!important;
    font-weight:700!important;
    text-decoration:none!important;
    letter-spacing:.04em!important;
  }
  @media (max-width:768px){
    .sidebar{
      width:min(86vw,280px)!important;
      left:12px!important;
      top:12px!important;
      height:calc(100vh - 24px)!important;
      transform:translateX(calc(-100% - 24px));
    }
    .sidebar.open{transform:translateX(0)!important}
    .sidebar .sb-brand{padding:16px 16px 12px!important}
    .sidebar .sb-toolbar{padding:0 16px 12px!important}
    .sidebar .sb-nav{padding:4px 10px 18px!important}
    .sidebar .sb-item{padding:10px 12px!important}
    .sidebar .sb-close{display:inline-flex!important}
  }
  body .sidebar#sidebar{
    background:#073dcc!important;
    background:linear-gradient(180deg,#073dcc 0%,#0634b0 100%)!important;
    color:#fff!important;
  }
  body .sidebar#sidebar .sb-name,
  body .sidebar#sidebar .sb-footer a,
  body .sidebar#sidebar .sb-footer div{color:#fff!important}
  body .sidebar#sidebar .sb-sub,
  body .sidebar#sidebar .sb-section,
  body .sidebar#sidebar .sb-footer,
  body .sidebar#sidebar .sb-item{color:rgba(232,240,255,.84)!important}
  body .sidebar#sidebar .sb-item:hover{color:#fff!important;background:rgba(255,255,255,.12)!important}
  body .sidebar#sidebar .sb-item.active{color:#fff!important;background:rgba(255,255,255,.18)!important}
  body .sidebar#sidebar .sb-item.active i{color:#073dcc!important;background:#fff200!important}
</style>
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
<aside class="sidebar" id="sidebar">
  <div class="sb-brand">
    <div class="sb-brand-main">
      <div class="sb-icon">
        <img src="<%= sidebarLogoSrc %>" alt="Logo <%= company %>" style="width:30px;height:30px;object-fit:contain" onerror="this.onerror=null;this.src='/img/mss-logo.png'">
      </div>
      <div class="sb-brand-copy">
        <div class="sb-name"><%= company %></div>
        <div class="sb-sub"><%= t('admin.panel', 'Admin Panel') %></div>
        <div class="sb-brand-partner">
          <%- include('../../partials/partner_brand_badge', { settings: (typeof settings !== 'undefined' ? settings : {}), variant: 'sidebar-brand', label: 'Mitra Resmi' }) %>
        </div>
      </div>
    </div>
    <button class="sb-close btn btn-g btn-sm" onclick="toggleSidebar()"><i class="bi bi-x-lg"></i></button>
  </div>
  <div class="sb-toolbar">
    <div class="sb-lang-group">
      <a href="/lang/id" class="sb-lang-btn <%= ((typeof lang !== 'undefined' ? lang : 'id') === 'id') ? 'active' : '' %>">ID</a>
      <a href="/lang/en" class="sb-lang-btn <%= ((typeof lang !== 'undefined' ? lang : 'id') === 'en') ? 'active' : '' %>">EN</a>
    </div>
    <button class="sb-theme-toggle" type="button" data-theme-toggle aria-label="Ganti tema admin">
      <i class="bi bi-moon-stars"></i>
      <span>Gelap</span>
    </button>
  </div>
  <nav class="sb-nav">
    <div class="sb-section"><%= t('admin.section.main', 'UTAMA') %></div>
    <a href="/admin" class="sb-item <%= (!activePage || activePage==='dashboard') ? 'active' : '' %>">
      <i class="bi bi-speedometer2"></i><span><%= t('admin.nav.dashboard', 'Dashboard') %></span>
    </a>
    <a href="/admin/customers" class="sb-item <%= activePage==='customers' ? 'active' : '' %>">
      <i class="bi bi-people"></i><span><%= t('admin.nav.customers', 'Pelanggan') %></span>
    </a>
    <% if (typeof session !== 'undefined' && session.isAdmin) { %>
    <a href="/admin/usage-audit" class="sb-item <%= activePage==='usage_audit' ? 'active' : '' %>">
      <i class="bi bi-clipboard2-pulse"></i><span>Audit Usage</span>
    </a>
    <% } %>
    <a href="/admin/billing" class="sb-item <%= activePage==='billing' ? 'active' : '' %>">
      <i class="bi bi-receipt"></i><span><%= t('admin.nav.invoices', 'Tagihan') %></span>
    </a>
    <a href="/admin/bookkeeping" class="sb-item <%= activePage==='bookkeeping' ? 'active' : '' %>">
      <i class="bi bi-cash-coin"></i><span>Pembukuan</span>
    </a>
    <a href="/admin/reports" class="sb-item <%= activePage==='reports' ? 'active' : '' %>">
      <i class="bi bi-bar-chart-line"></i><span><%= t('admin.nav.finance_report', 'Laporan Keuangan') %></span>
    </a>

    <% const cashierOnly = typeof session !== 'undefined' && session.isCashier && !session.isAdmin; %>
    <% if (!cashierOnly) { %>
    <div class="sb-section">JARINGAN</div>
    <a href="/admin/mikrotik" class="sb-item <%= activePage==='mikrotik' ? 'active' : '' %>">
      <i class="bi bi-router"></i><span><%= t('admin.nav.mikrotik', 'MikroTik') %></span>
    </a>
    <% if (typeof session !== 'undefined' && session.isAdmin) { %>
    <a href="/admin/monitoring" class="sb-item <%= activePage==='monitoring' ? 'active' : '' %>">
      <i class="bi bi-broadcast-pin"></i><span>Manajemen ONU</span>
    </a>
    <a href="/admin/olts" class="sb-item <%= activePage==='olts' ? 'active' : '' %>">
      <i class="bi bi-hdd-rack"></i><span><%= t('admin.nav.olt_management', 'Manajemen OLT') %></span>
    </a>
    <% } %>
    <a href="/admin/map" class="sb-item <%= activePage==='map' ? 'active' : '' %>">
      <i class="bi bi-map"></i><span><%= t('admin.nav.network_map', 'Peta Jaringan') %></span>
    </a>

    <div class="sb-section">OPERASIONAL</div>
    <a href="/admin/tickets" class="sb-item <%= activePage==='tickets' ? 'active' : '' %>">
      <i class="bi bi-headset"></i><span>Gangguan</span>
    </a>
    <a href="/admin/whatsapp" class="sb-item <%= activePage==='whatsapp' ? 'active' : '' %>">
      <i class="bi bi-megaphone"></i><span><%= t('admin.nav.whatsapp', 'WA & Pengumuman') %></span>
    </a>
    <% if (typeof session !== 'undefined' && session.isAdmin) { %>
    <a href="/admin/settings#settings-monitoring" class="sb-item <%= activePage==='webhook_logs' ? 'active' : '' %>">
      <i class="bi bi-activity"></i><span>Webhook Log</span>
    </a>
    <% } %>
    <% if (typeof session !== 'undefined' && session.isAdmin) { %>
    <a href="/admin/technician-tasks" class="sb-item <%= activePage==='technician_tasks' ? 'active' : '' %>">
      <i class="bi bi-clipboard-check"></i><span>Tugas Teknisi</span>
      <% if (Number(adminPendingTechnicianCustomerRequests || 0) > 0) { %>
        <span class="sb-badge"><%= Number(adminPendingTechnicianCustomerRequests || 0) > 99 ? '99+' : Number(adminPendingTechnicianCustomerRequests || 0) %></span>
      <% } %>
    </a>
    <a href="/admin/customer-requests" class="sb-item <%= activePage==='customer_requests' ? 'active' : '' %>">
      <i class="bi bi-person-check"></i><span>Approval Pelanggan</span>
      <% if (Number(adminPendingCustomerRequests || 0) > 0) { %>
        <span class="sb-badge"><%= Number(adminPendingCustomerRequests || 0) > 99 ? '99+' : Number(adminPendingCustomerRequests || 0) %></span>
      <% } %>
    </a>
    <% } %>
    <a href="/admin/collector-payments" class="sb-item <%= activePage==='collector_payments' ? 'active' : '' %>">
      <i class="bi bi-check2-square"></i><span>Approval Kolektor</span>
      <% if (Number(adminPendingCollectorApprovals || 0) > 0) { %>
        <span class="sb-badge"><%= Number(adminPendingCollectorApprovals || 0) > 99 ? '99+' : Number(adminPendingCollectorApprovals || 0) %></span>
      <% } %>
    </a>

    <div class="sb-section">LAINNYA</div>
    <a href="/admin/packages" class="sb-item <%= activePage==='packages' ? 'active' : '' %>">
      <i class="bi bi-box-seam"></i><span><%= t('admin.nav.internet_packages', 'Paket Internet') %></span>
    </a>
    <a href="/admin/inventory" class="sb-item <%= activePage==='inventory' ? 'active' : '' %>">
      <i class="bi bi-boxes"></i><span>Inventaris (Stok)</span>
    </a>
    <a href="/admin/cashiers/reports" class="sb-item <%= activePage==='cashiers_reports' ? 'active' : '' %>">
      <i class="bi bi-journal-text"></i><span>Laporan Kasir</span>
    </a>
    <% } %>

    <% if (typeof session !=='undefined' && (session.isAdmin || session.isCashier)) { %>
      <div class="sb-section">MANAJEMEN USER</div>
      <% if (session.isAdmin) { %>
      <a href="/admin/accounts" class="sb-item <%= activePage==='accounts' ? 'active' : '' %>">
        <i class="bi bi-people"></i><span>Pengelolaan Akun</span>
      </a>
      <% } %>
      <a href="/admin/agents" class="sb-item <%= activePage==='agents' ? 'active' : '' %>">
        <i class="bi bi-person-badge"></i><span><%= t('admin.nav.agents', 'Agent') %></span>
      </a>
      <% if (session.isAdmin) { %>
        <a href="/admin/agents/reports" class="sb-item <%= activePage==='agents_reports' ? 'active' : '' %>">
          <i class="bi bi-journal-text"></i><span><%= t('admin.nav.agent_reports', 'Laporan Agent') %></span>
        </a>
        <a href="/admin/settings" class="sb-item <%= activePage==='settings' ? 'active' : '' %>">
          <i class="bi bi-gear"></i><span><%= t('admin.nav.settings', 'Pengaturan') %></span>
        </a>
      <% } %>
    <% } %>

        <% if (typeof session !=='undefined' && session.isAdmin) { %>
          <div class="sb-section">SISTEM</div>
          <a href="/admin/backup" class="sb-item <%= activePage==='backup' ? 'active' : '' %>">
            <i class="bi bi-hdd-stack"></i><span>Backup & Recovery</span>
          </a>
          <% if (typeof selfUpdateEnabled === 'undefined' || selfUpdateEnabled) { %>
            <a href="/admin/update" class="sb-item <%= activePage==='update' ? 'active' : '' %>">
              <i class="bi bi-cloud-arrow-down"></i><span>Update Aplikasi</span>
            </a>
          <% } %>
          <a href="/admin/audit-logs" class="sb-item <%= activePage==='audit_logs' ? 'active' : '' %>">
            <i class="bi bi-shield-lock"></i><span>Log Aktivitas</span>
          </a>

          <% } %>
            <a href="/admin/logout" class="sb-item logout">
              <i class="bi bi-box-arrow-left"></i><span><%= t('common.logout', 'Logout') %></span>
            </a>
  </nav>
  <div class="sb-footer">
    <div>
      <i class="bi bi-stars"></i>
      <span><%= company %></span>
    </div>
  </div>
</aside>

<script>
  (function() {
    const savedTheme = localStorage.getItem('admin-theme')
      || document.documentElement.dataset.adminTheme
      || 'light';
    document.documentElement.dataset.adminTheme = savedTheme;
    document.documentElement.style.colorScheme = savedTheme === 'light' ? 'light' : 'dark';
    if (document.body) document.body.dataset.theme = savedTheme;
  })();

  function toggleSidebar() {
    const sb = document.getElementById('sidebar');
    const ov = document.getElementById('sidebarOverlay');
    sb.classList.toggle('open');
    ov.classList.toggle('show');
  }

  function syncThemeButtons(theme) {
    document.documentElement.dataset.adminTheme = theme;
    document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
    if (document.body) document.body.dataset.theme = theme;
    document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
      const icon = button.querySelector('i');
      const label = button.querySelector('span');
      if (icon) {
        icon.className = theme === 'light' ? 'bi bi-moon-stars' : 'bi bi-sun';
      }
      if (label) {
        label.textContent = theme === 'light' ? 'Gelap' : 'Terang';
      }
    });
  }

  function toggleAdminTheme() {
    const currentTheme = document.body?.dataset.theme || document.documentElement.dataset.adminTheme || 'light';
    const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
    localStorage.setItem('admin-theme', nextTheme);
    syncThemeButtons(nextTheme);
  }

  function restoreAdminTheme() {
    const theme = localStorage.getItem('admin-theme')
      || document.documentElement.dataset.adminTheme
      || 'light';
    syncThemeButtons(theme);
  }

  restoreAdminTheme();
  document.addEventListener('click', (event) => {
    const toggleButton = event.target.closest('[data-theme-toggle]');
    if (!toggleButton) return;
    event.preventDefault();
    toggleAdminTheme();
  });

  window.addEventListener('pageshow', restoreAdminTheme);
  window.addEventListener('storage', (event) => {
    if (event.key === 'admin-theme') restoreAdminTheme();
  });

  (function preserveAdminScrollPosition() {
    const storageKey = `admin-scroll:${window.location.pathname}`;
    let ticking = false;

    const getScrollContainer = () => {
      const main = document.querySelector('.mw');
      if (main && main.scrollHeight > main.clientHeight) return main;
      return document.scrollingElement || document.documentElement;
    };

    const getScrollTop = () => {
      const target = getScrollContainer();
      if (target === document.scrollingElement || target === document.documentElement || target === document.body) {
        return window.scrollY || window.pageYOffset || target.scrollTop || 0;
      }
      return target.scrollTop || 0;
    };

    const saveScroll = () => {
      try {
        sessionStorage.setItem(storageKey, String(getScrollTop()));
      } catch (_error) {}
    };

    const restoreScroll = (attempt = 0) => {
      try {
        const raw = sessionStorage.getItem(storageKey);
        if (raw === null || raw === '') return;
        const y = Math.max(0, parseInt(raw, 10) || 0);
        if (!y) return;
        const target = getScrollContainer();
        const maxY = Math.max(0, (target.scrollHeight || 0) - (target.clientHeight || window.innerHeight || 0));
        const nextY = maxY > 0 ? Math.min(y, maxY) : y;
        requestAnimationFrame(() => {
          if (target === document.scrollingElement || target === document.documentElement || target === document.body) {
            window.scrollTo({ top: nextY, left: 0, behavior: 'instant' });
          } else {
            target.scrollTo({ top: nextY, left: 0, behavior: 'instant' });
          }
          if (attempt < 4 && Math.abs(getScrollTop() - nextY) > 8) {
            window.setTimeout(() => restoreScroll(attempt + 1), 120);
          }
        });
      } catch (_error) {}
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        saveScroll();
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    const initialContainer = document.querySelector('.mw');
    if (initialContainer) initialContainer.addEventListener('scroll', onScroll, { passive: true });

    document.addEventListener('submit', () => {
      saveScroll();
    }, true);

    document.addEventListener('submit', (event) => {
      const form = event.target;
      if (!form || form.tagName !== 'FORM') return;
      const method = String(form.getAttribute('method') || 'GET').trim().toUpperCase();
      if (method === 'GET') return;
      const action = String(form.getAttribute('action') || window.location.pathname).trim();
      if (action && !action.startsWith('/admin') && !action.startsWith(window.location.pathname)) return;
      const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;
      let field = form.querySelector('input[name="_admin_return_to"]');
      if (!field) {
        field = document.createElement('input');
        field.type = 'hidden';
        field.name = '_admin_return_to';
        form.appendChild(field);
      }
      field.value = currentUrl;
    }, true);

    document.addEventListener('click', (event) => {
      const trigger = event.target.closest('a, button');
      if (!trigger) return;
      if (trigger.closest('form')) {
        saveScroll();
        return;
      }
      if (trigger.tagName === 'A') {
        const href = trigger.getAttribute('href') || '';
        if (href.startsWith('/admin') || href.startsWith(window.location.pathname)) {
          saveScroll();
        }
      }
    }, true);

    window.addEventListener('beforeunload', saveScroll);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') saveScroll();
    });
    document.addEventListener('DOMContentLoaded', () => restoreScroll());
    window.addEventListener('pageshow', restoreScroll);
    window.addEventListener('load', () => restoreScroll());
    restoreScroll();
  })();
</script>
<% if (typeof adminPushEnabled !== 'undefined' && adminPushEnabled && adminOneSignalAppId && adminPushExternalId) { %>
<script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer data-onesignal-admin-sdk="true"></script>
<script>
  window.OneSignalDeferred = window.OneSignalDeferred || [];
  window.__ADMIN_ONESIGNAL_APP_ID = <%- JSON.stringify(adminOneSignalAppId) %>;
  window.__ADMIN_ONESIGNAL_EXTERNAL_ID = <%- JSON.stringify(adminPushExternalId) %>;
  OneSignalDeferred.push(async function(OneSignal) {
    try {
      await OneSignal.init({
        appId: window.__ADMIN_ONESIGNAL_APP_ID,
        notifyButton: { enable: false },
        allowLocalhostAsSecureOrigin: true,
        serviceWorkerPath: '/OneSignalSDKWorker.js',
        serviceWorkerUpdaterPath: '/OneSignalSDKUpdaterWorker.js',
        serviceWorkerParam: { scope: '/' },
        autoResubscribe: true
      });
      if (window.__ADMIN_ONESIGNAL_EXTERNAL_ID && typeof OneSignal.login === 'function') {
        await OneSignal.login(window.__ADMIN_ONESIGNAL_EXTERNAL_ID);
      }
      if (OneSignal.Notifications && OneSignal.Notifications.permission !== true && typeof OneSignal.Notifications.requestPermission === 'function') {
        try { await OneSignal.Notifications.requestPermission(); } catch (_error) {}
      }
      window.__ADMIN_ONESIGNAL_READY = true;
    } catch (error) {
      console.warn('OneSignal admin gagal dipasang:', error);
    }
  });
</script>
<% } %>
