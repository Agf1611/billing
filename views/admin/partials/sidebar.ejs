        <span class="sb-badge"><%= Number(adminPendingCustomerRequests || 0) > 99 ? '99+' : Number(adminPendingCustomerRequests || 0) %></span>
      <% } %>
    </a>
    <% } %>
    <a href="/admin/collector-payments" class="sb-item <%= activePage==='collector_payments' ? 'active' : '' %>">
      <i class="bi bi-check2-square"></i><span>Approval Kolektor</span>
    </a>

    <div class="sb-section">LAINNYA</div>
    <a href="/admin/packages" class="sb-item <%= activePage==='packages' ? 'active' : '' %>">
      <i class="bi bi-box-seam"></i><span><%= t('admin.nav.internet_packages', 'Paket Internet') %></span>
    </a>
    <a href="/admin/inventory" class="sb-item <%= activePage==='inventory' ? 'active' : '' %>">
      <i class="bi bi-boxes"></i><span>Inventaris (Stok)</span>
    </a>
