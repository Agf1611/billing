<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.customers.title', 'Pelanggan') %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .usage-bar { height: 4px; background: var(--bg3); border-radius: 2px; margin: 4px 0; overflow: hidden; width: 100px; }
    .usage-fill { height: 100%; width: var(--p, 0%); background: var(--b, var(--primary)); transition: width 0.3s; }
    #picker-map { height: 400px; width: 100%; border-radius: 8px; margin-bottom: 15px; }
    .picker-icon { color: #3b82f6; font-size: 32px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)); display: block; width: 32px; height: 32px; text-align: center; line-height: 32px; text-shadow: -1.5px -1.5px 0 #fff, 1.5px -1.5px 0 #fff, -1.5px 1.5px 0 #fff, 1.5px 1.5px 0 #fff; }
    .location-input-group{display:flex;gap:6px;align-items:stretch}
    .location-input-group .fc{flex:1}
    .location-action-btn{min-width:42px;padding:0 10px;display:inline-flex;align-items:center;justify-content:center;gap:6px;white-space:nowrap}
    .picker-toolbar{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
    .picker-toolbar .btn{min-height:38px}
    .picker-toolbar .hint{margin:0}
    .discount-toggle-card{
      border:1px solid var(--border);
      border-radius:14px;
      background:rgba(99,102,241,.06);
      padding:12px;
    }
    .discount-toggle-line{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      cursor:pointer;
      font-weight:800;
      color:var(--text);
      margin:0;
    }
    .discount-toggle-line input{position:absolute;opacity:0;pointer-events:none}
    .discount-switch{
      width:48px;
      height:28px;
      border-radius:999px;
      background:rgba(148,163,184,.35);
      position:relative;
      flex:0 0 48px;
      transition:.2s ease;
      box-shadow:inset 0 0 0 1px rgba(148,163,184,.28);
    }
    .discount-switch::after{
      content:'';
      position:absolute;
      top:4px;
      left:4px;
      width:20px;
      height:20px;
      border-radius:50%;
      background:#fff;
      box-shadow:0 4px 10px rgba(15,23,42,.18);
      transition:.2s ease;
    }
    .discount-toggle-line input:checked + .discount-switch{background:linear-gradient(135deg,#6366f1,#22c55e)}
    .discount-toggle-line input:checked + .discount-switch::after{transform:translateX(20px)}
    .discount-amount-wrap{margin-top:10px}
    .discount-amount-wrap[hidden]{display:none!important}
    .customer-overview-shell{display:none}
    .customer-overview-top{padding:14px 18px 72px;color:#fff;position:relative}
    .customer-overview-title{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
    .customer-overview-title h3{margin:0;font-size:19px;display:flex;align-items:center;gap:12px}
    .customer-overview-title .info-chip{display:inline-flex;align-items:center;gap:7px;padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.1);font-size:11px;font-weight:700}
    .customer-overview-banner{background:#fff;color:#3b82c4;border-radius:18px;padding:11px 14px;display:flex;align-items:center;gap:10px;box-shadow:0 14px 30px rgba(15,23,42,.12)}
    .customer-overview-banner i{width:30px;height:30px;border-radius:50%;display:grid;place-items:center;background:#e9f4ff;color:#2f8fe8;font-size:17px}
    .customer-overview-content{margin-top:-52px;padding:0 14px 14px}
    .customer-overview-card{background:#fff;border-radius:22px;padding:15px 14px 14px;border:1px solid rgba(148,163,184,.16);box-shadow:0 18px 44px rgba(15,23,42,.12)}
    .customer-overview-toolbar{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:10px}
    .customer-period-form{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .customer-period-form label{font-size:12px;color:#64748b}
    .customer-period-form .period-group{display:flex;align-items:center;gap:6px}
    .customer-period-form select{border:0;background:transparent;font-size:15px;font-weight:800;color:#18213f;outline:none;padding:0 14px 0 0}
    .customer-period-form .period-submit{display:inline-flex;align-items:center;gap:6px;border:0;background:#21316f;color:#fff;border-radius:999px;padding:8px 12px;font-size:12px;font-weight:700}
    .customer-overview-total{font-size:12px;color:#4aa4dd;font-weight:700}
    .overview-section{margin-top:8px}
    .overview-section + .overview-section{margin-top:14px}
    .overview-section h4{margin:0 0 7px;font-size:13px;color:#1b294f}
    .overview-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .overview-card{display:flex;gap:9px;align-items:flex-start;padding:8px 6px;border-radius:14px}
    .overview-icon{width:40px;height:40px;border-radius:12px;display:grid;place-items:center;font-size:20px;flex:0 0 auto;box-shadow:inset 0 0 0 1px rgba(255,255,255,.65)}
    .overview-icon.orange{background:#fff1e8;color:#ff7c1c}
    .overview-icon.blue{background:#eaf4ff;color:#3da0f0}
    .overview-icon.gray{background:#f3f4f6;color:#666}
    .overview-icon.green{background:#ebffe8;color:#39d80d}
    .overview-icon.mint{background:#eafcf5;color:#17b35d}
    .overview-icon.amber{background:#fff7e6;color:#ffb200}
    .overview-icon.red{background:#fff1f2;color:#ef4444}
    .overview-icon.rose{background:#fff0ef;color:#ef4444}
    .overview-copy{min-width:0}
    .overview-label{display:block;color:#5f687d;font-size:11px;margin-bottom:3px}
    .overview-value{display:block;color:#111827;font-size:22px;font-weight:800;line-height:1;letter-spacing:0}
    .overview-amount{display:block;margin-top:4px;color:#1f2937;font-size:11.5px}
    .overview-foot{display:flex;align-items:center;gap:6px;margin-top:4px;font-size:11px;color:#3498db;font-weight:700}
    .overview-link{display:inline-flex;align-items:center;gap:6px;margin-top:4px;font-size:11px;color:#3498db;font-weight:700;text-decoration:none}
    .overview-link:hover{text-decoration:underline}
    .mobile-add-customer{display:none}
    .page-tools{display:flex;gap:8px;flex-wrap:wrap}
    .page-tools .tool-label{display:inline}
    .desktop-search-block{display:grid;gap:5px;min-width:0}
    .desktop-filter-eyebrow{
      display:block;
      font-size:10px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .desktop-filter-hint{
      margin:0;
      font-size:11px;
      line-height:1.45;
      color:var(--muted);
    }
    .desktop-filter-field{
      display:grid;
      gap:6px;
      min-width:0;
    }
    .desktop-filter-field > span{
      font-size:11px;
      font-weight:800;
      letter-spacing:.05em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .mobile-stack{display:none}
    .customer-card{background:var(--bg2);border:1px solid var(--border);border-radius:15px;padding:9px;display:grid;gap:6px}
    .customer-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .customer-head strong{display:block;font-size:13px;line-height:1.12}
    .customer-sub{margin-top:2px;font-size:10px;color:var(--muted);line-height:1.3}
    .customer-chip-row{display:flex;gap:6px;flex-wrap:wrap}
    .customer-chip-row .badge{font-size:10px;padding:6px 9px}
    .customer-inline-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:7px}
    .customer-inline-box{padding:6px 8px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05)}
    .customer-inline-box small{display:block;font-size:8.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px}
    .customer-inline-box strong{display:block;font-size:10.5px;line-height:1.22}
    .customer-inline-box span{display:block;font-size:9.5px;line-height:1.22;color:var(--muted)}
    .customer-meta-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .customer-meta{padding:7px 8px;border-radius:11px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05)}
    .customer-meta small{display:block;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
    .customer-meta strong,.customer-meta span{display:block;font-size:10.5px;line-height:1.28}
    .customer-address-line{display:flex;align-items:flex-start;gap:6px;font-size:10.5px;color:var(--muted);line-height:1.28}
    .customer-address-line i{margin-top:1px;color:var(--primary)}
    .customer-address-line span{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
    .customer-actions{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:5px}
    .customer-actions .btn,.customer-actions form .btn{justify-content:center;padding:0;height:32px;min-height:32px;border-radius:10px}
    .customer-actions form{margin:0}
    .action-mini{display:inline-flex;align-items:center;justify-content:center;gap:6px}
    .action-mini i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:16px;
      height:16px;
      font-size:14px;
      line-height:1;
      flex:0 0 16px;
    }
    .action-mini .action-label{display:none}
    .quick-filter-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
    .quick-filter-row .btn{
      padding:6px 9px;
      display:inline-flex;
      align-items:center;
      gap:6px;
      min-width:0;
    }
    .quick-filter-row .btn i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:16px;
      height:16px;
      font-size:14px;
      line-height:1;
      flex:0 0 16px;
    }
    .quick-filter-row .btn .filter-chip-label{
      min-width:0;
      font-weight:800;
      line-height:1.1;
      white-space:nowrap;
    }
    .quick-filter-row .btn .filter-chip-count{
      margin-left:auto;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:24px;
      height:20px;
      padding:0 7px;
      border-radius:999px;
      background:rgba(99,102,241,.12);
      color:var(--primary);
      font-size:11px;
      font-weight:800;
      line-height:1;
      flex:0 0 auto;
    }
    .quick-filter-row .btn.is-active{background:var(--primary);border-color:var(--primary);color:#fff;box-shadow:0 10px 20px rgba(79,70,229,.22)}
    .quick-filter-row .btn.is-active .filter-chip-count{background:rgba(255,255,255,.18);color:#fff}
    .mobile-filter-toggle{display:none;position:relative;align-items:center;gap:8px}
    .mobile-filter-toggle .mobile-filter-toggle-label{display:none;font-weight:800}
    .mobile-filter-badge{
      position:absolute;
      top:-5px;
      right:-5px;
      min-width:18px;
      height:18px;
      padding:0 5px;
      border-radius:999px;
      background:#ef4444;
      color:#fff;
      font-size:10px;
      font-weight:800;
      display:none;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 18px rgba(239,68,68,.24)
    }
    .mobile-filter-badge.show{display:inline-flex}
    .customer-filter-form{display:flex;align-items:center;gap:8px;flex-wrap:nowrap;width:100%}
    .customer-search-row{display:flex;gap:8px;align-items:center;flex-wrap:nowrap;width:100%;min-width:0}
    .customer-search-row .sinput{flex:1 1 auto;min-width:0}
    .customer-filter-form .customer-search-row{flex:1 1 430px;max-width:520px}
    .customer-filter-panel{display:flex;gap:8px;align-items:center;justify-content:flex-end;flex:1 1 auto;min-width:0;max-width:none;box-sizing:border-box;flex-wrap:nowrap;overflow-x:auto;overflow-y:hidden;scrollbar-width:none}
    .customer-filter-panel::-webkit-scrollbar{display:none}
    .customer-filter-main-row{display:flex;gap:8px;align-items:center;flex-wrap:nowrap;justify-content:flex-end;flex:0 0 auto;min-width:0}
    .customer-filter-panel .mobile-filter-field{min-width:0;flex:0 0 auto}
    .customer-filter-panel select.mobile-filter-field{
      width:auto !important;
      min-width:140px;
      padding-right:36px;
      appearance:auto;
      -webkit-appearance:menulist;
      text-indent:0;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .customer-filter-panel select.mobile-filter-field[name="status"]{min-width:140px}
    .customer-filter-panel select.mobile-filter-field[name="segment"]{min-width:160px}
    .customer-filter-panel select.mobile-filter-field[name="month"]{min-width:124px}
    .customer-filter-panel select.mobile-filter-field[name="year"]{min-width:96px}
    .customer-filter-panel select.mobile-filter-field[name="package_id"]{min-width:150px}
    .customer-filter-panel .mobile-date-row{display:flex;gap:6px;align-items:center;flex-wrap:nowrap;flex:0 0 auto}
    .customer-filter-panel .mobile-filter-actions{display:flex;gap:6px;align-items:center;flex-wrap:nowrap;flex:0 0 auto}
    .customer-filter-panel .fs,
    .customer-filter-panel .fc,
    .customer-filter-panel .btn{white-space:nowrap}
    .customer-filter-panel .mobile-filter-actions .btn{
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .customer-table-action{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:6px;
      line-height:1;
    }
    .customer-table-action i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:16px;
      height:16px;
      font-size:14px;
      line-height:1;
      flex:0 0 16px;
    }
    .customer-reset-btn{
      width:32px;
      min-width:32px;
      padding:0;
    }
    .customer-reset-btn .customer-table-action span:last-child{display:none}
    .customer-filter-summary{display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;margin-top:8px;padding:7px 10px;border-radius:12px;border:1px solid var(--border);background:rgba(255,255,255,.03)}
    .customer-filter-summary strong{font-size:12px;color:var(--text)}
    .customer-filter-summary span{font-size:11px;color:var(--muted)}
    .customer-filter-summary .summary-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .customer-filter-summary .summary-chip{display:inline-flex;align-items:center;gap:5px;padding:5px 8px;border-radius:999px;background:rgba(99,102,241,.12);color:var(--primary);font-size:10.5px;font-weight:700}
    .customer-profile-mini{display:grid;gap:3px;margin-top:6px;font-size:10.5px;line-height:1.25;color:var(--muted)}
    .customer-profile-mini strong{color:var(--text);font-size:11px}
    .customer-profile-tags{display:flex;gap:5px;flex-wrap:wrap;margin-top:4px}
    .profile-tag{display:inline-flex;align-items:center;gap:4px;padding:4px 7px;border-radius:999px;border:1px solid var(--border);background:rgba(255,255,255,.04);font-size:9.5px;font-weight:800;color:var(--muted)}
    .profile-tag.warn{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.28);color:#f59e0b}
    .profile-tag.boost{background:rgba(34,197,94,.12);border-color:rgba(34,197,94,.28);color:#22c55e}
    .speed-boost-card{border:1px solid var(--border);border-radius:14px;background:rgba(34,197,94,.07);padding:12px;display:grid;gap:10px}
    .speed-boost-card .speed-boost-head{display:flex;align-items:center;gap:8px;font-weight:800;color:var(--text)}
    .table-empty-state{
      display:grid;
      justify-items:center;
      gap:10px;
      padding:18px 12px;
      text-align:center;
    }
    .table-empty-state i{
      width:48px;
      height:48px;
      border-radius:16px;
      display:grid;
      place-items:center;
      font-size:22px;
      color:var(--primary);
      background:rgba(99,102,241,.12);
      box-shadow:inset 0 0 0 1px rgba(99,102,241,.12);
    }
    .table-empty-state strong{
      font-size:15px;
      line-height:1.3;
      color:var(--text);
    }
    .table-empty-state span{
      max-width:420px;
      font-size:12px;
      line-height:1.55;
      color:var(--muted);
    }
    .customer-table{
      position:relative;
      overflow:auto;
      scrollbar-gutter:stable;
    }
    .customer-table.is-loading::before{
      content:'';
      position:absolute;
      inset:0;
      background:rgba(7,12,24,.42);
      backdrop-filter:blur(3px);
      z-index:5;
    }
    .customer-table.is-loading::after{
      content:attr(data-loading-text);
      position:absolute;
      top:24px;
      right:24px;
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:12px 16px;
      border-radius:14px;
      background:rgba(15,23,42,.94);
      color:#fff;
      font-size:12px;
      font-weight:800;
      letter-spacing:.02em;
      box-shadow:0 16px 34px rgba(15,23,42,.24);
      z-index:6;
    }
    .customer-table.is-loading .dtbl{
      pointer-events:none;
    }
    @media(min-width:769px){
      .page-filter-card .card-hd{
        align-items:flex-start;
        gap:14px;
      }
      .page-tools{
        align-items:center;
        justify-content:flex-end;
        gap:10px;
      }
      .page-tools .btn{
        min-height:42px;
        padding:0 14px;
        border-radius:14px;
        font-weight:700;
      }
      .desktop-search-block{
        gap:0;
      }
      .desktop-search-block .desktop-filter-eyebrow,
      .desktop-search-block .desktop-filter-hint{
        display:none;
      }
      .customer-filter-form{
        display:flex;
        align-items:center;
        gap:8px;
        flex-wrap:nowrap;
      }
      .customer-search-row{
        display:flex;
        align-items:center;
        flex:0 0 300px;
        max-width:300px;
      }
      .customer-search-row .desktop-search-block,
      .customer-search-row .sinput{
        width:100%;
      }
      .customer-search-row .sinput{
        max-width:none !important;
      }
      .customer-filter-panel{
        padding:0;
        border:0;
        border-radius:0;
        background:transparent;
        overflow:visible;
        display:flex;
        align-items:center;
        gap:7px;
        flex:1 1 auto;
        min-width:0;
      }
      .customer-filter-main-row,
      .customer-filter-panel .mobile-date-row{
        display:flex;
        align-items:center;
        gap:7px;
        flex-wrap:nowrap;
        width:auto;
      }
      .customer-filter-panel .mobile-filter-actions{
        display:flex;
        align-items:center;
        justify-content:flex-end;
        gap:6px;
        margin-left:auto;
        width:auto;
        flex:0 0 auto;
      }
      .customer-filter-panel .desktop-filter-field{
        gap:0;
      }
      .customer-filter-panel .desktop-filter-field > span{
        display:none;
      }
      .customer-filter-panel .desktop-filter-field .fs,
      .customer-filter-panel .desktop-filter-field .fc{
        width:auto !important;
        min-height:36px;
        height:36px;
        font-size:12px;
      }
      .customer-filter-panel select[name="status"]{min-width:116px}
      .customer-filter-panel select[name="segment"]{min-width:128px}
      .customer-filter-panel select[name="package_id"]{min-width:138px}
      .customer-filter-panel select[name="month"]{min-width:92px}
      .customer-filter-panel select[name="year"]{min-width:78px}
      .customer-filter-panel input[name="billingDayStart"],
      .customer-filter-panel input[name="billingDayEnd"]{
        width:82px !important;
        padding-left:9px;
        padding-right:9px;
      }
      .customer-filter-panel .mobile-filter-actions .btn{
        min-height:36px;
        height:36px;
        padding:0 10px;
      }
      .customer-filter-summary{
        margin-top:8px;
        padding:7px 10px;
        border-radius:12px;
      }
      .customer-filter-summary strong{
        display:block;
        font-size:12px;
        margin-bottom:1px;
      }
      .quick-filter-row{
        display:flex;
        flex-wrap:nowrap;
        overflow:auto;
        scrollbar-width:none;
        gap:6px;
        margin-top:8px;
        padding:4px;
        padding-bottom:5px;
        border:1px solid rgba(255,255,255,.05);
        border-radius:12px;
        background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.018));
        align-items:center;
      }
      .quick-filter-row::-webkit-scrollbar{display:none}
      .quick-filter-row .btn{
        min-height:30px;
        padding:4px 8px;
        border-radius:10px;
        justify-content:flex-start;
        flex:0 0 auto;
        background:transparent;
        border-color:transparent;
        box-shadow:none;
      }
      .quick-filter-row .btn i{
        width:13px;
        height:13px;
        font-size:11px;
        flex:0 0 13px;
      }
      .quick-filter-row .btn .filter-chip-label{
        font-size:10px;
        font-weight:800;
      }
