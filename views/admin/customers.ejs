bindUploadPreview('e_house_photo_file', 'edit_house_preview', 'edit_house_preview_name', 'Preview Rumah');

function toDateTimeLocalInput(value) {
  if (!value) return '';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '';
  const pad = (number) => String(number).padStart(2, '0');
  return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
}

function editCust(idx) {
  const c = customersData[idx];
  if (!c) return;
  document.getElementById('editForm').action='/admin/customers/'+c.id+'/update';
