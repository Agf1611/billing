let customerSearchAbortController = null;
async function syncCustomerSearchSuggestions(query) {
  const input = document.getElementById('customerSearchInput');
  const list = document.getElementById('customerSearchSuggestions');
  if (!input || !list) return;
  const keyword = String(query || '').trim();
  if (keyword.length < 2) {
    list.replaceChildren();
    return;
  }
  try {
    if (customerSearchAbortController) customerSearchAbortController.abort();
    customerSearchAbortController = new AbortController();
    const res = await fetch(`/admin/api/customers/suggest?q=${encodeURIComponent(keyword)}`, {
      signal: customerSearchAbortController.signal
    });
    if (!res.ok) return;
    const rows = await res.json();
    list.replaceChildren();
    (Array.isArray(rows) ? rows : []).forEach((row) => {
      const option = document.createElement('option');
      const name = String(row.name || '').trim();
      const phone = String(row.phone || '').trim();
      const pppoe = String(row.pppoe_username || '').trim();
      const tag = String(row.genieacs_tag || '').trim();
      option.value = name || phone || pppoe || tag;
      option.label = [phone, pppoe, tag].filter(Boolean).join(' • ');
      list.appendChild(option);
    });
  } catch (error) {
    if (error && error.name === 'AbortError') return;
    console.error('Failed to load customer suggestions', error);
  }
}

document.getElementById('customerSearchInput')?.addEventListener('input', (event) => {
  syncCustomerSearchSuggestions(event.target.value);
});

function triggerCustomerAutoSearch(force = false) {
  const input = document.getElementById('customerSearchInput');
  const form = document.getElementById('customerSearchForm');
  if (!input || !form) return;
  const keyword = String(input.value || '').trim();
  if (!force && keyword.length > 0 && keyword.length < 2) return;
  const params = new URLSearchParams(new FormData(form));
  params.set('page', '1');
  const nextUrl = `${form.action}?${params.toString()}`;
  if (`${window.location.pathname}${window.location.search}` === `${form.action.replace(window.location.origin, '')}?${params.toString()}`) return;
  window.location.assign(nextUrl);
}

document.getElementById('customerSearchInput')?.addEventListener('change', () => {
  triggerCustomerAutoSearch(true);
});

