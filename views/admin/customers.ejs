<script>
const customersData = JSON.parse(document.getElementById('customers-data').textContent);
const appSettings = JSON.parse(document.getElementById('settings-data').textContent);
let pickerMap, pickerMarker, activePickerType;
let payCustomerId = null;
let payBillingMeta = null;

const PAY_MNS = JSON.parse(document.getElementById('pay-months-data').textContent);
const PAY_I18N = JSON.parse(document.getElementById('pay-i18n-data').textContent);

const officeCoords = {
  lat: parseFloat(appSettings.office_lat) || -7.140868012256965,
  lng: parseFloat(appSettings.office_lng) || 107.00277733308137
};

function openModal(id){document.getElementById(id).classList.add('show')}
function closeModal(id){document.getElementById(id).classList.remove('show')}
function syncCustomerMobileFilterLayout() {
  const form = document.getElementById('customerSearchForm');
  const searchRow = form?.querySelector('.customer-search-row');
  const panel = document.getElementById('customerFilterPanel');
  const dateRow = panel?.querySelector('.mobile-date-row');
  const actionRow = panel?.querySelector('.mobile-filter-actions');
  if (!form || !searchRow || !panel) return;
  const isMobile = window.innerWidth <= 1100;
  searchRow.removeAttribute('style');
  panel.removeAttribute('style');
  dateRow?.removeAttribute('style');
  actionRow?.removeAttribute('style');
  if (!isMobile) panel.classList.remove('show');
}
function toggleCustomerFilterPanel(force) {
  const panel = document.getElementById('customerFilterPanel');
  if (!panel) return;
  syncCustomerMobileFilterLayout();
  if (window.innerWidth > 1100) return;
  if (typeof force === 'boolean') {
    panel.classList.toggle('show', force);
    return;
  }
  panel.classList.toggle('show');
}

function getActiveCustomerFilterCount() {
  const statusValue = String(document.querySelector('#customerSearchForm [name="status"]')?.value || '').trim();
  const segmentValue = String(document.querySelector('#customerSearchForm [name="segment"]')?.value || '').trim();
  const packageValue = String(document.querySelector('#customerSearchForm [name="package_id"]')?.value || '').trim();
  const monthValue = String(document.querySelector('#customerSearchForm [name="month"]')?.value || '').trim();
  const yearValue = String(document.querySelector('#customerSearchForm [name="year"]')?.value || '').trim();
  const billingDayStartValue = String(document.querySelector('#customerSearchForm [name="billingDayStart"]')?.value || '').trim();
  const billingDayEndValue = String(document.querySelector('#customerSearchForm [name="billingDayEnd"]')?.value || '').trim();
  let count = 0;
  if (statusValue && statusValue !== 'active') count += 1;
  if (segmentValue) count += 1;
  if (packageValue) count += 1;
  if (monthValue && Number(monthValue) !== (new Date().getMonth() + 1)) count += 1;
  if (yearValue && Number(yearValue) !== new Date().getFullYear()) count += 1;
  if (billingDayStartValue) count += 1;
  if (billingDayEndValue) count += 1;
  return count;
}

function syncCustomerFilterBadge() {
  const badge = document.getElementById('customerFilterBadge');
  if (!badge) return;
  const count = getActiveCustomerFilterCount();
  badge.textContent = count > 99 ? '99+' : String(count);
  badge.classList.toggle('show', count > 0);
}

function applyLocationToInputs(type, lat, lng) {
  if (!type) return;
  const prefix = type === 'add' ? 'add_' : 'e_';
  const latInput = document.getElementById(prefix + 'lat');
  const lngInput = document.getElementById(prefix + 'lng');
  if (latInput) latInput.value = Number(lat).toFixed(8);
  if (lngInput) lngInput.value = Number(lng).toFixed(8);
}

function syncPickerMarker(lat, lng) {
  if (!pickerMap || !pickerMarker) return;
  pickerMarker.setLatLng([lat, lng]);
  pickerMap.setView([lat, lng], Math.max(pickerMap.getZoom() || 16, 16));
}

function openPicker(type) {
  activePickerType = type;
  openModal('mapPickerModal');
  
  let currentLat = document.getElementById(type === 'add' ? 'add_lat' : 'e_lat').value;
  let currentLng = document.getElementById(type === 'add' ? 'add_lng' : 'e_lng').value;
  
  let startLat = parseFloat(currentLat) || officeCoords.lat;
  let startLng = parseFloat(currentLng) || officeCoords.lng;

  setTimeout(() => {
    if (!pickerMap) {
      pickerMap = L.map('picker-map').setView([startLat, startLng], 16);
      L.tileLayer('https://{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
        maxZoom: 20,
        subdomains: ['mt0', 'mt1', 'mt2', 'mt3']
      }).addTo(pickerMap);
      
      const customIcon = L.divIcon({
        html: '<i class="bi bi-geo-alt-fill picker-icon"></i>',
        className: 'custom-div-icon',
        iconSize: [32, 32],
        iconAnchor: [16, 32]
      });

      pickerMarker = L.marker([startLat, startLng], { 
        draggable: true,
        icon: customIcon
      }).addTo(pickerMap);
      
      pickerMarker.on('dragend', function() {
        const pos = pickerMarker.getLatLng();
        applyLocationToInputs(activePickerType, pos.lat, pos.lng);
      });

      pickerMap.on('click', function(e) {
        pickerMarker.setLatLng(e.latlng);
        applyLocationToInputs(activePickerType, e.latlng.lat, e.latlng.lng);
      });
    } else {
      pickerMap.setView([startLat, startLng], 16);
      pickerMarker.setLatLng([startLat, startLng]);
      pickerMap.invalidateSize();
    }
  }, 300);
}

function useCurrentLocation(type, keepModalOpen = false) {
  const targetType = type || activePickerType || 'add';
  requestDeviceLocation((lat, lng) => {
    activePickerType = targetType;
    applyLocationToInputs(targetType, lat, lng);
    if (keepModalOpen) syncPickerMarker(lat, lng);
  });
}

async function requestDeviceLocation(onSuccess) {
  if (!navigator.geolocation) {
    alert('Browser ini tidak mendukung GPS.');
    return;
  }

  try {
    if (window.median?.android?.geoLocation?.promptLocationServices) {
      window.median.android.geoLocation.promptLocationServices();
      await new Promise((resolve) => setTimeout(resolve, 700));
    }
  } catch (_) {}

  navigator.geolocation.getCurrentPosition((position) => {
    const lat = Number(position.coords.latitude || 0);
    const lng = Number(position.coords.longitude || 0);
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
      alert('Koordinat GPS tidak valid.');
      return;
    }
    onSuccess(lat, lng);
  }, () => {
    const inMedianApp = Boolean(window.median?.android?.geoLocation?.promptLocationServices);
    if (inMedianApp && window.median?.open?.appSettings) {
      const openSettings = confirm('Lokasi GPS belum diizinkan. Buka pengaturan aplikasi untuk mengaktifkan izin lokasi?');
      if (openSettings) {
        try { window.median.open.appSettings(); } catch (_) {}
      }
      return;
    }
    alert('Lokasi GPS tidak berhasil diambil. Pastikan izin lokasi diaktifkan.');
  }, {
    enableHighAccuracy: true,
    timeout: 12000,
    maximumAge: 0
  });
}

function toggleConnectionFields(type) {
