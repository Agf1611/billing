<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.customers.title', 'Pelanggan') %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .usage-bar { height: 4px; background: var(--bg3); border-radius: 2px; margin: 4px 0; overflow: hidden; width: 100px; }
    .usage-fill { height: 100%; width: var(--p, 0%); background: var(--b, var(--primary)); transition: width 0.3s; }
    #picker-map { height: 400px; width: 100%; border-radius: 8px; margin-bottom: 15px; }
    .picker-icon { color: #3b82f6; font-size: 32px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)); display: block; width: 32px; height: 32px; text-align: center; line-height: 32px; text-shadow: -1.5px -1.5px 0 #fff, 1.5px -1.5px 0 #fff, -1.5px 1.5px 0 #fff, 1.5px 1.5px 0 #fff; }
    .location-input-group{display:flex;gap:6px;align-items:stretch}
    .location-input-group .fc{flex:1}
    .location-action-btn{min-width:42px;padding:0 10px;display:inline-flex;align-items:center;justify-content:center;gap:6px;white-space:nowrap}
    .picker-toolbar{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
    .picker-toolbar .btn{min-height:38px}
    .picker-toolbar .hint{margin:0}
    .customer-overview-shell{display:none}
    .customer-overview-top{padding:18px 20px 88px;color:#fff;position:relative}
    .customer-overview-title{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px}
    .customer-overview-title h3{margin:0;font-size:19px;display:flex;align-items:center;gap:12px}
    .customer-overview-title .info-chip{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.1);font-size:12px;font-weight:700}
    .customer-overview-banner{background:#fff;color:#3b82c4;border-radius:22px;padding:16px 18px;display:flex;align-items:center;gap:14px;box-shadow:0 14px 30px rgba(15,23,42,.12)}
    .customer-overview-banner i{width:36px;height:36px;border-radius:50%;display:grid;place-items:center;background:#e9f4ff;color:#2f8fe8;font-size:20px}
    .customer-overview-content{margin-top:-62px;padding:0 16px 18px}
    .customer-overview-card{background:#fff;border-radius:26px;padding:22px 18px 18px;border:1px solid rgba(148,163,184,.16);box-shadow:0 18px 44px rgba(15,23,42,.12)}
    .customer-overview-toolbar{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:18px}
    .customer-period-form{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
    .customer-period-form label{font-size:14px;color:#64748b}
    .customer-period-form .period-group{display:flex;align-items:center;gap:10px}
    .customer-period-form select{border:0;background:transparent;font-size:18px;font-weight:800;color:#18213f;outline:none;padding:0 18px 0 0}
    .customer-period-form .period-submit{display:inline-flex;align-items:center;gap:8px;border:0;background:#21316f;color:#fff;border-radius:999px;padding:10px 15px;font-weight:700}
    .customer-overview-total{font-size:14px;color:#4aa4dd;font-weight:700}
    .overview-section{margin-top:12px}
    .overview-section + .overview-section{margin-top:22px}
    .overview-section h4{margin:0 0 12px;font-size:15px;color:#1b294f}
    .overview-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .overview-card{display:flex;gap:14px;align-items:flex-start;padding:12px 8px;border-radius:18px}
    .overview-icon{width:54px;height:54px;border-radius:16px;display:grid;place-items:center;font-size:26px;flex:0 0 auto;box-shadow:inset 0 0 0 1px rgba(255,255,255,.65)}
    .overview-icon.orange{background:#fff1e8;color:#ff7c1c}
    .overview-icon.blue{background:#eaf4ff;color:#3da0f0}
    .overview-icon.gray{background:#f3f4f6;color:#666}
    .overview-icon.green{background:#ebffe8;color:#39d80d}
    .overview-icon.mint{background:#eafcf5;color:#17b35d}
    .overview-icon.amber{background:#fff7e6;color:#ffb200}
    .overview-icon.red{background:#fff1f2;color:#ef4444}
    .overview-icon.rose{background:#fff0ef;color:#ef4444}
    .overview-copy{min-width:0}
    .overview-label{display:block;color:#5f687d;font-size:13px;margin-bottom:4px}
    .overview-value{display:block;color:#111827;font-size:28px;font-weight:800;line-height:1}
    .overview-amount{display:block;margin-top:6px;color:#1f2937;font-size:13px}
    .overview-foot{display:flex;align-items:center;gap:8px;margin-top:5px;font-size:12px;color:#3498db;font-weight:700}
    .overview-link{display:inline-flex;align-items:center;gap:8px;margin-top:6px;font-size:12px;color:#3498db;font-weight:700;text-decoration:none}
    .overview-link:hover{text-decoration:underline}
    .mobile-add-customer{display:none}
    .page-tools{display:flex;gap:8px;flex-wrap:wrap}
    .page-tools .tool-label{display:inline}
    .mobile-stack{display:none}
    .customer-card{background:var(--bg2);border:1px solid var(--border);border-radius:15px;padding:9px;display:grid;gap:6px}
    .customer-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .customer-head strong{display:block;font-size:13px;line-height:1.12}
    .customer-sub{margin-top:2px;font-size:10px;color:var(--muted);line-height:1.3}
    .customer-chip-row{display:flex;gap:6px;flex-wrap:wrap}
    .customer-chip-row .badge{font-size:10px;padding:6px 9px}
    .customer-inline-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:7px}
    .customer-inline-box{padding:6px 8px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05)}
    .customer-inline-box small{display:block;font-size:8.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px}
    .customer-inline-box strong{display:block;font-size:10.5px;line-height:1.22}
    .customer-inline-box span{display:block;font-size:9.5px;line-height:1.22;color:var(--muted)}
    .customer-meta-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .customer-meta{padding:7px 8px;border-radius:11px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05)}
    .customer-meta small{display:block;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
    .customer-meta strong,.customer-meta span{display:block;font-size:10.5px;line-height:1.28}
    .customer-address-line{display:flex;align-items:flex-start;gap:6px;font-size:10.5px;color:var(--muted);line-height:1.28}
    .customer-address-line i{margin-top:1px;color:var(--primary)}
    .customer-address-line span{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
    .customer-actions{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:5px}
    .customer-actions .btn,.customer-actions form .btn{justify-content:center;padding:0;height:32px;min-height:32px;border-radius:10px}
    .customer-actions form{margin:0}
    .action-mini{display:inline-flex;align-items:center;justify-content:center;gap:6px}
    .action-mini i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:16px;
      height:16px;
      font-size:14px;
      line-height:1;
      flex:0 0 16px;
    }
    .action-mini .action-label{display:none}
    .quick-filter-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
    .quick-filter-row .btn{
      padding:8px 12px;
      display:inline-flex;
      align-items:center;
      gap:8px;
      min-width:0;
    }
    .quick-filter-row .btn i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:16px;
      height:16px;
      font-size:14px;
      line-height:1;
      flex:0 0 16px;
    }
    .quick-filter-row .btn .filter-chip-label{
      min-width:0;
      font-weight:800;
      line-height:1.1;
      white-space:nowrap;
    }
    .quick-filter-row .btn .filter-chip-count{
      margin-left:auto;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:28px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:rgba(99,102,241,.12);
      color:var(--primary);
      font-size:11px;
      font-weight:800;
      line-height:1;
      flex:0 0 auto;
    }
    .quick-filter-row .btn.is-active{background:var(--primary);border-color:var(--primary);color:#fff;box-shadow:0 10px 20px rgba(79,70,229,.22)}
    .quick-filter-row .btn.is-active .filter-chip-count{background:rgba(255,255,255,.18);color:#fff}
    .mobile-filter-toggle{display:none;position:relative}
    .mobile-filter-badge{
      position:absolute;
      top:-5px;
      right:-5px;
      min-width:18px;
      height:18px;
      padding:0 5px;
      border-radius:999px;
      background:#ef4444;
      color:#fff;
      font-size:10px;
      font-weight:800;
      display:none;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 18px rgba(239,68,68,.24)
    }
    .mobile-filter-badge.show{display:inline-flex}
    .customer-filter-form{display:flex;align-items:center;gap:10px;flex-wrap:nowrap;width:100%}
    .customer-search-row{display:flex;gap:10px;align-items:center;flex-wrap:nowrap;width:100%;min-width:0}
    .customer-search-row .sinput{flex:1 1 auto;min-width:0}
    .customer-filter-form .customer-search-row{flex:0 1 360px;max-width:360px}
    .customer-filter-panel{display:flex;gap:10px;align-items:center;justify-content:flex-end;flex:1 1 auto;min-width:0;max-width:none;box-sizing:border-box;flex-wrap:nowrap;overflow-x:auto;overflow-y:hidden;scrollbar-width:none}
    .customer-filter-panel::-webkit-scrollbar{display:none}
    .customer-filter-main-row{display:flex;gap:10px;align-items:center;flex-wrap:nowrap;justify-content:flex-end;flex:0 0 auto;min-width:0}
    .customer-filter-panel .mobile-filter-field{min-width:0}
    .customer-filter-panel .mobile-date-row{display:flex;gap:8px;align-items:center;flex-wrap:nowrap;flex:0 0 auto}
    .customer-filter-panel .mobile-filter-actions{display:flex;gap:8px;align-items:center;flex-wrap:nowrap;flex:0 0 auto}
    .customer-filter-panel .fs,
    .customer-filter-panel .fc,
    .customer-filter-panel .btn{white-space:nowrap}
    .customer-filter-summary{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-top:14px;padding:10px 12px;border-radius:14px;border:1px solid var(--border);background:rgba(255,255,255,.03)}
    .customer-filter-summary strong{font-size:13px;color:var(--text)}
    .customer-filter-summary span{font-size:12px;color:var(--muted)}
    .customer-filter-summary .summary-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .customer-filter-summary .summary-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:rgba(99,102,241,.12);color:var(--primary);font-size:11px;font-weight:700}
    .upload-preview-row{display:flex;align-items:flex-start;gap:10px;margin-top:10px;flex-wrap:wrap}
    .upload-preview-card{width:104px;min-height:104px;border-radius:16px;border:1px dashed rgba(148,163,184,.35);background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
    .upload-preview-card img{width:100%;height:104px;object-fit:cover;display:block}
    .upload-preview-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:10px;color:var(--muted);font-size:11px;text-align:center;line-height:1.35}
    .upload-preview-empty i{font-size:20px;color:var(--primary)}
    .upload-preview-meta{display:flex;flex-direction:column;gap:4px;max-width:220px}
    .upload-preview-name{font-size:11px;color:var(--text);line-height:1.4;word-break:break-word}
    .upload-preview-state{font-size:10px;color:var(--muted)}
    .upload-preview-clear{min-height:32px}
    body[data-theme="light"] .customer-card{
      background:rgba(255,255,255,.9);
      box-shadow:0 14px 30px rgba(165,162,211,.12);
    }
    body[data-theme="light"] .customer-filter-summary{
      background:rgba(105,88,255,.04);
      border-color:rgba(148,163,184,.18);
    }
    body[data-theme="light"] .customer-meta{
      background:rgba(105,88,255,.04);
      border-color:rgba(148,163,184,.18);
    }
    body[data-theme="light"] .customer-inline-box{
      background:rgba(105,88,255,.04);
      border-color:rgba(148,163,184,.18);
    }
    body[data-theme="light"] .customer-head strong,
    body[data-theme="light"] .customer-meta strong,
    body[data-theme="light"] .customer-meta span,
    body[data-theme="light"] .customer-inline-box strong{
      color:#24304a;
    }
    body[data-theme="light"] .customer-inline-box span{
      color:#6f7d98;
    }
    body[data-theme="light"] .customer-sub,
    body[data-theme="light"] .customer-address-line{
      color:#6f7d98;
    }
    body[data-theme="dark"] .customer-overview-shell{
      background:linear-gradient(180deg,#0d1730 0%,#101c36 150px,#0f172a 150px,#0f172a 100%);
    }
    body[data-theme="dark"] .tbl-wrap,
    body[data-theme="dark"] .dtbl{
      color:var(--text);
    }
    body[data-theme="dark"] .dtbl td{
      color:rgba(226,232,240,.94);
    }
    body[data-theme="dark"] .dtbl td strong,
    body[data-theme="dark"] .dtbl td b,
    body[data-theme="dark"] .dtbl td .text-strong{
      color:#f8fafc;
    }
    body[data-theme="dark"] .dtbl td .text-muted,
    body[data-theme="dark"] .dtbl td div[style*='font-size:10px'],
    body[data-theme="dark"] .dtbl td div[style*='font-size:12px']{
      color:rgba(148,163,184,.94) !important;
    }
    body[data-theme="dark"] .dtbl td a,
    body[data-theme="dark"] .dtbl td .usage-label,
    body[data-theme="dark"] .dtbl td .customer-inline-link{
      color:#e2e8f0;
    }
    body[data-theme="dark"] .dtbl td .package-name,
    body[data-theme="dark"] .dtbl td .package-line,
    body[data-theme="dark"] .dtbl td .usage-line,
    body[data-theme="dark"] .dtbl td .address-line{
      color:#e2e8f0;
    }
    body[data-theme="dark"] .dtbl td .package-sub,
    body[data-theme="dark"] .dtbl td .usage-sub,
    body[data-theme="dark"] .dtbl td .address-sub{
      color:#94a3b8;
    }
    body[data-theme="dark"] .customer-overview-banner,
    body[data-theme="dark"] .customer-overview-card{
      background:rgba(17,24,39,.96);
      color:var(--text);
      border:1px solid var(--border);
      box-shadow:0 18px 44px rgba(2,6,23,.34);
    }
    body[data-theme="dark"] .customer-overview-banner i{
      background:rgba(59,130,246,.14);
      color:#7ab8ff;
    }
    body[data-theme="dark"] .customer-period-form label,
    body[data-theme="dark"] .overview-label,
    body[data-theme="dark"] .customer-overview-total,
    body[data-theme="dark"] .overview-amount{
      color:var(--muted);
    }
    body[data-theme="dark"] .customer-period-form select,
    body[data-theme="dark"] .overview-section h4,
    body[data-theme="dark"] .overview-value,
    body[data-theme="dark"] .overview-copy strong,
    body[data-theme="dark"] .customer-overview-banner strong,
    body[data-theme="dark"] .customer-overview-banner span{
      color:var(--text);
    }
    body[data-theme="dark"] .overview-link,
    body[data-theme="dark"] .overview-foot{
      color:#7ab8ff;
    }
    body[data-theme="dark"] .overview-icon.gray{
      background:rgba(148,163,184,.12);
      color:#cbd5e1;
    }
    body[data-theme="dark"] .overview-icon.blue{
      background:rgba(59,130,246,.14);
      color:#7ab8ff;
    }
    body[data-theme="dark"] .overview-icon.green{
      background:rgba(34,197,94,.14);
      color:#6ee7a1;
    }
    body[data-theme="dark"] .overview-icon.orange,
    body[data-theme="dark"] .overview-icon.amber{
      background:rgba(245,158,11,.14);
      color:#fbbf24;
    }
    body[data-theme="dark"] .overview-icon.red,
    body[data-theme="dark"] .overview-icon.rose{
      background:rgba(239,68,68,.14);
      color:#fda4af;
    }
    body[data-theme="dark"] .overview-icon.mint{
      background:rgba(20,184,166,.14);
      color:#5eead4;
    }
    @media(max-width:768px){
      .topbar{
        display:grid;
        grid-template-columns:minmax(0,1fr) auto;
        align-items:start;
        gap:8px;
      }
      .topbar .tb-title{min-width:0}
      .topbar .tb-right{
        justify-self:end;
        display:flex;
        align-items:center;
        gap:6px;
        flex-wrap:nowrap;
      }
      .topbar .tb-right .adm-badge{display:none}
      .topbar .tb-right .tb-theme-btn{min-width:42px;padding:0 10px}
      .topbar .tb-right .tb-theme-btn span{display:none}
      .topbar .tb-right > .btn.btn-g.btn-sm:last-child{min-width:42px;padding:0 10px}
      .customer-overview-shell{border-radius:24px;background:linear-gradient(180deg,#1f2f73 0%,#1f2f73 140px,#f7f9ff 140px,#fff 100%)}
      .customer-overview-top{padding:16px 16px 82px}
      .customer-overview-title h3{font-size:17px}
      .customer-overview-title .info-chip{padding:8px 12px}
      .customer-overview-content{padding:0 10px 16px}
      .customer-overview-card{padding:18px 14px 88px}
      .customer-period-form{width:100%;justify-content:space-between}
      .customer-period-form .period-group{gap:6px}
      .customer-period-form select{font-size:17px}
      .customer-overview-total{width:100%}
      .overview-grid{gap:8px}
      .overview-card{padding:10px 4px}
      .overview-icon{width:48px;height:48px;font-size:23px;border-radius:14px}
      .overview-label{font-size:12px}
      .overview-value{font-size:24px}
      .overview-amount{font-size:12px}
      .mobile-add-customer{display:flex;position:sticky;bottom:14px;left:0;right:0;justify-content:center;z-index:15;margin-top:-68px}
      .mobile-add-customer .btn{width:min(100%,340px);border-radius:18px;min-height:54px;font-size:16px;box-shadow:0 18px 36px rgba(31,47,115,.25)}
      .card-hd{align-items:flex-start}
      .card-hd h6{line-height:1.35}
      .page-tools{width:100%;display:grid;grid-template-columns:46px 46px minmax(0,1fr);gap:8px}
      .page-tools .btn{justify-content:center;min-width:0}
      .page-tools .btn:nth-child(1),
      .page-tools .btn:nth-child(2){padding-inline:0}
      .page-tools .btn:nth-child(1) .tool-label,
      .page-tools .btn:nth-child(2) .tool-label{display:none}
      .location-input-group{flex-wrap:wrap}
      .location-action-btn{flex:1}
      .srow{align-items:stretch}
      .srow .sinput{max-width:none !important;flex:1 1 auto}
      #customerSearchForm{display:block !important;width:100%}
      .customer-filter-form{display:block !important;width:100%}
      .mobile-filter-toggle{display:inline-flex;flex:0 0 46px;min-width:46px;height:46px;padding:0;justify-content:center}
      .customer-search-row{
        display:grid;
        grid-template-columns:minmax(0,1fr) 46px;
        align-items:start;
        gap:8px;
        width:100%;
        margin-bottom:10px;
      }
      .customer-search-row .sinput{
        min-width:0;
        width:100%;
        max-width:none !important;
      }
      .customer-filter-form .customer-search-row{max-width:none}
      .customer-search-row .mobile-filter-toggle{align-self:stretch}
      .customer-filter-panel{
        display:none;
        position:static !important;
        float:none !important;
        width:100%;
        min-width:0;
        gap:8px;
        margin-top:10px;
        padding:10px;
        border:1px solid var(--border);
        border-radius:16px;
        background:rgba(255,255,255,.03);
        overflow:visible;
      }
      .customer-filter-panel.show{display:grid !important;grid-template-columns:1fr}
      .customer-filter-main-row{
        display:grid;
        grid-template-columns:repeat(3,minmax(0,1fr));
        gap:8px;
        width:100%;
      }
      .customer-filter-panel .mobile-filter-field{width:100%}
      .customer-filter-panel .mobile-date-row{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:8px;
        margin-top:8px;
        width:100%;
      }
      .customer-filter-panel .fs,
      .customer-filter-panel .fc,
      .customer-filter-panel .btn{width:100% !important;max-width:none !important}
      .customer-filter-panel .btn{justify-content:center}
      .customer-filter-panel .btn-apply-mobile{display:inline-flex}
      .customer-filter-panel .mobile-filter-actions{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:8px;
        margin-top:8px;
        width:100%;
      }
      .quick-filter-row{
        display:grid;
        grid-template-columns:repeat(4,minmax(0,1fr));
        gap:6px;
      }
      .quick-filter-row .btn{
        width:100%;
        justify-content:center;
        min-height:42px;
        padding:7px 6px;
        font-size:10.5px;
        gap:5px;
      }
      .tbl-wrap{display:none}
      .mobile-stack{display:grid;gap:8px;padding:0 0 12px}
    }
    @media(max-width:576px){
      .customer-filter-main-row{grid-template-columns:repeat(3,minmax(0,1fr))}
      .customer-card{padding:8px;gap:6px}
      .customer-head strong{font-size:13px}
      .customer-sub{font-size:10px}
      .customer-chip-row{gap:5px}
      .customer-chip-row .badge{font-size:9.5px;padding:5px 8px}
      .customer-inline-grid{gap:6px}
      .customer-inline-box{padding:6px 7px}
      .customer-inline-box small{font-size:8px}
      .customer-inline-box strong{font-size:10px}
      .customer-inline-box span{font-size:9px}
      .customer-meta{padding:6px 7px}
      .customer-meta small{font-size:8.5px;margin-bottom:2px}
      .customer-meta strong,.customer-meta span{font-size:10px}
      .customer-meta-grid{display:none}
      .customer-actions{grid-template-columns:repeat(5,minmax(0,1fr));gap:5px}
      .customer-actions .btn,.customer-actions form .btn{height:42px;min-height:42px;border-radius:11px}
      .customer-actions .action-mini{flex-direction:column;gap:2px;line-height:1}
      .customer-actions .action-mini i{
        width:17px;
        height:17px;
        font-size:14px;
        flex-basis:17px;
      }
      .customer-actions .action-mini .action-label{
        display:block;
        font-size:8.5px;
        font-weight:700;
        letter-spacing:.01em;
      }
      .page-tools{grid-template-columns:42px 42px minmax(0,1fr);gap:6px}
      .page-tools .btn{min-height:42px}
      .upload-preview-card{width:92px;min-height:92px}
      .upload-preview-card img{height:92px}
    }
    @media(max-width:430px){
      .topbar .tb-title{
        font-size:0;
        display:flex;
        align-items:center;
        gap:8px;
      }
      .topbar .tb-title::after{
        content:"Manajemen Pelanggan";
        font-size:14px;
        font-weight:800;
        color:var(--text);
        white-space:nowrap;
        overflow:hidden;
        text-overflow:ellipsis;
      }
      .customer-filter-panel{gap:6px;padding:8px}
      .customer-filter-main-row{grid-template-columns:repeat(3,minmax(0,1fr));gap:6px}
      .customer-filter-panel .mobile-date-row{
        grid-template-columns:1fr 1fr;
        gap:6px;
      }
      .quick-filter-row{grid-template-columns:repeat(4,minmax(0,1fr));gap:5px}
      .quick-filter-row .btn{
        min-height:44px;
        padding:5px 2px;
        gap:2px;
        flex-direction:column;
        align-items:center;
        justify-content:center;
      }
      .quick-filter-row .btn .filter-chip-label{
        max-width:100%;
        font-size:8.5px;
        line-height:1.05;
        text-align:center;
        white-space:nowrap;
      }
      .quick-filter-row .btn .filter-chip-count{
        margin-left:0;
        min-width:18px;
        height:16px;
        padding:0 4px;
        font-size:7.5px;
      }
      .quick-filter-row .btn i{
        display:none;
      }
      .customer-filter-panel .fs,
      .customer-filter-panel .fc{
        min-height:42px;
        font-size:11px;
        padding-left:10px;
        padding-right:28px;
      }
      .customer-filter-panel .mobile-filter-actions{
        grid-template-columns:1fr 1fr;
      }
    }
    body[data-theme="light"] .customer-overview-shell{
      background:linear-gradient(180deg,#23377d 0%,#23377d 152px,#f5f8ff 152px,#ffffff 100%);
      border-color:rgba(148,163,184,.18);
    }
    body[data-theme="light"] .customer-overview-card{
      border-color:rgba(191,219,254,.8);
      box-shadow:0 18px 38px rgba(63,82,157,.12);
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'customers', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-people"></i> <%= t('admin.customers.manage_title', 'Manajemen Pelanggan') %></div>
    <div class="tb-right">
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %></span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>
<div class="page admin-shell-page">

    <% if (msg) { %>
    <div class="alert alert-<%= msg.type === 'success' ? 's' : 'd' %>">
      <i class="bi bi-<%= msg.type === 'success' ? 'check-circle' : 'exclamation-circle' %>"></i> <%= msg.text %>
    </div>
    <% } %>
    <%
      const currentSearch = typeof search !== 'undefined' ? search : '';
      const currentFilterStatus = typeof filterStatus !== 'undefined' ? filterStatus : '';
      const currentBillingDayStart = typeof billingDayStart !== 'undefined' ? billingDayStart : '';
      const currentBillingDayEnd = typeof billingDayEnd !== 'undefined' ? billingDayEnd : '';
      const currentSelectedMonth = typeof selectedMonth !== 'undefined' ? selectedMonth : (new Date().getMonth() + 1);
      const currentSelectedYear = typeof selectedYear !== 'undefined' ? selectedYear : new Date().getFullYear();
      const currentPageNumber = typeof currentPage !== 'undefined' ? currentPage : 1;
      const currentStatusLabel = currentFilterStatus === 'active'
        ? 'Pelanggan Aktif'
        : currentFilterStatus === 'inactive'
          ? 'Pelanggan Nonaktif'
          : currentFilterStatus === 'suspended'
            ? 'Pelanggan Terisolir'
            : 'Semua Pelanggan';
      const totalPageCount = typeof totalPages !== 'undefined' ? totalPages : 1;
      const totalCustomerRows = typeof totalCustomersCount !== 'undefined' ? totalCustomersCount : customers.length;
      const customerRowOffset = (currentPageNumber - 1) * (typeof pageSize !== 'undefined' ? pageSize : customers.length || 25);
      const currentCustomerOverview = (typeof customerOverview !== 'undefined' && customerOverview) ? customerOverview : {
        month: currentSelectedMonth,
        year: currentSelectedYear,
        totalCustomers: Number(customers?.length || 0),
        activeCustomers: 0,
        activeRevenue: 0,
        newCustomers: 0,
        unpaidCustomers: 0,
        unpaidAmount: 0,
        paidCustomers: 0,
        paidAmount: 0,
        cashTransactions: 0,
        cashAmount: 0,
        onlineTransactions: 0,
        onlineAmount: 0,
        suspendedCustomers: 0,
        inactiveCustomers: 0
      };
      const customerMonthNames = (lang === 'en')
        ? ['January','February','March','April','May','June','July','August','September','October','November','December']
        : ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
      const reportMonthLabel = customerMonthNames[(currentCustomerOverview.month || currentSelectedMonth || 1) - 1] || customerMonthNames[0];
      const reportYearLabel = currentCustomerOverview.year || currentSelectedYear || new Date().getFullYear();
    %>

    <div class="customer-overview-shell">
      <div class="customer-overview-top">
        <div class="customer-overview-title">
          <h3><i class="bi bi-arrow-left"></i> Pelanggan</h3>
          <div class="info-chip"><i class="bi bi-info-circle-fill"></i> Info</div>
        </div>
        <div class="customer-overview-banner">
          <i class="bi bi-info-circle-fill"></i>
          <div>Ada <strong><%= currentCustomerOverview.unpaidCustomers %></strong> pelanggan belum bayar bulan <%= reportMonthLabel %> <%= reportYearLabel %></div>
        </div>
      </div>

      <div class="customer-overview-content">
        <div class="customer-overview-card">
          <div class="customer-overview-toolbar">
            <form method="GET" action="/admin/customers" class="customer-period-form">
              <input type="hidden" name="search" value="<%= currentSearch || '' %>">
              <input type="hidden" name="status" value="<%= currentFilterStatus || '' %>">
              <div class="period-group">
                <label>Bulan :</label>
                <select name="month">
                  <% for (let m = 1; m <= 12; m++) { %>
                    <option value="<%= m %>" <%= Number(currentSelectedMonth) === m ? 'selected' : '' %>><%= customerMonthNames[m - 1] %></option>
                  <% } %>
                </select>
              </div>
              <div class="period-group">
                <select name="year">
                  <% for (let y = new Date().getFullYear() + 1; y >= 2023; y--) { %>
                    <option value="<%= y %>" <%= Number(currentSelectedYear) === y ? 'selected' : '' %>><%= y %></option>
                  <% } %>
                </select>
              </div>
              <button type="submit" class="period-submit"><i class="bi bi-funnel"></i> Tampilkan</button>
            </form>
            <div class="customer-overview-total">Pelanggan (Total : <%= currentCustomerOverview.totalCustomers %> Orang)</div>
          </div>

          <div class="overview-section">
            <h4>Pelanggan</h4>
            <div class="overview-grid">
              <div class="overview-card">
                <div class="overview-icon orange"><i class="bi bi-person"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Pelanggan Aktif</span>
                  <span class="overview-value"><%= currentCustomerOverview.activeCustomers %></span>
                  <span class="overview-amount">Rp. <%= Number(currentCustomerOverview.activeRevenue || 0).toLocaleString('id-ID') %></span>
                </div>
              </div>
              <div class="overview-card">
                <div class="overview-icon blue"><i class="bi bi-people-fill"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Pelanggan Baru</span>
                  <span class="overview-value"><%= currentCustomerOverview.newCustomers %></span>
                  <span class="overview-amount">Bulan <%= reportMonthLabel %> <%= reportYearLabel %></span>
                </div>
              </div>
            </div>
          </div>

          <div class="overview-section">
            <h4>Tagihan</h4>
            <div class="overview-grid">
              <div class="overview-card">
                <div class="overview-icon gray"><i class="bi bi-receipt"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Belum Bayar</span>
                  <span class="overview-value"><%= currentCustomerOverview.unpaidCustomers %></span>
                  <span class="overview-amount">Rp. <%= Number(currentCustomerOverview.unpaidAmount || 0).toLocaleString('id-ID') %></span>
                  <a class="overview-link" href="/admin/billing?month=<%= currentSelectedMonth %>&year=<%= currentSelectedYear %>&status=unpaid"><i class="bi bi-eye-fill"></i> Lihat tagihan</a>
                </div>
              </div>
              <div class="overview-card">
                <div class="overview-icon green"><i class="bi bi-person-fill-check"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Lunas Bayar</span>
                  <span class="overview-value"><%= currentCustomerOverview.paidCustomers %></span>
                  <span class="overview-amount">Rp. <%= Number(currentCustomerOverview.paidAmount || 0).toLocaleString('id-ID') %></span>
                  <a class="overview-link" href="/admin/billing?month=<%= currentSelectedMonth %>&year=<%= currentSelectedYear %>&status=paid"><i class="bi bi-eye-fill"></i> Lihat tagihan</a>
                </div>
              </div>
            </div>
          </div>

          <div class="overview-section">
            <h4>Transaksi Bayar Bulan <%= reportMonthLabel %> <%= reportYearLabel %></h4>
            <div class="overview-grid">
              <div class="overview-card">
                <div class="overview-icon mint"><i class="bi bi-gift"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Transaksi Cash</span>
                  <span class="overview-value"><%= currentCustomerOverview.cashTransactions %></span>
                  <span class="overview-amount">Rp. <%= Number(currentCustomerOverview.cashAmount || 0).toLocaleString('id-ID') %></span>
                </div>
              </div>
              <div class="overview-card">
                <div class="overview-icon amber"><i class="bi bi-wallet2"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Transaksi Online</span>
                  <span class="overview-value"><%= currentCustomerOverview.onlineTransactions %></span>
                  <span class="overview-amount">Rp. <%= Number(currentCustomerOverview.onlineAmount || 0).toLocaleString('id-ID') %></span>
                </div>
              </div>
            </div>
          </div>

          <div class="overview-section">
            <h4>Status Layanan</h4>
            <div class="overview-grid">
              <div class="overview-card">
                <div class="overview-icon red"><i class="bi bi-x-lg"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Isolir / Suspend</span>
                  <span class="overview-value"><%= currentCustomerOverview.suspendedCustomers %></span>
                  <a class="overview-link" href="<%= buildCustomerFilterHref({ status: 'suspended' }) %>"><i class="bi bi-eye-fill"></i> Lihat daftar</a>
                </div>
              </div>
              <div class="overview-card">
                <div class="overview-icon rose"><i class="bi bi-arrow-return-left"></i></div>
                <div class="overview-copy">
                  <span class="overview-label">Berhenti / Nonaktif</span>
                  <span class="overview-value"><%= currentCustomerOverview.inactiveCustomers %></span>
                  <a class="overview-link" href="<%= buildCustomerFilterHref({ status: 'inactive' }) %>"><i class="bi bi-eye-fill"></i> Lihat daftar</a>
                </div>
              </div>
            </div>
          </div>

          <div class="mobile-add-customer">
            <button class="btn btn-p" type="button" onclick="openModal('addModal')"><i class="bi bi-plus-lg"></i> TAMBAH PELANGGAN</button>
          </div>
        </div>
      </div>
    </div>

    <%
      function buildCustomerFilterHref(overrides = {}) {
        const params = new URLSearchParams();
        const merged = {
          search: currentSearch || '',
          status: currentFilterStatus || '',
          billingDayStart: currentBillingDayStart || '',
          billingDayEnd: currentBillingDayEnd || '',
          month: currentSelectedMonth || '',
          year: currentSelectedYear || '',
          page: currentPageNumber || 1,
          ...overrides
        };
        Object.entries(merged).forEach(([key, value]) => {
          if (value !== '' && value != null) params.set(key, String(value));
        });
        const qs = params.toString();
        return `/admin/customers${qs ? '?' + qs : ''}`;
      }
    %>

    <!-- Search & Add -->
    <div class="card page-filter-card admin-compact-card">
      <div class="card-hd">
        <h6><i class="bi bi-people"></i> <%= t('admin.customers.list', 'Daftar Pelanggan') %> (<%= totalCustomerRows %>)</h6>
        <div class="page-tools">
          <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
          <a href="/admin/customers/export" class="btn btn-g btn-sm" aria-label="<%= t('admin.customers.export_excel', 'Export Excel') %>"><i class="bi bi-file-earmark-excel"></i> <span class="tool-label"><%= t('admin.customers.export_excel', 'Export Excel') %></span></a>
          <button class="btn btn-g btn-sm" onclick="openModal('importModal')" aria-label="<%= t('admin.customers.import_excel', 'Import Excel') %>"><i class="bi bi-file-earmark-arrow-up"></i> <span class="tool-label"><%= t('admin.customers.import_excel', 'Import Excel') %></span></button>
          <button class="btn btn-p btn-sm" onclick="openModal('addModal')"><i class="bi bi-plus-lg"></i> <span class="tool-label"><%= t('admin.customers.add', 'Tambah Pelanggan') %></span></button>
          <% } %>
        </div>
      </div>
      <div class="card-bd" style="padding-bottom:0">
          <form method="GET" action="/admin/customers" class="srow customer-filter-form" id="customerSearchForm" style="width:100%">
            <div class="customer-search-row">
              <div class="sinput" style="max-width:340px">
                <i class="bi bi-search"></i>
                <input class="fc" id="customerSearchInput" name="search" list="customerSearchSuggestions" autocomplete="off" placeholder="<%= t('admin.customers.search_placeholder', 'Cari nama, telepon, tag...') %>" value="<%= currentSearch %>">
                <datalist id="customerSearchSuggestions"></datalist>
              </div>
              <button class="btn btn-g btn-sm mobile-filter-toggle" type="button" onclick="toggleCustomerFilterPanel()" aria-label="Filter pelanggan">
                <i class="bi bi-funnel"></i>
                <span class="mobile-filter-badge" id="customerFilterBadge"></span>
              </button>
            </div>
            <div class="customer-filter-panel" id="customerFilterPanel">
              <div class="customer-filter-main-row">
                <select class="fs mobile-filter-field" name="status" style="width:140px">
                  <option value="active" <%= currentFilterStatus==='active' ? 'selected':'' %>><%= t('admin.customers.filter.active', 'Aktif') %></option>
                  <option value="all" <%= !currentFilterStatus ? 'selected':'' %>><%= t('admin.customers.filter.all_status', 'Semua Status') %></option>
                  <option value="suspended" <%= currentFilterStatus==='suspended' ? 'selected':'' %>><%= t('admin.customers.filter.suspended', 'Suspend') %></option>
                  <option value="inactive" <%= currentFilterStatus==='inactive' ? 'selected':'' %>><%= t('admin.customers.filter.inactive', 'Nonaktif') %></option>
                </select>
                <select class="fs mobile-filter-field" name="month" style="width:124px">
                  <% for (let m = 1; m <= 12; m++) { %>
                  <option value="<%= m %>" <%= Number(currentSelectedMonth || 0) === m ? 'selected' : '' %>><%= customerMonthNames[m-1] %></option>
                  <% } %>
                </select>
                <select class="fs mobile-filter-field" name="year" style="width:96px">
                  <% for (let y = new Date().getFullYear(); y >= 2023; y--) { %>
                  <option value="<%= y %>" <%= Number(currentSelectedYear || 0) === y ? 'selected' : '' %>><%= y %></option>
                  <% } %>
                </select>
              </div>
              <div class="mobile-date-row">
                <input class="fc mobile-advanced-filter" type="number" name="billingDayStart" min="1" max="31" placeholder="Tgl tagih dari" value="<%= currentBillingDayStart %>" style="width:130px">
                <input class="fc mobile-advanced-filter" type="number" name="billingDayEnd" min="1" max="31" placeholder="Tgl tagih sampai" value="<%= currentBillingDayEnd %>" style="width:140px">
              </div>
              <div class="mobile-filter-actions">
                <button class="btn btn-g btn-sm btn-apply-mobile" type="submit"><i class="bi bi-check2"></i> Terapkan</button>
                <% if (currentSearch || currentFilterStatus !== 'active' || currentBillingDayStart || currentBillingDayEnd || Number(currentSelectedMonth || 0) !== (new Date().getMonth() + 1) || Number(currentSelectedYear || 0) !== new Date().getFullYear()) { %><a href="/admin/customers" class="btn btn-g btn-sm"><i class="bi bi-x"></i> <%= t('common.reset', 'Reset') %></a><% } %>
              </div>
            </div>
        </form>
        <div class="customer-filter-summary">
          <div>
            <strong><%= currentStatusLabel %></strong>
            <span><%= totalCustomerRows %> pelanggan</span>
          </div>
          <div class="summary-meta">
            <span class="summary-chip"><i class="bi bi-calendar-check"></i> <%= reportMonthLabel %> <%= reportYearLabel %></span>
            <% if (currentBillingDayStart || currentBillingDayEnd) { %>
              <span class="summary-chip"><i class="bi bi-funnel"></i> Tagihan <%= currentBillingDayStart || '1' %>-<%= currentBillingDayEnd || '31' %></span>
            <% } %>
          </div>
        </div>
        <div class="quick-filter-row page-chip-row">
          <a href="<%= buildCustomerFilterHref({ status: 'active', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'active' ? 'is-active' : '' %>"><i class="bi bi-check-circle"></i><span class="filter-chip-label">Aktif</span><span class="filter-chip-count"><%= Number(stats.active || 0) %></span></a>
          <a href="<%= buildCustomerFilterHref({ status: 'suspended', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'suspended' ? 'is-active' : '' %>"><i class="bi bi-pause-circle"></i><span class="filter-chip-label">Suspend</span><span class="filter-chip-count"><%= Number(stats.suspended || 0) %></span></a>
          <a href="<%= buildCustomerFilterHref({ status: 'inactive', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'inactive' ? 'is-active' : '' %>"><i class="bi bi-x-circle"></i><span class="filter-chip-label">Nonaktif</span><span class="filter-chip-count"><%= Number(stats.inactive || 0) %></span></a>
          <a href="<%= buildCustomerFilterHref({ status: 'all', page: 1 }) %>" class="btn btn-g btn-sm <%= !currentFilterStatus ? 'is-active' : '' %>"><i class="bi bi-arrow-repeat"></i><span class="filter-chip-label">Semua</span><span class="filter-chip-count"><%= Number(stats.total || 0) %></span></a>
        </div>
      </div>
      <div class="tbl-wrap">
        <table class="dtbl">
          <thead>
            <tr>
              <th>#</th>
              <th><%= t('admin.customers.table.name', 'Nama') %></th>
              <th><%= t('admin.customers.table.phone_tag', 'Telepon / Tag ONU') %></th>
              <th><%= t('admin.customers.table.package', 'Paket') %></th>
              <th>Usage (FUP)</th>
              <th><%= t('admin.customers.table.address', 'Alamat') %></th>
              <th><%= t('admin.customers.table.status', 'Status') %></th>
              <th><%= t('admin.customers.table.unpaid', 'Tagihan Belum Bayar') %></th>
              <th><%= t('admin.customers.table.actions', 'Aksi') %></th>
            </tr>
          </thead>
          <tbody>
          <% if (customers.length === 0) { %>
            <tr><td colspan="8" class="text-center text-muted" style="padding:32px"><%= t('admin.customers.empty', 'Belum ada pelanggan') %></td></tr>
          <% } %>
          <% customers.forEach((c, i) => { %>
            <tr>
              <td class="text-muted"><%= customerRowOffset + i + 1 %></td>
              <td class="fw6"><%= c.name %></td>
              <td>
                <div><%= c.phone || '-' %></div>
                <% if (c.genieacs_tag) { %><div style="font-size:11px;color:var(--primary)"><i class="bi bi-wifi"></i> <%= c.genieacs_tag %></div><% } %>
              </td>
              <td>
                <% if (c.package_name) { %>
                  <div><%= c.package_name %></div>
                  <div style="font-size:11px;color:var(--muted)"><%= (c.speed_down/1000).toFixed(0) %>/<%= (c.speed_up/1000).toFixed(0) %> Mbps &bull; Rp <%= c.package_price ? c.package_price.toLocaleString('id-ID') : '-' %></div>
                <% } else { %><span class="text-muted">-</span><% } %>
              </td>
              <td>
                <% 
                  const usedGB = ((c.bytes_in || 0) + (c.bytes_out || 0)) / (1024 * 1024 * 1024);
                  const limitGB = c.fup_limit_gb || 0;
                  const useFup = c.use_fup === 1;
                %>
                <div class="fw6" style="font-size:12px"><%= usedGB.toFixed(2) %> GB</div>
                <% if (useFup && limitGB > 0) { 
                   const percent = Math.min(100, (usedGB / limitGB) * 100);
                   const barColor = percent > 90 ? 'var(--danger)' : percent > 70 ? 'var(--warning)' : 'var(--success)';
                %>
                  <div class="usage-bar">
                    <div class="usage-fill" style="--p: <%= percent %>%; --b: <%= barColor %>;"></div>
                  </div>
                  <div style="font-size:10px; color:var(--muted)">Limit: <%= limitGB %> GB</div>
                <% } else { %>
                  <div style="font-size:10px; color:var(--muted)">Unlimited</div>
                <% } %>
              </td>
              <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= c.address || '-' %></td>
              <td>
                <% if (c.status==='active') { %><span class="badge bs"><i class="bi bi-circle-fill" style="font-size:7px"></i><%= t('admin.customers.filter.active', 'Aktif') %></span>
                <% } else if (c.status==='suspended') { %><span class="badge bw"><%= t('admin.customers.filter.suspended', 'Suspend') %></span>
                <% } else { %><span class="badge bm"><%= t('admin.customers.filter.inactive', 'Nonaktif') %></span><% } %>
                <div style="font-size:10px;margin-top:4px">
                  <i class="bi bi-clock-history"></i> <%= t('admin.customers.auto_isolate.label', 'Auto Isolir') %>:
                  <span class="<%= c.auto_isolate === 0 ? 'text-danger' : 'text-success' %>">
                    <%= c.auto_isolate === 0 ? t('admin.customers.auto_isolate.off', 'OFF') : t('admin.customers.auto_isolate.date_prefix', 'Tgl ') + (c.isolate_day || 10) %>
                  </span>
                </div>
              </td>
              <td class="text-center">
                <% if (c.unpaid_count > 0) { %>
                  <span class="badge bd"><%= c.unpaid_count %> <%= t('admin.customers.unpaid_suffix', 'tagihan') %></span>
                <% } else { %><span class="text-muted" style="font-size:12px"><%= t('admin.customers.paid_label', 'Lunas') %></span><% } %>
              </td>
              <td>
                <button class="btn btn-g btn-icon btn-sm" title="Detail Pelanggan" data-id="<%= c.id %>" onclick="openCustomerDetail(+this.dataset.id)"><i class="bi bi-eye"></i></button>
                <button class="btn btn-s btn-icon btn-sm" title="<%= t('admin.customers.actions.generate_invoice', 'Generate Tagihan') %>" data-idx="<%= i %>" onclick="openGenInvoice(+this.dataset.idx)"><i class="bi bi-lightning-charge"></i></button>
                <button class="btn btn-p btn-icon btn-sm" title="<%= t('admin.customers.actions.pay_invoice', 'Bayar Tagihan') %>" data-idx="<%= i %>" onclick="openPayInvoice(+this.dataset.idx)"><i class="bi bi-cash-coin"></i></button>
                <form method="POST" action="/admin/customers/<%= c.id %>/usage/reset" style="display:inline" onsubmit="return confirm('Reset penggunaan data bulan ini untuk pelanggan ini?')">
                  <button type="submit" class="btn btn-s btn-sm" title="Reset penggunaan data bulan ini"><i class="bi bi-arrow-clockwise"></i> Reset Usage</button>
                </form>
                <% if (typeof session !== 'undefined' && !session.isCashier) { %>
                <% if (c.package_id && (c.package_promo_cycles || 0) > 0) { %>
                <form method="POST" action="/admin/customers/<%= c.id %>/billing/reset-promo-cycles" style="display:inline" onsubmit="return confirm('Reset counter siklus promo untuk pelanggan ini? Tagihan berikutnya akan memakai harga promo lagi sesuai pengaturan paket.')">
                  <button type="submit" class="btn btn-g btn-icon btn-sm" title="Reset siklus promo"><i class="bi bi-arrow-counterclockwise"></i></button>
                </form>
                <% } %>
                <% if (c.package_id && c.install_date && c.package_prorate_first_invoice) { %>
                <form method="POST" action="/admin/customers/<%= c.id %>/billing/install-prorata" style="display:inline" onsubmit="return confirm('Buat tagihan SUSULAN prorata untuk bulan tanggal pasang? Hanya jika belum ada tagihan periode itu. Dasar harga: reguler (bukan promo).')">
                  <button type="submit" class="btn btn-g btn-icon btn-sm" title="Susulan prorata bulan pasang"><i class="bi bi-calendar2-check"></i></button>
                </form>
                <% } %>
                <% } %>
                <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                <button class="btn btn-g btn-icon btn-sm" title="<%= t('common.edit', 'Edit') %>" data-idx="<%= i %>" onclick="editCust(+this.dataset.idx)"><i class="bi bi-pencil"></i></button>
                <form method="POST" action="/admin/customers/<%= c.id %>/delete" style="display:inline" data-confirm-msg=<%- JSON.stringify(t('admin.customers.confirm_delete', 'Hapus pelanggan ini?')) %> onsubmit="return confirm(this.dataset.confirmMsg)">
                  <button class="btn btn-d btn-icon btn-sm" title="<%= t('common.delete', 'Hapus') %>"><i class="bi bi-trash"></i></button>
                </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <div class="mobile-stack">
        <% if (customers.length === 0) { %>
          <div class="text-center text-muted" style="padding:18px 6px"><%= t('admin.customers.empty', 'Belum ada pelanggan') %></div>
        <% } %>
        <% customers.forEach((c, i) => { %>
          <% 
            const usedGB = ((c.bytes_in || 0) + (c.bytes_out || 0)) / (1024 * 1024 * 1024);
            const limitGB = c.fup_limit_gb || 0;
            const useFup = c.use_fup === 1;
          %>
          <div class="customer-card">
            <div class="customer-head">
              <div>
                <strong><%= c.name %></strong>
                <div class="customer-sub"><%= c.phone || '-' %><% if (c.genieacs_tag) { %> &bull; <span style="color:var(--primary)"><%= c.genieacs_tag %></span><% } %></div>
              </div>
              <div>
                <% if (c.status==='active') { %><span class="badge bs"><i class="bi bi-circle-fill" style="font-size:7px"></i>Aktif</span>
                <% } else if (c.status==='suspended') { %><span class="badge bw">Suspend</span>
                <% } else { %><span class="badge bm">Nonaktif</span><% } %>
              </div>
            </div>

            <div class="customer-chip-row">
              <% if (c.unpaid_count > 0) { %>
                <span class="badge bd"><%= c.unpaid_count %> tagihan</span>
              <% } else { %>
                <span class="badge bs">Lunas</span>
              <% } %>
              <span class="badge bm">Auto: <%= c.auto_isolate === 0 ? 'OFF' : 'Tgl ' + (c.isolate_day || 10) %></span>
              <% if (c.package_name) { %>
                <span class="badge bm"><%= c.package_name %></span>
              <% } %>
              <span class="badge bm"><%= usedGB.toFixed(2) %> GB</span>
            </div>

            <div class="customer-inline-grid">
              <div class="customer-inline-box">
                <small>Paket</small>
                <strong><%= c.package_name || '-' %></strong>
                <span><% if (c.package_name) { %><%= (c.speed_down/1000).toFixed(0) %>/<%= (c.speed_up/1000).toFixed(0) %> Mbps • Rp <%= c.package_price ? c.package_price.toLocaleString('id-ID') : '-' %><% } else { %>-<% } %></span>
              </div>
              <div class="customer-inline-box">
                <small>Usage</small>
                <strong><%= usedGB.toFixed(2) %> GB</strong>
                <span><% if (useFup && limitGB > 0) { %>Limit <%= limitGB %> GB<% } else { %>Unlimited<% } %></span>
              </div>
            </div>

            <div class="customer-meta-grid">
              <div class="customer-meta">
                <small>Paket</small>
                <strong><%= c.package_name || '-' %></strong>
                <span><% if (c.package_name) { %><%= (c.speed_down/1000).toFixed(0) %>/<%= (c.speed_up/1000).toFixed(0) %> Mbps &bull; Rp <%= c.package_price ? c.package_price.toLocaleString('id-ID') : '-' %><% } else { %>-<% } %></span>
              </div>
              <div class="customer-meta">
                <small>Usage</small>
                <strong><%= usedGB.toFixed(2) %> GB</strong>
                <span><% if (useFup && limitGB > 0) { %>Limit <%= limitGB %> GB<% } else { %>Unlimited<% } %></span>
              </div>
            </div>

            <div class="customer-address-line">
              <i class="bi bi-geo-alt"></i>
              <span><%= c.address || '-' %></span>
            </div>

            <div class="customer-actions">
              <button class="btn btn-g btn-sm" type="button" title="Detail Pelanggan" data-id="<%= c.id %>" onclick="openCustomerDetail(+this.dataset.id)">
                <span class="action-mini"><i class="bi bi-eye"></i><span class="action-label">Detail</span></span>
              </button>
              <button class="btn btn-s btn-sm" type="button" title="Generate Tagihan" data-idx="<%= i %>" onclick="openGenInvoice(+this.dataset.idx)">
                <span class="action-mini"><i class="bi bi-lightning-charge"></i><span class="action-label">Tagih</span></span>
              </button>
              <button class="btn btn-p btn-sm" type="button" title="Bayar Tagihan" data-idx="<%= i %>" onclick="openPayInvoice(+this.dataset.idx)">
                <span class="action-mini"><i class="bi bi-cash-coin"></i><span class="action-label">Bayar</span></span>
              </button>
              <form method="POST" action="/admin/customers/<%= c.id %>/usage/reset" onsubmit="return confirm('Reset penggunaan data bulan ini untuk pelanggan ini?')">
                <button class="btn btn-s btn-sm" type="submit" title="Reset penggunaan data" style="width:100%">
                  <span class="action-mini"><i class="bi bi-arrow-clockwise"></i><span class="action-label">Reset Usage</span></span>
                </button>
              </form>
              <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
              <button class="btn btn-g btn-sm" type="button" title="Edit" data-idx="<%= i %>" onclick="editCust(+this.dataset.idx)">
                <span class="action-mini"><i class="bi bi-pencil"></i><span class="action-label">Edit</span></span>
              </button>
              <form method="POST" action="/admin/customers/<%= c.id %>/delete" data-confirm-msg=<%- JSON.stringify(t('admin.customers.confirm_delete', 'Hapus pelanggan ini?')) %> onsubmit="return confirm(this.dataset.confirmMsg)">
                <button class="btn btn-d btn-sm" type="submit" title="Hapus" style="width:100%">
                  <span class="action-mini"><i class="bi bi-trash"></i><span class="action-label">Hapus</span></span>
                </button>
              </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
      <% if (totalPageCount > 1) { %>
      <div class="card-bd" style="border-top:1px solid var(--border);display:flex;justify-content:center;gap:8px;flex-wrap:wrap">
        <a href="<%= buildCustomerFilterHref({ page: Math.max(1, currentPageNumber - 1) }) %>" class="btn btn-g btn-sm <%= currentPageNumber <= 1 ? 'disabled' : '' %>"><i class="bi bi-chevron-left"></i></a>
        <% for (let p = 1; p <= totalPageCount; p++) { %>
          <a href="<%= buildCustomerFilterHref({ page: p }) %>" class="btn btn-sm <%= p === currentPageNumber ? 'btn-p' : 'btn-g' %>"><%= p %></a>
        <% } %>
        <a href="<%= buildCustomerFilterHref({ page: Math.min(totalPageCount, currentPageNumber + 1) }) %>" class="btn btn-g btn-sm <%= currentPageNumber >= totalPageCount ? 'disabled' : '' %>"><i class="bi bi-chevron-right"></i></a>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal Tambah -->
<div class="mo" id="addModal">
  <div class="mb">
    <div class="mh"><span class="mt"><i class="bi bi-person-plus"></i> Tambah Pelanggan</span><button class="mc" onclick="closeModal('addModal')">&times;</button></div>
    <form method="POST" action="/admin/customers" enctype="multipart/form-data">
      <div class="mbody">
        <div class="form-row">
          <div class="fg"><label class="fl">Nama Lengkap *</label><input class="fc" name="name" required placeholder="John Doe"></div>
          <div class="fg"><label class="fl">No. Telepon / WA</label><input class="fc" name="phone" placeholder="08xxx"></div>
        </div>
        <div class="fg"><label class="fl">Email (Untuk Notifikasi Payment)</label><input class="fc" name="email" type="email" placeholder="customer@example.com"></div>
        <div class="fg"><label class="fl">Alamat</label><textarea class="fc" name="address" placeholder="Jl. Example..."></textarea></div>
        <div class="form-row">
          <div class="fg"><label class="fl">NIK</label><input class="fc" name="nik" placeholder="Opsional"></div>
          <div class="fg"><label class="fl">NPWP</label><input class="fc" name="npwp" placeholder="Opsional"></div>
        </div>
        <div class="form-row">
          <div class="fg">
            <label class="fl">Upload KTP</label>
            <input class="fc" type="file" name="ktp_photo_file" id="add_ktp_photo_file" accept="image/*">
            <div class="upload-preview-row">
              <div class="upload-preview-card" id="add_ktp_preview">
                <div class="upload-preview-empty"><i class="bi bi-card-image"></i><span>Preview KTP</span></div>
              </div>
              <div class="upload-preview-meta">
                <div class="upload-preview-name" id="add_ktp_preview_name">Belum ada file dipilih</div>
                <div class="upload-preview-state">JPG, PNG, atau WEBP</div>
                <button type="button" class="btn btn-g btn-sm upload-preview-clear" onclick="clearUploadPreview('add_ktp_photo_file','add_ktp_preview','add_ktp_preview_name','Preview KTP')">Hapus</button>
              </div>
            </div>
          </div>
          <div class="fg">
            <label class="fl">Foto Rumah</label>
            <input class="fc" type="file" name="house_photo_file" id="add_house_photo_file" accept="image/*">
            <div class="upload-preview-row">
              <div class="upload-preview-card" id="add_house_preview">
                <div class="upload-preview-empty"><i class="bi bi-house-door"></i><span>Preview Rumah</span></div>
              </div>
              <div class="upload-preview-meta">
                <div class="upload-preview-name" id="add_house_preview_name">Belum ada file dipilih</div>
                <div class="upload-preview-state">Foto tampak depan atau patokan rumah</div>
                <button type="button" class="btn btn-g btn-sm upload-preview-clear" onclick="clearUploadPreview('add_house_photo_file','add_house_preview','add_house_preview_name','Preview Rumah')">Hapus</button>
              </div>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="fg" id="add_normal_pppoe_profile_field">
            <label class="fl">Paket Internet</label>
            <select class="fs" name="package_id">
              <option value="">-- Pilih Paket --</option>
              <% packages.forEach(p => { %>
              <option value="<%= p.id %>"><%= p.name %> - Rp <%= p.price.toLocaleString('id-ID') %></option>
              <% }) %>
            </select>
          </div>
          <div class="fg"><label class="fl">Tag ONU (GenieACS)</label><input class="fc" name="genieacs_tag" placeholder="Sama dengan ID pelanggan"></div>
        </div>
        <div class="form-row">
          <div class="fg" id="e_normal_pppoe_profile_field">
            <label class="fl">Router MikroTik</label>
            <select class="fs" name="router_id" id="add_router_select" onchange="loadPppoeAdd(this.value)">
              <option value="">-- Default (Pengaturan) --</option>
              <% if (typeof routers !== 'undefined') { %>
                <% routers.forEach(r => { %>
                  <option value="<%= r.id %>"><%= r.name %> (<%= r.host %>)</option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="fg">
            <label class="fl">Metode Koneksi</label>
            <select class="fs" name="connection_type" id="add_connection_type" onchange="toggleConnectionFields('add')">
              <option value="pppoe">PPPoE (MikroTik)</option>
              <option value="static">Static IP (MikroTik)</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="fg" id="add_pppoe_field">
            <label class="fl">PPPoE Username</label>
            <input class="fc" name="pppoe_username" list="add_pppoe_list" placeholder="Pilih / cari dari MikroTik">
            <datalist id="add_pppoe_list"></datalist>
            <div class="hint" id="add_pppoe_hint"></div>
          </div>
          <div class="fg">
            <label class="fl">Profil PPPoE Normal</label>
            <input class="fc" name="normal_pppoe_profile" placeholder="Contoh: paket-5mb">
            <div class="hint">Opsional. Jika kosong, sistem akan memakai profil default dari paket.</div>
          </div>
          <div class="fg" id="add_static_field" style="display:none">
            <label class="fl">IP Address Pelanggan</label>
            <input class="fc" name="static_ip" placeholder="Contoh: 192.168.10.10">
          </div>
        </div>
        <div class="form-row" id="add_pppoe_secret_row">
          <div class="fg">
            <label class="fl">Sinkron Secret PPPoE</label>
            <label class="ck" style="margin-top:8px">
              <input type="checkbox" name="create_pppoe_secret" id="add_create_pppoe_secret" checked>
              <span>Buat secret otomatis di MikroTik jika username belum ada</span>
            </label>
            <div class="hint">Kalau dicentang, admin tidak perlu tambah secret manual di Winbox.</div>
          </div>
          <div class="fg" id="add_pppoe_password_field">
            <label class="fl">Password PPPoE Baru</label>
            <input class="fc" name="pppoe_password" id="add_pppoe_password" placeholder="Kosongkan = sama dengan username">
            <div class="hint">Dipakai hanya saat secret baru dibuat otomatis.</div>
          </div>
        </div>
        <div class="form-row">
          <div class="fg" id="add_mac_field" style="display:none">
            <label class="fl">MAC Address (Optional)</label>
            <input class="fc" name="mac_address" placeholder="Contoh: AA:BB:CC:DD:EE:FF">
          </div>
          <div class="fg" style="max-width:200px">
            <label class="fl">Profile Isolir / Address List</label>
            <select class="fs" name="isolir_profile" id="add_isolir_select">
              <option value="BEATISOLIR">BEATISOLIR</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="fg">
            <label class="fl">Status</label>
            <select class="fs" name="status">
              <option value="active">Aktif</option>
              <option value="suspended">Suspend</option>
              <option value="inactive">Nonaktif</option>
            </select>
          </div>
          <div class="fg"><label class="fl">Tanggal Pasang</label><input class="fc" type="date" name="install_date"></div>
        </div>
        <div class="form-row">
          <div class="fg">
            <label class="fl">Isolir Otomatis</label>
            <select class="fs" name="auto_isolate">
              <option value="1">Aktif</option>
              <option value="0">Tidak Aktif</option>
            </select>
          </div>
          <div class="fg">
            <label class="fl">Tanggal Isolir (1-31)</label>
            <input class="fc" type="number" name="isolate_day" value="10" min="1" max="31">
          </div>
        </div>
        <div class="form-row">
          <div class="fg">
            <label class="fl">Perangkat OLT</label>
            <select class="fs" name="olt_id">
              <option value="">-- Tanpa OLT --</option>
              <% if (typeof olts !== 'undefined') { %>
                <% olts.forEach(o => { %>
                  <option value="<%= o.id %>"><%= o.name %> (<%= o.brand %>)</option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="fg">
            <label class="fl">ODP</label>
            <select class="fs" name="odp_id">
              <option value="">-- Tanpa ODP --</option>
              <% if (typeof odps !== 'undefined') { %>
                <% odps.forEach(o => { %>
                  <option value="<%= o.id %>"><%= o.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
        </div>
        <div class="fg"><label class="fl">Port PON / ODP</label><input class="fc" name="pon_port" placeholder="Contoh: PON 1/1, ODP-01"></div>
        <div class="form-row">
          <div class="fg">
            <label class="fl">Latitude</label>
            <input class="fc" name="lat" id="add_lat" placeholder="-7.140868012256965">
          </div>
          <div class="fg">
            <label class="fl">Longitude</label>
            <div class="location-input-group">
              <input class="fc" name="lng" id="add_lng" placeholder="107.00277733308137">
              <button type="button" class="btn btn-g btn-sm location-action-btn" onclick="useCurrentLocation('add')" title="Ambil GPS"><i class="bi bi-crosshair"></i><span class="desk-only">GPS</span></button>
              <button type="button" class="btn btn-g btn-sm location-action-btn" onclick="openPicker('add')" title="Pilih di Peta"><i class="bi bi-geo-alt"></i><span class="desk-only">Peta</span></button>
            </div>
          </div>
        </div>
        <div class="fg"><label class="fl">Catatan</label><textarea class="fc" name="notes" placeholder="Opsional..."></textarea></div>
      </div>
      <div class="mf">
        <button type="button" class="btn btn-g" onclick="closeModal('addModal')">Batal</button>
        <button type="submit" class="btn btn-p"><i class="bi bi-check-lg"></i> Simpan Pelanggan</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Import -->
<div class="mo" id="importModal">
  <div class="mb" style="max-width:400px">
    <div class="mh"><span class="mt"><i class="bi bi-file-earmark-arrow-up"></i> Import Pelanggan</span><button class="mc" onclick="closeModal('importModal')">&times;</button></div>
    <form method="POST" action="/admin/customers/import" enctype="multipart/form-data">
      <div class="mbody">
        <p style="font-size:13px;color:var(--muted);margin-bottom:16px">
          Unggah file Excel (.xlsx) sesuai template import pelanggan.
          <br><br>
          <a href="/admin/customers/import-template" style="color:var(--primary);text-decoration:none"><i class="bi bi-download"></i> Unduh template import</a>
        </p>
        <div class="fg">
          <label class="fl">Pilih File Excel</label>
          <input type="file" name="file" class="fc" accept=".xlsx" required>
        </div>
      </div>
      <div class="mf">
        <button type="button" class="btn btn-g" onclick="closeModal('importModal')">Batal</button>
        <button type="submit" class="btn btn-p"><i class="bi bi-upload"></i> Mulai Impor</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Edit -->
<div class="mo" id="editModal">
  <div class="mb">
    <div class="mh"><span class="mt"><i class="bi bi-pencil"></i> Edit Pelanggan</span><button class="mc" onclick="closeModal('editModal')">&times;</button></div>
    <form method="POST" id="editForm" enctype="multipart/form-data">
      <div class="mbody">
        <div class="form-row">
          <div class="fg"><label class="fl">Nama Lengkap *</label><input class="fc" name="name" id="e_name" required></div>
          <div class="fg"><label class="fl">No. Telepon / WA</label><input class="fc" name="phone" id="e_phone"></div>
        </div>
        <div class="fg"><label class="fl">Email (Untuk Notifikasi Payment)</label><input class="fc" name="email" id="e_email" type="email"></div>
        <div class="fg"><label class="fl">Alamat</label><textarea class="fc" name="address" id="e_address"></textarea></div>
        <div class="form-row">
          <div class="fg"><label class="fl">NIK</label><input class="fc" name="nik" id="e_nik" placeholder="Opsional"></div>
          <div class="fg"><label class="fl">NPWP</label><input class="fc" name="npwp" id="e_npwp" placeholder="Opsional"></div>
        </div>
        <div class="form-row">
          <div class="fg">
            <label class="fl">Upload KTP Baru</label>
            <input class="fc" type="file" name="ktp_photo_file" id="e_ktp_photo_file" accept="image/*">
            <div class="hint">Kosongkan jika tidak ingin mengganti file lama.</div>
            <div class="upload-preview-row">
              <div class="upload-preview-card" id="edit_ktp_preview">
                <div class="upload-preview-empty"><i class="bi bi-card-image"></i><span>Preview KTP</span></div>
              </div>
              <div class="upload-preview-meta">
