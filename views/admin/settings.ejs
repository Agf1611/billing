            </div>
          </div>
          <div class="form-row" style="grid-column: span 2;">
            <div class="fg">
              <label class="fl">Push Tagihan Baru</label>
              <select class="fs" name="onesignal_push_invoice_enabled">
                <option value="true" <%= settings.onesignal_push_invoice_enabled !== false ? 'selected' : '' %>>Aktif</option>
                <option value="false" <%= settings.onesignal_push_invoice_enabled === false ? 'selected' : '' %>>Nonaktif</option>
              </select>
            </div>
            <div class="fg">
              <label class="fl">Push Pengumuman / Broadcast</label>
              <select class="fs" name="onesignal_push_announcement_enabled">
                <option value="true" <%= settings.onesignal_push_announcement_enabled !== false ? 'selected' : '' %>>Aktif</option>
                <option value="false" <%= settings.onesignal_push_announcement_enabled === false ? 'selected' : '' %>>Nonaktif</option>
              </select>
            </div>
          </div>
          <div class="fg" style="grid-column: span 2;">
            <div style="font-size:10px; color:var(--muted); margin-top:4px">
              Setelah diisi, pelanggan bisa menyalakan notif dari aplikasi Median. Push dipakai untuk tagihan baru dan pengumuman pelanggan.
            </div>
          </div>
          <div class="fg" style="grid-column: span 2;">
            <label class="fl">Template Chat Tagihan</label>
            <textarea class="fc" name="whatsapp_billing_message" rows="8" placeholder="Halo {{nama}}, ..."><%= settings.whatsapp_billing_message || '' %></textarea>
          </div>
          <div class="fg" style="grid-column: span 2;">
            <label class="fl">Template Chat Isolir</label>
            <textarea class="fc" name="whatsapp_isolation_message" rows="8" placeholder="Halo {{nama}}, ..."><%= settings.whatsapp_isolation_message || '' %></textarea>
          </div>
          <div class="fg" style="grid-column: span 2;">
            <label class="fl">Pesan Status Isolir di Portal</label>
            <textarea class="fc" name="customer_isolation_notice" rows="4" placeholder="Layanan internet Anda sedang dinonaktifkan sementara ..."><%= settings.customer_isolation_notice || '' %></textarea>
          </div>
        </div>

        <!-- Payment Gateway -->
        <div class="settings-panel-section" data-settings-pane="payment" style="grid-column: span 2">
          <h6 class="settings-pane-title"><i class="bi bi-wallet2"></i> Gateway Pembayaran & QRIS</h6>
          <%
            const qrisStaticConfigured = Boolean(String(settings.qris_static_qr_url || '').trim() || String(settings.qris_static_payload || '').trim());
            const qrisStaticEnabled = settings.qris_static_enabled === false || settings.qris_static_enabled === 'false'
              ? false
              : qrisStaticConfigured;
            const qrisServerPort = Number(settings.server_port || 0) || 0;
            const qrisUniqueRangeText = qrisServerPort === 3002
              ? '001-399'
              : qrisServerPort === 3001
                ? '400-599'
                : '001-599';
          %>
          
          <div class="form-row3" style="margin-bottom: 20px;">
            <div class="fg">
              <label class="fl">Default Gateway</label>
              <select class="fs" name="default_gateway">
                <option value="tripay" <%= settings.default_gateway === 'tripay' ? 'selected' : '' %>>Tripay</option>
                <option value="midtrans" <%= settings.default_gateway === 'midtrans' ? 'selected' : '' %>>Midtrans</option>
                <option value="xendit" <%= settings.default_gateway === 'xendit' ? 'selected' : '' %>>Xendit</option>
                <option value="duitku" <%= settings.default_gateway === 'duitku' ? 'selected' : '' %>>Duitku</option>
              </select>
            </div>
          </div>

          <div style="background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px; margin-bottom: 15px;">
            <h6 style="font-size:12px; margin-bottom: 10px;">QRIS Statis (Semi-Otomatis)</h6>
            <div class="form-row3" style="margin-bottom:10px;">
              <div class="fg">
                <label class="fl">Status QRIS Statis</label>
                <select class="fs" name="qris_static_enabled">
                  <option value="true" <%= settings.qris_static_enabled === false ? '' : 'selected' %>>Aktif</option>
                  <option value="false" <%= settings.qris_static_enabled === false ? 'selected' : '' %>>Nonaktif</option>
                </select>
                <div style="font-size:10px; color:var(--muted); margin-top:4px">Jika dinonaktifkan, QRIS Instan tidak ditawarkan ke pelanggan walaupun payload atau gambar QR masih tersimpan.</div>
              </div>
            <div class="fg">
              <label class="fl">Range Kode Unik Instance Ini</label>
              <input class="fc" value="<%= qrisUniqueRangeText %>" readonly>
                <div style="font-size:10px; color:var(--muted); margin-top:4px">Range ini diatur otomatis sesuai instance aplikasi agar kode pembayaran tidak bentrok.</div>
            </div>
              <div class="fg">
                <label class="fl">Status Konfigurasi</label>
                <input class="fc" value="<%= qrisStaticEnabled ? 'Aktif dan siap dipakai' : (qrisStaticConfigured ? 'Disimpan tetapi sedang nonaktif' : 'Belum ada konfigurasi QRIS') %>" readonly>
              </div>
            </div>
            <% if (settings.qris_static_qr_url) { %>
              <div class="asset-preview-card" style="margin-bottom:12px;">
                <button type="button" class="asset-remove-btn" title="Hapus gambar QRIS" aria-label="Hapus gambar QRIS" onclick="removeQrisStaticQr()">
                  <i class="bi bi-trash"></i>
                </button>
                <img id="qris_static_qr_preview" src="<%= settings.qris_static_qr_url %>" alt="QRIS statik aktif" style="width:92px;height:92px;object-fit:contain;border-radius:14px;background:#fff;padding:8px;border:1px solid var(--border)">
                <div style="font-size:12px;color:var(--muted);min-width:0">
                  <div style="font-weight:700;color:var(--text);margin-bottom:4px">QRIS statik aktif</div>
                  <div style="word-break:break-all"><%= settings.qris_static_qr_url %></div>
                </div>
              </div>
            <% } else { %>
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;padding:12px;border:1px dashed var(--border);border-radius:14px;background:var(--bg2);font-size:12px;color:var(--muted)">
                <img id="qris_static_qr_preview" src="" alt="Preview QRIS statik" style="display:none;width:92px;height:92px;object-fit:contain;border-radius:14px;background:#fff;padding:8px;border:1px solid var(--border)">
                <i id="qris_static_qr_placeholder" class="bi bi-qr-code" style="font-size:28px;color:var(--brand)"></i>
                <div>Belum ada gambar QRIS statik. Anda bisa isi URL atau upload gambar QRIS langsung di bawah ini.</div>
              </div>
            <% } %>
            <div class="form-row3">
              <div class="fg">
                <label class="fl">QRIS Static QR URL (opsional)</label>
                <input class="fc" name="qris_static_qr_url" value="<%= settings.qris_static_qr_url || '' %>" placeholder="https://.../qris.png atau link QRIS">
                <div style="font-size:10px; color:var(--muted); margin-top:4px">Boleh dikosongkan jika Anda memilih upload file gambar QRIS. Link halaman seperti <span class="mono">linkqr.id/qris</span> tidak selalu bisa dipakai langsung untuk QRIS dinamis.</div>
              </div>
              <div class="fg">
                <label class="fl">Payload QRIS Merchant</label>
                <textarea class="fc" name="qris_static_payload" rows="4" placeholder="Tempel payload string QRIS asli dari merchant / aplikasi kasir"><%= settings.qris_static_payload || '' %></textarea>
                <div style="font-size:10px; color:var(--muted); margin-top:4px">Jika diisi, sistem akan membuat QRIS dinamis per tagihan dengan nominal tepat otomatis saat pelanggan scan.</div>
              </div>
              <div class="fg">
                <label class="fl">Upload Gambar QRIS</label>
                <input class="fc" type="file" name="qris_static_qr_file" id="qris_static_qr_file" accept=".png,.jpg,.jpeg,.webp,.svg,image/*">
                <div style="font-size:10px; color:var(--muted); margin-top:4px">Dipakai sebagai fallback jika payload QRIS merchant belum diisi. Sistem akan mencoba membaca payload QRIS otomatis dari gambar ini.</div>
              </div>
            </div>
            <div class="form-row3" style="margin-top:10px">
              <div class="fg">
                <label class="fl">Mode QRIS</label>
                <input class="fc" value="<%= !qrisStaticEnabled ? 'QRIS statis nonaktif' : (settings.qris_static_payload ? 'QRIS dinamis nominal otomatis' : 'QRIS gambar + nominal unik manual') %>" readonly>
              </div>
              <div class="fg">
                <label class="fl">Secret Auto Verifikasi QRIS</label>
                <div class="secret-field">
                  <input class="fc" type="password" name="payment_notif_secret" value="<%= settings.payment_notif_secret || '' %>" placeholder="minimal 8 karakter">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat secret auto verifikasi">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                <div style="font-size:10px; color:var(--muted); margin-top:4px">Dipakai oleh endpoint <span class="mono">POST /api/webhook/v1/payment-notif</span>. Secret ini harus sama dengan yang dipakai MacroDroid / sumber notifikasi mutasi.</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:12px">
              <button type="button" class="btn btn-g btn-sm" id="test_qris_payload_btn">
                <i class="bi bi-qr-code-scan"></i> Tes Baca Payload
              </button>
              <div id="qris_payload_test_result" style="display:none;padding:10px 12px;border-radius:12px;font-size:12px;line-height:1.5"></div>
            </div>
          </div>

          <!-- Tripay Section -->
          <div style="background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px; margin-bottom: 15px;">
            <h6 style="font-size:12px; margin-bottom: 10px;">Tripay Configuration</h6>
            <div class="form-row3">
              <div class="fg">
                <label class="fl">Status Tripay</label>
                <select class="fs" name="tripay_enabled">
                  <option value="true" <%= settings.tripay_enabled === true ? 'selected' : '' %>>Aktif</option>
                  <option value="false" <%= settings.tripay_enabled === false ? 'selected' : '' %>>Nonaktif</option>
                </select>
              </div>
              <div class="fg">
                <label class="fl">Tripay API Key</label>
                <div class="secret-field">
                  <input class="fc" name="tripay_api_key" value="<%= settings.tripay_api_key || '' %>" type="password">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat API key">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>
              <div class="fg">
                <label class="fl">Tripay Private Key</label>
                <div class="secret-field">
                  <input class="fc" name="tripay_private_key" value="<%= settings.tripay_private_key || '' %>" type="password">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat private key">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="form-row3">
              <div class="fg">
                <label class="fl">Tripay Merchant Code</label>
                <input class="fc" name="tripay_merchant_code" value="<%= settings.tripay_merchant_code || '' %>" placeholder="Txxxx">
              </div>
              <div class="fg">
                <label class="fl">Tripay Mode</label>
                <select class="fs" name="tripay_mode">
                  <option value="sandbox" <%= settings.tripay_mode === 'sandbox' ? 'selected' : '' %>>Sandbox</option>
                  <option value="live" <%= settings.tripay_mode === 'live' ? 'selected' : '' %>>Live</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Midtrans Section -->
          <div style="background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px;">
            <h6 style="font-size:12px; margin-bottom: 10px;">Midtrans Configuration</h6>
            <div class="form-row3">
              <div class="fg">
                <label class="fl">Status Midtrans</label>
                <select class="fs" name="midtrans_enabled">
                  <option value="true" <%= settings.midtrans_enabled === true ? 'selected' : '' %>>Aktif</option>
                  <option value="false" <%= settings.midtrans_enabled === false ? 'selected' : '' %>>Nonaktif</option>
                </select>
              </div>
              <div class="fg">
                <label class="fl">Midtrans Server Key</label>
                <div class="secret-field">
                  <input class="fc" name="midtrans_server_key" value="<%= settings.midtrans_server_key || '' %>" type="password">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat server key">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>
              <div class="fg">
                <label class="fl">Midtrans Mode</label>
                <select class="fs" name="midtrans_mode">
                  <option value="sandbox" <%= settings.midtrans_mode === 'sandbox' ? 'selected' : '' %>>Sandbox</option>
                  <option value="live" <%= settings.midtrans_mode === 'live' ? 'selected' : '' %>>Live</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Xendit Section -->
          <div style="background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px; margin-top: 15px;">
            <h6 style="font-size:12px; margin-bottom: 10px;">Xendit Configuration</h6>
            <div class="form-row2">
              <div class="fg">
                <label class="fl">Status Xendit</label>
                <select class="fs" name="xendit_enabled">
                  <option value="true" <%= settings.xendit_enabled === true ? 'selected' : '' %>>Aktif</option>
                  <option value="false" <%= settings.xendit_enabled === false ? 'selected' : '' %>>Nonaktif</option>
                </select>
              </div>
              <div class="fg">
                <label class="fl">Xendit Secret API Key</label>
                <div class="secret-field">
                  <input class="fc" name="xendit_api_key" value="<%= settings.xendit_api_key || '' %>" type="password" placeholder="xnd_development_...">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat API key">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="fg" style="margin-top:10px">
              <label class="fl">Xendit Callback Token</label>
              <div class="secret-field">
                <input class="fc" name="xendit_callback_token" value="<%= settings.xendit_callback_token || '' %>" type="password" placeholder="token webhook xendit">
                <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat token">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
            </div>
            <div style="font-size: 10px; color: var(--muted); margin-top: 4px;">Wajib diisi jika Xendit aktif. Callback tanpa token akan ditolak.</div>
          </div>

          <!-- Duitku Section -->
          <div style="background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px; margin-top: 15px;">
            <h6 style="font-size:12px; margin-bottom: 10px;">Duitku Configuration</h6>
            <div class="form-row3">
              <div class="fg">
                <label class="fl">Status Duitku</label>
                <select class="fs" name="duitku_enabled">
                  <option value="true" <%= settings.duitku_enabled === true ? 'selected' : '' %>>Aktif</option>
                  <option value="false" <%= settings.duitku_enabled === false ? 'selected' : '' %>>Nonaktif</option>
                </select>
              </div>
              <div class="fg">
                <label class="fl">Duitku Merchant Code</label>
                <input class="fc" name="duitku_merchant_code" value="<%= settings.duitku_merchant_code || '' %>" placeholder="Dxxxx">
              </div>
              <div class="fg">
                <label class="fl">Duitku API Key</label>
                <div class="secret-field">
                  <input class="fc" name="duitku_api_key" value="<%= settings.duitku_api_key || '' %>" type="password">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat API key">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="form-row2">
              <div class="fg">
                <label class="fl">Duitku Mode</label>
                <select class="fs" name="duitku_mode">
                  <option value="sandbox" <%= settings.duitku_mode === 'sandbox' ? 'selected' : '' %>>Sandbox</option>
                  <option value="live" <%= settings.duitku_mode === 'live' ? 'selected' : '' %>>Live</option>
                </select>
              </div>
            </div>
          </div>

          <div class="fg" style="margin-top: 15px;">
            <label class="fl">Link Webhook (Copy ke Dashboard Gateway)</label>
            <div style="display:flex;gap:8px">
              <input class="fc" id="webhook_url" readonly value="<%= (typeof paymentWebhookUrl !== 'undefined' && paymentWebhookUrl) ? paymentWebhookUrl : ('http://' + (settings.server_host || 'localhost') + ':' + (settings.server_port || 3001) + '/customer/payment/callback') %>">
              <button type="button" class="btn btn-g" onclick="copyWebhook()"><i class="bi bi-copy"></i></button>
            </div>
            <div style="font-size: 10px; color: var(--muted); margin-top: 4px;">Gunakan link ini untuk kolom Webhook URL di Tripay atau Midtrans Notification URL.</div>
          </div>
        </div>

      </div>
      
          <div class="card-bd" style="border-top:1px solid var(--border);padding-top:20px;text-align:right">
            <button type="submit" class="btn btn-p"><i class="bi bi-save"></i> Simpan Pengaturan</button>
          </div>
        </div>
    </form>
  </div>
</div>

<script>
const settingsCategoryButtons = Array.from(document.querySelectorAll('[data-settings-target]'));
const settingsPaneTargets = Array.from(document.querySelectorAll('.settings-panel-section, .settings-card-pane'));
const settingsShellCards = Array.from(document.querySelectorAll('[data-settings-shell="config"]'));

function showSettingsPane(name) {
  const pane = String(name || 'usaha').trim();
  const configPanes = new Set(['usaha', 'payment', 'akun', 'integrasi', 'whatsapp']);
  const sectionInput = document.getElementById('settings_section');
  settingsCategoryButtons.forEach((btn) => {
    btn.classList.toggle('active', btn.getAttribute('data-settings-target') === pane);
  });
  settingsPaneTargets.forEach((node) => {
    node.classList.toggle('active', node.getAttribute('data-settings-pane') === pane);
  });
  settingsShellCards.forEach((card) => {
    card.classList.toggle('active', configPanes.has(pane) || pane === 'telegram');
  });
  if (sectionInput) sectionInput.value = pane;
  try { history.replaceState(null, '', `#settings-${pane}`); } catch {}
}

settingsCategoryButtons.forEach((btn) => {
  btn.addEventListener('click', () => showSettingsPane(btn.getAttribute('data-settings-target')));
});

const initialSettingsPane = (location.hash || '').startsWith('#settings-')
  ? String(location.hash || '').replace('#settings-', '')
  : '<%= activeSettingsPane || "usaha" %>';
showSettingsPane(initialSettingsPane);

function syncWhatsappProviderFields() {
  const provider = document.getElementById('whatsappProvider');
  const isMpwa = provider && provider.value === 'mpwa';
  document.querySelectorAll('[data-mpwa-settings]').forEach((node) => {
    node.style.display = isMpwa ? '' : 'none';
  });
}

document.getElementById('whatsappProvider')?.addEventListener('change', syncWhatsappProviderFields);
syncWhatsappProviderFields();

function removeCompanyLogo() {
  submitAssetRemoval('usaha', 'remove_company_logo', 'Hapus logo usaha yang sedang dipakai?');
}

function removePwaLogo() {
  submitAssetRemoval('usaha', 'remove_pwa_logo', 'Hapus logo PWA aplikasi yang sedang dipakai?');
}

function removeSupportLogo() {
  submitAssetRemoval('usaha', 'remove_support_logo', 'Hapus logo support by ISP yang sedang dipakai?');
}

function removeInvoiceSignature() {
  submitAssetRemoval('usaha', 'remove_invoice_signature', 'Hapus tanda tangan invoice yang sedang dipakai?');
}

function removeInvoiceStamp() {
  submitAssetRemoval('usaha', 'remove_invoice_stamp', 'Hapus cap atau stempel invoice yang sedang dipakai?');
}

function removeQrisStaticQr() {
  submitAssetRemoval('payment', 'remove_qris_static_qr', 'Hapus gambar QRIS statik yang sedang dipakai?');
}

function submitAssetRemoval(targetSection, flagId, message) {
  const form = document.getElementById('admin-settings-form');
  const flag = document.getElementById(flagId);
  const section = document.getElementById('settings_section');
  if (!form || !flag || !section) return;
  if (!confirm(message)) return;
  section.value = targetSection;
  flag.value = '1';
  form.submit();
}

function copyWebhook() {
  const el = document.getElementById('webhook_url');
  el.select();
  document.execCommand('copy');
  alert('Link Webhook berhasil disalin!');
}
async function syncTelegram() {
  try {
    const res = await fetch('/admin/api/telegram/sync', { method: 'POST' });
    const data = await res.json();
    if (data.success) alert(data.message);
    else alert('Gagal: ' + data.error);
  } catch (e) { alert('Error: ' + e.message); }
}

document.addEventListener('click', (event) => {
  const toggle = event.target.closest('[data-secret-toggle]');
  if (!toggle) return;
  const field = toggle.closest('.secret-field');
  const input = field ? field.querySelector('input') : null;
  if (!input) return;
  const visible = input.type === 'text';
  input.type = visible ? 'password' : 'text';
  const icon = toggle.querySelector('i');
  if (icon) {
    icon.classList.toggle('bi-eye', visible);
    icon.classList.toggle('bi-eye-slash', !visible);
  }
  toggle.setAttribute('aria-label', visible ? 'Lihat data sensitif' : 'Sembunyikan data sensitif');
});

const qrisStaticQrInput = document.getElementById('qris_static_qr_file');
if (qrisStaticQrInput) {
  qrisStaticQrInput.addEventListener('change', () => {
    const file = qrisStaticQrInput.files && qrisStaticQrInput.files[0];
    if (!file) return;
    let preview = document.getElementById('qris_static_qr_preview');
    const placeholder = document.getElementById('qris_static_qr_placeholder');
    if (!preview) return;
    const blobUrl = URL.createObjectURL(file);
    preview.style.display = 'block';
    if (placeholder) placeholder.style.display = 'none';
    preview.src = blobUrl;
    preview.onload = () => {
      try { URL.revokeObjectURL(blobUrl); } catch {}
    };
  });
}

const qrisPayloadTestBtn = document.getElementById('test_qris_payload_btn');
const qrisPayloadTestResult = document.getElementById('qris_payload_test_result');
if (qrisPayloadTestBtn && qrisPayloadTestResult) {
  qrisPayloadTestBtn.addEventListener('click', async () => {
    const form = document.getElementById('admin-settings-form');
    const payloadField = form ? form.querySelector('[name="qris_static_payload"]') : null;
    const qrUrlField = form ? form.querySelector('[name="qris_static_qr_url"]') : null;
    const fileField = document.getElementById('qris_static_qr_file');
    const formData = new FormData();
    formData.append('qris_static_payload', payloadField ? payloadField.value : '');
    formData.append('qris_static_qr_url', qrUrlField ? qrUrlField.value : '');
    if (fileField && fileField.files && fileField.files[0]) {
      formData.append('qris_static_qr_file', fileField.files[0]);
    }

    qrisPayloadTestBtn.disabled = true;
    qrisPayloadTestResult.style.display = 'block';
    qrisPayloadTestResult.style.background = 'rgba(59,130,246,.12)';
    qrisPayloadTestResult.style.border = '1px solid rgba(59,130,246,.35)';
    qrisPayloadTestResult.style.color = 'var(--text)';
    qrisPayloadTestResult.innerHTML = '<i class="bi bi-arrow-repeat"></i> Mengecek payload QRIS...';

    try {
      const response = await fetch('/admin/settings/payment/test-qris-payload', {
        method: 'POST',
        body: formData,
        credentials: 'same-origin'
      });
      const result = await response.json();
      const isOk = Boolean(result && result.ok);
      const payloadInfo = isOk && result.payloadLength
        ? `<div style="margin-top:4px;font-size:11px;opacity:.8">Payload terbaca: ${result.payloadLength} karakter${result.source ? ` â€¢ sumber: ${escHtml(result.source)}` : ''}</div>`
        : '';
      qrisPayloadTestResult.style.background = isOk ? 'rgba(34,197,94,.12)' : 'rgba(244,63,94,.12)';
      qrisPayloadTestResult.style.border = isOk ? '1px solid rgba(34,197,94,.35)' : '1px solid rgba(244,63,94,.35)';
      qrisPayloadTestResult.innerHTML = `${isOk ? '<i class="bi bi-check-circle"></i>' : '<i class="bi bi-x-circle"></i>'} ${escHtml(result && result.message ? result.message : 'Tidak ada respons.')}${payloadInfo}`;
    } catch (error) {
      qrisPayloadTestResult.style.background = 'rgba(244,63,94,.12)';
      qrisPayloadTestResult.style.border = '1px solid rgba(244,63,94,.35)';
      qrisPayloadTestResult.innerHTML = `<i class="bi bi-x-circle"></i> ${escHtml(error && error.message ? error.message : 'Gagal mengetes payload QRIS.')}`;
    } finally {
      qrisPayloadTestBtn.disabled = false;
    }
  });
}

function escHtml(s) {
  return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

if ('serviceWorker' in navigator) {
  try { navigator.serviceWorker.register('/sw.js', { scope: '/admin/' }).catch(() => {}); } catch {}
}

async function copyText(text) {
  const v = String(text ?? '');
  try {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      await navigator.clipboard.writeText(v);
      return true;
    }
  } catch {}
  try {
    const ta = document.createElement('textarea');
    ta.value = v;
    ta.style.position = 'fixed';
    ta.style.left = '-9999px';
    ta.style.top = '0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    const ok = document.execCommand('copy');
    ta.remove();
    return ok;
  } catch {
    return false;
  }
}

function canNotify() {
  return typeof Notification !== 'undefined';
}

function notifEnabled() {
  return localStorage.getItem('ew_notif_enabled') === '1';
}

function setNotifEnabled(v) {
  localStorage.setItem('ew_notif_enabled', v ? '1' : '0');
}

function updateNotifHint() {
  const el = document.getElementById('ew_notif_hint');
  if (!el) return;
  const perm = canNotify() ? Notification.permission : 'unsupported';
  const enabled = notifEnabled();
  let msg = '';
  if (perm === 'unsupported') msg = 'Notifikasi browser tidak didukung di device ini.';
  else if (perm === 'denied') msg = 'Notifikasi diblokir. Izinkan di pengaturan browser.';
  else if (perm === 'granted') msg = enabled ? 'Notif aktif. Notifikasi muncul saat ada log baru (mode Live).' : 'Notif siap, tapi masih nonaktif.';
  else msg = 'Klik "Aktifkan Notif" untuk minta izin notifikasi.';
  el.textContent = msg;
}

async function showBrowserNotification(title, options) {
  if (!canNotify()) return false;
  try {
    const registration = await navigator.serviceWorker.getRegistration('/admin/');
    if (registration && registration.active) {
      registration.active.postMessage({
        type: 'SHOW_NOTIFICATION',
        title,
        body: String(options?.body || ''),
        tag: String(options?.tag || ''),
        data: options?.data || {},
        requireInteraction: Boolean(options?.requireInteraction),
        renotify: Boolean(options?.renotify),
        icon: '<%= (settings.pwa_logo_url || settings.company_logo_url || "/img/mss-logo.png") %>',
        badge: '<%= (settings.pwa_logo_url || settings.company_logo_url || "/img/mss-logo.png") %>'
      });
      return true;
    }
  } catch {}
  try {
    new Notification(title, options || {});
    return true;
  } catch {
    return false;
  }
}

async function enableEwalletNotif() {
  if (!canNotify()) return updateNotifHint();
  try {
    const perm = await Notification.requestPermission();
    if (perm === 'granted') {
      setNotifEnabled(true);
      updateNotifHint();
      await showBrowserNotification('E-Wallet Monitor', {
        body: 'Notifikasi aktif.',
        tag: 'ewallet-monitor-enabled',
        data: { url: '/admin/settings#settings-monitoring' }
      });
      return;
    }
    setNotifEnabled(false);
    updateNotifHint();
  } catch {
    setNotifEnabled(false);
    updateNotifHint();
  }
}

let ewLastId = Number(localStorage.getItem('ew_last_id') || 0);
let ewLiveTimer = null;
const ewLiveDefault = <%- JSON.stringify(Boolean(settings.ewallet_live_auto_start)) %>;
const ewStoredLive = localStorage.getItem('ew_live_active');
let ewLiveActive = ewStoredLive === null ? ewLiveDefault : ewStoredLive === '1';

function setEwalletLivePref(v) {
  localStorage.setItem('ew_live_active', v ? '1' : '0');
  const input = document.getElementById('ew_live_pref_input');
  if (input) input.value = v ? 'true' : 'false';
}

function syncEwalletLiveButton() {
  const btn = document.getElementById('ew_live_btn');
  if (!btn) return;
  btn.className = ewLiveActive ? 'btn btn-d btn-sm' : 'btn btn-p btn-sm';
  btn.replaceChildren();
  const icon = document.createElement('i');
  icon.className = ewLiveActive ? 'bi bi-stop-circle' : 'bi bi-broadcast';
  btn.appendChild(icon);
  btn.append(document.createTextNode(ewLiveActive ? ' Stop' : ' Live'));
}

function startEwalletLive() {
  if (ewLiveTimer) {
    clearInterval(ewLiveTimer);
    ewLiveTimer = null;
  }
  loadEwalletLogs(true);
  ewLiveTimer = setInterval(() => loadEwalletLogs(true), 5000);
}

function stopEwalletLive() {
  if (ewLiveTimer) {
    clearInterval(ewLiveTimer);
    ewLiveTimer = null;
  }
}

function showEwalletNotification(row) {
  if (!notifEnabled()) return;
  if (!canNotify() || Notification.permission !== 'granted') return;
  const svc = String(row?.service || 'E-Wallet');
  const amt = row?.parsed_ok ? `Rp ${(Number(row.parsed_amount) || 0).toLocaleString('id-ID')}` : 'Nominal tidak terdeteksi';
  const body = String(row?.content || '').replace(/\r?\n/g, ' ').slice(0, 140);
  showBrowserNotification(`${svc}: ${amt}`, {
    body,
    tag: `ewallet-log-${Number(row?.id || 0) || Date.now()}`,
    data: { url: '/admin/settings#settings-monitoring' }
  });
}

function toggleEwalletLive() {
  ewLiveActive = !ewLiveActive;
  setEwalletLivePref(ewLiveActive);
  syncEwalletLiveButton();
  if (ewLiveActive) {
    startEwalletLive();
  } else {
    stopEwalletLive();
  }
}

function saveEwalletLivePref() {
  setEwalletLivePref(ewLiveActive);
  const form = document.getElementById('ew_live_pref_form');
  if (form) form.submit();
}

async function loadEwalletLogs() {
  const body = document.getElementById('ew_logs_body');
  const service = document.getElementById('ew_service')?.value || '';
  const q = document.getElementById('ew_q')?.value || '';
  const limit = document.getElementById('ew_limit')?.value || '200';
  if (!body) return;
  body.replaceChildren();
  body.insertAdjacentHTML('beforeend', '<tr><td colspan="7" class="text-center text-muted">Memuat...</td></tr>');
  try {
    const query = `limit=${encodeURIComponent(limit)}&service=${encodeURIComponent(service)}&q=${encodeURIComponent(q)}`;
    const endpoints = [
      `/admin/api/webhook/payment-notif/logs?${query}`,
      `/api/webhook/payment-notif/logs?${query}`
    ];
    let res = null;
    let data = null;
    let lastError = null;
    for (const url of endpoints) {
      try {
        const attempt = await fetch(url, {
          headers: {
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          credentials: 'same-origin'
        });
        const contentType = String(attempt.headers.get('content-type') || '').toLowerCase();
        if (!contentType.includes('application/json')) {
          const raw = (await attempt.text()).slice(0, 160).replace(/\s+/g, ' ').trim();
          if (attempt.status === 401 || attempt.redirected) {
            throw new Error('Sesi admin berakhir. Silakan refresh halaman lalu login ulang.');
          }
          if (raw.startsWith('<!DOCTYPE') || raw.startsWith('<html')) {
            throw new Error('Endpoint log webhook membalas halaman HTML, bukan JSON. Biasanya route admin belum sinkron atau sesi login sedang dialihkan.');
          }
          throw new Error(raw ? `Respons tidak valid dari server: ${raw}` : 'Respons server tidak valid.');
        }
        const payload = await attempt.json();
        res = attempt;
        data = payload;
        lastError = null;
        break;
      } catch (error) {
        lastError = error;
      }
    }
    if (!res || !data) throw lastError || new Error('Gagal memuat log webhook.');
    if (!res.ok || !data.ok) throw new Error(data.error || 'Gagal memuat log');
    const rows = Array.isArray(data.rows) ? data.rows : [];
    if (rows.length === 0) {
      body.replaceChildren();
      body.insertAdjacentHTML('beforeend', '<tr><td colspan="7" class="text-center text-muted">Belum ada data.</td></tr>');
      return;
    }
    const newest = rows[0];
    const newestId = Number(newest?.id || 0);
    if (newestId && ewLastId === 0) {
      ewLastId = newestId;
      localStorage.setItem('ew_last_id', String(ewLastId));
    } else if (newestId && newestId > ewLastId) {
      ewLastId = newestId;
      localStorage.setItem('ew_last_id', String(ewLastId));
      showEwalletNotification(newest);
    }

    body.replaceChildren();
    body.insertAdjacentHTML('beforeend', rows.map(r => {
      const ok = Number(r.parsed_ok || 0) ? 'Y' : 'N';
      const amount = (r.parsed_amount != null && r.parsed_amount !== '') ? Number(r.parsed_amount).toLocaleString('id-ID') : '-';
      const created = r.created_at_local ? escHtml(r.created_at_local) : (r.created_at ? escHtml(r.created_at) : '-');
      const svc = escHtml(r.service || '-');
      const content = escHtml((r.content || '').replace(/\r?\n/g, ' '));
      const okBadge = ok === 'Y' ? '<span class="badge s">OK</span>' : '<span class="badge w">-</span>';
      const amountHtml = ok === 'Y'
        ? `<span class="mono" style="font-weight:900;color:#065f46">Rp ${amount}</span>`
        : `<span class="mono">Rp ${amount}</span>`;
      const rawEnc = encodeURIComponent(String(r.content || ''));
      const rawShortEnc = encodeURIComponent(String(r.content || '').replace(/\r?\n/g, ' ').slice(0, 180));
      const matchedId = Number(r.matched_invoice_id || 0) || 0;
      const matchedCustomer = String(r.matched_customer_name || '').trim();
      const matchedPhone = String(r.matched_customer_phone || '').trim();
      const matchedPeriod = r.matched_period_month && r.matched_period_year ? `${r.matched_period_month}/${r.matched_period_year}` : '';
      const matchedMonth = Number(r.matched_period_month || 0) || (new Date().getMonth() + 1);
      const matchedYear = Number(r.matched_period_year || 0) || new Date().getFullYear();
      const agentTopupId = Number(r.matched_agent_topup_id || 0) || 0;
      const matchHtml = matchedId
        ? `<a class="mono" href="/admin/billing?month=${encodeURIComponent(String(matchedMonth))}&year=${encodeURIComponent(String(matchedYear))}&status=all&search=${encodeURIComponent('INV-' + matchedId)}" target="_blank">INV-${matchedId}${matchedCustomer ? ` - ${escHtml(matchedCustomer)}` : ''}${matchedPeriod ? ` (${escHtml(matchedPeriod)})` : ''}</a>${matchedPhone ? `<div class="muted small">${escHtml(matchedPhone)}</div>` : ''}`
        : agentTopupId
          ? `<a class="mono" href="/admin/agents/reports?search=${agentTopupId}" target="_blank">Topup Agent #${agentTopupId}</a>${r.matched_agent_name ? `<div class="muted small">${escHtml(r.matched_agent_name)}</div>` : ''}`
          : '<span class="muted">-</span>';
      return `<tr>
        <td class="mono">${created}</td>
        <td>${svc}</td>
        <td>${amountHtml}</td>
        <td>${okBadge}</td>
        <td>${matchHtml}</td>
        <td style="max-width:720px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${content}">${content}</td>
        <td>
          <button type="button" class="btn btn-g btn-sm btn-copy-ew" data-raw="${rawEnc}" data-short="${rawShortEnc}">
            <i class="bi bi-copy"></i>
          </button>
        </td>
      </tr>`;
    }).join(''));

    body.querySelectorAll('.btn-copy-ew').forEach(btn => {
      btn.addEventListener('click', async () => {
        const rawEnc = btn.getAttribute('data-raw') || '';
        const rawShortEnc = btn.getAttribute('data-short') || '';
        const decoded = decodeURIComponent(rawEnc);
        const shortText = rawShortEnc ? decodeURIComponent(rawShortEnc) : 'Tersalin.';
        const ok = await copyText(decoded);
        if (ok) {
          alert(`Tersalin:\n${shortText}`);
        } else {
          alert('Gagal menyalin.');
        }
      });
    });
  } catch (e) {
    body.replaceChildren();
    body.insertAdjacentHTML('beforeend', `<tr><td colspan="7" class="text-center text-muted">${escHtml(e.message)}</td></tr>`);
  }
}

async function clearEwalletLogs() {
  if (!confirm('Hapus semua log e-wallet?')) return;
  try {
    const endpoints = [
      '/admin/api/webhook/payment-notif/clear',
      '/api/webhook/payment-notif/clear'
    ];
    let res = null;
    let data = null;
    let lastError = null;
    for (const url of endpoints) {
      try {
        const attempt = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          credentials: 'same-origin',
          body: '{}'
        });
        const contentType = String(attempt.headers.get('content-type') || '').toLowerCase();
        if (!contentType.includes('application/json')) {
          const raw = (await attempt.text()).slice(0, 160).replace(/\s+/g, ' ').trim();
          if (attempt.status === 401 || attempt.redirected) throw new Error('Sesi admin berakhir. Silakan login ulang.');
          if (raw.startsWith('<!DOCTYPE') || raw.startsWith('<html')) {
            throw new Error('Endpoint hapus log membalas HTML, bukan JSON. Route admin kemungkinan belum sinkron.');
          }
          throw new Error(raw ? `Respons tidak valid dari server: ${raw}` : 'Respons server tidak valid.');
        }
        const payload = await attempt.json();
        res = attempt;
        data = payload;
        lastError = null;
        break;
      } catch (error) {
        lastError = error;
      }
    }
    if (!res || !data) throw lastError || new Error('Gagal menghapus log webhook.');
    if (!res.ok || !data.ok) throw new Error(data.error || 'Gagal menghapus log');
    await loadEwalletLogs();
  } catch (e) {
    alert(e.message);
  }
}

setTimeout(loadEwalletLogs, 200);
setTimeout(updateNotifHint, 250);
setTimeout(() => {
  syncEwalletLiveButton();
  if (ewLiveActive) startEwalletLive();
}, 300);
setTimeout(()=>document.querySelectorAll('.alert').forEach(a=>a.style.display='none'),5000);
</script>
</body>
</html>
