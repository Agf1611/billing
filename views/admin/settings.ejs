<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.settings.title', 'Pengaturan') %> | <%= company %></title>
  <meta name="theme-color" content="#0f172a">
  <link rel="manifest" href="/admin/manifest.webmanifest">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .secret-inline{display:flex;gap:8px;align-items:stretch}
    .secret-field{position:relative;flex:1}
    .secret-field .fc{padding-right:46px}
    .settings-category-card{padding:12px 14px;border:1px solid var(--border);border-radius:22px;background:rgba(15,23,42,.32);margin-bottom:16px}
    .settings-category-head{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
    .settings-category-head strong{font-size:14px}
    .settings-category-head span{font-size:12px;color:var(--muted)}
    .settings-category-list{display:flex;gap:10px;flex-wrap:wrap}
    .settings-category-btn{
      border:1px solid rgba(148,163,184,.18);
      background:rgba(15,23,42,.42);
      color:var(--text);
      border-radius:999px;
      padding:10px 14px;
      font:600 12px/1 "Segoe UI",sans-serif;
      cursor:pointer;
      transition:.18s ease;
      display:inline-flex;
      align-items:center;
      gap:8px
    }
    .settings-category-btn.active{
      background:linear-gradient(135deg, rgba(99,102,241,.96), rgba(79,70,229,.9));
      border-color:transparent;
      box-shadow:0 12px 26px rgba(79,70,229,.24)
    }
    .settings-category-btn:hover{transform:translateY(-1px);border-color:rgba(99,102,241,.35)}
    .settings-panel-section{display:none}
    .settings-panel-section.active{display:block}
    .settings-card-pane{display:none}
    .settings-card-pane.active{display:block}
    .settings-shell-card{display:none}
    .settings-shell-card.active{display:block}
    .settings-pane-title{display:flex;align-items:center;gap:10px;margin:0 0 14px;font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
    .settings-pane-title i{font-size:14px;color:var(--brand)}
    .secret-toggle{
      position:absolute;right:10px;top:50%;transform:translateY(-50%);
      width:32px;height:32px;border:0;border-radius:10px;
      background:transparent;color:var(--muted);display:flex;align-items:center;justify-content:center;
      cursor:pointer;transition:.2s ease
    }
    .secret-toggle:hover{background:rgba(99,102,241,.12);color:var(--brand)}
    .secret-toggle:focus-visible{outline:2px solid rgba(99,102,241,.35);outline-offset:2px}
    body[data-theme="light"] .settings-category-card{
      background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(244,247,255,.96));
      border-color:rgba(202,210,231,.9);
      box-shadow:0 18px 42px rgba(148,163,184,.16);
    }
    body[data-theme="light"] .settings-category-btn{
      background:#eef2ff;
      border-color:#d6def3;
      color:#44506a;
      box-shadow:none;
    }
    body[data-theme="light"] .settings-category-btn.active{
      background:linear-gradient(135deg,#5b63f6,#6b4df5);
      color:#fff;
      box-shadow:0 14px 28px rgba(99,102,241,.24);
    }
    body[data-theme="light"] .settings-category-btn:hover{
      background:#f7f9ff;
      border-color:#c8d2ee;
    }
    body[data-theme="light"] .settings-category-btn.active:hover{
      background:linear-gradient(135deg,#5b63f6,#6b4df5);
    }
    body[data-theme="light"] .settings-shell-card,
    body[data-theme="light"] .settings-card-pane{
      border-color:rgba(208,216,235,.92);
      box-shadow:0 20px 48px rgba(148,163,184,.14);
    }
    body[data-theme="light"] .settings-shell-card .card-bd,
    body[data-theme="light"] .settings-card-pane .card-bd{
      background:rgba(255,255,255,.98);
    }
    body[data-theme="light"] .settings-shell-card .fc,
    body[data-theme="light"] .settings-shell-card .fs,
    body[data-theme="light"] .settings-card-pane .fc,
    body[data-theme="light"] .settings-card-pane .fs{
      background:#f6f8ff;
      border-color:#d7dff1;
      color:#32405b;
    }
    body[data-theme="light"] .settings-shell-card .fl,
    body[data-theme="light"] .settings-card-pane .fl,
    body[data-theme="light"] .settings-pane-title,
    body[data-theme="light"] .settings-category-head strong,
    body[data-theme="light"] .card-hd h6{
      color:#2a3650;
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'settings', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-gear"></i> <%= t('admin.settings.system_title', 'Pengaturan Sistem') %></div>
    <div class="tb-right">
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %></span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i> <%= t('common.logout', 'Logout') %></a>
    </div>
  </div>
  <div class="page">

    <% if (msg) { %>
    <div class="alert alert-<%= msg.type==='success'?'s':'d' %>">
      <i class="bi bi-<%= msg.type==='success'?'check-circle':'exclamation-circle' %>"></i> <%= msg.text %>
    </div>
    <% } %>

    <div class="settings-category-card">
      <div class="settings-category-head">
        <div>
          <strong>Pilih Jenis Pengaturan</strong>
        </div>
      </div>
      <div class="settings-category-list">
        <button type="button" class="settings-category-btn active" data-settings-target="usaha"><i class="bi bi-buildings"></i> Profil Usaha</button>
        <button type="button" class="settings-category-btn" data-settings-target="payment"><i class="bi bi-wallet2"></i> Payment</button>
        <button type="button" class="settings-category-btn" data-settings-target="akun"><i class="bi bi-shield-lock"></i> Akun Admin</button>
        <button type="button" class="settings-category-btn" data-settings-target="integrasi"><i class="bi bi-router"></i> API & MikroTik</button>
        <button type="button" class="settings-category-btn" data-settings-target="whatsapp"><i class="bi bi-whatsapp"></i> WhatsApp</button>
        <button type="button" class="settings-category-btn" data-settings-target="telegram"><i class="bi bi-telegram"></i> Telegram</button>
        <button type="button" class="settings-category-btn" data-settings-target="monitoring"><i class="bi bi-bell"></i> Webhook Log</button>
      </div>
    </div>

    <div class="card mb16 settings-card-pane" data-settings-pane="monitoring">
      <div class="card-hd" style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
        <h6 style="margin:0"><i class="bi bi-wallet2"></i> <%= t('admin.settings.ewallet_logs.title', 'Log Notifikasi E-Wallet (Webhook)') %></h6>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <button type="button" class="btn btn-g btn-sm" onclick="enableEwalletNotif()"><i class="bi bi-bell"></i> <%= t('admin.settings.ewallet_logs.enable_notif', 'Aktifkan Notif') %></button>
          <button type="button" class="btn btn-p btn-sm" onclick="toggleEwalletLive()" id="ew_live_btn"><i class="bi bi-broadcast"></i> <%= t('admin.settings.ewallet_logs.live', 'Live') %></button>
          <button type="button" class="btn btn-g btn-sm" onclick="loadEwalletLogs()"><i class="bi bi-arrow-clockwise"></i> <%= t('common.refresh', 'Refresh') %></button>
          <button type="button" class="btn btn-d btn-sm" onclick="clearEwalletLogs()"><i class="bi bi-trash"></i> <%= t('common.clear', 'Clear') %></button>
        </div>
      </div>
      <div class="card-bd">
        <div class="form-row" style="align-items:flex-end">
          <div class="fg">
            <label class="fl"><%= t('admin.settings.ewallet_logs.service', 'Service') %></label>
            <input class="fc" id="ew_service" placeholder="DANA / Gojek / ShopeePay (opsional)">
          </div>
          <div class="fg" style="flex:2">
            <label class="fl"><%= t('admin.settings.ewallet_logs.search', 'Cari') %></label>
            <input class="fc" id="ew_q" placeholder="kata kunci (opsional)">
          </div>
          <div class="fg w160">
            <label class="fl"><%= t('admin.settings.ewallet_logs.limit', 'Limit') %></label>
            <select class="fs" id="ew_limit">
              <option value="50">50</option>
              <option value="100">100</option>
              <option value="200" selected>200</option>
              <option value="500">500</option>
            </select>
          </div>
        </div>
        <div class="hint" style="margin-top:6px">
          Endpoint MacroDroid: <span class="mono">POST /api/webhook/v1/payment-notif</span>
        </div>
        <div class="hint" style="margin-top:6px" id="ew_notif_hint"></div>
        <div class="tbl-wrap" style="margin-top:10px;max-height:420px;overflow:auto">
          <table class="dtbl">
            <thead>
              <tr>
                <th style="width:160px"><%= t('common.time', 'Waktu') %></th>
                <th style="width:110px">Service</th>
                <th style="width:120px"><%= t('admin.settings.ewallet_logs.amount', 'Nominal') %></th>
                <th style="width:80px">OK</th>
                <th style="width:90px">Match</th>
                <th><%= t('admin.settings.ewallet_logs.content', 'Content') %></th>
                <th style="width:80px"><%= t('common.actions', 'Aksi') %></th>
              </tr>
            </thead>
            <tbody id="ew_logs_body">
              <tr><td colspan="7" class="text-center text-muted"><%= t('common.loading', 'Memuat data...') %></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <form method="POST" action="/admin/settings" enctype="multipart/form-data">
        <input type="hidden" name="settings_section" id="settings_section" value="<%= activeSettingsPane || 'usaha' %>">

        <div class="card mb16 settings-card-pane" data-settings-pane="telegram">
          <div class="card-hd"><h6><i class="bi bi-telegram"></i> <%= t('admin.settings.telegram.title', 'Pengaturan Telegram Bot (Backup Admin)') %></h6></div>
          <div class="card-bd">
            <div class="form-row">
              <div class="fg">
                <label class="fl"><%= t('admin.settings.telegram.status', 'Status Bot Telegram') %></label>
                <select class="fs" name="telegram_enabled">
                  <option value="true" <%= settings.telegram_enabled ? 'selected' : '' %>><%= t('common.active', 'Aktif') %></option>
                  <option value="false" <%= !settings.telegram_enabled ? 'selected' : '' %>><%= t('common.inactive', 'Nonaktif') %></option>
                </select>
              </div>
              <div class="fg">
                <label class="fl"><%= t('admin.settings.telegram.admin_id', 'Admin Telegram ID') %></label>
                <input class="fc" name="telegram_admin_id" value="<%= settings.telegram_admin_id || '' %>" placeholder="Contoh: 12345678">
              </div>
            </div>
            <div class="fg">
              <label class="fl"><%= t('admin.settings.telegram.bot_token', 'Telegram Bot Token') %></label>
              <div class="secret-inline">
                <div class="secret-field">
                  <input class="fc" type="password" name="telegram_bot_token" value="<%= settings.telegram_bot_token || '' %>" placeholder="Dapatkan dari @BotFather">
                  <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat token">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                <button type="button" class="btn btn-g" onclick="syncTelegram()" title="<%= t('admin.settings.telegram.sync_title', 'Sinkronkan / Hapus Webhook Lama') %>"><i class="bi bi-arrow-repeat"></i> <%= t('admin.settings.telegram.sync', 'Sinkronkan') %></button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mb16 settings-shell-card active" data-settings-shell="config">
          <div class="card-hd"><h6><i class="bi bi-sliders"></i> Detail Pengaturan</h6></div>
          <div class="card-bd" style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
        
        <!-- General Info -->
        <div class="settings-panel-section active" data-settings-pane="usaha">
          <h6 class="settings-pane-title"><i class="bi bi-buildings"></i> Profil Usaha & Invoice</h6>
          <div class="fg">
            <label class="fl">Nama ISP / Brand</label>
            <input class="fc" name="company_header" value="<%= settings.company_header || '' %>">
          </div>
          <div class="fg">
            <label class="fl"><%= t('admin.settings.footer_info', 'Info Footer') %></label>
            <input class="fc" name="footer_info" value="<%= settings.footer_info || '' %>">
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl">Nama PT / Badan Usaha</label>
              <input class="fc" name="company_legal_name" value="<%= settings.company_legal_name || '' %>" placeholder="Contoh: PT Contoh Jaringan Nusantara">
            </div>
            <div class="fg">
              <label class="fl">Sumber Internet / Upstream ISP</label>
              <input class="fc" name="upstream_provider_name" value="<%= settings.upstream_provider_name || '' %>" placeholder="Contoh: Telkom / Moratel / Biznet">
            </div>
          </div>
          <div class="fg">
            <label class="fl">Domain Publik Portal</label>
            <input class="fc" name="public_base_url" value="<%= settings.public_base_url || '' %>" placeholder="Contoh: https://gembok.ahnnet.my.id">
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl">Tampilkan Footer Support by ISP</label>
              <select class="fs" name="support_by_enabled">
                <option value="false" <%= !settings.support_by_enabled ? 'selected' : '' %>>Nonaktif</option>
                <option value="true" <%= settings.support_by_enabled ? 'selected' : '' %>>Aktif</option>
              </select>
            </div>
            <div class="fg">
              <label class="fl">Logo Support by ISP</label>
              <% if (settings.support_isp_logo_url) { %>
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;padding:10px 12px;border:1px solid var(--border);border-radius:14px;background:var(--bg2)">
                  <img src="<%= settings.support_isp_logo_url %>" alt="Logo support saat ini" style="width:48px;height:48px;object-fit:contain;border-radius:12px;background:#fff;padding:6px;border:1px solid var(--border)">
                  <div style="font-size:12px;color:var(--muted)">
                    <div style="font-weight:700;color:var(--text)">Logo support saat ini</div>
                    <div><%= settings.support_isp_logo_url %></div>
                  </div>
                </div>
              <% } %>
              <input class="fc" type="file" name="support_isp_logo_file" accept=".png,.jpg,.jpeg,.webp,.svg,image/*">
            </div>
          </div>
          <div class="fg">
            <label class="fl">Upload Logo Usaha / ISP</label>
            <% if (settings.company_logo_url) { %>
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;padding:10px 12px;border:1px solid var(--border);border-radius:14px;background:var(--bg2)">
                <img src="<%= settings.company_logo_url %>" alt="Logo Saat Ini" style="width:54px;height:54px;object-fit:contain;border-radius:14px;background:#fff;padding:6px;border:1px solid var(--border)">
                <div style="font-size:12px;color:var(--muted)">
                  <div style="font-weight:700;color:var(--text)">Logo saat ini</div>
                  <div><%= settings.company_logo_url %></div>
                </div>
              </div>
            <% } %>
            <input class="fc" type="file" name="company_logo_file" accept=".png,.jpg,.jpeg,.webp,.svg,image/*">
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl">Upload Tanda Tangan Invoice</label>
              <% if (settings.invoice_signature_url) { %>
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;padding:10px 12px;border:1px solid var(--border);border-radius:14px;background:var(--bg2)">
                  <img src="<%= settings.invoice_signature_url %>" alt="Tanda tangan saat ini" style="width:120px;height:54px;object-fit:contain;border-radius:10px;background:#fff;padding:6px;border:1px solid var(--border)">
                  <div style="font-size:12px;color:var(--muted)">
                    <div style="font-weight:700;color:var(--text)">Tanda tangan saat ini</div>
                    <div><%= settings.invoice_signature_url %></div>
                  </div>
                </div>
              <% } %>
              <input class="fc" type="file" name="invoice_signature_file" accept=".png,.jpg,.jpeg,.webp,.svg,image/*">
            </div>
            <div class="fg">
              <label class="fl">Upload Cap / Stempel Invoice</label>
              <% if (settings.invoice_stamp_url) { %>
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;padding:10px 12px;border:1px solid var(--border);border-radius:14px;background:var(--bg2)">
                  <img src="<%= settings.invoice_stamp_url %>" alt="Cap saat ini" style="width:86px;height:86px;object-fit:contain;border-radius:14px;background:#fff;padding:6px;border:1px solid var(--border)">
                  <div style="font-size:12px;color:var(--muted)">
                    <div style="font-weight:700;color:var(--text)">Cap saat ini</div>
                    <div><%= settings.invoice_stamp_url %></div>
                  </div>
                </div>
              <% } %>
              <input class="fc" type="file" name="invoice_stamp_file" accept=".png,.jpg,.jpeg,.webp,.svg,image/*">
            </div>
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl"><%= t('admin.settings.owner_name', 'Nama Manajer / Owner') %></label>
              <input class="fc" name="company_manager" value="<%= settings.company_manager || '' %>" placeholder="Admin Pusat">
            </div>
            <div class="fg">
              <label class="fl">Jabatan Penandatangan Invoice</label>
              <input class="fc" name="invoice_signer_title" value="<%= settings.invoice_signer_title || 'Finance' %>" placeholder="Finance / Direktur / Admin">
            </div>
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl"><%= t('admin.settings.primary_phone', 'Telepon Utama (CS)') %></label>
              <input class="fc" name="company_phone" value="<%= settings.company_phone || '' %>" placeholder="081234567890">
            </div>
          </div>
          <div class="fg">
            <label class="fl"><%= t('admin.settings.company_email', 'Email Perusahaan') %></label>
            <input class="fc" name="company_email" value="<%= settings.company_email || '' %>" placeholder="support@isp.com">
          </div>
          <div class="fg">
            <label class="fl"><%= t('admin.settings.office_address', 'Alamat Kantor') %></label>
            <input class="fc" name="company_address" value="<%= settings.company_address || '' %>" placeholder="Jl. Utama No. 123">
          </div>
          <div style="margin:18px 0 10px;font-size:13px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:1px">
            <i class="bi bi-bank"></i> Pembayaran Manual
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl">Bank Tujuan</label>
              <input class="fc" name="manual_payment_bank" value="<%= settings.manual_payment_bank || '' %>" placeholder="BCA / BRI / Mandiri">
            </div>
            <div class="fg">
              <label class="fl">Nomor Rekening</label>
              <input class="fc" name="manual_payment_account_number" value="<%= settings.manual_payment_account_number || '' %>" placeholder="1234567890">
            </div>
          </div>
          <div class="fg">
            <label class="fl">Atas Nama Rekening</label>
            <input class="fc" name="manual_payment_account_name" value="<%= settings.manual_payment_account_name || '' %>" placeholder="Nama pemilik rekening">
          </div>
          <div class="fg">
            <label class="fl">Catatan Transfer Manual</label>
            <textarea class="fc" name="manual_payment_notes" rows="3" placeholder="Contoh: Kirim bukti transfer ke WhatsApp admin setelah pembayaran."><%= settings.manual_payment_notes || '' %></textarea>
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl"><%= t('admin.settings.office_lat', 'Latitude Kantor') %></label>
              <input class="fc" name="office_lat" value="<%= settings.office_lat || '-7.140868012256965' %>" placeholder="-7.140868012256965">
            </div>
            <div class="fg">
              <label class="fl"><%= t('admin.settings.office_lng', 'Longitude Kantor') %></label>
              <input class="fc" name="office_lng" value="<%= settings.office_lng || '107.00277733308137' %>" placeholder="107.00277733308137">
            </div>
          </div>
          <div class="fg">
            <label class="fl"><%= t('admin.settings.operational_hours', 'Jam Operasional') %></label>
            <input class="fc" name="operational_hours" value="<%= settings.operational_hours || '' %>" placeholder="Setiap Hari: 08.00 - 22.00 WIB">
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl"><%= t('admin.settings.server_port', 'Port Server') %></label>
              <input class="fc" type="number" name="server_port" value="<%= settings.server_port || 3001 %>">
            </div>
            <div class="fg">
              <label class="fl"><%= t('admin.settings.customer_otp_login', 'Login OTP Pelanggan') %></label>
              <select class="fs" name="login_otp_enabled">
                <option value="true" <%= settings.login_otp_enabled ? 'selected' : '' %>><%= t('admin.settings.otp_enabled', 'Aktif (Kirim via WA)') %></option>
                <option value="false" <%= !settings.login_otp_enabled ? 'selected' : '' %>><%= t('admin.settings.otp_disabled', 'Nonaktif (Langsung)') %></option>
              </select>
            </div>
          </div>
        </div>

        <!-- GenieACS & MikroTik -->
        <div class="settings-panel-section" data-settings-pane="integrasi">
          <h6 class="settings-pane-title"><i class="bi bi-router"></i> API Eksternal & MikroTik</h6>
          <div class="fg">
            <label class="fl">GenieACS API URL</label>
            <input class="fc" name="genieacs_url" value="<%= settings.genieacs_url || '' %>" placeholder="http://192.168.8.89:7557">
          </div>
          <div class="form-row">
            <div class="fg">
              <label class="fl">GenieACS Username</label>
              <input class="fc" name="genieacs_username" value="<%= settings.genieacs_username || '' %>">
            </div>
            <div class="fg">
              <label class="fl">GenieACS Password</label>
              <div class="secret-field">
                <input class="fc" type="password" name="genieacs_password" value="<%= settings.genieacs_password || '' %>">
                <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat password">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="form-row" style="margin-top:20px">
            <div class="fg">
              <label class="fl">MikroTik IP / Host</label>
              <input class="fc" name="mikrotik_host" value="<%= settings.mikrotik_host || '' %>" placeholder="192.168.1.1">
