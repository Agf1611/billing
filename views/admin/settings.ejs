          </div>

        </div>

        <!-- Admin Auth -->
        <div class="settings-panel-section" data-settings-pane="akun">
          <h6 class="settings-pane-title"><i class="bi bi-shield-lock"></i> Akun Pengguna Admin</h6>
          <div class="form-row">
            <div class="fg">
              <label class="fl">Username Admin</label>
              <input class="fc" name="admin_username" value="<%= settings.admin_username || '' %>">
            </div>
            <div class="fg">
              <label class="fl">Password Admin</label>
              <div class="secret-field">
                <input class="fc" type="password" name="admin_password" value="<%= settings.admin_password || '' %>">
                <button type="button" class="secret-toggle" data-secret-toggle aria-label="Lihat password">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
              <div style="font-size:10px; color:var(--muted); margin-top:4px">Minimal 12 karakter. Jangan gunakan password bawaan.</div>
