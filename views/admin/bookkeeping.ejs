      }
      .bk-filter-main-row.period-filter-row {
        grid-template-columns: 1fr 1fr;
      }
      .bk-filter-main-row .bk-search-mobile {
        display: none;
      }
      .bk-mode-head {
        padding: 14px;
        align-items: flex-start;
      }
      .bk-total-strip {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 7px;
      }
      .bk-total-card {
        padding: 10px 9px;
        border-radius: 15px;
      }
      .bk-total-card span {
        font-size: 9px;
        letter-spacing: .03em;
        margin-bottom: 5px;
      }
      .bk-total-card strong {
        font-size: clamp(12px, 3.3vw, 16px);
        white-space: normal;
        overflow-wrap: anywhere;
      }
      .bk-filter-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 8px;
      }
      .bk-filter-actions .btn {
        width: 100%;
        min-width: 0;
      }
      .bk-summary-panel-head,
      .bk-summary-panel-body,
      .bk-toggle > summary,
      .bk-toggle-body,
      .bk-list-card .card-hd,
      .bk-list-card .card-bd {
        padding-left: 14px;
        padding-right: 14px;
      }
      .bk-summary-panel-head {
        flex-direction: column;
        align-items: flex-start;
      }
      .tbl-wrap {
        display: none;
      }
      .bk-mobile-list {
        display: block;
      }
      .bk-list-head {
        align-items: flex-start;
      }
      .bk-role-grid {
        grid-template-columns: 1fr 1fr;
      }
      .bk-finance-menu {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .bk-compact-summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .bk-cash-metrics {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .bk-balance-compact-row {
        grid-template-columns: minmax(0, 1fr);
        align-items: flex-start;
      }
      .bk-balance-compact-amount {
        text-align: left;
      }
    }
    @media (max-width: 576px) {
      .bk-filter-panel {
        padding: 8px;
      }
      .bk-filter-main-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .bk-filter-main-row.period-filter-row {
        grid-template-columns: 1fr 1fr;
      }
      .bk-filter-main-row.ledger-filter-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .bk-filter-main-row .fs {
        min-height: 42px;
        font-size: 11px;
        padding-left: 10px;
        padding-right: 28px;
      }
      .bk-breakdown-grid {
        gap: 8px;
      }
      .bk-breakdown-item {
        padding: 10px 11px;
      }
      .bk-breakdown-top {
        font-size: 11px;
        gap: 6px;
      }
      .bk-breakdown-amount {
        font-size: 15px;
      }
      .bk-breakdown-meta {
        font-size: 10px;
      }
      .bk-mobile-grid {
        grid-template-columns: 1fr;
      }
      .bk-mobile-head,
      .bk-inline-item,
      .bk-detail-card,
      .bk-detail-focus-row {
        flex-direction: column;
      }
      .bk-detail-focus-head,
      .bk-detail-focus-row {
        grid-template-columns: 1fr;
      }
      .bk-detail-focus-head {
        padding: 15px 14px;
      }
      .bk-detail-focus-body {
        padding: 14px;
      }
      .bk-detail-focus-stats {
        grid-template-columns: 1fr;
      }
      .bk-detail-focus-title h3 {
        font-size: 23px;
      }
      .bk-detail-amount {
        text-align: left;
      }
      .bk-detail-focus-amount {
        text-align: left;
      }
      .bk-role-grid {
        grid-template-columns: 1fr;
      }
      .bk-finance-menu {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .bk-compact-summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .bk-pager {
        align-items: stretch;
      }
      .bk-pager-actions,
      .bk-pager-actions .btn {
        width: 100%;
        justify-content: center;
      }
      .bk-mode-head {
        flex-direction: column;
      }
      .bk-cash-person > summary {
        grid-template-columns: minmax(0, 1fr);
      }
      .bk-cash-person-head {
        grid-template-columns: minmax(0, 1fr) auto;
      }
      .bk-cash-remaining {
        text-align: left;
      }
      .bk-cash-metrics {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 6px;
      }
      .bk-cash-metric {
        padding: 6px 6px;
      }
      .bk-cash-metric span {
        font-size: 9px;
      }
      .bk-cash-metric strong {
        font-size: 11px;
        white-space: normal;
      }
      .bk-amount,
      .bk-inline-amount {
        text-align: left;
      }
    }
    @media (min-width: 769px) {
      .bk-filter-search-row .bk-search-mobile {
        display: none;
      }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'bookkeeping', company }) %>
<div class="mw">
  <div class="topbar bookkeeping-topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-cash-coin"></i>
      <span>Pembukuan</span>
    </div>
    <div class="tb-right">
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= pageSession.isCashier ? 'Kasir' : 'Admin' %></span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>

<div class="page admin-shell-page">
    <% if (pageMsg && pageMsg.text) { %>
      <div class="alert alert-<%= pageMsg.type === 'error' ? 'd' : 's' %>" style="margin-bottom:16px"><%= pageMsg.text %></div>
    <% } %>

    <div class="bk-shell">
      <section class="bk-card bk-filter-card">
        <div class="bk-filter-top">
          <div class="bk-filter-copy">
            <strong>Periode Pembukuan</strong>
            <span><%= filterMeta %></span>
          </div>
          <div class="bk-filter-cta">
            <a href="/admin/bookkeeping/export?month=<%= selectedMonth %>&year=<%= selectedYear %>" class="btn btn-g btn-sm bk-action-mini">
              <i class="bi bi-file-earmark-excel"></i> <span>Export</span>
            </a>
            <% if (!pageSession.isCashier) { %>
            <a href="/admin/bookkeeping/new?month=<%= selectedMonth %>&year=<%= selectedYear %>" class="btn btn-g btn-sm bk-action-mini">
              <i class="bi bi-plus-circle"></i> <span>Tambah</span>
            </a>
            <% } %>
          </div>
        </div>
        <form method="GET" action="/admin/bookkeeping" class="bk-filter-form" id="bkFilterForm">
          <% if (selectedCategoryDetail) { %>
            <input type="hidden" name="detail_section" value="<%= selectedDetailSection %>">
            <input type="hidden" name="detail_bucket" value="<%= selectedDetailBucket %>">
          <% } %>
          <% if (!selectedCategoryDetail && selectedView !== 'summary') { %>
            <input type="hidden" name="view" value="<%= selectedView %>">
          <% } %>
          <div class="bk-filter-search-row">
            <% if (isLedgerView) { %>
              <input class="fs" type="text" name="search" value="<%= selectedSearch %>" placeholder="Cari transaksi" aria-label="Cari transaksi">
            <% } else { %>
              <div class="bk-period-pill"><i class="bi bi-calendar3"></i> <%= monthLabel %> <%= selectedYear %></div>
            <% } %>
            <button class="btn btn-g btn-sm bk-filter-toggle" type="button" onclick="toggleBookkeepingFilterPanel()" aria-label="Filter pembukuan">
              <i class="bi bi-funnel"></i>
            </button>
          </div>
          <div class="bk-filter-panel" id="bkFilterPanel">
            <div class="bk-filter-main-row <%= isLedgerView ? 'ledger-filter-row' : 'period-filter-row' %>">
              <select class="fs" name="month" aria-label="Bulan">
                <% for (let m = 1; m <= 12; m++) { %>
                  <option value="<%= m %>" <%= selectedMonth === m ? 'selected' : '' %>><%= monthNames[m - 1] %></option>
                <% } %>
              </select>
              <input class="fs" type="number" name="year" value="<%= selectedYear %>" placeholder="Tahun" aria-label="Tahun">
              <% if (isLedgerView) { %>
                <select class="fs" name="type" aria-label="Jenis transaksi">
                  <option value="" <%= !selectedType ? 'selected' : '' %>>Semua jenis</option>
                  <option value="income" <%= selectedType === 'income' ? 'selected' : '' %>>Pemasukan</option>
                  <option value="expense" <%= selectedType === 'expense' ? 'selected' : '' %>>Pengeluaran</option>
                </select>
              <% } %>
            </div>
            <div class="bk-filter-actions">
              <button class="btn btn-p btn-sm" type="submit"><i class="bi bi-funnel"></i> Tampilkan</button>
              <a href="/admin/bookkeeping?month=<%= now.getMonth() + 1 %>&year=<%= now.getFullYear() %>" class="btn btn-g btn-sm"><i class="bi bi-x"></i> Reset</a>
            </div>
          </div>
        </form>
      </section>

      <% if (selectedCategoryDetail) { %>
        <section class="bk-card bk-detail-focus" id="bk-category-detail">
          <div class="bk-detail-focus-head">
            <div class="bk-detail-focus-title">
              <strong><i class="bi <%= selectedCategoryDetail.icon || 'bi-list-ul' %>"></i> <%= isAdminCashDetail ? adminCashTitle : selectedCategoryDetail.title %></strong>
              <h3>Rp <%= Number(isAdminCashDetail ? (selectedCashHolderRow ? selectedCashHolderRow.currentBalance : cashOverviewRemaining) : selectedCategoryDetail.amount || 0).toLocaleString('id-ID') %></h3>
              <span><%= monthLabel %> <%= selectedYear %></span>
            </div>
            <a class="bk-summary-badge" href="<%= selectedCashHolderRow ? bkDetailUrl('admin', 'cash') : bkBaseUrl() %>"><i class="bi bi-arrow-left"></i> Kembali</a>
          </div>
          <div class="bk-detail-focus-body">
            <% if (isAdminCashDetail) { %>
              <% if (selectedCashHolderRow) { %>
                <div class="bk-detail-focus-stats">
                  <div class="bk-detail-focus-stat"><span>Diterima</span><strong>Rp <%= Number(selectedCashHolderRow.totalReceived || 0).toLocaleString('id-ID') %></strong></div>
                  <div class="bk-detail-focus-stat"><span>Setor</span><strong>Rp <%= Number(selectedCashHolderRow.settlementOut || 0).toLocaleString('id-ID') %></strong></div>
                  <div class="bk-detail-focus-stat"><span>Sisa</span><strong>Rp <%= Number(selectedCashHolderRow.currentBalance || 0).toLocaleString('id-ID') %></strong></div>
                </div>
                <% if (!selectedCashHolderTransactions.length) { %>
                  <div class="bk-empty" style="padding:18px 14px"><strong>Belum ada transaksi</strong></div>
                <% } else { %>
                  <div class="bk-detail-focus-list">
                    <% selectedCashHolderTransactions.forEach((row) => { %>
                      <article class="bk-detail-focus-row">
                        <div class="bk-detail-focus-main">
                          <strong><%= row.title || '-' %></strong>
                          <span><%= row.subtitle || row.source || '-' %></span>
                          <span><i class="bi bi-calendar3"></i> <%= row.date || '-' %></span>
                        </div>
                        <div class="bk-detail-focus-amount <%= row.type === 'expense' ? 'expense' : 'income' %>">
                          Rp <%= Number(row.amount || 0).toLocaleString('id-ID') %>
                        </div>
                      </article>
                    <% }) %>
                  </div>
                <% } %>
              <% } else { %>
                <div class="bk-cash-overview">
                  <% cashOverviewRows.forEach((item) => { %>
                    <article class="bk-cash-person">
                      <div class="bk-cash-person-head">
                        <a class="bk-cash-person-link" href="<%= bkCashHolderUrl(item) %>">
                          <div class="bk-cash-name">
                            <strong><%= item.label %></strong>
                            <span><%= item.roleLabel || 'Petugas' %><%= item.isActive === false ? ' - Nonaktif' : '' %></span>
                          </div>
                          <div class="bk-cash-remaining">Rp <%= Number(item.currentBalance || 0).toLocaleString('id-ID') %></div>
                        </a>
                        <div class="bk-cash-actions">
                          <a class="btn btn-g btn-sm" href="<%= bkCashHolderUrl(item) %>" aria-label="Lihat transaksi <%= item.label %>"><i class="bi bi-chevron-right"></i></a>
                          <% if (!pageSession.isCashier && item.role !== 'admin' && Number(item.currentBalance || 0) > 0) { %>
                            <a class="btn btn-p btn-sm" href="<%= bkViewUrl('settlements') %>"><i class="bi bi-box-arrow-in-down"></i> Setor</a>
                          <% } %>
                        </div>
                      </div>
                      <div class="bk-cash-metrics">
                        <div class="bk-cash-metric in">
                          <span>Diterima</span>
                          <strong>Rp <%= Number(item.totalReceived || 0).toLocaleString('id-ID') %></strong>
                        </div>
                        <div class="bk-cash-metric out">
                          <span>Setor</span>
                          <strong>Rp <%= Number(item.settlementOut || 0).toLocaleString('id-ID') %></strong>
                        </div>
                        <div class="bk-cash-metric out">
                          <span>Keluar</span>
                          <strong>Rp <%= Number(item.expense || 0).toLocaleString('id-ID') %></strong>
                        </div>
                        <div class="bk-cash-metric">
                          <span>Transaksi</span>
                          <strong><%= Number(item.paidCount || 0) %> sukses</strong>
                        </div>
                        <div class="bk-cash-metric">
                          <span>Invoice</span>
                          <strong>Rp <%= Number(item.invoiceIncome || 0).toLocaleString('id-ID') %></strong>
                        </div>
                        <div class="bk-cash-metric">
                          <span>Manual</span>
                          <strong>Rp <%= Number(item.manualIncome || 0).toLocaleString('id-ID') %></strong>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            <% } else { %>
            <div class="bk-detail-focus-stats">
              <div class="bk-detail-focus-stat">
                <span>Transaksi</span>
                <strong><%= Number(selectedCategoryDetail.count || 0) %> data</strong>
              </div>
            </div>

            <% if (!detailRows.length) { %>
              <div class="bk-empty" style="padding:22px 14px">
                <strong>Belum ada data</strong>
              </div>
            <% } else { %>
              <div class="bk-detail-focus-list">
                <% detailRows.forEach((row) => { %>
                  <article class="bk-detail-focus-row">
                    <div class="bk-detail-focus-main">
                      <strong><%= row.title || '-' %></strong>
                      <span><%= row.subtitle || row.source || '-' %></span>
                      <span><i class="bi bi-calendar3"></i> <%= row.date || '-' %><% if (row.holderLabel) { %> - <%= row.holderLabel %><% } %></span>
                    </div>
                    <div class="bk-detail-focus-side">
                      <div class="bk-detail-focus-amount <%= row.type === 'expense' ? 'expense' : 'income' %>">
                        Rp <%= Number(row.amount || 0).toLocaleString('id-ID') %>
                      </div>
                      <% if (!pageSession.isCashier && (!row.source || String(row.source).toLowerCase() === 'manual')) { %>
                        <a class="btn btn-g btn-sm" href="/admin/bookkeeping/<%= row.id %>/edit?month=<%= selectedMonth %>&year=<%= selectedYear %>"><i class="bi bi-pencil"></i> Edit</a>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } %>
            <% } %>
          </div>
        </section>
      <% } else { %>

      <% if (isSummaryView) { %>
      <div class="bk-total-strip">
        <div class="bk-total-card income">
          <span>Pemasukan</span>
          <strong>Rp <%= totalIncome.toLocaleString('id-ID') %></strong>
        </div>
        <div class="bk-total-card expense">
          <span>Pengeluaran</span>
          <strong>Rp <%= totalExpense.toLocaleString('id-ID') %></strong>
        </div>
        <div class="bk-total-card net">
          <span>Bersih</span>
          <strong>Rp <%= Number(comparison.netAmount || balance).toLocaleString('id-ID') %></strong>
        </div>
      </div>

      <div class="bk-summary-grid" id="bk-finance-summary">
        <section class="bk-card">
          <div class="bk-summary-panel-head">
            <div>
              <strong>Pemasukan Total</strong>
              <h3>Rp <%= totalIncome.toLocaleString('id-ID') %></h3>
              <span><%= incomeCount %> transaksi</span>
            </div>
            <span class="bk-summary-badge"><i class="bi bi-arrow-down-left-circle"></i> Pemasukan</span>
          </div>
          <div class="bk-summary-panel-body">
            <div class="bk-breakdown-grid">
              <% incomeCards.forEach((item) => { %>
                <a class="bk-breakdown-item tone-<%= item.tone %>" href="<%= bkDetailUrl('income', item.bucket) %>">
                  <div class="bk-breakdown-top"><i class="bi <%= item.icon %>"></i><span><%= item.label %></span></div>
                  <div class="bk-breakdown-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                  <div class="bk-breakdown-meta"><%= Number(item.count || 0) %> transaksi</div>
                  <span class="bk-click-hint">Lihat detail <i class="bi bi-chevron-right"></i></span>
                </a>
              <% }) %>
            </div>
          </div>
        </section>

        <section class="bk-card">
          <div class="bk-summary-panel-head">
            <div>
              <strong>Pengeluaran Total</strong>
              <h3>Rp <%= totalExpense.toLocaleString('id-ID') %></h3>
              <span><%= expenseCount %> transaksi</span>
            </div>
            <span class="bk-summary-badge"><i class="bi bi-arrow-up-right-circle"></i> Pengeluaran</span>
          </div>
          <div class="bk-summary-panel-body">
            <div class="bk-profit-stack">
              <div class="bk-breakdown-grid">
                <% expenseCards.forEach((item) => { %>
                  <a class="bk-breakdown-item" href="<%= bkDetailUrl('expense', item.bucket) %>">
                    <div class="bk-breakdown-top"><i class="bi <%= item.icon %>"></i><span><%= item.label %></span></div>
                    <div class="bk-breakdown-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                    <div class="bk-breakdown-meta"><%= Number(item.count || 0) %> transaksi</div>
                    <span class="bk-click-hint">Lihat detail <i class="bi bi-chevron-right"></i></span>
                  </a>
                <% }) %>
              </div>
            </div>
          </div>
        </section>
      </div>

      <section class="bk-card">
          <div class="bk-summary-panel-head">
            <div>
              <strong>Menu Keuangan</strong>
            </div>
          <span class="bk-summary-badge"><i class="bi bi-grid"></i> Menu</span>
        </div>
        <div class="bk-summary-panel-body">
          <div class="bk-finance-menu">
            <a class="bk-finance-menu-item" href="<%= bkDetailUrl('admin', 'cash') %>">
              <i class="bi bi-person-circle"></i>
              <span>Uang di Admin</span>
            </a>
            <a class="bk-finance-menu-item" href="<%= bkViewUrl('ledger') %>">
              <i class="bi bi-list-ul"></i>
              <span>Semua Pembukuan</span>
            </a>
            <a class="bk-finance-menu-item" href="<%= bkViewUrl('role-payments') %>">
              <i class="bi bi-person-check"></i>
              <span>Pembayaran Peran</span>
            </a>
            <a class="bk-finance-menu-item" href="<%= bkViewUrl('staff-cash') %>">
              <i class="bi bi-wallet2"></i>
              <span>Saldo Petugas</span>
            </a>
            <a class="bk-finance-menu-item" href="<%= bkViewUrl('settlements') %>">
              <i class="bi bi-box-arrow-in-down"></i>
              <span>Riwayat Setor</span>
            </a>
          </div>
        </div>
      </section>
      <% } %>

      <% if (isRolePaymentsView) { %>
      <section class="bk-card">
        <div class="bk-mode-head">
          <div>
            <strong>Pembayaran Peran</strong>
            <span><%= monthLabel %> <%= selectedYear %></span>
          </div>
          <a class="bk-summary-badge" href="<%= bkBaseUrl() %>"><i class="bi bi-arrow-left"></i> Kembali</a>
        </div>
        <div class="bk-list-card card-bd">
          <div class="bk-list-head">
            <div class="bk-subtitle" style="margin-bottom:0">
              <strong>Pembayaran per Peran</strong>
              <span><%= rolePaymentBreakdown.length %> peran</span>
            </div>
            <div class="bk-chip-row">
              <span class="bk-chip"><i class="bi bi-person-badge"></i> <strong><%= rolePaymentBreakdown.length %></strong> peran aktif</span>
              <span class="bk-chip"><i class="bi bi-cash-coin"></i> Setor <strong>Rp <%= Number(settlementSummary.totalAmount || 0).toLocaleString('id-ID') %></strong></span>
            </div>
          </div>
          <% if (!rolePaymentBreakdown.length) { %>
            <div class="bk-empty">
              <i class="bi bi-people"></i>
              <strong>Belum ada data</strong>
            </div>
          <% } else { %>
            <div class="bk-role-grid">
              <% rolePaymentBreakdown.forEach((item) => { %>
                <article class="bk-role-card">
                  <strong><%= item.label %></strong>
                  <div class="bk-role-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                  <div class="bk-role-meta"><%= Number(item.count || 0) %> transaksi - <%= Number(item.actorCount || 0) %> petugas</div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>
      <% } %>

      <% if (isStaffCashView || isSettlementsView) { %>
      <section class="bk-card bk-balance-toggle">
        <div class="bk-mode-head">
          <div>
            <strong><%= isSettlementsView ? 'Riwayat Setor' : 'Saldo Kas Petugas' %></strong>
            <span><%= monthLabel %> <%= selectedYear %></span>
          </div>
          <a class="bk-summary-badge" href="<%= bkBaseUrl() %>"><i class="bi bi-arrow-left"></i> Kembali</a>
        </div>
        <div class="bk-toggle-body">
          <div class="bk-compact-summary">
            <div class="bk-compact-stat"><span>Kas Admin</span><strong>Rp <%= Number(adminCashBalance?.currentBalance || 0).toLocaleString('id-ID') %></strong></div>
            <div class="bk-compact-stat"><span>Saldo Petugas</span><strong>Rp <%= Number(staffBalanceTotal || 0).toLocaleString('id-ID') %></strong></div>
            <div class="bk-compact-stat"><span>Petugas Bersaldo</span><strong><%= staffWithBalance.length %> orang</strong></div>
            <div class="bk-compact-stat"><span>Total Setor</span><strong>Rp <%= Number(settlementSummary.totalAmount || 0).toLocaleString('id-ID') %></strong></div>
          </div>
          <div class="bk-balance-shell <%= isSettlementsView ? 'settlements-only' : '' %>">
            <% if (isStaffCashView) { %>
            <div class="bk-balance-list">
              <article class="bk-balance-card">
                <div class="bk-balance-head">
                  <div>
                    <span class="bk-balance-role">Admin</span>
                    <strong><%= adminCashBalance?.label || 'Admin' %></strong>
                  </div>
                  <span class="bk-balance-status <%= Number(adminCashBalance?.currentBalance || 0) <= 0 ? 'zero' : '' %>">Kas admin bersih</span>
                </div>
                <div class="bk-balance-amount">Rp <%= Number(adminCashBalance?.currentBalance || 0).toLocaleString('id-ID') %></div>
                <div class="bk-role-meta">Pembayaran langsung admin + setor masuk - pengeluaran admin.</div>
                <div class="bk-balance-chip-row">
                  <span class="bk-balance-chip">Invoice <b>Rp <%= Number(adminCashBalance?.invoiceIncome || 0).toLocaleString('id-ID') %></b></span>
                  <span class="bk-balance-chip">Manual <b>Rp <%= Number(adminCashBalance?.manualIncome || 0).toLocaleString('id-ID') %></b></span>
                  <span class="bk-balance-chip">Setor masuk <b>Rp <%= Number(adminCashBalance?.settlementIn || 0).toLocaleString('id-ID') %></b></span>
                  <span class="bk-balance-chip">Keluar <b>Rp <%= Number(adminCashBalance?.expense || 0).toLocaleString('id-ID') %></b></span>
                </div>
              </article>
              <% if (!staffBalances.length) { %>
                <div class="bk-empty">
                  <i class="bi bi-wallet2"></i>
                  <strong>Belum ada data</strong>
                </div>
              <% } else { %>
                <% staffBalances.forEach((item) => { %>
                  <article class="bk-balance-card">
                    <div class="bk-balance-head">
                      <div>
                        <span class="bk-balance-role"><%= item.roleLabel %></span>
                        <strong><%= item.label %></strong>
                      </div>
                      <span class="bk-balance-status <%= item.currentBalance <= 0 ? 'zero' : (String(item.statusLabel || '').toLowerCase().includes('sebagian') ? 'partial' : '') %>"><%= item.statusLabel %></span>
                    </div>
                    <div class="bk-balance-amount">Rp <%= Number(item.currentBalance || 0).toLocaleString('id-ID') %></div>
                    <div class="bk-role-meta">
                      <% if (!item.isActive) { %><span class="bk-balance-inactive">Nonaktif</span> - <% } %>
                      Invoice Rp <%= Number(item.invoiceIncome || 0).toLocaleString('id-ID') %> - Manual Rp <%= Number(item.manualIncome || 0).toLocaleString('id-ID') %>
                    </div>
                    <div class="bk-balance-chip-row">
                      <span class="bk-balance-chip">Setor keluar <b>Rp <%= Number(item.settlementOut || 0).toLocaleString('id-ID') %></b></span>
                      <span class="bk-balance-chip">Setor masuk <b>Rp <%= Number(item.settlementIn || 0).toLocaleString('id-ID') %></b></span>
                      <span class="bk-balance-chip">Pengeluaran <b>Rp <%= Number(item.expense || 0).toLocaleString('id-ID') %></b></span>
                    </div>
                  </article>
                <% }) %>
              <% } %>
            </div>
            <% } %>

            <% if (isSettlementsView) { %>
            <div class="bk-settlement-list">
              <% if (!pageSession.isCashier) { %>
              <article class="bk-settlement-card">
                <div class="bk-settlement-head">
                  <div>
                    <strong>Setor ke Admin</strong>
                    <div class="bk-role-meta">Admin mencatat uang fisik yang diterima dari petugas.</div>
                  </div>
                  <span class="bk-balance-status">Input manual</span>
                </div>
                <form method="POST" action="/admin/bookkeeping/settlements" class="bk-form-inline">
                  <input type="hidden" name="month" value="<%= selectedMonth %>">
                  <input type="hidden" name="year" value="<%= selectedYear %>">
                  <div class="bk-form-inline-grid">
                    <div class="full">
                      <label class="fl">Petugas sumber</label>
                      <select class="fc" name="from_holder" id="settlementHolderSelect" onchange="syncSettlementHolderFields()" required>
                        <option value="">Pilih petugas</option>
                        <% settlementOptions.forEach((item) => { %>
                          <option value="<%= item.role %>:<%= item.entityId %>"><%= item.label %><%= item.isActive ? '' : ' (nonaktif)' %></option>
                        <% }) %>
                      </select>
                      <input type="hidden" name="from_role" id="settlementFromRole">
                      <input type="hidden" name="from_entity_id" id="settlementFromEntityId">
                    </div>
                    <div>
                      <label class="fl">Tanggal setor</label>
                      <input class="fc" type="date" name="settlement_date" value="<%= new Date().toISOString().slice(0, 10) %>" required>
                    </div>
                    <div>
                      <label class="fl">Nominal setor</label>
                      <input class="fc" type="number" min="1" name="amount" placeholder="Contoh: 300000" required>
                    </div>
                    <div class="full">
                      <label class="fl">Catatan</label>
                      <textarea class="fc" name="notes" rows="3" placeholder="Contoh: setor tunai putaran sore"></textarea>
                    </div>
                  </div>
                  <button class="btn btn-p" type="submit"><i class="bi bi-box-arrow-in-down-right"></i> Catat Setor</button>
                </form>
              </article>
              <% } %>

              <article class="bk-settlement-card">
                <div class="bk-settlement-head">
                  <div>
                    <strong>Riwayat Setor</strong>
                    <div class="bk-role-meta"><%= Number(settlementSummary.totalCount || 0) %> transaksi setor pada periode ini.</div>
                  </div>
                  <span class="bk-balance-status <%= Number(settlementSummary.totalAmount || 0) <= 0 ? 'zero' : '' %>">Rp <%= Number(settlementSummary.totalAmount || 0).toLocaleString('id-ID') %></span>
                </div>
                <% if (!settlementRows.length) { %>
                  <div class="bk-empty" style="padding:18px 14px">
                    <strong>Belum ada data</strong>
                  </div>
                <% } else { %>
                  <div class="bk-inline-list">
                    <% settlementRows.forEach((item) => { %>
                      <div class="bk-inline-item">
                        <div>
                          <strong><%= item.fromLabel %> -> <%= item.toLabel %></strong>
                          <span><%= item.settlementDate || '-' %> - Dicatat oleh <b><%= item.createdByName || 'Admin' %></b></span>
                          <span><%= item.notes || 'Tanpa catatan' %></span>
                        </div>
                        <div class="bk-inline-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </article>
            </div>
            <% } %>
          </div>
        </div>
      </section>
      <% } %>

      <% if (isLedgerView) { %>
      <section class="bk-card bk-list-card" id="bk-all-ledger">
        <div class="bk-mode-head">
          <div>
            <strong><i class="bi bi-journal-text"></i> Semua Pembukuan</strong>
            <span><%= monthLabel %> <%= selectedYear %></span>
          </div>
          <a class="bk-summary-badge" href="<%= bkBaseUrl() %>"><i class="bi bi-arrow-left"></i> Kembali</a>
        </div>
        <div class="bk-summary-panel-body">
          <div class="bk-chip-row">
            <span class="bk-chip"><i class="bi bi-wallet2"></i> Total <strong><%= totalEntryCount %></strong></span>
            <span class="bk-chip"><i class="bi bi-list-ol"></i> Halaman <strong><%= bkCurrentPage %>/<%= bkTotalPages %></strong></span>
            <span class="bk-chip"><i class="bi bi-arrow-down-left-circle"></i> Masuk <strong><%= incomeCount %></strong></span>
            <span class="bk-chip"><i class="bi bi-arrow-up-right-circle"></i> Keluar <strong><%= expenseCount %></strong></span>
          </div>
        </div>
        <div class="card-bd">
          <% if (!pageEntries.length) { %>
            <div class="bk-empty">
              <i class="bi bi-journal-x"></i>
              <strong>Belum ada data</strong>
            </div>
          <% } else { %>
            <div class="tbl-wrap">
              <table class="dtbl">
                <thead>
                  <tr>
                    <th style="width:116px">Tanggal</th>
                    <th style="width:120px">Jenis</th>
                    <th style="width:150px">Kategori</th>
                    <th>Keterangan</th>
                    <th style="width:130px">Petugas</th>
                    <th class="num" style="width:160px">Nominal</th>
                    <th class="num" style="width:74px"></th>
                  </tr>
                </thead>
                <tbody>
                  <% pageEntries.forEach((entry) => { %>
                    <tr>
                      <td><span class="bk-entry-main"><%= entry.entry_date || '-' %></span></td>
                      <td>
                        <span class="bk-type <%= entry.type === 'income' ? 'income' : 'expense' %>">
                          <i class="bi <%= entry.type === 'income' ? 'bi-arrow-down-left' : 'bi-arrow-up-right' %>"></i>
                          <%= entry.type === 'income' ? 'Masuk' : 'Keluar' %>
                        </span>
                      </td>
                      <td>
                        <div class="bk-entry-copy">
                          <span class="bk-entry-main"><%= entry.category || '-' %></span>
                          <% if (entry.source_type) { %>
                            <span class="bk-source <%= entry.source_type === 'invoice' ? 'invoice' : '' %>"><%= entry.source_type %></span>
                          <% } %>
                          <span class="bk-source"><%= String(entry.payment_method || 'cash').toUpperCase() %></span>
                        </div>
                      </td>
                      <td>
                        <div class="bk-entry-copy">
                          <span class="bk-entry-main"><%= entry.description || '-' %></span>
                          <% if (entry.customer_name) { %><span class="bk-entry-sub"><%= entry.customer_name %></span><% } %>
                        </div>
                      </td>
                      <td>
                        <div class="bk-entry-copy">
                          <span class="bk-entry-main"><%= entry.created_by_name || '-' %></span>
                          <% if (entry.holder_label) { %><span class="bk-entry-sub">Kas dipegang: <%= entry.holder_label %></span><% } %>
                        </div>
                      </td>
                      <td class="num bk-amount <%= entry.type === 'income' ? 'income' : 'expense' %>">Rp <%= Number(entry.amount || 0).toLocaleString('id-ID') %></td>
                      <td class="num">
                        <% if (!pageSession.isCashier && String(entry.source_type || '') !== 'invoice') { %>
                          <div style="display:inline-flex;gap:6px;justify-content:flex-end">
                            <a class="btn btn-g btn-sm" href="/admin/bookkeeping/<%= entry.id %>/edit?month=<%= selectedMonth %>&year=<%= selectedYear %>"><i class="bi bi-pencil"></i></a>
                            <form method="POST" action="/admin/bookkeeping/<%= entry.id %>/delete" onsubmit="return confirm('Hapus data pembukuan ini?')">
                              <button class="btn btn-d btn-sm" type="submit"><i class="bi bi-trash"></i></button>
                            </form>
                          </div>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <div class="bk-mobile-list">
              <% pageEntries.forEach((entry) => { %>
                <article class="bk-mobile-card <%= entry.type === 'income' ? 'income' : 'expense' %>">
                  <div class="bk-mobile-head">
                    <div>
                      <div class="bk-mobile-top">
                        <span class="bk-type <%= entry.type === 'income' ? 'income' : 'expense' %>">
                          <i class="bi <%= entry.type === 'income' ? 'bi-arrow-down-left' : 'bi-arrow-up-right' %>"></i>
                          <%= entry.type === 'income' ? 'Masuk' : 'Keluar' %>
                        </span>
                        <span class="bk-date"><%= entry.entry_date || '-' %></span>
                      </div>
                      <div class="bk-entry-main"><%= entry.category || '-' %></div>
                      <div class="bk-entry-sub"><%= entry.description || '-' %></div>
                    </div>
                    <div class="bk-amount <%= entry.type === 'income' ? 'income' : 'expense' %>">Rp <%= Number(entry.amount || 0).toLocaleString('id-ID') %></div>
                  </div>

                  <div class="bk-mobile-grid">
                    <div class="bk-mobile-cell">
                      <div class="bk-mobile-label">Petugas</div>
                      <div class="bk-mobile-value"><%= entry.created_by_name || '-' %></div>
                    </div>
                    <% if (entry.holder_label) { %>
                      <div class="bk-mobile-cell">
                        <div class="bk-mobile-label">Kas dipegang</div>
                        <div class="bk-mobile-value"><%= entry.holder_label %></div>
                      </div>
                    <% } %>
                    <div class="bk-mobile-cell">
                      <div class="bk-mobile-label">Sumber</div>
                      <div class="bk-mobile-value"><%= entry.source_type || 'manual' %> - <%= String(entry.payment_method || 'cash').toUpperCase() %></div>
                    </div>
                    <% if (entry.customer_name) { %>
                      <div class="bk-mobile-cell" style="grid-column:1 / -1">
                        <div class="bk-mobile-label">Pelanggan</div>
                        <div class="bk-mobile-value"><%= entry.customer_name %></div>
                      </div>
                    <% } %>
                  </div>

                  <% if (!pageSession.isCashier && String(entry.source_type || '') !== 'invoice') { %>
                    <div class="bk-mobile-actions">
                      <a class="btn btn-g btn-sm" href="/admin/bookkeeping/<%= entry.id %>/edit?month=<%= selectedMonth %>&year=<%= selectedYear %>"><i class="bi bi-pencil"></i> Edit</a>
                      <form method="POST" action="/admin/bookkeeping/<%= entry.id %>/delete" onsubmit="return confirm('Hapus data pembukuan ini?')">
                        <button class="btn btn-d btn-sm" type="submit"><i class="bi bi-trash"></i> Hapus</button>
                      </form>
                    </div>
                  <% } %>
                </article>
              <% }) %>
            </div>
            <div class="bk-pager">
              <div class="bk-pager-info">
                Menampilkan <%= ((bkCurrentPage - 1) * bkPageSize) + 1 %>-<%= Math.min(totalEntryCount, bkCurrentPage * bkPageSize) %> dari <%= totalEntryCount %> entri
              </div>
              <div class="bk-pager-actions">
                <a class="btn btn-g btn-sm <%= bkCurrentPage <= 1 ? 'disabled' : '' %>" href="<%= bkPageUrl(Math.max(1, bkCurrentPage - 1)) %>">
                  <i class="bi bi-chevron-left"></i> Sebelumnya
                </a>
                <span class="bk-chip"><i class="bi bi-list-ol"></i> <strong><%= bkCurrentPage %>/<%= bkTotalPages %></strong></span>
                <a class="btn btn-g btn-sm <%= bkCurrentPage >= bkTotalPages ? 'disabled' : '' %>" href="<%= bkPageUrl(Math.min(bkTotalPages, bkCurrentPage + 1)) %>">
                  Berikutnya <i class="bi bi-chevron-right"></i>
                </a>
              </div>
            </div>
          <% } %>
        </div>
      </section>
      <% } %>
      <% } %>
    </div>
  </div>
</div>
<script>
function syncBookkeepingMobileFilterLayout() {
  const form = document.getElementById('bkFilterForm');
  const searchRow = form?.querySelector('.bk-filter-search-row');
  const panel = document.getElementById('bkFilterPanel');
  if (!form || !searchRow || !panel) return;
  if (window.innerWidth > 768) {
    panel.classList.remove('show');
  }
}

function toggleBookkeepingFilterPanel(force) {
  const panel = document.getElementById('bkFilterPanel');
  if (!panel) return;
  syncBookkeepingMobileFilterLayout();
  if (window.innerWidth > 768) return;
  if (typeof force === 'boolean') {
    panel.classList.toggle('show', force);
    return;
  }
  panel.classList.toggle('show');
}

function syncSettlementHolderFields() {
  const source = document.getElementById('settlementHolderSelect');
  const roleInput = document.getElementById('settlementFromRole');
  const entityInput = document.getElementById('settlementFromEntityId');
  if (!source || !roleInput || !entityInput) return;
  const [role = '', entityId = ''] = String(source.value || '').split(':');
  roleInput.value = role;
  entityInput.value = entityId;
}

window.addEventListener('resize', syncBookkeepingMobileFilterLayout);
document.addEventListener('DOMContentLoaded', () => {
  syncBookkeepingMobileFilterLayout();
  syncSettlementHolderFields();
  document.getElementById('bkFilterForm')?.addEventListener('submit', () => {
    if (window.innerWidth <= 768) toggleBookkeepingFilterPanel(false);
  });
});
</script>
</body>
</html>
