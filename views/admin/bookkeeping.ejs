<%
  const pageLang = (typeof lang !== 'undefined' && lang) ? lang : 'id';
  const pageSession = (typeof session !== 'undefined' && session) ? session : {};
  const pageMsg = (typeof msg !== 'undefined' && msg) ? msg : null;
  const pageEntries = Array.isArray(entries) ? entries : [];
  const totalEntryCount = Number(typeof totalEntries !== 'undefined' ? totalEntries : pageEntries.length);
  const bkCurrentPage = Math.max(1, Number(typeof currentPage !== 'undefined' ? currentPage : 1) || 1);
  const bkTotalPages = Math.max(1, Number(typeof totalPages !== 'undefined' ? totalPages : 1) || 1);
  const bkPageSize = Math.max(1, Number(typeof pageSize !== 'undefined' ? pageSize : 20) || 20);
  const now = new Date();
  const selectedMonth = Number(filterMonth || (now.getMonth() + 1));
  const selectedYear = Number(filterYear || now.getFullYear());
  const selectedType = String(type || '').trim();
  const selectedSearch = String(search || '').trim();
  const selectedDetailSection = String(typeof detailSection !== 'undefined' ? detailSection : '').trim();
  const selectedDetailBucket = String(typeof detailBucket !== 'undefined' ? detailBucket : '').trim();
  const selectedCashHolderKey = String(typeof cashHolder !== 'undefined' ? cashHolder : '').trim().toLowerCase();
  const selectedCashHolderTransactions = Array.isArray(typeof cashHolderTransactions !== 'undefined' ? cashHolderTransactions : []) ? cashHolderTransactions : [];
  const selectedCategoryDetail = (typeof categoryDetail !== 'undefined' && categoryDetail) ? categoryDetail : null;
  const rawSelectedView = String(typeof view !== 'undefined' ? view : '').trim().toLowerCase();
  const allowedBookkeepingViews = ['summary', 'ledger', 'staff-cash', 'settlements', 'role-payments'];
  const selectedView = selectedCategoryDetail ? 'detail' : (allowedBookkeepingViews.includes(rawSelectedView) ? rawSelectedView : 'summary');
  const isSummaryView = selectedView === 'summary';
  const isLedgerView = selectedView === 'ledger';
  const isStaffCashView = selectedView === 'staff-cash';
  const isSettlementsView = selectedView === 'settlements';
  const isRolePaymentsView = selectedView === 'role-payments';
  const monthNames = (pageLang === 'en')
    ? ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
    : ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
  const monthLabel = monthNames[Math.max(0, Math.min(11, selectedMonth - 1))] || monthNames[now.getMonth()];
  const totalIncome = Number(summary?.total_income || 0);
  const totalExpense = Number(summary?.total_expense || 0);
  const balance = totalIncome - totalExpense;
  const incomeCount = Number(summary?.income_count || 0);
  const expenseCount = Number(summary?.expense_count || 0);
  const dashboardData = dashboard || {};
  const ledgerDashboard = cashLedger || {};
  const incomeBreakdown = dashboardData.income || {};
  const expenseBreakdown = dashboardData.expense || {};
  const comparison = dashboardData.comparison || {};
  const actorBreakdown = Array.isArray(dashboardData.actors) ? dashboardData.actors : [];
  const recentPayments = Array.isArray(dashboardData.recentPayments) ? dashboardData.recentPayments : [];
  const approvalBreakdown = Array.isArray(dashboardData.approvals) ? dashboardData.approvals : [];
  const rolePaymentBreakdown = Array.isArray(ledgerDashboard.rolePayments) ? ledgerDashboard.rolePayments : [];
  const cashBalances = Array.isArray(ledgerDashboard.balances) ? ledgerDashboard.balances : [];
  const adminCashBalance = ledgerDashboard.adminBalance || null;
  const settlementSummary = ledgerDashboard.settlementSummary || {};
  const settlementRows = Array.isArray(ledgerDashboard.settlements) ? ledgerDashboard.settlements : [];
  const settlementOptions = Array.isArray(settlementSourceOptions) ? settlementSourceOptions : [];
  const staffBalances = cashBalances.filter((item) => item.role !== 'admin');
  const staffWithBalance = staffBalances.filter((item) => Number(item.currentBalance || 0) > 0);
  const staffBalanceTotal = staffBalances.reduce((sum, item) => sum + Number(item.currentBalance || 0), 0);
  const actorPaymentMap = new Map(actorBreakdown.map((item) => [String(item.label || '').trim().toLowerCase(), item]));
  const cashOverviewRows = cashBalances.map((item) => {
    const actor = actorPaymentMap.get(String(item.label || '').trim().toLowerCase()) || {};
    const totalReceived = Number(item.invoiceIncome || 0) + Number(item.manualIncome || 0) + Number(item.settlementIn || 0);
    const paidRows = recentPayments.filter((payment) => String(payment.actorLabel || '').trim().toLowerCase() === String(item.label || '').trim().toLowerCase());
    return {
      ...item,
      totalReceived,
      paidAmount: Number(actor.amount || 0),
      paidCount: Number(item.invoiceCount || 0) + Number(item.manualCount || 0),
      recentPayments: paidRows.slice(0, 8)
    };
  });
  const isAdminCashDetail = selectedCategoryDetail && selectedDetailSection === 'admin' && selectedDetailBucket === 'cash';
  const cashOverviewRemaining = cashOverviewRows.reduce((sum, item) => sum + Number(item.currentBalance || 0), 0);
  const selectedCashHolderRow = cashOverviewRows.find((item) => `${item.role}:${item.entityId == null ? 'null' : item.entityId}` === selectedCashHolderKey) || null;
  const adminCashTitle = selectedCashHolderRow ? selectedCashHolderRow.label : 'Uang di Admin';
  const bkPageParams = new URLSearchParams();
  bkPageParams.set('month', String(selectedMonth));
  bkPageParams.set('year', String(selectedYear));
  if (isLedgerView) bkPageParams.set('view', 'ledger');
  if (selectedType) bkPageParams.set('type', selectedType);
  if (selectedSearch) bkPageParams.set('search', selectedSearch);
  const bkPageUrl = (pageNo) => {
    const params = new URLSearchParams(bkPageParams);
    params.set('page', String(pageNo));
    return `/admin/bookkeeping?${params.toString()}`;
  };
  const bkDetailUrl = (section, bucket) => {
    const params = new URLSearchParams();
    params.set('month', String(selectedMonth));
    params.set('year', String(selectedYear));
    params.set('detail_section', String(section || ''));
    params.set('detail_bucket', String(bucket || ''));
    return `/admin/bookkeeping?${params.toString()}#bk-category-detail`;
  };
  const bkViewUrl = (nextView) => {
    const params = new URLSearchParams();
    params.set('month', String(selectedMonth));
    params.set('year', String(selectedYear));
    if (nextView && nextView !== 'summary') params.set('view', String(nextView));
    return `/admin/bookkeeping?${params.toString()}`;
  };
  const bkBaseUrl = () => `/admin/bookkeeping?month=${selectedMonth}&year=${selectedYear}`;
  const bkCashHolderUrl = (item) => {
    const params = new URLSearchParams();
    params.set('month', String(selectedMonth));
    params.set('year', String(selectedYear));
    params.set('detail_section', 'admin');
    params.set('detail_bucket', 'cash');
    params.set('cash_holder', `${item.role}:${item.entityId == null ? 'null' : item.entityId}`);
    return `/admin/bookkeeping?${params.toString()}#bk-category-detail`;
  };
  const incomeCards = [
    { label: 'Transaksi Cash', amount: Number(incomeBreakdown.cash?.amount || 0), count: Number(incomeBreakdown.cash?.count || 0), icon: 'bi-cash-stack', tone: 'cash', bucket: 'cash' },
    { label: 'Transaksi Online', amount: Number(incomeBreakdown.online?.amount || 0), count: Number(incomeBreakdown.online?.count || 0), icon: 'bi-qr-code-scan', tone: 'online', bucket: 'online' },
    { label: 'Transfer / Bank', amount: Number(incomeBreakdown.transfer?.amount || 0), count: Number(incomeBreakdown.transfer?.count || 0), icon: 'bi-bank2', tone: 'bank', bucket: 'transfer' },
    { label: 'Pemasukan Lain', amount: Number(incomeBreakdown.other?.amount || 0), count: Number(incomeBreakdown.other?.count || 0), icon: 'bi-piggy-bank', tone: 'other', bucket: 'other' },
    { label: 'Mitra Bayar Bulan Ini', amount: Number(incomeBreakdown.partner?.amount || 0), count: Number(incomeBreakdown.partner?.count || 0), icon: 'bi-people-fill', tone: 'partner', bucket: 'partner' }
  ];
  const expenseCards = [
    { ...(expenseBreakdown.salary || { label: 'Gaji Karyawan', amount: 0, count: 0 }), bucket: 'salary', icon: 'bi-person-vcard' },
    { ...(expenseBreakdown.installation || { label: 'Pasang Baru', amount: 0, count: 0 }), bucket: 'installation', icon: 'bi-hammer' },
    { ...(expenseBreakdown.repair_tools || { label: 'Perbaikan Alat', amount: 0, count: 0 }), bucket: 'repair_tools', icon: 'bi-tools' },
    { ...(expenseBreakdown.bandwidth || { label: 'Bayar Bandwidth', amount: 0, count: 0 }), bucket: 'bandwidth', icon: 'bi-router' },
    { ...(expenseBreakdown.collection || { label: 'Bayar Kang Tagih', amount: 0, count: 0 }), bucket: 'collection', icon: 'bi-person-check' },
    { ...(expenseBreakdown.utilities || { label: 'Listrik / PDAM / Pulsa', amount: 0, count: 0 }), bucket: 'utilities', icon: 'bi-lightning-charge' },
    { ...(expenseBreakdown.marketing || { label: 'Bayar Marketing', amount: 0, count: 0 }), bucket: 'marketing', icon: 'bi-megaphone' },
    { ...(expenseBreakdown.other || { label: 'Lain Lain', amount: 0, count: 0 }), bucket: 'other', icon: 'bi-grid' }
  ];
  const detailRows = Array.isArray(selectedCategoryDetail?.rows) ? selectedCategoryDetail.rows : [];
  const filterMeta = isLedgerView
    ? `${totalEntryCount} entri, halaman ${bkCurrentPage}/${bkTotalPages}`
    : `${monthLabel} ${selectedYear}`;
%>
<!DOCTYPE html>
<html lang="<%= pageLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .bk-shell {
      display: grid;
      gap: 16px;
    }
    .bk-card,
    .bk-list-card,
    .bk-toggle {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow-soft);
      overflow: hidden;
    }
    .bk-filter-card {
      padding: 16px 18px;
      display: grid;
      gap: 14px;
      background:
        linear-gradient(135deg, rgba(124, 116, 255, 0.08), rgba(92, 141, 255, 0.04)),
        var(--surface);
    }
    .bk-filter-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .bk-filter-copy strong {
      display: block;
      font-size: 17px;
      color: var(--text);
      margin-bottom: 4px;
    }
    .bk-filter-copy span {
      font-size: 12px;
      color: var(--muted);
    }
    .bk-filter-form {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      flex-wrap: nowrap;
    }
    .bk-filter-search-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 0 1 320px;
      max-width: 320px;
      width: 100%;
      min-width: 0;
    }
    .bk-filter-search-row .fs {
      flex: 1 1 auto;
      min-width: 0;
    }
    .bk-filter-toggle {
      display: none;
      position: relative;
      flex: 0 0 46px;
      min-width: 46px;
      height: 46px;
      padding: 0;
      justify-content: center;
    }
    .bk-filter-panel {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1 1 auto;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: none;
    }
    .bk-filter-panel::-webkit-scrollbar {
      display: none;
    }
    .bk-filter-main-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1 1 auto;
      min-width: 0;
      flex-wrap: nowrap;
    }
    .bk-filter-main-row .fs {
      min-width: 0;
      white-space: nowrap;
    }
    .bk-filter-main-row .bk-search-desktop {
      min-width: 220px;
      flex: 1 1 220px;
    }
    .bk-filter-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 0 0 auto;
    }
    .bk-filter-actions .btn {
      min-width: 120px;
    }
    .bk-period-pill {
      min-height: 46px;
      width: 100%;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 0 14px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      color: var(--text);
      font-size: 13px;
      font-weight: 900;
      white-space: nowrap;
    }
    .bk-mode-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    }
    .bk-mode-head > div {
      min-width: 0;
      display: grid;
      gap: 5px;
    }
    .bk-mode-head strong {
      color: var(--text);
      font-size: 18px;
      line-height: 1.2;
    }
    .bk-mode-head span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }
    .bk-total-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    .bk-total-card {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 18px;
      padding: 14px;
      background: var(--surface);
      box-shadow: var(--shadow-soft);
      min-width: 0;
    }
    .bk-total-card span {
      display: block;
      color: var(--muted);
      font-size: 11px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 7px;
    }
    .bk-total-card strong {
      display: block;
      color: var(--text);
      font-size: 22px;
      line-height: 1.15;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bk-total-card.income strong { color: #22c55e; }
    .bk-total-card.expense strong { color: #fb7185; }
    .bk-total-card.net strong { color: var(--primary); }
    .bk-summary-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 16px;
    }
    .bk-summary-panel-head {
      padding: 18px 18px 14px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }
    .bk-summary-panel-head strong {
      display: block;
      font-size: 13px;
      color: var(--muted);
      letter-spacing: .05em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .bk-summary-panel-head h3 {
      margin: 0;
      font-size: 29px;
      color: var(--text);
      line-height: 1.1;
    }
    .bk-summary-panel-head span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }
    .bk-summary-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 11px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      font-size: 11px;
      font-weight: 800;
      color: var(--text);
      white-space: nowrap;
      text-decoration: none;
    }
    .bk-summary-panel-body {
      padding: 16px 18px 18px;
    }
    .bk-breakdown-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .bk-breakdown-item {
      display: block;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 18px;
      padding: 12px 13px;
      background: var(--surface-soft);
      min-width: 0;
      color: inherit;
      text-decoration: none;
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }
    .bk-breakdown-item:hover {
      transform: translateY(-1px);
      border-color: rgba(124, 116, 255, 0.35);
      background: rgba(124, 116, 255, 0.08);
    }
    .bk-breakdown-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
    }
    .bk-breakdown-top i {
      font-size: 14px;
      color: var(--primary);
    }
    .bk-breakdown-item.tone-cash .bk-breakdown-top i { color: #22c55e; }
    .bk-breakdown-item.tone-online .bk-breakdown-top i { color: #7c74ff; }
    .bk-breakdown-item.tone-other .bk-breakdown-top i { color: #f59e0b; }
    .bk-breakdown-item.tone-partner .bk-breakdown-top i { color: #38bdf8; }
    .bk-breakdown-amount {
      font-size: 17px;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
    }
    .bk-breakdown-meta {
      margin-top: 5px;
      font-size: 11px;
      color: var(--muted);
    }
    .bk-click-hint {
      display: none;
      align-items: center;
      gap: 5px;
      margin-top: 8px;
      font-size: 11px;
      font-weight: 800;
      color: var(--primary);
    }
    .bk-finance-menu {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 10px;
    }
    .bk-finance-menu-item {
      display: grid;
      justify-items: center;
      gap: 8px;
      padding: 14px 10px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      color: var(--text);
      text-decoration: none;
      text-align: center;
      font-size: 12px;
      font-weight: 800;
      min-width: 0;
    }
    .bk-finance-menu-item i {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border-radius: 16px;
      background: rgba(124, 116, 255, 0.12);
      color: var(--primary);
      font-size: 22px;
    }
    .bk-finance-menu-item:hover {
      border-color: rgba(124, 116, 255, 0.35);
      background: rgba(124, 116, 255, 0.08);
    }
    .bk-detail-card {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      padding: 13px 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    }
    .bk-detail-card:last-child {
      border-bottom: 0;
    }
    .bk-detail-copy {
      display: grid;
      gap: 5px;
      min-width: 0;
    }
    .bk-detail-copy strong {
      color: var(--text);
      font-size: 13px;
      line-height: 1.35;
    }
    .bk-detail-copy span {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.45;
    }
    .bk-detail-amount {
      flex: 0 0 auto;
      font-size: 13px;
      font-weight: 900;
      color: var(--text);
      text-align: right;
      white-space: nowrap;
    }
    .bk-detail-amount.income {
      color: #22c55e;
    }
    .bk-detail-amount.expense {
      color: #fb7185;
    }
    .bk-detail-focus {
      overflow: hidden;
    }
    .bk-detail-focus-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: start;
      padding: 18px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
      background:
        linear-gradient(135deg, rgba(124, 116, 255, 0.10), rgba(20, 184, 166, 0.06)),
        var(--surface);
    }
    .bk-detail-focus-title {
      display: grid;
      gap: 7px;
      min-width: 0;
    }
    .bk-detail-focus-title strong {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
      font-size: 18px;
      line-height: 1.25;
    }
    .bk-detail-focus-title h3 {
      margin: 0;
      font-size: 28px;
      line-height: 1;
      color: var(--text);
      letter-spacing: -0.02em;
    }
    .bk-detail-focus-title span {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .bk-detail-focus-body {
      padding: 16px 18px 18px;
      display: grid;
      gap: 12px;
    }
    .bk-detail-focus-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    .bk-detail-focus-stat {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 16px;
      padding: 11px 12px;
      background: var(--surface-soft);
      min-width: 0;
    }
    .bk-detail-focus-stat span {
      display: block;
      font-size: 10px;
      color: var(--muted);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 5px;
    }
    .bk-detail-focus-stat strong {
      display: block;
      color: var(--text);
      font-size: 15px;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bk-detail-focus-list {
      display: grid;
      gap: 9px;
    }
    .bk-detail-focus-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: start;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 16px;
      background: var(--surface-soft);
    }
    .bk-detail-focus-main {
      display: grid;
      gap: 5px;
      min-width: 0;
    }
    .bk-detail-focus-main strong {
      color: var(--text);
      font-size: 14px;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }
    .bk-detail-focus-main span {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }
    .bk-detail-focus-amount {
      font-size: 14px;
      font-weight: 950;
      text-align: right;
      white-space: nowrap;
      color: var(--text);
    }
    .bk-detail-focus-amount.income { color: #22c55e; }
    .bk-detail-focus-amount.expense { color: #fb7185; }
    .bk-detail-focus-side {
      display: grid;
      justify-items: end;
      gap: 8px;
    }
    .bk-profit-stack {
      display: grid;
      gap: 12px;
    }
    .bk-comparison-card {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 18px;
      padding: 14px;
      background: var(--surface-soft);
    }
    .bk-comparison-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
      font-size: 12px;
      color: var(--muted);
    }
    .bk-comparison-row strong {
      color: var(--text);
      font-size: 15px;
    }
    .bk-progress {
      width: 100%;
      height: 8px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(148, 163, 184, 0.18);
    }
    .bk-progress > span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--primary), var(--primary-2));
    }
