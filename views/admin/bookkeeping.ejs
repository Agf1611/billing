<%
  const pageLang = (typeof lang !== 'undefined' && lang) ? lang : 'id';
  const pageSession = (typeof session !== 'undefined' && session) ? session : {};
  const pageMsg = (typeof msg !== 'undefined' && msg) ? msg : null;
  const pageEntries = Array.isArray(entries) ? entries : [];
  const now = new Date();
  const selectedMonth = Number(filterMonth || (now.getMonth() + 1));
  const selectedYear = Number(filterYear || now.getFullYear());
  const selectedType = String(type || '').trim();
  const selectedSearch = String(search || '').trim();
  const monthNames = (pageLang === 'en')
    ? ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
    : ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
  const monthLabel = monthNames[Math.max(0, Math.min(11, selectedMonth - 1))] || monthNames[now.getMonth()];
  const totalIncome = Number(summary?.total_income || 0);
  const totalExpense = Number(summary?.total_expense || 0);
  const balance = totalIncome - totalExpense;
  const incomeCount = Number(summary?.income_count || 0);
  const expenseCount = Number(summary?.expense_count || 0);
  const dashboardData = dashboard || {};
  const incomeBreakdown = dashboardData.income || {};
  const expenseBreakdown = dashboardData.expense || {};
  const comparison = dashboardData.comparison || {};
  const actorBreakdown = Array.isArray(dashboardData.actors) ? dashboardData.actors : [];
  const recentPayments = Array.isArray(dashboardData.recentPayments) ? dashboardData.recentPayments : [];
  const approvalBreakdown = Array.isArray(dashboardData.approvals) ? dashboardData.approvals : [];
  const incomeCards = [
    { label: 'Pembayaran Tunai', amount: Number(incomeBreakdown.cash?.amount || 0), count: Number(incomeBreakdown.cash?.count || 0), icon: 'bi-cash-stack', tone: 'cash' },
    { label: 'Pembayaran Online', amount: Number(incomeBreakdown.online?.amount || 0), count: Number(incomeBreakdown.online?.count || 0), icon: 'bi-qr-code-scan', tone: 'online' },
    { label: 'Pemasukan Lain', amount: Number(incomeBreakdown.other?.amount || 0), count: Number(incomeBreakdown.other?.count || 0), icon: 'bi-piggy-bank', tone: 'other' },
    { label: 'Pendapatan Mitra', amount: Number(incomeBreakdown.partner?.amount || 0), count: Number(incomeBreakdown.partner?.count || 0), icon: 'bi-people-fill', tone: 'partner' }
  ];
  const expenseCards = [
    expenseBreakdown.salary || { label: 'Gaji Karyawan', amount: 0, count: 0 },
    expenseBreakdown.installation || { label: 'Pasang Baru', amount: 0, count: 0 },
    expenseBreakdown.repair_tools || { label: 'Perbaikan / Alat', amount: 0, count: 0 },
    expenseBreakdown.bandwidth || { label: 'Bayar Bandwidth', amount: 0, count: 0 }
  ];
%>
<!DOCTYPE html>
<html lang="<%= pageLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .bk-shell {
      display: grid;
      gap: 16px;
    }
    .bk-card,
    .bk-list-card,
    .bk-toggle {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow-soft);
      overflow: hidden;
    }
    .bk-filter-card {
      padding: 16px 18px;
      display: grid;
      gap: 14px;
      background:
        linear-gradient(135deg, rgba(124, 116, 255, 0.08), rgba(92, 141, 255, 0.04)),
        var(--surface);
    }
    .bk-filter-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .bk-filter-copy strong {
      display: block;
      font-size: 17px;
      color: var(--text);
      margin-bottom: 4px;
    }
    .bk-filter-copy span {
      font-size: 12px;
      color: var(--muted);
    }
    .bk-filter-form {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      flex-wrap: nowrap;
    }
    .bk-filter-search-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 0 1 320px;
      max-width: 320px;
      width: 100%;
      min-width: 0;
    }
    .bk-filter-search-row .fs {
      flex: 1 1 auto;
      min-width: 0;
    }
    .bk-filter-toggle {
      display: none;
      position: relative;
      flex: 0 0 46px;
      min-width: 46px;
      height: 46px;
      padding: 0;
      justify-content: center;
    }
    .bk-filter-panel {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1 1 auto;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: none;
    }
    .bk-filter-panel::-webkit-scrollbar {
      display: none;
    }
    .bk-filter-main-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1 1 auto;
      min-width: 0;
      flex-wrap: nowrap;
    }
    .bk-filter-main-row .fs {
      min-width: 0;
      white-space: nowrap;
    }
    .bk-filter-main-row .bk-search-desktop {
      min-width: 220px;
      flex: 1 1 220px;
    }
    .bk-filter-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 0 0 auto;
    }
    .bk-filter-actions .btn {
      min-width: 120px;
    }
    .bk-summary-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 16px;
    }
    .bk-summary-panel-head {
      padding: 18px 18px 14px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }
    .bk-summary-panel-head strong {
      display: block;
      font-size: 13px;
      color: var(--muted);
      letter-spacing: .05em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .bk-summary-panel-head h3 {
      margin: 0;
      font-size: 29px;
      color: var(--text);
      line-height: 1.1;
    }
    .bk-summary-panel-head span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }
    .bk-summary-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 11px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      font-size: 11px;
      font-weight: 800;
      color: var(--text);
      white-space: nowrap;
    }
    .bk-summary-panel-body {
      padding: 16px 18px 18px;
    }
    .bk-breakdown-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .bk-breakdown-item {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 18px;
      padding: 12px 13px;
      background: var(--surface-soft);
      min-width: 0;
    }
    .bk-breakdown-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
    }
    .bk-breakdown-top i {
      font-size: 14px;
      color: var(--primary);
    }
    .bk-breakdown-item.tone-cash .bk-breakdown-top i { color: #22c55e; }
    .bk-breakdown-item.tone-online .bk-breakdown-top i { color: #7c74ff; }
    .bk-breakdown-item.tone-other .bk-breakdown-top i { color: #f59e0b; }
    .bk-breakdown-item.tone-partner .bk-breakdown-top i { color: #38bdf8; }
    .bk-breakdown-amount {
      font-size: 17px;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
    }
    .bk-breakdown-meta {
      margin-top: 5px;
      font-size: 11px;
      color: var(--muted);
    }
    .bk-profit-stack {
      display: grid;
      gap: 12px;
    }
    .bk-comparison-card {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 18px;
      padding: 14px;
      background: var(--surface-soft);
    }
    .bk-comparison-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
      font-size: 12px;
      color: var(--muted);
    }
    .bk-comparison-row strong {
      color: var(--text);
      font-size: 15px;
    }
    .bk-progress {
      width: 100%;
      height: 8px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(148, 163, 184, 0.18);
    }
    .bk-progress > span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--primary), var(--primary-2));
    }
    .bk-toggle > summary {
      list-style: none;
      cursor: pointer;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-weight: 800;
      color: var(--text);
    }
    .bk-toggle > summary::-webkit-details-marker {
      display: none;
    }
    .bk-toggle-copy {
      display: grid;
      gap: 4px;
    }
    .bk-toggle-copy span {
      font-size: 12px;
      color: var(--muted);
      font-weight: 600;
    }
    .bk-toggle-body {
      padding: 0 18px 18px;
      display: grid;
      gap: 14px;
    }
    .bk-subtitle {
      display: grid;
      gap: 4px;
      margin-bottom: 10px;
    }
    .bk-subtitle strong {
      font-size: 15px;
      color: var(--text);
    }
    .bk-subtitle span {
      font-size: 12px;
      color: var(--muted);
    }
    .bk-actor-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .bk-actor-card {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 18px;
      padding: 13px 14px;
      background: var(--surface-soft);
    }
    .bk-actor-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }
    .bk-actor-title strong {
      font-size: 13px;
      color: var(--text);
    }
    .bk-actor-role {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--primary);
    }
    .bk-actor-meta {
      display: grid;
      gap: 4px;
      font-size: 11px;
      color: var(--muted);
    }
    .bk-actor-meta b {
      color: var(--text);
    }
    .bk-inline-list {
      display: grid;
      gap: 10px;
    }
    .bk-inline-item {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 16px;
      background: var(--surface-soft);
      border: 1px solid rgba(148, 163, 184, 0.14);
    }
    .bk-inline-item strong {
      display: block;
      font-size: 13px;
      color: var(--text);
      margin-bottom: 4px;
    }
    .bk-inline-item span {
      display: block;
      font-size: 11px;
      color: var(--muted);
      line-height: 1.45;
    }
    .bk-inline-amount {
      white-space: nowrap;
      font-size: 14px;
      font-weight: 800;
      color: var(--text);
      text-align: right;
    }
    .bk-list-card .card-hd,
    .bk-list-card .card-bd {
      padding: 16px 18px;
    }
    .bk-list-card .card-hd {
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    }
    .bk-list-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .bk-chip-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .bk-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 11px;
      border-radius: 999px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
    }
    .bk-chip i { color: var(--primary); }
    .bk-chip strong { color: var(--text); }
    .bk-type {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 11px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }
    .bk-type.income {
      background: rgba(34, 197, 94, 0.14);
      color: #22c55e;
    }
    .bk-type.expense {
      background: rgba(251, 113, 133, 0.14);
      color: #fb7185;
    }
    .bk-source {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 999px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }
    .bk-source.invoice {
      color: var(--primary);
      border-color: rgba(124, 116, 255, 0.18);
      background: rgba(124, 116, 255, 0.08);
    }
    .bk-entry-copy {
      display: grid;
      gap: 4px;
      min-width: 0;
    }
    .bk-entry-main {
      color: var(--text);
      font-weight: 700;
      line-height: 1.45;
    }
    .bk-entry-sub {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.4;
    }
    .bk-amount {
      text-align: right;
      font-weight: 800;
      color: var(--text);
      white-space: nowrap;
    }
    .bk-amount.income { color: #22c55e; }
    .bk-amount.expense { color: #fb7185; }
    .bk-empty {
      padding: 26px 18px;
      border: 1px dashed var(--border);
      border-radius: 18px;
      background: var(--surface-soft);
      text-align: center;
    }
    .bk-empty i {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      margin-bottom: 12px;
      border-radius: 18px;
      background: var(--surface-soft);
      color: var(--primary);
      font-size: 20px;
    }
    .bk-empty strong {
      display: block;
      font-size: 15px;
      color: var(--text);
      margin-bottom: 5px;
    }
    .bk-empty span {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.55;
    }
    .bk-mobile-list {
      display: none;
    }
    .bk-mobile-card {
      border: 1px solid var(--border);
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 30%),
        var(--surface-soft);
      padding: 14px 15px;
      box-shadow: var(--shadow-soft);
      position: relative;
      overflow: hidden;
    }
    .bk-mobile-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 4px;
      border-radius: 18px 0 0 18px;
      background: linear-gradient(180deg, var(--primary), var(--primary-2));
    }
    .bk-mobile-card.income::before {
      background: linear-gradient(180deg, #22c55e, #34d399);
    }
    .bk-mobile-card.expense::before {
      background: linear-gradient(180deg, #fb7185, #ff9db0);
    }
    .bk-mobile-card + .bk-mobile-card {
      margin-top: 10px;
    }
    .bk-mobile-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }
    .bk-mobile-top {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .bk-mobile-top .bk-date {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }
    .bk-mobile-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      margin-top: 12px;
    }
    .bk-mobile-cell {
      padding: 10px 12px;
      border-radius: 14px;
      background: var(--surface-soft);
    }
    .bk-mobile-label {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .bk-mobile-value {
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.45;
    }
    .bk-mobile-actions {
      display: flex;
      justify-content: flex-end;
      margin-top: 12px;
    }
    body[data-theme="light"] .bk-card,
    body[data-theme="light"] .bk-list-card,
    body[data-theme="light"] .bk-toggle,
    body[data-theme="light"] .bk-mobile-card,
    body[data-theme="light"] .bk-empty {
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 16px 36px rgba(165, 162, 211, 0.12);
    }
    body[data-theme="light"] .bk-filter-card {
      background:
        linear-gradient(135deg, rgba(105, 88, 255, 0.08), rgba(92, 141, 255, 0.06)),
        rgba(255, 255, 255, 0.9);
    }
    @media (max-width: 1100px) {
      .bk-summary-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 900px) {
      .bk-filter-form {
        flex-wrap: wrap;
      }
      .bk-filter-search-row,
      .bk-filter-panel {
        max-width: none;
        flex: 1 1 100%;
      }
      .bk-actor-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 768px) {
      .bk-filter-card {
        padding: 14px;
      }
      .bk-filter-top {
        align-items: stretch;
      }
      .bk-filter-top .btn {
        width: 100%;
        justify-content: center;
      }
      .bk-filter-form {
        display: block;
      }
      .bk-filter-search-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 46px;
        gap: 8px;
        max-width: none;
        margin-top: 8px;
      }
      .bk-filter-search-row .bk-search-desktop {
        display: none;
      }
      .bk-filter-search-row .bk-search-mobile {
        display: block;
      }
      .bk-filter-toggle {
        display: inline-flex;
      }
      .bk-filter-panel {
        display: none;
        width: 100%;
        margin-top: 10px;
        padding: 10px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(255,255,255,.03);
        overflow: visible;
      }
      .bk-filter-panel.show {
        display: grid;
        grid-template-columns: 1fr;
      }
      .bk-filter-main-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
      }
      .bk-filter-main-row .bk-search-mobile {
        display: none;
      }
      .bk-filter-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 8px;
      }
      .bk-filter-actions .btn {
        width: 100%;
        min-width: 0;
      }
      .bk-summary-panel-head,
      .bk-summary-panel-body,
      .bk-toggle > summary,
      .bk-toggle-body,
      .bk-list-card .card-hd,
      .bk-list-card .card-bd {
        padding-left: 14px;
        padding-right: 14px;
      }
      .bk-summary-panel-head {
        flex-direction: column;
        align-items: flex-start;
      }
      .tbl-wrap {
        display: none;
      }
      .bk-mobile-list {
        display: block;
      }
      .bk-list-head {
        align-items: flex-start;
      }
    }
    @media (max-width: 576px) {
      .bk-filter-panel {
        padding: 8px;
      }
      .bk-filter-main-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .bk-filter-main-row .fs {
        min-height: 42px;
        font-size: 11px;
        padding-left: 10px;
        padding-right: 28px;
      }
      .bk-breakdown-grid {
        gap: 8px;
      }
      .bk-breakdown-item {
        padding: 10px 11px;
      }
      .bk-breakdown-top {
        font-size: 11px;
        gap: 6px;
      }
      .bk-breakdown-amount {
        font-size: 15px;
      }
      .bk-breakdown-meta {
        font-size: 10px;
      }
      .bk-mobile-grid {
        grid-template-columns: 1fr;
      }
      .bk-mobile-head,
      .bk-inline-item {
        flex-direction: column;
      }
      .bk-amount,
      .bk-inline-amount {
        text-align: left;
      }
    }
    @media (min-width: 769px) {
      .bk-filter-search-row .bk-search-mobile {
        display: none;
      }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'bookkeeping', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-cash-coin"></i>
      <span>Pembukuan</span>
    </div>
    <div class="tb-right">
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= pageSession.isCashier ? 'Kasir' : 'Admin' %></span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>

<div class="page admin-shell-page">
    <% if (pageMsg && pageMsg.text) { %>
      <div class="alert alert-<%= pageMsg.type === 'error' ? 'd' : 's' %>" style="margin-bottom:16px"><%= pageMsg.text %></div>
    <% } %>

    <div class="bk-shell">
      <section class="bk-card bk-filter-card">
        <div class="bk-filter-top">
          <div class="bk-filter-copy">
            <strong>Periode Pembukuan</strong>
            <span><%= monthLabel %> <%= selectedYear %> - <%= pageEntries.length %> entri tampil</span>
          </div>
          <% if (!pageSession.isCashier) { %>
          <a href="/admin/bookkeeping/new?month=<%= selectedMonth %>&year=<%= selectedYear %>" class="btn btn-g btn-sm">
            <i class="bi bi-plus-circle"></i> Tambah Pembukuan
          </a>
          <% } %>
        </div>
        <form method="GET" action="/admin/bookkeeping" class="bk-filter-form" id="bkFilterForm">
          <div class="bk-filter-search-row">
            <input class="fs" type="text" name="search" value="<%= selectedSearch %>" placeholder="Cari kategori / keterangan" aria-label="Cari kategori / keterangan">
            <button class="btn btn-g btn-sm bk-filter-toggle" type="button" onclick="toggleBookkeepingFilterPanel()" aria-label="Filter pembukuan">
              <i class="bi bi-funnel"></i>
            </button>
          </div>
          <div class="bk-filter-panel" id="bkFilterPanel">
            <div class="bk-filter-main-row">
              <select class="fs" name="month" aria-label="Bulan">
                <% for (let m = 1; m <= 12; m++) { %>
                  <option value="<%= m %>" <%= selectedMonth === m ? 'selected' : '' %>><%= monthNames[m - 1] %></option>
                <% } %>
              </select>
              <input class="fs" type="number" name="year" value="<%= selectedYear %>" placeholder="Tahun" aria-label="Tahun">
              <select class="fs" name="type" aria-label="Jenis transaksi">
                <option value="" <%= !selectedType ? 'selected' : '' %>>Semua jenis</option>
                <option value="income" <%= selectedType === 'income' ? 'selected' : '' %>>Pemasukan</option>
                <option value="expense" <%= selectedType === 'expense' ? 'selected' : '' %>>Pengeluaran</option>
              </select>
            </div>
            <div class="bk-filter-actions">
              <button class="btn btn-p btn-sm" type="submit"><i class="bi bi-funnel"></i> Tampilkan</button>
              <a href="/admin/bookkeeping?month=<%= now.getMonth() + 1 %>&year=<%= now.getFullYear() %>" class="btn btn-g btn-sm"><i class="bi bi-x"></i> Reset</a>
            </div>
          </div>
        </form>
      </section>

      <div class="bk-summary-grid">
        <section class="bk-card">
          <div class="bk-summary-panel-head">
            <div>
              <strong>Pemasukan Total</strong>
              <h3>Rp <%= totalIncome.toLocaleString('id-ID') %></h3>
              <span><%= incomeCount %> transaksi masuk pada <%= monthLabel %> <%= selectedYear %></span>
            </div>
            <span class="bk-summary-badge"><i class="bi bi-arrow-down-left-circle"></i> Pemasukan</span>
          </div>
          <div class="bk-summary-panel-body">
            <div class="bk-breakdown-grid">
              <% incomeCards.forEach((item) => { %>
                <div class="bk-breakdown-item tone-<%= item.tone %>">
                  <div class="bk-breakdown-top"><i class="bi <%= item.icon %>"></i><span><%= item.label %></span></div>
                  <div class="bk-breakdown-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                  <div class="bk-breakdown-meta"><%= Number(item.count || 0) %> transaksi</div>
                </div>
              <% }) %>
            </div>
          </div>
        </section>

        <section class="bk-card">
          <div class="bk-summary-panel-head">
            <div>
              <strong>Rekap Ringkas</strong>
              <h3>Rp <%= Number(comparison.netAmount || balance).toLocaleString('id-ID') %></h3>
              <span><%= Number(comparison.netAmount || balance) >= 0 ? 'Selisih bersih periode ini' : 'Selisih minus periode ini' %></span>
            </div>
            <span class="bk-summary-badge"><i class="bi bi-wallet2"></i> Laba Rugi</span>
          </div>
          <div class="bk-summary-panel-body">
            <div class="bk-profit-stack">
              <div class="bk-comparison-card">
                <div class="bk-comparison-row"><span>Total Pemasukan</span><strong>Rp <%= Number(comparison.incomeAmount || totalIncome).toLocaleString('id-ID') %></strong></div>
                <div class="bk-comparison-row"><span>Total Pengeluaran</span><strong>Rp <%= Number(comparison.expenseAmount || totalExpense).toLocaleString('id-ID') %></strong></div>
                <div class="bk-comparison-row" style="margin-bottom:0"><span>Total Bersih</span><strong>Rp <%= Number(comparison.netAmount || balance).toLocaleString('id-ID') %></strong></div>
              </div>
              <div class="bk-comparison-card">
                <div class="bk-comparison-row"><span>Persentase pengeluaran</span><strong><%= Number(comparison.expenseVsIncomePercent || 0) %>%</strong></div>
                <div class="bk-progress"><span style="width:<%= Math.min(100, Number(comparison.expenseVsIncomePercent || 0)) %>%"></span></div>
              </div>
              <div class="bk-breakdown-grid">
                <% expenseCards.forEach((item, idx) => { %>
                  <div class="bk-breakdown-item">
                    <div class="bk-breakdown-top"><i class="bi <%= idx % 2 === 0 ? 'bi-receipt-cutoff' : 'bi-tools' %>"></i><span><%= item.label %></span></div>
                    <div class="bk-breakdown-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                    <div class="bk-breakdown-meta"><%= Number(item.count || 0) %> transaksi</div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </section>
      </div>

      <details class="bk-toggle">
        <summary>
          <div class="bk-toggle-copy">
            <strong>Info Petugas & Approval Pembayaran</strong>
            <span>Lihat ringkasan pembayaran per petugas dan approval lapangan.</span>
          </div>
          <span class="bk-summary-badge"><i class="bi bi-chevron-down"></i> Buka</span>
        </summary>
        <div class="bk-toggle-body">
          <section>
            <div class="bk-subtitle">
              <strong>Ringkasan Pembayaran per Petugas</strong>
              <span>Diambil dari tagihan yang sudah lunas pada periode terpilih.</span>
            </div>
            <% if (!actorBreakdown.length) { %>
              <div class="bk-empty" style="padding:18px 14px">
                <strong>Belum ada data petugas</strong>
                <span>Pembayaran yang sudah diproses admin, kasir, kolektor, atau teknisi akan muncul di sini.</span>
              </div>
            <% } else { %>
              <div class="bk-actor-grid">
                <% actorBreakdown.forEach((actor) => { %>
                  <div class="bk-actor-card">
                    <div class="bk-actor-title">
                      <strong><%= actor.label %></strong>
                      <span class="bk-actor-role"><%= actor.role %></span>
                    </div>
                    <div class="bk-actor-meta">
                      <div>Total masuk: <b>Rp <%= Number(actor.amount || 0).toLocaleString('id-ID') %></b></div>
                      <div>Cash: <b>Rp <%= Number(actor.cashAmount || 0).toLocaleString('id-ID') %></b> - Online: <b>Rp <%= Number(actor.onlineAmount || 0).toLocaleString('id-ID') %></b></div>
                      <div><b><%= Number(actor.count || 0) %></b> transaksi - terakhir <%= actor.lastPaidAt || '-' %></div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>

          <section>
            <div class="bk-subtitle">
              <strong>Daftar Pembayaran Terbaru</strong>
              <span>Menampilkan pembayaran lunas per bulan dan siapa yang memprosesnya.</span>
            </div>
            <% if (!recentPayments.length) { %>
              <div class="bk-empty" style="padding:18px 14px">
                <strong>Belum ada pembayaran terbaru</strong>
                <span>Daftar pembayaran lunas akan muncul otomatis di sini.</span>
              </div>
            <% } else { %>
              <div class="bk-inline-list">
                <% recentPayments.forEach((item) => { %>
                  <div class="bk-inline-item">
                    <div>
                      <strong><%= item.customerName %> - <%= monthNames[Math.max(0, Math.min(11, (item.periodMonth || 1) - 1))] %> <%= item.periodYear %></strong>
                      <span>Dilunaskan oleh <b><%= item.actorLabel %></b> - Kanal <b><%= item.gateway %></b></span>
                      <span>Waktu: <%= item.paidAt || '-' %></span>
                    </div>
                    <div class="bk-inline-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>

          <section>
            <div class="bk-subtitle">
              <strong>Approval Pembayaran Kolektor</strong>
              <span>Ringkasan pembayaran lapangan yang di-OK-kan admin atau kasir.</span>
            </div>
            <% if (!approvalBreakdown.length) { %>
              <div class="bk-empty" style="padding:18px 14px">
                <strong>Belum ada approval periode ini</strong>
                <span>Saat ada approval pembayaran kolektor, rangkumannya akan tampil di sini.</span>
              </div>
            <% } else { %>
              <div class="bk-inline-list">
                <% approvalBreakdown.forEach((item) => { %>
                  <div class="bk-inline-item">
                    <div>
                      <strong><%= item.customerName %></strong>
                      <span>Kolektor: <b><%= item.collectorName %></b> - Di-OK-kan oleh <b><%= item.approvedBy %></b></span>
                      <span>Waktu approval: <%= item.decidedAt || '-' %></span>
                    </div>
                    <div class="bk-inline-amount">Rp <%= Number(item.amount || 0).toLocaleString('id-ID') %></div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>
        </div>
      </details>

      <section class="bk-list-card">
        <div class="card-hd">
          <h6><i class="bi bi-journal-text"></i> Riwayat Pembukuan</h6>
        </div>
        <div class="card-bd">
          <div class="bk-list-head">
            <div class="bk-subtitle" style="margin-bottom:0">
              <strong>Riwayat Transaksi</strong>
              <span>Semua entri untuk <%= monthLabel %> <%= selectedYear %></span>
            </div>
            <div class="bk-chip-row">
              <span class="bk-chip"><i class="bi bi-wallet2"></i> Total <strong><%= pageEntries.length %></strong> entri</span>
              <span class="bk-chip"><i class="bi bi-arrow-down-left-circle"></i> Masuk <strong><%= incomeCount %></strong></span>
              <span class="bk-chip"><i class="bi bi-arrow-up-right-circle"></i> Keluar <strong><%= expenseCount %></strong></span>
            </div>
          </div>

          <% if (!pageEntries.length) { %>
            <div class="bk-empty">
              <i class="bi bi-journal-x"></i>
              <strong>Belum ada data pembukuan</strong>
              <span>Gunakan tombol tambah untuk mencatat pemasukan atau pengeluaran baru.</span>
            </div>
          <% } else { %>
            <div class="tbl-wrap">
              <table class="dtbl">
                <thead>
                  <tr>
                    <th style="width:116px">Tanggal</th>
                    <th style="width:120px">Jenis</th>
                    <th style="width:150px">Kategori</th>
                    <th>Keterangan</th>
                    <th style="width:130px">Petugas</th>
                    <th class="num" style="width:160px">Nominal</th>
                    <th class="num" style="width:74px"></th>
                  </tr>
                </thead>
                <tbody>
                  <% pageEntries.forEach((entry) => { %>
                    <tr>
                      <td><span class="bk-entry-main"><%= entry.entry_date || '-' %></span></td>
                      <td>
                        <span class="bk-type <%= entry.type === 'income' ? 'income' : 'expense' %>">
                          <i class="bi <%= entry.type === 'income' ? 'bi-arrow-down-left' : 'bi-arrow-up-right' %>"></i>
                          <%= entry.type === 'income' ? 'Masuk' : 'Keluar' %>
                        </span>
                      </td>
                      <td>
                        <div class="bk-entry-copy">
                          <span class="bk-entry-main"><%= entry.category || '-' %></span>
                          <% if (entry.source_type) { %>
                            <span class="bk-source <%= entry.source_type === 'invoice' ? 'invoice' : '' %>"><%= entry.source_type %></span>
                          <% } %>
                        </div>
                      </td>
                      <td>
                        <div class="bk-entry-copy">
                          <span class="bk-entry-main"><%= entry.description || '-' %></span>
                          <% if (entry.customer_name) { %><span class="bk-entry-sub"><%= entry.customer_name %></span><% } %>
                        </div>
                      </td>
                      <td><span class="bk-entry-main"><%= entry.created_by_name || '-' %></span></td>
                      <td class="num bk-amount <%= entry.type === 'income' ? 'income' : 'expense' %>">Rp <%= Number(entry.amount || 0).toLocaleString('id-ID') %></td>
                      <td class="num">
                        <% if (!pageSession.isCashier && String(entry.source_type || '') !== 'invoice') { %>
                          <form method="POST" action="/admin/bookkeeping/<%= entry.id %>/delete" onsubmit="return confirm('Hapus data pembukuan ini?')">
                            <button class="btn btn-d btn-sm" type="submit"><i class="bi bi-trash"></i></button>
                          </form>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <div class="bk-mobile-list">
              <% pageEntries.forEach((entry) => { %>
                <article class="bk-mobile-card <%= entry.type === 'income' ? 'income' : 'expense' %>">
                  <div class="bk-mobile-head">
                    <div>
                      <div class="bk-mobile-top">
                        <span class="bk-type <%= entry.type === 'income' ? 'income' : 'expense' %>">
                          <i class="bi <%= entry.type === 'income' ? 'bi-arrow-down-left' : 'bi-arrow-up-right' %>"></i>
                          <%= entry.type === 'income' ? 'Masuk' : 'Keluar' %>
                        </span>
                        <span class="bk-date"><%= entry.entry_date || '-' %></span>
                      </div>
                      <div class="bk-entry-main"><%= entry.category || '-' %></div>
                      <div class="bk-entry-sub"><%= entry.description || '-' %></div>
                    </div>
                    <div class="bk-amount <%= entry.type === 'income' ? 'income' : 'expense' %>">Rp <%= Number(entry.amount || 0).toLocaleString('id-ID') %></div>
                  </div>

                  <div class="bk-mobile-grid">
                    <div class="bk-mobile-cell">
                      <div class="bk-mobile-label">Petugas</div>
                      <div class="bk-mobile-value"><%= entry.created_by_name || '-' %></div>
                    </div>
                    <div class="bk-mobile-cell">
                      <div class="bk-mobile-label">Sumber</div>
                      <div class="bk-mobile-value"><%= entry.source_type || 'manual' %></div>
                    </div>
                    <% if (entry.customer_name) { %>
                      <div class="bk-mobile-cell" style="grid-column:1 / -1">
                        <div class="bk-mobile-label">Pelanggan</div>
                        <div class="bk-mobile-value"><%= entry.customer_name %></div>
                      </div>
                    <% } %>
                  </div>

                  <% if (!pageSession.isCashier && String(entry.source_type || '') !== 'invoice') { %>
                    <div class="bk-mobile-actions">
                      <form method="POST" action="/admin/bookkeeping/<%= entry.id %>/delete" onsubmit="return confirm('Hapus data pembukuan ini?')">
                        <button class="btn btn-d btn-sm" type="submit"><i class="bi bi-trash"></i> Hapus</button>
                      </form>
                    </div>
                  <% } %>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>
    </div>
  </div>
</div>
<script>
function syncBookkeepingMobileFilterLayout() {
  const form = document.getElementById('bkFilterForm');
  const searchRow = form?.querySelector('.bk-filter-search-row');
  const panel = document.getElementById('bkFilterPanel');
  if (!form || !searchRow || !panel) return;
  if (window.innerWidth > 768) {
    panel.classList.remove('show');
  }
}

function toggleBookkeepingFilterPanel(force) {
  const panel = document.getElementById('bkFilterPanel');
  if (!panel) return;
  syncBookkeepingMobileFilterLayout();
  if (window.innerWidth > 768) return;
  if (typeof force === 'boolean') {
    panel.classList.toggle('show', force);
    return;
  }
  panel.classList.toggle('show');
}

window.addEventListener('resize', syncBookkeepingMobileFilterLayout);
document.addEventListener('DOMContentLoaded', () => {
  syncBookkeepingMobileFilterLayout();
  document.getElementById('bkFilterForm')?.addEventListener('submit', () => {
    if (window.innerWidth <= 768) toggleBookkeepingFilterPanel(false);
  });
});
</script>
</body>
</html>
