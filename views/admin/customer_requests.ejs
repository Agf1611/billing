<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | <%= company %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .req-list{display:grid;gap:14px}
    .req-card{border:1px solid var(--border);border-radius:20px;background:rgba(255,255,255,.04);padding:16px}
    .req-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:12px}
    .req-cell{padding:10px 12px;border-radius:14px;background:rgba(255,255,255,.04)}
    .req-label{font-size:11px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
    .req-value{font-size:13px;font-weight:700;color:var(--text);word-break:break-word}
    @media (max-width: 768px){.req-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'customer_requests', company }) %>
<div class="main">
  <div class="topbar">
    <div class="d-flex align-items-center gap-2">
      <button class="btn btn-g btn-sm" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <span class="title"><i class="bi bi-person-check"></i> Approval Pelanggan Teknisi</span>
    </div>
    <div class="d-flex align-items-center gap-2">
      <a href="/admin/customer-requests?status=pending" class="btn btn-g btn-sm <%= status === 'pending' ? 'btn-p' : '' %>">Pending</a>
      <a href="/admin/customer-requests?status=approved" class="btn btn-g btn-sm <%= status === 'approved' ? 'btn-p' : '' %>">Approved</a>
      <a href="/admin/customer-requests?status=rejected" class="btn btn-g btn-sm <%= status === 'rejected' ? 'btn-p' : '' %>">Rejected</a>
    </div>
  </div>

  <% if (msg) { %>
    <div class="alert alert-<%= msg.type === 'error' ? 'danger' : 'success' %> mt-3"><%= msg.text %></div>
  <% } %>

  <div class="req-list mt-3">
    <% if (!rows || rows.length === 0) { %>
      <div class="cardx p-4 text-center text-muted">Belum ada pengajuan pelanggan.</div>
    <% } %>
    <% (rows || []).forEach(row => { const payload = JSON.parse(String(row.payload_json || '{}') || '{}'); %>
      <div class="req-card">
        <div class="d-flex justify-content-between align-items-start gap-3">
          <div>
            <div class="fw-bold fs-5"><%= row.customer_name %></div>
            <div class="text-muted small">Teknisi: <%= row.technician_name %> (@<%= row.technician_username %>)</div>
          </div>
          <span class="badge <%= row.status === 'approved' ? 'text-bg-success' : (row.status === 'rejected' ? 'text-bg-danger' : 'text-bg-warning') %>"><%= String(row.status || '').toUpperCase() %></span>
        </div>

        <div class="req-grid">
          <div class="req-cell"><div class="req-label">No. HP</div><div class="req-value"><%= row.customer_phone || '-' %></div></div>
          <div class="req-cell"><div class="req-label">Paket</div><div class="req-value"><%= row.package_name || '-' %></div></div>
          <div class="req-cell"><div class="req-label">Router</div><div class="req-value"><%= row.router_name || '-' %></div></div>
          <div class="req-cell"><div class="req-label">PPPoE</div><div class="req-value"><%= row.pppoe_username || '-' %></div></div>
          <div class="req-cell"><div class="req-label">Alamat</div><div class="req-value"><%= payload.address || '-' %></div></div>
          <div class="req-cell"><div class="req-label">Status Pengajuan</div><div class="req-value"><%= payload.status || 'active' %></div></div>
        </div>

        <% if (row.review_note) { %>
          <div class="mt-3 text-muted small">Catatan: <%= row.review_note %></div>
        <% } %>

        <% if (row.status === 'pending') { %>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <form method="POST" action="/admin/customer-requests/<%= row.id %>/approve" class="d-flex gap-2 flex-wrap">
              <input class="fc" name="review_note" placeholder="Catatan approve (opsional)" style="min-width:260px">
              <button class="btn btn-s" type="submit"><i class="bi bi-check2-circle"></i> Approve</button>
            </form>
            <form method="POST" action="/admin/customer-requests/<%= row.id %>/reject" class="d-flex gap-2 flex-wrap">
              <input class="fc" name="review_note" placeholder="Alasan reject" style="min-width:260px">
              <button class="btn btn-d" type="submit"><i class="bi bi-x-circle"></i> Reject</button>
            </form>
          </div>
        <% } else if (row.status === 'approved' && row.approved_customer_name) { %>
          <div class="mt-3 small text-success">Sudah menjadi pelanggan aktif: <strong><%= row.approved_customer_name %></strong></div>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>
</body>
</html>
