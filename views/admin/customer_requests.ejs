<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .request-shell{display:grid;gap:18px}
    .request-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .request-filter-row{display:flex;gap:8px;flex-wrap:wrap}
    .request-list{display:grid;gap:14px}
    .request-card{
      background:var(--bg2);
      border:1px solid var(--border);
      border-radius:20px;
      padding:16px;
      box-shadow:var(--shadow-card);
      display:grid;
      gap:14px;
    }
    .request-head{display:flex;justify-content:space-between;align-items:flex-start;gap:14px}
    .request-title{display:grid;gap:4px}
    .request-title strong{font-size:18px;line-height:1.2;color:var(--text)}
    .request-subtitle{font-size:12px;color:var(--muted)}
    .request-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}
    .request-cell{
      padding:12px;
      border-radius:16px;
      background:var(--surface-soft);
      border:1px solid rgba(255,255,255,.05);
      min-width:0;
    }
    .request-label{
      display:block;
      margin-bottom:6px;
      font-size:10px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .request-value{
      display:block;
      color:var(--text);
      font-size:13px;
      font-weight:700;
      line-height:1.45;
      word-break:break-word;
    }
    .request-note{
      padding:12px 14px;
      border-radius:14px;
      background:rgba(255,255,255,.03);
      border:1px dashed var(--border);
      color:var(--muted);
      font-size:12px;
      line-height:1.55;
    }
    .request-actions{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }
    .request-form{
      display:grid;
      gap:8px;
      padding:12px;
      border-radius:16px;
      background:rgba(255,255,255,.025);
      border:1px solid var(--border);
    }
    .request-form .fc{width:100%}
    .request-form .btn{justify-content:center}
    .request-empty{
      padding:34px 18px;
      text-align:center;
      color:var(--muted);
      border:1px dashed var(--border);
      border-radius:20px;
      background:rgba(255,255,255,.03);
    }
    .request-approved{
      color:var(--success);
      font-size:13px;
      font-weight:700;
    }
    body[data-theme="light"] .request-card{
      background:rgba(255,255,255,.92);
      box-shadow:0 18px 40px rgba(165,162,211,.14);
    }
    body[data-theme="light"] .request-cell{
      background:rgba(105,88,255,.04);
      border-color:rgba(148,163,184,.16);
    }
    body[data-theme="light"] .request-form{
      background:rgba(255,255,255,.7);
    }
    @media (max-width: 992px){
      .request-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media (max-width: 768px){
      .request-head{flex-direction:column;align-items:flex-start}
      .request-actions{grid-template-columns:1fr}
    }
    @media (max-width: 576px){
      .request-grid{grid-template-columns:1fr}
      .request-card{padding:14px}
      .request-title strong{font-size:16px}
      .request-filter-row{width:100%}
      .request-filter-row .btn{flex:1;justify-content:center}
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'customer_requests', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-person-check"></i> Approval Pelanggan Teknisi
    </div>
    <div class="tb-right">
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>

  <div class="page">
    <% if (msg) { %>
      <div class="alert alert-<%= msg.type === 'error' ? 'd' : 's' %>">
        <i class="bi bi-<%= msg.type === 'error' ? 'exclamation-circle' : 'check-circle' %>"></i>
        <span><%= msg.text %></span>
      </div>
    <% } %>

    <div class="card">
      <div class="card-hd request-toolbar">
        <h6><i class="bi bi-list-check"></i> Daftar Pengajuan</h6>
        <div class="request-filter-row">
          <a href="/admin/customer-requests?status=pending" class="btn btn-g btn-sm <%= status === 'pending' ? 'btn-p' : '' %>">Pending</a>
          <a href="/admin/customer-requests?status=approved" class="btn btn-g btn-sm <%= status === 'approved' ? 'btn-p' : '' %>">Approved</a>
          <a href="/admin/customer-requests?status=rejected" class="btn btn-g btn-sm <%= status === 'rejected' ? 'btn-p' : '' %>">Rejected</a>
        </div>
      </div>
      <div class="card-bd request-shell">
        <div class="mini-stats">
          <div class="mini-stat">
            <span class="k">Status aktif</span>
            <strong><%= String(status || 'pending').toUpperCase() %></strong>
          </div>
          <div class="mini-stat">
            <span class="k">Total data</span>
            <strong><%= Array.isArray(rows) ? rows.length : 0 %> request</strong>
          </div>
        </div>

        <div class="request-list">
          <% if (!rows || rows.length === 0) { %>
            <div class="request-empty">Belum ada pengajuan pelanggan.</div>
          <% } %>

          <% (rows || []).forEach(row => { const payload = JSON.parse(String(row.payload_json || '{}') || '{}'); %>
            <div class="request-card">
              <div class="request-head">
                <div class="request-title">
                  <strong><%= row.customer_name %></strong>
                  <div class="request-subtitle">Teknisi: <%= row.technician_name %> (@<%= row.technician_username %>)</div>
                </div>
                <span class="badge <%= row.status === 'approved' ? 'ok' : (row.status === 'rejected' ? 'no' : 'warn') %>"><%= String(row.status || '').toUpperCase() %></span>
              </div>

              <div class="request-grid">
                <div class="request-cell"><span class="request-label">No. HP</span><span class="request-value"><%= row.customer_phone || '-' %></span></div>
                <div class="request-cell"><span class="request-label">Paket</span><span class="request-value"><%= row.package_name || '-' %></span></div>
                <div class="request-cell"><span class="request-label">Router</span><span class="request-value"><%= row.router_name || '-' %></span></div>
                <div class="request-cell"><span class="request-label">Mode Secret</span><span class="request-value"><%= payload.create_pppoe_secret ? 'Buat baru saat approve' : 'Pakai secret existing' %></span></div>
                <div class="request-cell"><span class="request-label">PPPoE</span><span class="request-value"><%= row.pppoe_username || '-' %></span></div>
                <div class="request-cell"><span class="request-label">Password PPPoE</span><span class="request-value"><%= payload.pppoe_password || '(ikut username)' %></span></div>
                <div class="request-cell"><span class="request-label">Profile Normal</span><span class="request-value"><%= payload.normal_pppoe_profile || '(ikut paket)' %></span></div>
                <div class="request-cell"><span class="request-label">Alamat</span><span class="request-value"><%= payload.address || '-' %></span></div>
                <div class="request-cell"><span class="request-label">Status Pelanggan</span><span class="request-value"><%= payload.status || 'active' %></span></div>
                <div class="request-cell"><span class="request-label">Tanggal Pasang</span><span class="request-value"><%= payload.install_date || '-' %></span></div>
              </div>

              <% if (row.review_note) { %>
                <div class="request-note">Catatan review: <strong><%= row.review_note %></strong></div>
              <% } %>

              <% if (row.status === 'pending') { %>
                <div class="request-actions">
                  <form method="POST" action="/admin/customer-requests/<%= row.id %>/approve" class="request-form">
                    <input class="fc" name="review_note" placeholder="Catatan approve (opsional)">
                    <button class="btn btn-s" type="submit"><i class="bi bi-check2-circle"></i> Approve</button>
                  </form>
                  <form method="POST" action="/admin/customer-requests/<%= row.id %>/reject" class="request-form">
                    <input class="fc" name="review_note" placeholder="Alasan reject">
                    <button class="btn btn-d" type="submit"><i class="bi bi-x-circle"></i> Reject</button>
                  </form>
                </div>
              <% } else if (row.status === 'approved' && row.approved_customer_name) { %>
                <div class="request-approved">Sudah menjadi pelanggan aktif: <strong><%= row.approved_customer_name %></strong></div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
