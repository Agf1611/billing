<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .request-shell{display:grid;gap:18px}
    .request-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .request-filter-row{display:flex;gap:8px;flex-wrap:wrap}
    .request-list{display:grid;gap:12px}
    .request-card{
      background:var(--bg2);
      border:1px solid var(--border);
      border-radius:18px;
      padding:14px;
      box-shadow:var(--shadow-card);
      display:grid;
      gap:12px;
    }
    .request-summary{
      display:grid;
      grid-template-columns:minmax(0,1fr) auto;
      gap:12px;
      align-items:start;
    }
    .request-main{display:grid;gap:6px;min-width:0}
    .request-title-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .request-title{font-size:17px;font-weight:800;line-height:1.2;color:var(--text);word-break:break-word}
    .request-type{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:5px 9px;
      border-radius:999px;
      font-size:11px;
      font-weight:700;
      background:var(--surface-soft);
      color:var(--muted);
      border:1px solid var(--border);
    }
    .request-subtitle{font-size:12px;color:var(--muted);line-height:1.45}
    .request-meta{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }
    .request-pill{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:7px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:700;
      background:var(--surface-soft);
      color:var(--text);
      border:1px solid rgba(255,255,255,.06);
      white-space:nowrap;
    }
    .request-side{
      display:flex;
      align-items:flex-start;
      gap:8px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }
    .request-icon-btn{
      width:38px;
      height:38px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:12px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      cursor:pointer;
      transition:.18s ease;
    }
    .request-icon-btn:hover{transform:translateY(-1px);border-color:var(--pri);color:var(--pri)}
    .request-modal{
      position:fixed;
      inset:0;
      z-index:80;
      display:none;
      align-items:flex-end;
      justify-content:center;
      padding:18px;
      background:rgba(9,12,20,.58);
      backdrop-filter:blur(10px);
    }
    .request-modal.is-open{display:flex}
    .request-modal-sheet{
      width:min(760px,100%);
      max-height:min(86vh,920px);
      overflow:auto;
      background:var(--bg2);
      border:1px solid var(--border);
      border-radius:24px 24px 20px 20px;
      box-shadow:0 24px 80px rgba(0,0,0,.28);
      padding:18px;
      display:grid;
      gap:14px;
    }
    .request-modal-head{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
    }
    .request-modal-title{display:grid;gap:4px}
    .request-modal-title strong{font-size:18px;line-height:1.25;color:var(--text)}
    .request-modal-subtitle{font-size:12px;color:var(--muted);line-height:1.5}
    .request-modal-close{
      width:40px;
      height:40px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:14px;
      border:1px solid var(--border);
      background:var(--surface-soft);
      color:var(--text);
      cursor:pointer;
    }
    .request-detail-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .request-cell{
      padding:12px;
      border-radius:14px;
      background:var(--surface-soft);
      border:1px solid rgba(255,255,255,.05);
      min-width:0;
    }
    .request-label{
      display:block;
      margin-bottom:6px;
      font-size:10px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .request-value{
      display:block;
      color:var(--text);
      font-size:13px;
      font-weight:700;
      line-height:1.5;
      word-break:break-word;
    }
    .request-note{
      padding:12px 14px;
      border-radius:14px;
      background:rgba(255,255,255,.03);
      border:1px dashed var(--border);
      color:var(--muted);
      font-size:12px;
      line-height:1.6;
    }
    .request-note strong{color:var(--text)}
    .request-actions{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }
    .request-form{
      display:grid;
      gap:8px;
      padding:10px;
      border-radius:14px;
      background:rgba(255,255,255,.025);
      border:1px solid var(--border);
    }
    .request-action-btn{
      width:100%;
      justify-content:center;
      gap:8px;
      min-height:40px;
    }
    .request-action-label-short{display:none}
    .request-approved{
      color:var(--success);
      font-size:13px;
      font-weight:700;
      line-height:1.5;
    }
    .request-empty{
      padding:34px 18px;
      text-align:center;
      color:var(--muted);
      border:1px dashed var(--border);
      border-radius:20px;
      background:rgba(255,255,255,.03);
    }
    body[data-theme="light"] .request-card{
      background:rgba(255,255,255,.94);
      box-shadow:0 18px 40px rgba(165,162,211,.14);
    }
    body[data-theme="light"] .request-cell,
    body[data-theme="light"] .request-icon-btn{
      background:rgba(105,88,255,.04);
      border-color:rgba(148,163,184,.16);
    }
    body[data-theme="light"] .request-modal-sheet,
    body[data-theme="light"] .request-form{
      background:rgba(255,255,255,.72);
    }
    @media (max-width: 992px){
      .request-detail-grid{grid-template-columns:1fr 1fr}
    }
    @media (max-width: 768px){
      .request-summary{grid-template-columns:1fr}
      .request-side{justify-content:flex-start}
      .request-actions{grid-template-columns:1fr}
    }
    @media (max-width: 576px){
      .request-card{padding:12px}
      .request-title{font-size:15px}
      .request-detail-grid{grid-template-columns:1fr}
      .request-filter-row{width:100%}
      .request-filter-row .btn{flex:1;justify-content:center}
      .request-meta{gap:6px}
      .request-pill{font-size:11px;padding:6px 9px}
      .request-actions{grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
      .request-form{padding:8px;gap:6px}
      .request-form .fc{font-size:12px;padding:8px 10px}
      .request-action-label-full{display:none}
      .request-action-label-short{display:inline}
      .request-action-btn{min-height:38px;padding:9px 10px;font-size:12px}
      .request-modal{padding:10px}
      .request-modal-sheet{
        width:100%;
        max-height:88vh;
        padding:14px;
        border-radius:22px 22px 18px 18px;
      }
      .request-modal-title strong{font-size:16px}
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'customer_requests', company }) %>
<%
  const statusLabels = {
    pending: 'Pending',
    approved: 'Approved',
    scheduled: 'Scheduled',
    processing: 'Processing',
    completed: 'Completed',
    rejected: 'Rejected',
    cancelled: 'Cancelled'
  };
  const packageStatusLabels = {
    pending: 'Menunggu review admin',
    approved: 'Disetujui admin',
    scheduled: 'Menunggu siklus berikutnya',
    processing: 'Sedang diproses sistem',
    completed: 'Selesai diterapkan',
    rejected: 'Ditolak admin',
    cancelled: 'Dibatalkan'
  };
  const packageChangeLabels = {
    upgrade: 'Upgrade',
    downgrade: 'Downgrade',
    lateral: 'Ganti paket setara'
  };
  const statusBadgeClass = (value) => {
    const key = String(value || '').toLowerCase();
    if (key === 'completed' || key === 'approved') return 'bs';
    if (key === 'rejected' || key === 'cancelled') return 'bd';
    if (key === 'scheduled' || key === 'processing') return 'bw';
    return 'bp';
  };
  const formatDateTime = (value) => value ? new Date(value).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) : '-';
  const filters = ['pending', 'approved', 'scheduled', 'processing', 'completed', 'rejected', 'cancelled'];
%>
<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-person-check"></i> Approval Pelanggan & Perubahan Paket
    </div>
    <div class="tb-right">
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>

  <div class="page">
    <% if (msg) { %>
      <div class="alert alert-<%= msg.type === 'error' ? 'd' : 's' %>">
        <i class="bi bi-<%= msg.type === 'error' ? 'exclamation-circle' : 'check-circle' %>"></i>
        <span><%= msg.text %></span>
      </div>
    <% } %>

    <div class="card">
      <div class="card-hd request-toolbar">
        <h6><i class="bi bi-list-check"></i> Daftar Pengajuan</h6>
        <div class="request-filter-row">
          <% filters.forEach((filterKey) => { %>
            <a href="/admin/customer-requests?status=<%= filterKey %>" class="btn btn-g btn-sm <%= status === filterKey ? 'btn-p' : '' %>">
              <%= statusLabels[filterKey] || filterKey %>
            </a>
          <% }) %>
        </div>
      </div>
      <div class="card-bd request-shell">
        <div class="mini-stats">
          <div class="mini-stat">
            <span class="k">Status aktif</span>
            <strong><%= statusLabels[String(status || 'pending').toLowerCase()] || String(status || 'pending').toUpperCase() %></strong>
          </div>
          <div class="mini-stat">
            <span class="k">Total data</span>
            <strong><%= Array.isArray(rows) ? rows.length : 0 %> request</strong>
          </div>
        </div>

        <div class="request-list">
          <% if (!rows || rows.length === 0) { %>
            <div class="request-empty">Belum ada pengajuan pada status ini.</div>
          <% } %>

          <% (rows || []).forEach((row, index) => {
            const payload = row.request_type === 'new_customer' ? JSON.parse(String(row.payload_json || '{}') || '{}') : {};
            const requestStatus = String(row.status || '').toLowerCase();
            const isPackageChange = row.request_type === 'package_change';
            const canForceProcess = isPackageChange && ['approved', 'scheduled', 'processing'].includes(requestStatus);
            const canCancelRequest = isPackageChange && ['approved', 'scheduled', 'processing', 'pending'].includes(requestStatus);
            const detailId = `request-detail-${row.request_type || 'request'}-${row.id}-${index}`;
            const requestLabel = isPackageChange ? (packageChangeLabels[String(row.change_kind || '').toLowerCase()] || 'Perubahan Paket') : 'Pelanggan Baru';
            const summarySecondary = isPackageChange
              ? `${row.current_package_name || '-'} → ${row.target_package_name || '-'}`
              : `${row.package_name || '-'} • ${row.router_name || 'Tanpa router'}`;
            const summaryMetaDate = isPackageChange ? formatDateTime(row.requested_at || row.created_at) : (payload.install_date || '-');
          %>
            <div class="request-card" data-request-card>
              <div class="request-summary">
                <div class="request-main">
                  <div class="request-title-row">
                    <div class="request-title"><%= row.customer_name %></div>
                    <span class="request-type">
                      <i class="bi bi-<%= isPackageChange ? 'arrow-left-right' : 'person-plus' %>"></i>
                      <%= requestLabel %>
                    </span>
                  </div>
                  <div class="request-subtitle">
                    <% if (isPackageChange) { %>
                      Portal pelanggan • <%= row.customer_phone || '-' %>
                    <% } else { %>
                      Teknisi: <%= row.technician_name %> (@<%= row.technician_username %>)
                    <% } %>
                  </div>
                  <div class="request-meta">
                    <span class="request-pill"><i class="bi bi-box-seam"></i> <%= summarySecondary %></span>
                    <span class="request-pill"><i class="bi bi-calendar3"></i> <%= summaryMetaDate %></span>
                    <% if (!isPackageChange && row.pppoe_username) { %>
                      <span class="request-pill"><i class="bi bi-router"></i> <%= row.pppoe_username %></span>
                    <% } %>
                  </div>
                </div>
                <div class="request-side">
                  <span class="badge <%= statusBadgeClass(requestStatus) %>">
                    <%= isPackageChange ? (packageStatusLabels[requestStatus] || requestStatus.toUpperCase()) : (statusLabels[requestStatus] || requestStatus.toUpperCase()) %>
                  </span>
                  <button type="button" class="request-icon-btn" aria-haspopup="dialog" aria-controls="<%= detailId %>" onclick="openRequestDetail('<%= detailId %>')">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>

              <% if (requestStatus === 'pending') { %>
                <div class="request-actions">
                  <form method="POST" action="<%= isPackageChange ? `/admin/package-change-requests/${row.id}/approve` : `/admin/customer-requests/${row.id}/approve` %>" class="request-form">
                    <input class="fc" name="review_note" placeholder="Catatan approve (opsional)">
                    <button class="btn btn-s request-action-btn" type="submit">
                      <i class="bi bi-check2-circle"></i>
                      <span class="request-action-label-full">Approve</span>
                      <span class="request-action-label-short">Acc</span>
                    </button>
                  </form>
                  <form method="POST" action="<%= isPackageChange ? `/admin/package-change-requests/${row.id}/reject` : `/admin/customer-requests/${row.id}/reject` %>" class="request-form">
                    <input class="fc" name="review_note" placeholder="Alasan reject">
                    <button class="btn btn-d request-action-btn" type="submit">
                      <i class="bi bi-x-circle"></i>
                      <span class="request-action-label-full">Reject</span>
                      <span class="request-action-label-short">Tolak</span>
                    </button>
                  </form>
                </div>
              <% } else if (canForceProcess || canCancelRequest) { %>
                <div class="request-actions">
                  <% if (canForceProcess) { %>
                    <form method="POST" action="/admin/package-change-requests/<%= row.id %>/complete" class="request-form">
                      <input class="fc" name="review_note" placeholder="Catatan penyelesaian (opsional)">
                      <button class="btn btn-s request-action-btn" type="submit">
                        <i class="bi bi-check2-square"></i>
                        <span class="request-action-label-full">Mark Completed</span>
                        <span class="request-action-label-short">Selesai</span>
                      </button>
                    </form>
                  <% } %>
                  <% if (canCancelRequest) { %>
                    <form method="POST" action="/admin/package-change-requests/<%= row.id %>/cancel" class="request-form">
                      <input class="fc" name="review_note" placeholder="Alasan pembatalan">
                      <button class="btn btn-w request-action-btn" type="submit">
                        <i class="bi bi-slash-circle"></i>
                        <span class="request-action-label-full">Cancel Request</span>
                        <span class="request-action-label-short">Batal</span>
                      </button>
                    </form>
                  <% } %>
                </div>
              <% } else if (!isPackageChange && requestStatus === 'approved' && row.approved_customer_name) { %>
                <div class="request-approved">Sudah menjadi pelanggan aktif: <strong><%= row.approved_customer_name %></strong></div>
              <% } else if (isPackageChange && requestStatus === 'completed') { %>
                <div class="request-approved">Perubahan paket sudah selesai diterapkan ke: <strong><%= row.target_package_name || 'paket baru' %></strong></div>
              <% } else if (isPackageChange && requestStatus === 'scheduled') { %>
                <div class="request-approved">Downgrade sudah dijadwalkan dan akan diproses otomatis pada tanggal efektifnya.</div>
              <% } %>
            </div>

            <div id="<%= detailId %>" class="request-modal" role="dialog" aria-modal="true" aria-hidden="true" onclick="closeRequestDetailFromBackdrop(event)">
              <div class="request-modal-sheet">
                <div class="request-modal-head">
                  <div class="request-modal-title">
                    <strong><%= row.customer_name %></strong>
                    <div class="request-modal-subtitle">
                      <% if (isPackageChange) { %>
                        Pengajuan perubahan paket dari portal pelanggan
                      <% } else { %>
                        Pengajuan pelanggan baru dari teknisi <%= row.technician_name %> (@<%= row.technician_username %>)
                      <% } %>
                    </div>
                  </div>
                  <button type="button" class="request-modal-close" onclick="closeRequestDetail('<%= detailId %>')">
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>

                <div class="request-detail-grid">
                  <% if (isPackageChange) { %>
                    <div class="request-cell"><span class="request-label">Nomor Pelanggan</span><span class="request-value"><%= row.customer_phone || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Jenis Perubahan</span><span class="request-value"><%= packageChangeLabels[String(row.change_kind || '').toLowerCase()] || String(row.change_kind || '-').toUpperCase() %></span></div>
                    <div class="request-cell"><span class="request-label">Paket Saat Ini</span><span class="request-value"><%= row.current_package_name || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Paket Tujuan</span><span class="request-value"><%= row.target_package_name || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Diajukan</span><span class="request-value"><%= formatDateTime(row.requested_at || row.created_at) %></span></div>
                    <div class="request-cell"><span class="request-label">Mulai Berlaku</span><span class="request-value"><%= formatDateTime(row.effective_at) %></span></div>
                    <div class="request-cell"><span class="request-label">Bisa Request Lagi</span><span class="request-value"><%= formatDateTime(row.eligibility_after) %></span></div>
                    <div class="request-cell"><span class="request-label">Direview Oleh</span><span class="request-value"><%= row.reviewed_by_name || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Sumber Request</span><span class="request-value"><%= row.request_source || 'portal' %></span></div>
                  <% } else { %>
                    <div class="request-cell"><span class="request-label">No. HP</span><span class="request-value"><%= row.customer_phone || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Paket</span><span class="request-value"><%= row.package_name || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Router</span><span class="request-value"><%= row.router_name || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Mode Secret</span><span class="request-value"><%= payload.create_pppoe_secret ? 'Buat baru saat approve' : 'Pakai secret existing' %></span></div>
                    <div class="request-cell"><span class="request-label">PPPoE</span><span class="request-value"><%= row.pppoe_username || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Password PPPoE</span><span class="request-value"><%= payload.pppoe_password || '(ikut username)' %></span></div>
                    <div class="request-cell"><span class="request-label">Profile Normal</span><span class="request-value"><%= payload.normal_pppoe_profile || '(ikut paket)' %></span></div>
                    <div class="request-cell"><span class="request-label">Alamat</span><span class="request-value"><%= payload.address || '-' %></span></div>
                    <div class="request-cell"><span class="request-label">Tanggal Pasang</span><span class="request-value"><%= payload.install_date || '-' %></span></div>
                  <% } %>
                </div>

                <% if (row.request_note) { %>
                  <div class="request-note"><strong>Catatan pengajuan:</strong> <%= row.request_note %></div>
                <% } %>

                <% if (row.review_note) { %>
                  <div class="request-note"><strong>Catatan review:</strong> <%= row.review_note %></div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleSidebar() {
    const sidebar = document.querySelector('.sidebar');
    if (sidebar) sidebar.classList.toggle('open');
  }

  function openRequestDetail(id) {
    const modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeRequestDetail(id) {
    const modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function closeRequestDetailFromBackdrop(event) {
    if (!event.target.classList.contains('request-modal')) return;
    closeRequestDetail(event.target.id);
  }

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    const activeModal = document.querySelector('.request-modal.is-open');
    if (activeModal) closeRequestDetail(activeModal.id);
  });
</script>
</body>
</html>
