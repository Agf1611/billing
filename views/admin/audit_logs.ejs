<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <%
    const monthNamesAudit = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
    const actionLabels = {
      CREATE: 'Data dibuat',
      UPDATE: 'Data diperbarui',
      DELETE: 'Data dihapus',
      LOGIN: 'Login',
      LOGOUT: 'Logout',
      MARK_INVOICE_PAID: 'Tagihan dilunaskan',
      INVOICE_PAID: 'Tagihan dilunaskan',
      PAYMENT_RECEIVED: 'Pembayaran diterima',
      SUSPEND_CUSTOMER: 'Pelanggan diisolir',
      REACTIVATE_CUSTOMER: 'Pelanggan diaktifkan',
      CHANGE_WIFI_PASSWORD: 'Password WiFi diubah',
      CHANGE_WIFI_NAME: 'Nama WiFi diubah'
    };
    const moduleLabels = {
      invoice: 'Tagihan',
      invoices: 'Tagihan',
      customer: 'Pelanggan',
      customers: 'Pelanggan',
      package: 'Paket',
      packages: 'Paket',
      admin: 'Admin',
      cashier: 'Kasir',
      technician: 'Teknisi',
      agent: 'Agent',
      payment: 'Pembayaran',
      pppoe: 'Layanan Internet',
      router: 'MikroTik',
      mikrotik: 'MikroTik',
      system: 'Sistem'
    };
    const titleizeAudit = (value) => String(value || '-')
      .replace(/_/g, ' ')
      .toLowerCase()
      .replace(/\b\w/g, (char) => char.toUpperCase());
    const actionLabel = (value) => actionLabels[String(value || '').toUpperCase()] || titleizeAudit(value);
    const moduleLabel = (value) => moduleLabels[String(value || '').toLowerCase()] || titleizeAudit(value);
    const actorLabel = (value) => moduleLabels[String(value || '').toLowerCase()] || titleizeAudit(value || 'Admin');
    const formatAuditMoney = (value) => {
      const amount = Number(value || 0);
      return Number.isFinite(amount) && amount > 0 ? `Rp ${amount.toLocaleString('id-ID')}` : '';
    };
    const formatAuditPeriod = (month, year) => {
      const m = Number(month || 0);
      const y = Number(year || 0);
      return m >= 1 && m <= 12 && y > 0 ? `${monthNamesAudit[m - 1]} ${y}` : '';
    };
    const pickAuditValue = (source, keys = []) => {
      if (!source || typeof source !== 'object') return '';
      for (const key of keys) {
        const value = source[key];
        if (value !== undefined && value !== null && String(value).trim() !== '') return value;
      }
      return '';
    };
    const auditDetailSummary = (log) => {
      const details = log && log.details && typeof log.details === 'object' ? log.details : {};
      const parts = [];
      const customerName = pickAuditValue(details, ['customer_name', 'customerName', 'name', 'customer']);
      const invoiceNo = pickAuditValue(details, ['invoice_number', 'invoiceNumber', 'invoice_id', 'invoiceId']);
      const amount = formatAuditMoney(pickAuditValue(details, ['amount', 'paid_amount', 'total', 'nominal']));
      const period = formatAuditPeriod(pickAuditValue(details, ['period_month', 'month']), pickAuditValue(details, ['period_year', 'year']));
      const method = pickAuditValue(details, ['payment_method', 'method', 'paymentMethod']);
      const statusBefore = pickAuditValue(details, ['old_status', 'status_before', 'from_status']);
      const statusAfter = pickAuditValue(details, ['new_status', 'status_after', 'to_status']);
      const note = pickAuditValue(details, ['note', 'notes', 'reason']);
      if (customerName) parts.push(`Pelanggan: ${customerName}`);
      if (invoiceNo) parts.push(`Ref: ${invoiceNo}`);
      if (period) parts.push(`Periode: ${period}`);
      if (amount) parts.push(`Nominal: ${amount}`);
      if (method) parts.push(`Metode: ${titleizeAudit(method)}`);
      if (statusBefore || statusAfter) parts.push(`Status: ${statusBefore || '-'} ke ${statusAfter || '-'}`);
      if (note) parts.push(`Catatan: ${String(note).slice(0, 120)}`);
      return parts.length ? parts.join(' | ') : 'Aktivitas tercatat.';
    };
  %>
  <style>
    .log-details { font-size: 12px; background: rgba(99,102,241,0.08); padding: 10px 12px; border-radius: 12px; line-height: 1.45; color: var(--text); max-width: 520px; }
    .badge-action { padding: 5px 10px; border-radius: 999px; font-weight: 700; font-size: 10px; display:inline-flex; align-items:center; gap:6px; white-space:nowrap; }
    .badge-CREATE { background: var(--sdim); color: var(--success); }
    .badge-UPDATE { background: var(--wdim); color: var(--warning); }
    .badge-DELETE { background: var(--ddim); color: var(--danger); }
    .badge-LOGIN { background: var(--pdim); color: var(--primary); }
    .badge-LOGOUT { background: var(--bg3); color: var(--muted); }
    .badge-MARK_INVOICE_PAID, .badge-INVOICE_PAID, .badge-PAYMENT_RECEIVED { background: rgba(16,185,129,.12); color: var(--success); }
    .stat-grid-4 { grid-template-columns: repeat(4, 1fr); }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'audit_logs', company }) %>

<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-shield-lock"></i>
      <span><%= title %></span>
    </div>
    <div class="tb-right">
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>

  <div class="page">
    <div class="stat-grid stat-grid-4">
      <div class="sc p">
        <div class="sc-label">Total Log</div>
        <div class="sc-val"><%= stats.total %></div>
      </div>
      <div class="sc s">
        <div class="sc-label">Aktivitas 24 Jam</div>
        <div class="sc-val"><%= stats.recent_24h %></div>
      </div>
      <div class="sc w">
        <div class="sc-label">Update Data</div>
        <div class="sc-val"><%= stats.by_action.find(a => a.action === 'UPDATE')?.count || 0 %></div>
      </div>
      <div class="sc d">
        <div class="sc-label">Penghapusan</div>
        <div class="sc-val"><%= stats.by_action.find(a => a.action === 'DELETE')?.count || 0 %></div>
      </div>
    </div>

    <div class="card">
      <div class="card-hd">
        <h6><i class="bi bi-list-columns-reverse"></i> Log Aktivitas Operasional</h6>
        <div class="flex gap">
          <form class="flex gap" method="GET">
            <select class="fs fs-sm" name="action" onchange="this.form.submit()">
              <option value="">-- Semua Aktivitas --</option>
              <% stats.by_action.forEach(a => { %>
                <option value="<%= a.action %>" <%= filters.action === a.action ? 'selected' : '' %>><%= actionLabel(a.action) %></option>
              <% }) %>
            </select>
            <select class="fs fs-sm" name="entity_type" onchange="this.form.submit()">
              <option value="">-- Semua Modul --</option>
              <% stats.by_entity_type.forEach(e => { %>
                <option value="<%= e.entity_type %>" <%= filters.entity_type === e.entity_type ? 'selected' : '' %>><%= moduleLabel(e.entity_type) %></option>
              <% }) %>
            </select>
          </form>
        </div>
      </div>
      <div class="tbl-wrap">
        <table class="dtbl">
          <thead>
            <tr>
              <th>Waktu</th>
              <th>Aktivitas</th>
              <th>Modul</th>
              <th>Referensi</th>
              <th>Pelaku</th>
              <th>Detail</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(log => { %>
              <tr>
                <td class="text-muted" style="font-size:11px">
                  <%= new Date(log.created_at).toLocaleString('id-ID') %>
                </td>
                <td>
                  <span class="badge-action badge-<%= String(log.action || '').replace(/[^A-Z0-9_]/gi, '_') %>"><%= actionLabel(log.action) %></span>
                </td>
                <td><span class="badge bm"><%= moduleLabel(log.entity_type) %></span></td>
                <td class="text-muted"><%= log.entity_id || '-' %></td>
                <td>
                  <div class="fw6"><%= log.actor_name %></div>
                  <div class="text-muted" style="font-size:10px"><%= actorLabel(log.actor_type) %></div>
                </td>
                <td>
                  <% if (log.details) { %>
                    <div class="log-details"><%= auditDetailSummary(log) %></div>
                  <% } else { %>
                    <span class="text-muted">Aktivitas tercatat.</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleDetails(id) {
    const el = document.getElementById(id);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
  }
  function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('open'); }
</script>
</body>
</html>
