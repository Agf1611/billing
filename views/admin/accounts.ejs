<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title>Pengelolaan Akun | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .role-filters{display:flex;gap:10px;flex-wrap:wrap}
    .role-chip{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;border:1px solid var(--border);background:var(--surface-soft);color:var(--muted);text-decoration:none;font-weight:800}
    .role-chip.active{color:var(--text);background:var(--surface-strong);box-shadow:inset 0 0 0 1px var(--border)}
    .stats-grid{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:16px;align-items:stretch}
    .stat-card{flex:0 0 auto;min-width:148px;padding:12px 16px;border-radius:18px;border:1px solid var(--border);background:var(--surface-soft)}
    .stat-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
    .stat-val{font-size:22px;line-height:1;font-weight:800}
    .role-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;font-size:11px;font-weight:800}
    .role-badge.tech{background:var(--idim);color:var(--info)}
    .role-badge.cashier{background:var(--pdim);color:var(--primary)}
    .role-badge.collector{background:var(--sdim);color:var(--success)}
    .role-field{display:none}
    .role-field.show{display:block}
    @media (max-width: 900px){.stat-card{min-width:132px}}
    @media (max-width: 640px){.stats-grid{gap:10px}.stat-card{min-width:calc(50% - 5px);padding:11px 14px}.stat-val{font-size:20px}}
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'accounts', company }) %>

<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-people"></i>
      <span>Pengelolaan Akun</span>
    </div>
    <div class="tb-right">
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %></span>
      <button class="btn btn-p btn-sm" onclick="openModal('addAccountModal')"><i class="bi bi-plus-lg"></i> Tambah Akun</button>
    </div>
  </div>

  <div class="page">
    <% if (msg) { %>
      <div class="alert alert-<%= msg.type==='error'?'d':'s' %>"><%= msg.text %></div>
    <% } %>

    <div class="stats-grid">
      <div class="stat-card"><div class="stat-label">Semua Akun</div><div class="stat-val"><%= Number(stats?.all || 0) %></div></div>
      <div class="stat-card"><div class="stat-label">Teknisi</div><div class="stat-val"><%= Number(stats?.technician || 0) %></div></div>
      <div class="stat-card"><div class="stat-label">Kasir</div><div class="stat-val"><%= Number(stats?.cashier || 0) %></div></div>
      <div class="stat-card"><div class="stat-label">Kolektor</div><div class="stat-val"><%= Number(stats?.collector || 0) %></div></div>
    </div>

    <div class="card" style="margin-bottom:16px">
      <div class="card-bd">
        <div class="role-filters">
          <a href="/admin/accounts?role=all" class="role-chip <%= filterRole === 'all' ? 'active' : '' %>"><i class="bi bi-grid-3x3-gap"></i> Semua</a>
          <a href="/admin/accounts?role=technician" class="role-chip <%= filterRole === 'technician' ? 'active' : '' %>"><i class="bi bi-person-gear"></i> Teknisi</a>
          <a href="/admin/accounts?role=cashier" class="role-chip <%= filterRole === 'cashier' ? 'active' : '' %>"><i class="bi bi-person-vcard"></i> Kasir</a>
          <a href="/admin/accounts?role=collector" class="role-chip <%= filterRole === 'collector' ? 'active' : '' %>"><i class="bi bi-person-badge"></i> Kolektor</a>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-hd">
        <h6><i class="bi bi-list-ul"></i> Daftar Akun Pengguna</h6>
      </div>
      <div class="tbl-wrap">
        <table class="dtbl">
          <thead>
            <tr>
              <th>Role</th>
              <th>Nama</th>
              <th>Username</th>
              <th>No. HP</th>
              <th>Area/Akses</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (!accounts || accounts.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted" style="padding:20px">Belum ada akun pada filter ini.</td></tr>
            <% } else { %>
              <% accounts.forEach((acc) => { %>
                <tr>
                  <td>
                    <span class="role-badge <%= acc.role %>">
                      <i class="bi <%= acc.role === 'technician' ? 'bi-person-gear' : acc.role === 'cashier' ? 'bi-person-vcard' : 'bi-person-badge' %>"></i>
                      <%= acc.role_label %>
                    </span>
                  </td>
                  <td><strong><%= acc.name %></strong></td>
                  <td><code><%= acc.username %></code></td>
                  <td><%= acc.phone || '-' %></td>
                  <td><%= acc.role === 'technician' ? (acc.area || '-') : acc.role_label %></td>
                  <td><span class="badge <%= acc.is_active ? 'bs' : 'bd' %>"><%= acc.is_active ? t('common.active','Aktif') : t('common.inactive','Nonaktif') %></span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="btn btn-g btn-icon btn-sm" onclick='editAccount(<%- JSON.stringify(acc) %>)'><i class="bi bi-pencil"></i></button>
                      <form action="/admin/accounts/<%= acc.role %>/<%= acc.id %>/delete" method="POST" onsubmit="return confirm('Hapus akun ini?')">
                        <button type="submit" class="btn btn-d btn-icon btn-sm"><i class="bi bi-trash"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="mo" id="addAccountModal">
  <div class="mb">
    <form action="/admin/accounts" method="POST">
      <div class="mh"><span class="mt">Tambah Akun Pengguna</span><button type="button" class="mc" onclick="closeModal('addAccountModal')">&times;</button></div>
      <div class="mbody">
        <div class="fg"><label class="fl">Akses / Role</label><select name="role" class="fs js-role-select" data-target-prefix="add" required><option value="technician">Teknisi</option><option value="cashier">Kasir</option><option value="collector">Kolektor</option></select></div>
        <div class="fg"><label class="fl">Nama Lengkap</label><input type="text" name="name" class="fc" required></div>
        <div class="fg"><label class="fl">Username Login</label><input type="text" name="username" class="fc" required></div>
        <div class="fg"><label class="fl">Password</label><input type="password" name="password" class="fc" required></div>
        <div class="fg"><label class="fl">No. HP</label><input type="text" name="phone" class="fc" placeholder="08123456789"></div>
        <div class="fg role-field show" id="add-area-wrap"><label class="fl">Area Tugas</label><input type="text" name="area" class="fc" placeholder="Contoh: Kelurahan A, Blok B"></div>
      </div>
      <div class="mf">
        <button type="button" class="btn btn-g" onclick="closeModal('addAccountModal')">Batal</button>
        <button type="submit" class="btn btn-p">Simpan</button>
      </div>
    </form>
  </div>
</div>

<div class="mo" id="editAccountModal">
  <div class="mb">
    <form id="editAccountForm" method="POST">
      <div class="mh"><span class="mt">Edit Akun Pengguna</span><button type="button" class="mc" onclick="closeModal('editAccountModal')">&times;</button></div>
      <div class="mbody">
        <div class="fg"><label class="fl">Akses / Role</label><select name="role" id="e-role" class="fs js-role-select" data-target-prefix="edit" required><option value="technician">Teknisi</option><option value="cashier">Kasir</option><option value="collector">Kolektor</option></select></div>
        <div class="fg"><label class="fl">Nama Lengkap</label><input type="text" name="name" id="e-name" class="fc" required></div>
        <div class="fg"><label class="fl">Username Login</label><input type="text" name="username" id="e-username" class="fc" required></div>
        <div class="fg"><label class="fl">Password</label><input type="password" name="password" id="e-password" class="fc" placeholder="Kosongkan jika tidak diubah"></div>
        <div class="fg"><label class="fl">No. HP</label><input type="text" name="phone" id="e-phone" class="fc"></div>
        <div class="fg role-field" id="edit-area-wrap"><label class="fl">Area Tugas</label><input type="text" name="area" id="e-area" class="fc"></div>
        <div class="fg"><label class="fl">Status Akun</label><select name="is_active" id="e-status" class="fs"><option value="1">Aktif</option><option value="0">Nonaktif</option></select></div>
      </div>
      <div class="mf">
        <button type="button" class="btn btn-g" onclick="closeModal('editAccountModal')">Batal</button>
        <button type="submit" class="btn btn-p">Simpan Perubahan</button>
      </div>
    </form>
  </div>
</div>

<script>
function openModal(id){document.getElementById(id).classList.add('show')}
function closeModal(id){document.getElementById(id).classList.remove('show')}

function syncRoleFields(prefix, role){
  const wrap = document.getElementById(prefix + '-area-wrap');
  if (!wrap) return;
  wrap.classList.toggle('show', role === 'technician');
}

document.querySelectorAll('.js-role-select').forEach((select) => {
  syncRoleFields(select.dataset.targetPrefix, select.value);
  select.addEventListener('change', () => syncRoleFields(select.dataset.targetPrefix, select.value));
});

function editAccount(acc){
  document.getElementById('editAccountForm').action = '/admin/accounts/' + acc.role + '/' + acc.id + '/update';
  document.getElementById('e-role').value = acc.role || 'technician';
  document.getElementById('e-name').value = acc.name || '';
  document.getElementById('e-username').value = acc.username || '';
  document.getElementById('e-password').value = '';
  document.getElementById('e-phone').value = acc.phone || '';
  document.getElementById('e-area').value = acc.area || '';
  document.getElementById('e-status').value = String(acc.is_active ? 1 : 0);
  syncRoleFields('edit', acc.role || 'technician');
  openModal('editAccountModal');
}
</script>
</body>
</html>
