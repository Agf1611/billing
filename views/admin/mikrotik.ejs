<script>
  const I18N = {
    addSecret: "<%= t('admin.mikrotik.actions.add_secret', 'Tambah Secret') %>",
    editSecret: "<%= t('admin.mikrotik.actions.edit_secret', 'Edit Secret') %>",
    addHotspotUser: "<%= t('admin.mikrotik.actions.add_hotspot_user', 'Tambah User Hotspot') %>",
    editHotspotUser: "<%= t('admin.mikrotik.actions.edit_hotspot_user', 'Edit User Hotspot') %>",
    addPppoeProfile: "<%= t('admin.mikrotik.actions.add_pppoe_profile', 'Tambah PPPoE Profile') %>",
    editPppoeProfile: "<%= t('admin.mikrotik.actions.edit_pppoe_profile', 'Edit PPPoE Profile') %>",
    addHotspotProfile: "<%= t('admin.mikrotik.actions.add_hotspot_profile', 'Tambah Hotspot Profile') %>",
    editHotspotProfile: "<%= t('admin.mikrotik.actions.edit_hotspot_profile', 'Edit Hotspot Profile') %>",
    saveFailed: "<%= t('admin.mikrotik.errors.save_failed', 'Gagal menyimpan') %>",
    deleteFailed: "<%= t('admin.mikrotik.errors.delete_failed', 'Gagal menghapus') %>",
    deleteSecretConfirm: "<%= t('admin.mikrotik.confirm.delete_secret', 'Hapus secret ini?') %>",
    deleteHotspotConfirm: "<%= t('admin.mikrotik.confirm.delete_hotspot_user', 'Hapus user hotspot ini?') %>",
    deleteProfileConfirm: "<%= t('admin.mikrotik.confirm.delete_profile', 'Hapus profile ini?') %>",
    emptySecrets: "<%= t('admin.mikrotik.empty.secrets', 'Tidak ada data secret') %>",
    emptyHotspotUsers: "<%= t('admin.mikrotik.empty.hotspot_users', 'Tidak ada data user hotspot') %>",
    emptyPppoeProfiles: "<%= t('admin.mikrotik.empty.pppoe_profiles', 'Tidak ada data PPPoE profile') %>",
    emptyHotspotProfiles: "<%= t('admin.mikrotik.empty.hotspot_profiles', 'Tidak ada data Hotspot profile') %>",
    loadFailed: "<%= t('admin.mikrotik.errors.load_failed', 'Gagal memuat data') %>",
    statusOnline: "<%= t('admin.mikrotik.status.online', 'Online') %>",
    statusOffline: "<%= t('admin.mikrotik.status.offline', 'Offline') %>",
    statusDisabled: "<%= t('admin.mikrotik.status.disabled', 'Disabled') %>",
    onlineNow: "Online sekarang",
    noLastOnline: "Belum pernah online",
    noOfflineDuration: "-",
    editLabel: "<%= t('common.edit', 'Edit') %>",
    deleteLabel: "<%= t('common.delete', 'Hapus') %>"
  };

  function showTab(e, id) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    e.currentTarget.classList.add('active');
    document.getElementById(id).classList.add('active');
  }

  function toggleMonitorToolbar(toolbarId, trigger) {
    const toolbar = document.getElementById(toolbarId);
    if (!toolbar) return;
    const isOpen = toolbar.classList.toggle('is-open');
    if (trigger) trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  }

  function openModal(id){document.getElementById(id).classList.add('show')}
  function closeModal(id){document.getElementById(id).classList.remove('show')}

  let pppoeData = [];
  let hotspotData = [];
  let pppoeProfilesData = [];
  let hotspotProfilesData = [];
  let profileOptionsRouterKey = null;
  let profileOptionsPromise = null;
  let searchDebounceTimer = null;
  let monitoringRefreshPromise = null;
  let pendingMonitoringRefresh = null;
  const monitoringSync = {
    lastSuccessAt: null,
    status: 'idle',
    detail: 'Saat pertama kali dibuka, data router dimuat lalu disimpan ke cache. Saat dibuka lagi, sistem menampilkan cache dulu agar lebih cepat. Gunakan refresh manual untuk update terbaru.'
  };
  const tableState = {
    pppoe: { page: 1, limit: 25, q: '', status: 'all', total: 0, totalPages: 1, filteredTotal: 0, onlineCount: 0 },
    hotspot: { page: 1, limit: 25, q: '', total: 0, totalPages: 1, filteredTotal: 0, onlineCount: 0 },
    pppoeProfiles: { page: 1, limit: 25, q: '', total: 0, totalPages: 1, filteredTotal: 0 },
    hotspotProfiles: { page: 1, limit: 25, q: '', total: 0, totalPages: 1, filteredTotal: 0 }
  };
  const loadState = {
    summary: false,
    pppoe: false,
    hotspot: false,
    pppoeProfiles: false,
    hotspotProfiles: false
  };
  const MONITORING_CACHE_KEY = 'billing-admin-mikrotik-cache-v4';
  const summaryState = {
    pppoeOnline: 0,
    hotspotOnline: 0,
    totalSecrets: 0,
    totalHotspot: 0
  };

  tableState.pppoe.status = tableState.pppoe.status || 'all';

  function getMonitoringRouterCacheKey() {
    return String(getRouterId() || 'default');
  }

  function readMonitoringCacheStore() {
    try {
      const raw = localStorage.getItem(MONITORING_CACHE_KEY);
      if (!raw) return { version: 4, routers: {} };
      const parsed = JSON.parse(raw);
      if (!parsed || typeof parsed !== 'object') return { version: 4, routers: {} };
      return {
        version: 4,
        routers: parsed.routers && typeof parsed.routers === 'object' ? parsed.routers : {}
      };
    } catch (error) {
      console.error('Failed to read MikroTik cache:', error);
      return { version: 4, routers: {} };
    }
  }

  function writeMonitoringCacheStore(store) {
    try {
      localStorage.setItem(MONITORING_CACHE_KEY, JSON.stringify(store));
    } catch (error) {
      console.error('Failed to write MikroTik cache:', error);
    }
  }

  function cloneTableStateForCache() {
    return {
      pppoe: { ...tableState.pppoe },
      hotspot: { ...tableState.hotspot },
      pppoeProfiles: { ...tableState.pppoeProfiles },
      hotspotProfiles: { ...tableState.hotspotProfiles }
    };
  }

  function persistMonitoringCache() {
    const store = readMonitoringCacheStore();
    store.routers[getMonitoringRouterCacheKey()] = {
      savedAt: new Date().toISOString(),
      lastSuccessAt: monitoringSync.lastSuccessAt ? monitoringSync.lastSuccessAt.toISOString() : null,
      summary: { ...summaryState },
      tableState: cloneTableStateForCache(),
      pppoe: {
        items: Array.isArray(pppoeData) ? pppoeData : []
      },
      hotspot: {
        items: Array.isArray(hotspotData) ? hotspotData : []
      },
      pppoeProfiles: {
        items: Array.isArray(pppoeProfilesData) ? pppoeProfilesData : []
      },
      hotspotProfiles: {
        items: Array.isArray(hotspotProfilesData) ? hotspotProfilesData : []
      }
    };
    writeMonitoringCacheStore(store);
  }

  function getMonitoringCacheEntry(routerKey = getMonitoringRouterCacheKey()) {
    const store = readMonitoringCacheStore();
    return store.routers?.[routerKey] || null;
  }

  function getDefaultRouterId() {
    const select = document.getElementById('global-router-id');
    if (!select) return '';
    const preferred = String(select.dataset.defaultRouterId || '').trim();
    if (preferred) return preferred;
    const firstRealOption = Array.from(select.options || []).find((option) => String(option.value || '').trim());
    return firstRealOption ? String(firstRealOption.value || '').trim() : '';
  }

  function ensureMonitoringRouterSelected() {
    const select = document.getElementById('global-router-id');
    if (!select) return '';
    const current = String(select.value || '').trim();
    if (current) return current;
    const fallback = getDefaultRouterId();
    if (fallback) select.value = fallback;
    return String(select.value || '').trim();
  }

  function getRouterId() {
    return ensureMonitoringRouterSelected();
  }

  function getActiveSecondaryTabId() {
    const active = document.querySelector('.tab-content.active');
    return active ? active.id : '';
  }

  function setTableMessage(tbodyId, colspan, message, tone = 'muted') {
    const tbody = document.getElementById(tbodyId);
    if (!tbody) return;
    const toneClass = tone === 'danger' ? 'text-danger' : 'text-muted';
    tbody.replaceChildren();
    const tr = document.createElement('tr');
    const td = document.createElement('td');
    td.colSpan = colspan;
    td.className = `text-center ${toneClass}`;
    td.textContent = String(message || '');
    tr.appendChild(td);
    tbody.appendChild(tr);
  }

  function setMobileListMessage(containerId, message, tone = 'muted') {
    const container = document.getElementById(containerId);
    if (!container) return;
    const extraClass = tone === 'danger' ? ' text-danger' : '';
    container.replaceChildren();
    const div = document.createElement('div');
    div.className = `monitor-mobile-empty${extraClass}`;
    div.textContent = String(message || '');
    container.appendChild(div);
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function safeText(value, fallback = '-') {
    const raw = value === undefined || value === null || value === '' ? fallback : value;
    return escapeHtml(raw);
  }

  function renderMobileCards(containerId, cards) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.replaceChildren();
    const html = (Array.isArray(cards) ? cards : []).join('');
    if (html) container.insertAdjacentHTML('beforeend', html);
  }

  function renderStatusBadge(status) {
    if (status === 'online') return `<span class="badge bs">${I18N.statusOnline}</span>`;
    if (status === 'disabled') return `<span class="badge bd">${I18N.statusDisabled}</span>`;
    return `<span class="badge bw">${I18N.statusOffline}</span>`;
  }

  function applySearchInputs() {
    const pppoeSearch = document.getElementById('pppoe-search');
