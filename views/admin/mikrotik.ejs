  function parseIsoDate(value) {
    if (!value) return null;
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? null : date;
  }

  function formatDateTimeShort(value) {
    const date = parseIsoDate(value);
    if (!date) return '-';
    return new Intl.DateTimeFormat('id-ID', {
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit'
    }).format(date);
  }

  function formatDurationCompact(totalSeconds) {
    const safeSeconds = Number(totalSeconds);
    if (!Number.isFinite(safeSeconds) || safeSeconds < 0) return I18N.noOfflineDuration;
    const days = Math.floor(safeSeconds / 86400);
    const hours = Math.floor((safeSeconds % 86400) / 3600);
    const minutes = Math.floor((safeSeconds % 3600) / 60);
    if (days > 0) return `${days}h ${hours}j`;
    if (hours > 0) return `${hours}j ${minutes}m`;
    return `${Math.max(1, minutes)}m`;
  }

  function getPppoeLastOnlineText(secret) {
    if (secret?.displayStatus === 'online') return I18N.onlineNow;
    if (secret?.lastOnlineAt) return formatDateTimeShort(secret.lastOnlineAt);
    return I18N.noLastOnline;
  }

  function getPppoeOfflineDurationText(secret) {
    if (secret?.displayStatus !== 'offline') return I18N.noOfflineDuration;
    return formatDurationCompact(secret?.offlineSeconds);
  }

