<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.nav.mikrotik_monitoring', 'Monitoring MikroTik') %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .status-badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; }
    .monitor-topbar-actions { display:flex; align-items:center; gap:12px; width:100%; }
    .monitor-topbar-main { display:flex; align-items:center; gap:12px; flex:1 1 auto; min-width:0; }
    .monitor-topbar-shortcuts { display:flex; align-items:center; gap:10px; flex:0 0 auto; }
    .monitor-toolbar {
      display:flex;
      align-items:center;
      justify-content:flex-end;
      gap:10px;
      flex-wrap:nowrap;
      width:100%;
      min-width:0;
    }
    .monitor-toolbar-stack{
      display:flex;
      align-items:center;
      gap:10px;
      flex:1 1 auto;
      min-width:0;
    }
    .monitor-toolbar-actions{
      display:flex;
      align-items:center;
      gap:8px;
      flex:0 0 auto;
    }
    .monitor-toolbar .fc-sm {
      min-width: 220px;
      flex:1 1 auto;
    }
    .monitor-toolbar .fs-sm {
      min-width: 160px;
      flex:0 0 160px;
    }
    .monitor-toolbar .btn { white-space:nowrap; }
    .monitor-filter-toggle{
      display:none;
      align-items:center;
      justify-content:center;
      gap:6px;
    }
    .monitor-sync { display:flex; justify-content:space-between; align-items:center; gap:14px; margin-bottom:16px; padding:12px 14px; border:1px solid var(--border); border-radius:16px; }
    .monitor-sync-meta { display:flex; flex-direction:column; gap:5px; }
    .monitor-sync-top { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .monitor-sync-title { font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:var(--muted); }
    .monitor-sync-badge { display:inline-flex; align-items:center; gap:5px; padding:3px 8px; border-radius:999px; background:rgba(47,107,255,.12); color:#9fc0ff; font-size:10px; font-weight:800; }
    .monitor-sync-row { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .monitor-sync-time-label { font-size:11px; color:var(--muted); }
    .monitor-sync-time { font-size:14px; font-weight:700; color:var(--text); }
    .monitor-sync-status { display:inline-flex; align-items:center; gap:6px; padding:4px 10px; border-radius:999px; font-size:12px; font-weight:700; }
    .monitor-sync-status.idle { background:rgba(99,102,241,.12); color:#a5b4fc; }
    .monitor-sync-status.syncing { background:rgba(245,158,11,.12); color:#fcd34d; }
    .monitor-sync-status.success { background:rgba(34,197,94,.12); color:#86efac; }
    .monitor-sync-status.error { background:rgba(239,68,68,.12); color:#fca5a5; }
    .monitor-sync-detail { font-size:12px; color:var(--muted); line-height:1.5; }
    .table-pager { display:flex; justify-content:space-between; align-items:center; gap:12px; padding-top:12px; flex-wrap:wrap; }
    .table-pager-meta { font-size:12px; color:var(--muted); }
    .table-pager-actions { display:flex; align-items:center; gap:8px; }
    .table-pager-page { min-width:72px; text-align:center; font-size:12px; color:var(--muted); }
    .monitor-mobile-list { display:none; }
    .monitor-mobile-card { border:1px solid var(--border); border-radius:16px; padding:9px 10px; }
    .monitor-mobile-card + .monitor-mobile-card { margin-top:7px; }
    .monitor-mobile-head { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:6px; }
    .monitor-mobile-name { font-size:13px; font-weight:800; color:var(--text); line-height:1.2; }
    .monitor-mobile-meta { font-size:10px; color:var(--muted); margin-top:1px; }
    .monitor-mobile-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:6px; }
    .monitor-mobile-cell { padding:7px 8px; border-radius:11px; min-width:0; }
    .monitor-mobile-cell.span-2 { grid-column:span 2; }
    .monitor-mobile-label { font-size:9px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); margin-bottom:2px; }
    .monitor-mobile-value { font-size:10.5px; font-weight:700; color:var(--text); word-break:break-word; line-height:1.25; }
    .monitor-mobile-actions { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:5px; margin-top:7px; }
    .monitor-mobile-actions .btn { justify-content:center; padding:0; height:32px; min-height:32px; font-size:11px; }
    .mikrotik-monitor-page .stat-grid { gap:10px !important; }
    .mikrotik-monitor-page .stat-grid .sc { min-height:0; padding:14px 14px 12px; border-radius:18px; }
    .mikrotik-monitor-page .stat-grid .sc-icon { width:42px; height:42px; font-size:18px; top:14px; right:14px; }
    .mikrotik-monitor-page .stat-grid .sc-label { max-width:75%; font-size:10px; line-height:1.25; letter-spacing:.05em; }
    .mikrotik-monitor-page .stat-grid .sc-val { font-size:19px; line-height:1.05; margin-top:10px; }
    .mikrotik-monitor-page .stat-grid .sc-sub { margin-top:6px; font-size:10px; }
    .mikrotik-monitor-page .card-hd { gap:10px; }
    .mikrotik-monitor-page .monitor-card-hd{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      flex-wrap:nowrap;
    }
    .mikrotik-monitor-page .card-hd h6 { margin:0; font-size:14px; line-height:1.25; }
    .monitor-mobile-empty { padding:18px 16px; text-align:center; color:var(--muted); border:1px dashed var(--border); border-radius:18px; }
    body[data-theme="light"] .monitor-sync,
    body[data-theme="light"] .monitor-mobile-card,
    body[data-theme="light"] .monitor-mobile-empty{
      background:rgba(255,255,255,.9);
      box-shadow:0 14px 30px rgba(165,162,211,.12);
    }
    body[data-theme="light"] .monitor-mobile-cell{
      background:rgba(105,88,255,.04);
      border:1px solid rgba(148,163,184,.18);
    }
    body[data-theme="light"] .monitor-sync-badge{
      background:rgba(105,88,255,.12);
      color:#5b57de;
    }
    body[data-theme="light"] .monitor-sync-status.idle{background:rgba(105,88,255,.12);color:#5b57de}
    body[data-theme="light"] .monitor-sync-status.syncing{background:rgba(245,158,11,.14);color:#c77f08}
    body[data-theme="light"] .monitor-sync-status.success{background:rgba(34,197,94,.14);color:#178658}
    body[data-theme="light"] .monitor-sync-status.error{background:rgba(239,68,68,.14);color:#c33d57}
    body[data-theme="light"] .monitor-mobile-name,
    body[data-theme="light"] .monitor-mobile-value,
    body[data-theme="light"] .monitor-sync-time{
      color:#24304a;
    }
    body[data-theme="light"] .table-pager-meta,
    body[data-theme="light"] .table-pager-page{
      color:#6f7d98;
    }
    body[data-theme="light"] .monitor-mobile-meta,
    body[data-theme="light"] .monitor-sync-time-label,
    body[data-theme="light"] .monitor-sync-detail{
      color:#6f7d98;
    }
    @media (max-width: 768px) {
      .topbar { align-items:flex-start; }
      .topbar .tb-right { width:100%; }
      .monitor-topbar-actions {
        display:grid;
        grid-template-columns:minmax(0,1fr);
        gap:8px;
      }
      .monitor-topbar-main {
        display:grid;
        grid-template-columns:minmax(0,1fr) auto;
        align-items:center;
        gap:8px;
      }
      .monitor-topbar-shortcuts {
        display:grid;
        grid-template-columns:repeat(3,minmax(0,1fr));
        gap:8px;
        width:100%;
      }
      .monitor-topbar-shortcuts .btn,
      .monitor-topbar-shortcuts .adm-badge {
        justify-content:center;
        min-height:42px;
        height:42px;
      }
      .router-selector { width:100%; justify-content:space-between; padding:10px 12px !important; border-radius:16px !important; margin:0; }
      .router-selector .fs { width:100% !important; }
      .mtabs, .tabs { overflow:auto; padding-bottom:8px; scrollbar-width:none; margin-bottom:12px; }
      .mtabs::-webkit-scrollbar, .tabs::-webkit-scrollbar { display:none; }
      .mtab, .tab { white-space:nowrap; }
      .mikrotik-monitor-page .mtabs{
        display:grid;
        grid-template-columns:repeat(3,minmax(0,1fr));
        gap:8px;
        border-bottom:none;
        padding-bottom:0;
      }
      .mikrotik-monitor-page .mtab{
        justify-content:center;
        gap:6px;
        padding:10px 12px;
        border-radius:14px;
        font-size:12px;
        text-align:center;
      }
      .mikrotik-monitor-page .mtab i{
        font-size:13px;
      }
      .monitor-sync {
        display:grid;
        grid-template-columns:minmax(0,1fr) auto;
        align-items:start;
        gap:10px;
        padding:10px 11px;
      }
      .monitor-sync-meta { gap:4px; min-width:0; }
      .monitor-toolbar {
        display:flex;
        flex-direction:column;
        align-items:stretch;
        justify-content:flex-start;
        gap:8px;
        width:100%;
      }
      .monitor-toolbar-stack{
        display:none;
        width:100%;
        grid-template-columns:1fr;
        gap:8px;
      }
      .monitor-toolbar.is-open .monitor-toolbar-stack{ display:grid; }
      .monitor-toolbar.monitor-toolbar-pppoe .monitor-toolbar-stack{ grid-template-columns:1fr; }
      .monitor-toolbar.monitor-toolbar-simple .monitor-toolbar-stack{ grid-template-columns:1fr; }
      .monitor-toolbar .fc-sm,
      .monitor-toolbar .fs-sm {
        min-width:0;
        width:100%;
        min-height:38px;
      }
      .monitor-toolbar-actions{
        width:100%;
        justify-content:space-between;
      }
      .monitor-toolbar .btn { justify-content:center; min-height:38px; height:38px; }
      .monitor-toolbar-actions .btn{ flex:1 1 0; }
      .monitor-filter-toggle{ display:inline-flex; }
      .monitor-sync-row { align-items:center; flex-direction:row; gap:8px; }
      .monitor-sync-time { font-size:13px; }
      #monitor-refresh-btn { min-height:38px; height:38px; padding:0 12px; align-self:flex-start; }
      .monitor-mobile-actions .btn { min-height:34px; height:34px; border-radius:11px; }
      .table-pager { align-items:stretch; }
      .table-pager-actions { width:100%; justify-content:space-between; }
      .table-pager-page { flex:1; }
      .tbl-wrap { display:none; }
      .monitor-mobile-list { display:block; }
      .mikrotik-monitor-page .stat-grid {
        display:grid;
        grid-auto-flow:column;
        grid-auto-columns:minmax(138px,1fr);
        grid-template-columns:none !important;
        overflow-x:auto;
        overflow-y:hidden;
        gap:8px !important;
        margin-bottom:12px !important;
        padding-bottom:4px;
        scrollbar-width:none;
      }
      .mikrotik-monitor-page .stat-grid::-webkit-scrollbar { display:none; }
      .mikrotik-monitor-page .stat-grid .sc { padding:10px 11px 9px; min-width:138px; }
      .mikrotik-monitor-page .stat-grid .sc-icon { width:34px; height:34px; font-size:15px; top:12px; right:12px; }
      .mikrotik-monitor-page .stat-grid .sc-val { font-size:16px; margin-top:7px; }
      .mikrotik-monitor-page .stat-grid .sc-label { max-width:68%; font-size:9px; }
      .mikrotik-monitor-page .card { border-radius:18px; }
      .mikrotik-monitor-page .card-hd { flex-direction:column; align-items:stretch; }
      .mikrotik-monitor-page .monitor-card-hd h6{ margin-bottom:0; }
      .mikrotik-monitor-page .tabs {
        display:grid;
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:8px;
        border-bottom:none;
        padding-bottom:0;
        margin-bottom:12px;
      }
      .mikrotik-monitor-page .tab{
        justify-content:center;
        text-align:center;
        padding:10px 12px;
        border-radius:14px;
        font-size:12px;
        line-height:1.15;
      }
    }
    @media (max-width: 520px) {
      .topbar { padding:12px 14px; border-radius:20px; }
      .monitor-topbar-actions { gap:6px; }
      .monitor-topbar-main { grid-template-columns:minmax(0,1fr) 42px; gap:6px; }
      .monitor-topbar-shortcuts { grid-template-columns:repeat(3,minmax(0,1fr)); gap:6px; }
      .monitor-topbar-shortcuts .btn,
      .monitor-topbar-shortcuts .adm-badge { min-height:38px; height:38px; font-size:11px; }
      .monitor-topbar-shortcuts .tb-theme-btn span,
      .monitor-topbar-shortcuts .adm-badge { font-size:10px; }
      .monitor-topbar-shortcuts .tb-theme-btn span { display:none; }
      .monitor-topbar-shortcuts .tb-theme-btn { padding-inline:0; }
      .monitor-topbar-shortcuts .btn i,
      .monitor-topbar-shortcuts .adm-badge i { margin-right:0; }
      .monitor-topbar-shortcuts .btn { gap:5px; }
      .monitor-mobile-grid { grid-template-columns:repeat(2,minmax(0,1fr)); gap:6px; }
      .monitor-mobile-card { padding:8px 9px; }
      .monitor-mobile-head { gap:7px; margin-bottom:5px; }
      .monitor-mobile-name { font-size:12.5px; }
      .monitor-mobile-meta { font-size:9.5px; }
      .monitor-mobile-cell { padding:6px 7px; border-radius:10px; }
      .monitor-mobile-label { font-size:8.5px; margin-bottom:2px; }
      .monitor-mobile-value { font-size:10px; line-height:1.2; }
      .monitor-mobile-actions { grid-template-columns:1fr 1fr; }
      .monitor-sync { gap:8px; padding:9px 10px; }
      .monitor-sync-title { font-size:10px; }
      .monitor-sync-time-label { font-size:10px; }
      .monitor-sync-detail { font-size:10px; line-height:1.35; }
      #monitor-refresh-btn { min-height:36px; height:36px; padding:0 10px; font-size:11px; }
      .mikrotik-monitor-page .stat-grid .sc { border-radius:16px; padding:9px 9px 8px; min-width:132px; }
      .mikrotik-monitor-page .stat-grid .sc-label { font-size:9px; max-width:72%; }
      .mikrotik-monitor-page .stat-grid .sc-val { font-size:14px; margin-top:6px; }
      .mikrotik-monitor-page .stat-grid .sc-icon { width:30px; height:30px; font-size:13px; top:10px; right:10px; }
      .mikrotik-monitor-page .mtabs { gap:6px; margin-bottom:10px; }
      .mikrotik-monitor-page .mtab{
        padding:9px 8px;
        font-size:11px;
        gap:4px;
      }
      .mikrotik-monitor-page .mtab i{font-size:12px}
      .mikrotik-monitor-page .mtab span,
      .mikrotik-monitor-page .mtab{line-height:1.1}
      .mikrotik-monitor-page .tabs { gap:6px; margin-bottom:10px; }
      .mikrotik-monitor-page .tab { font-size:11px; padding:9px 8px; }
      .monitor-toolbar .fs-sm { min-width:0; font-size:11px; }
      .monitor-toolbar .btn { font-size:11px; padding:0 10px; }
      .monitor-sync-badge { font-size:9px; padding:3px 7px; }
      .monitor-sync-time { font-size:12.5px; }
      .router-selector { padding:9px 11px !important; }
      .router-selector .fs { font-size:13px; }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'mikrotik', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-router"></i> <%= t('admin.nav.mikrotik_monitoring', 'Monitoring MikroTik') %></div>
    <div class="tb-right">
      <div class="monitor-topbar-actions">
        <div class="monitor-topbar-main">
          <div class="router-selector">
            <i class="bi bi-hdd-network small"></i>
            <% const defaultRouter = (routers || []).find(r => Number(r.is_active || 0) === 1) || (routers || [])[0] || null; %>
            <select id="global-router-id" class="fs" data-default-router-id="<%= defaultRouter ? defaultRouter.id : '' %>" onchange="changeRouter()">
              <option value="" style="color:black"><%= t('admin.mikrotik.default_router', '-- Default Router --') %></option>
              <% routers.forEach(r => { %>
                <option value="<%= r.id %>" style="color:black" <%= defaultRouter && String(defaultRouter.id) === String(r.id) ? 'selected' : '' %>><%= r.name %></option>
              <% }) %>
            </select>
          </div>
          <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
            <i class="bi bi-sun"></i>
            <span>Terang</span>
          </button>
        </div>
        <div class="monitor-topbar-shortcuts">
          <a href="#" onclick="downloadBackup(event)" class="btn btn-p btn-sm"><i class="bi bi-download"></i> <span>Backup</span></a>
          <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %></span>
          <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i> <span>Logout</span></a>
        </div>
      </div>
    </div>
  </div>
<div class="page admin-shell-page mikrotik-monitor-page">
    <% const mTab = 'monitoring'; %>

    <div class="mtabs">
      <a href="/admin/mikrotik" class="mtab <%= mTab==='monitoring' ? 'active' : '' %>"><i class="bi bi-router"></i> Data MikroTik</a>
      <a href="/admin/vouchers" class="mtab <%= mTab==='vouchers' ? 'active' : '' %>"><i class="bi bi-ticket-perforated"></i> Voucher</a>
      <a href="/admin/routers" class="mtab <%= mTab==='routers' ? 'active' : '' %>"><i class="bi bi-hdd-network"></i> Router</a>
    </div>

    <div class="monitor-sync">
      <div class="monitor-sync-meta">
        <div class="monitor-sync-top">
          <div class="monitor-sync-title">Status Data MikroTik</div>
          <div class="monitor-sync-badge"><i class="bi bi-lightning-charge-fill"></i> Auto saat buka</div>
        </div>
        <div class="monitor-sync-row">
          <div class="monitor-sync-time-label">Update terakhir</div>
          <div class="monitor-sync-time" id="monitor-last-update">Belum dimuat</div>
          <div class="monitor-sync-status idle" id="monitor-sync-status"><i class="bi bi-pause-circle"></i><span>Menunggu</span></div>
        </div>
        <div class="monitor-sync-detail" id="monitor-sync-detail">Data cache tampil lebih dulu. Gunakan refresh manual untuk ambil data router terbaru.</div>
      </div>
      <button class="btn btn-p btn-sm" id="monitor-refresh-btn" onclick="refreshNow()"><i class="bi bi-arrow-clockwise"></i> Refresh Manual</button>
    </div>

    <!-- Summary Cards -->
    <div class="stat-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:20px">
      <div class="sc p"><i class="bi bi-ethernet sc-icon"></i><div class="sc-label"><%= t('admin.mikrotik.stats.pppoe_online', 'PPPoE Online') %></div><div class="sc-val" id="pppoe-online-count">0</div></div>
      <div class="sc s"><i class="bi bi-wifi sc-icon"></i><div class="sc-label"><%= t('admin.mikrotik.stats.hotspot_online', 'Hotspot Online') %></div><div class="sc-val" id="hotspot-online-count">0</div></div>
      <div class="sc w"><i class="bi bi-people sc-icon"></i><div class="sc-label"><%= t('admin.mikrotik.stats.total_secrets', 'Total Secrets') %></div><div class="sc-val" id="total-secrets-count">0</div></div>
      <div class="sc d"><i class="bi bi-person-badge sc-icon"></i><div class="sc-label"><%= t('admin.mikrotik.stats.total_hotspot', 'Total Hotspot') %></div><div class="sc-val" id="total-hotspot-count">0</div></div>
    </div>

    <div class="tabs">
      <div class="tab active" onclick="showTab(event, 'pppoe')">PPPoE</div>
      <div class="tab" onclick="showTab(event, 'hotspot')">Hotspot</div>
      <div class="tab" onclick="showTab(event, 'pppoe-profiles')">Profil PPPoE</div>
      <div class="tab" onclick="showTab(event, 'hotspot-profiles-tab')">Profil Hotspot</div>
    </div>

    <!-- PPPoE Tab -->
    <div id="pppoe" class="tab-content active">
      <div class="card">
        <div class="card-hd monitor-card-hd">
          <h6><i class="bi bi-ethernet"></i> <%= t('admin.mikrotik.pppoe.title', 'Daftar PPPoE Secrets') %></h6>
          <div class="monitor-toolbar monitor-toolbar-pppoe" id="pppoe-toolbar">
            <div class="monitor-toolbar-stack">
              <input type="text" class="fc fc-sm" id="pppoe-search" placeholder="<%= t('admin.mikrotik.search_placeholder', 'Cari...') %>" oninput="setSecretsSearch(this.value)">
              <select class="fs fs-sm" id="pppoe-status-filter" onchange="setSecretsStatusFilter(this.value)">
                <option value="all">Semua Status</option>
                <option value="online">Online</option>
                <option value="offline">Offline</option>
                <option value="disabled">Disabled</option>
              </select>
            </div>
            <div class="monitor-toolbar-actions">
              <button type="button" class="btn btn-g btn-sm monitor-filter-toggle" onclick="toggleMonitorToolbar('pppoe-toolbar', this)" aria-expanded="false"><i class="bi bi-funnel"></i> Filter</button>
              <button class="btn btn-p btn-sm" onclick="openAddSecret()"><i class="bi bi-plus-lg"></i> <%= t('admin.mikrotik.actions.add_secret', 'Tambah Secret') %></button>
            </div>
          </div>
        </div>
        <div class="tbl-wrap">
          <table class="dtbl">
            <thead>
              <tr><th>Name</th><th>Profile</th><th>Last Online</th><th>Offline</th><th>Remote Address</th><th>Uptime</th><th>Status</th><th><%= t('common.actions', 'Aksi') %></th></tr>
            </thead>
            <tbody id="pppoe-list">
              <tr><td colspan="8" class="text-center text-muted"><%= t('common.loading', 'Memuat data...') %></td></tr>
            </tbody>
          </table>
        </div>
        <div class="monitor-mobile-list" id="pppoe-mobile-list">
          <div class="monitor-mobile-empty"><%= t('common.loading', 'Memuat data...') %></div>
        </div>
        <div class="table-pager">
