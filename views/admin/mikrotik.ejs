  async function refreshVisibleMonitoringData(force = false, reason = 'auto') {
    if (hasOpenModal()) return;
    const isManual = reason === 'manual';
    const waitingMessage = isManual
      ? 'Refresh manual dimulai. Tunggu sekitar 5 detik sebelum semua data diperbarui...'
      : 'Sedang mengambil data MikroTik untuk disimpan ke cache...';
    const loadingMessage = isManual
      ? 'Sedang memperbarui semua data MikroTik dari router...'
      : 'Sedang memuat semua data MikroTik dari router...';

    setMonitoringSyncStatus('syncing', waitingMessage);
    if (isManual) {
      await waitMs(5000);
    }
    setMonitoringSyncStatus('syncing', loadingMessage);
    await loadMonitoringSummary(force);
    await Promise.all([
      loadSecrets(force),
      loadHotspotUsers(force),
      loadPppoeProfiles(force),
      loadHotspotUserProfiles(force)
    ]);
    const now = new Date();
    setMonitoringSyncStatus('success', isManual ? 'Refresh manual selesai. Data MikroTik sudah diperbarui.' : 'Data MikroTik berhasil dimuat dan disimpan ke cache.', now);
    persistMonitoringCache();
  }

  async function queueMonitoringRefresh(force = false, reason = 'auto') {
    if (monitoringRefreshPromise) {
      pendingMonitoringRefresh = {
        force: pendingMonitoringRefresh ? (pendingMonitoringRefresh.force || force) : force,
        reason
      };
      return monitoringRefreshPromise;
    }
    monitoringRefreshPromise = refreshVisibleMonitoringData(force, reason)
      .finally(() => {
        monitoringRefreshPromise = null;
        if (pendingMonitoringRefresh) {
          const nextRefresh = pendingMonitoringRefresh;
          pendingMonitoringRefresh = null;
          queueMonitoringRefresh(nextRefresh.force, nextRefresh.reason).catch((error) => {
            console.error('Queued monitoring refresh failed:', error);
            setMonitoringSyncStatus('error', `Muat ulang data gagal: ${error.message || error}`);
          });
        }
      });
    return monitoringRefreshPromise;
  }

  async function refreshNow() {
    try {
      await queueMonitoringRefresh(true, 'manual');
    } catch (error) {
      console.error('Manual monitoring refresh failed:', error);
      setMonitoringSyncStatus('error', `Refresh manual gagal: ${error.message || error}`);
    }
  }

  async function loadProfiles() {
    try {
      const routerId = encodeURIComponent(getRouterId() || '');
      const [pResult, hResult] = await Promise.allSettled([
        fetchJsonWithTimeout(`/admin/api/mikrotik/profiles?routerId=${routerId}`),
        fetchJsonWithTimeout(`/admin/api/mikrotik/hotspot-user-profiles?routerId=${routerId}`)
      ]);
      const pProfiles = pResult.status === 'fulfilled' && Array.isArray(pResult.value) ? pResult.value : [];
      const hProfiles = hResult.status === 'fulfilled' && Array.isArray(hResult.value) ? hResult.value : [];

      const pSel = document.getElementById('s_profile');
      pSel.replaceChildren();
      pProfiles.forEach((p) => {
        const option = document.createElement('option');
        option.value = String(p.name || '');
        option.textContent = String(p.name || '');
        pSel.appendChild(option);
      });

      const hSel = document.getElementById('h_profile');
      hSel.replaceChildren();
      hProfiles.forEach((p) => {
        const option = document.createElement('option');
        option.value = String(p.name || '');
        option.textContent = String(p.name || '');
        hSel.appendChild(option);
      });
    } catch (err) {
      console.error('Error loadProfiles:', err);
    }
  }

  async function ensureProfileOptionsLoaded(force = false) {
    const routerKey = String(getRouterId() || '');
    if (!force && profileOptionsPromise && profileOptionsRouterKey === routerKey) {
      return profileOptionsPromise;
    }
    profileOptionsRouterKey = routerKey;
    profileOptionsPromise = loadProfiles().catch((err) => {
      profileOptionsPromise = null;
      throw err;
    });
    return profileOptionsPromise;
  }

