  function restoreMonitoringCacheForCurrentRouter() {
    const entry = getMonitoringCacheEntry();
    if (!entry || !entry.tableState) return false;
    const cachedSummary = entry.summary || {};
    const cachedPppoeItems = Array.isArray(entry.pppoe?.items) ? entry.pppoe.items : [];
    const cachedHotspotItems = Array.isArray(entry.hotspot?.items) ? entry.hotspot.items : [];
    const seemsBrokenEmptyState =
      Number(cachedSummary.pppoeOnline || 0) === 0 &&
      Number(cachedSummary.hotspotOnline || 0) === 0 &&
      Number(cachedSummary.totalSecrets || 0) === 0 &&
      Number(cachedSummary.totalHotspot || 0) === 0 &&
      cachedPppoeItems.length === 0 &&
      cachedHotspotItems.length === 0;
    if (seemsBrokenEmptyState) return false;

    tableState.pppoe = { ...tableState.pppoe, ...(entry.tableState.pppoe || {}) };
    tableState.hotspot = { ...tableState.hotspot, ...(entry.tableState.hotspot || {}) };
    tableState.pppoeProfiles = { ...tableState.pppoeProfiles, ...(entry.tableState.pppoeProfiles || {}) };
    tableState.hotspotProfiles = { ...tableState.hotspotProfiles, ...(entry.tableState.hotspotProfiles || {}) };
    applySearchInputs();

    applySummaryData(entry.summary || {}, { skipPersist: true });
    applyPppoeResponse({
      ...(entry.tableState.pppoe || {}),
      items: entry.pppoe?.items || []
    }, { skipPersist: true });
    applyHotspotResponse({
      ...(entry.tableState.hotspot || {}),
      items: entry.hotspot?.items || []
    }, { skipPersist: true });
    applyPppoeProfilesResponse({
      ...(entry.tableState.pppoeProfiles || {}),
      items: entry.pppoeProfiles?.items || []
    }, { skipPersist: true });
    applyHotspotProfilesResponse({
      ...(entry.tableState.hotspotProfiles || {}),
      items: entry.hotspotProfiles?.items || []
    }, { skipPersist: true });

    const lastSuccessAt = entry.lastSuccessAt ? new Date(entry.lastSuccessAt) : (entry.savedAt ? new Date(entry.savedAt) : null);
    monitoringSync.lastSuccessAt = lastSuccessAt && !Number.isNaN(lastSuccessAt.getTime()) ? lastSuccessAt : null;
    setMonitoringSyncStatus('success', 'Menampilkan data MikroTik dari cache. Tekan Refresh Manual kalau ingin ambil data terbaru dari router.', monitoringSync.lastSuccessAt);
    return true;
  }

  function refreshMonitoringAfterCacheRestore(reason = 'auto') {
    setMonitoringSyncStatus('syncing', 'Menampilkan cache tersimpan. Mengambil data terbaru dari router...');
    queueMonitoringRefresh(false, reason).catch((error) => {
      console.error('Background monitoring refresh failed:', error);
      setMonitoringSyncStatus('error', `Muat data terbaru gagal: ${error.message || error}`);
    });
  }

  function hasOpenModal() {
    return Boolean(document.querySelector('.mo.show'));
  }

  function formatSyncTime(date) {
    if (!date) return 'Belum dimuat';
    return new Intl.DateTimeFormat('id-ID', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      day: '2-digit',
      month: 'short'
    }).format(date);
  }

  function renderMonitoringSyncState() {
    const timeEl = document.getElementById('monitor-last-update');
    const statusEl = document.getElementById('monitor-sync-status');
    const detailEl = document.getElementById('monitor-sync-detail');
    const refreshBtn = document.getElementById('monitor-refresh-btn');
    if (timeEl) timeEl.textContent = formatSyncTime(monitoringSync.lastSuccessAt);
    if (detailEl) detailEl.textContent = monitoringSync.detail;
    if (statusEl) {
      const labelMap = {
        idle: { icon: 'pause-circle', text: 'Menunggu' },
        syncing: { icon: 'arrow-repeat', text: 'Memuat data' },
        success: { icon: 'check-circle', text: 'Siap dipakai' },
        error: { icon: 'exclamation-circle', text: 'Gagal muat' }
      };
      const current = labelMap[monitoringSync.status] || labelMap.idle;
      statusEl.className = `monitor-sync-status ${monitoringSync.status}`;
      statusEl.replaceChildren();
      const icon = document.createElement('i');
      icon.className = `bi bi-${current.icon}`;
      const label = document.createElement('span');
      label.textContent = String(current.text || '');
      statusEl.appendChild(icon);
      statusEl.appendChild(label);
    }
    if (refreshBtn) {
      refreshBtn.disabled = monitoringSync.status === 'syncing';
      refreshBtn.replaceChildren();
      const icon = document.createElement('i');
      icon.className = monitoringSync.status === 'syncing' ? 'bi bi-arrow-repeat' : 'bi bi-arrow-clockwise';
      refreshBtn.appendChild(icon);
      refreshBtn.append(document.createTextNode(monitoringSync.status === 'syncing' ? ' Memuat data...' : ' Refresh Manual'));
    }
  }

  function setMonitoringSyncStatus(status, detail, lastSuccessAt = null) {
    monitoringSync.status = status;
    if (typeof detail === 'string' && detail.trim()) monitoringSync.detail = detail;
    if (lastSuccessAt) monitoringSync.lastSuccessAt = lastSuccessAt;
    renderMonitoringSyncState();
  }

  function buildMonitoringUrl(path, params = {}, force = false) {
    const query = new URLSearchParams();
    for (const [key, value] of Object.entries(params || {})) {
      if (value === undefined || value === null || value === '') continue;
      query.set(key, String(value));
    }
    if (force) query.set('force', '1');
    const qs = query.toString();
    return qs ? `${path}?${qs}` : path;
  }

  function waitMs(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }

  function resetMonitoringView(message = 'Data router sedang disiapkan...') {
    document.getElementById('pppoe-online-count').innerText = '0';
    document.getElementById('hotspot-online-count').innerText = '0';
    document.getElementById('total-secrets-count').innerText = '0';
    document.getElementById('total-hotspot-count').innerText = '0';
    setTableMessage('pppoe-list', 8, message);
    setTableMessage('hotspot-list', 8, message);
    setTableMessage('pppoe-profiles-list', 5, message);
    setTableMessage('hotspot-profiles-list', 7, message);
    setMobileListMessage('pppoe-mobile-list', message);
    setMobileListMessage('hotspot-mobile-list', message);
    setMobileListMessage('pppoe-profiles-mobile-list', message);
    setMobileListMessage('hotspot-profiles-mobile-list', message);
  }

  function updatePaginationUi(kind) {
    const state = tableState[kind];
    if (!state) return;
    const metaEl = document.getElementById(`${kind}-pagination-meta`);
    const pageEl = document.getElementById(`${kind}-pagination-page`);
    const prevBtn = document.getElementById(`${kind}-prev-btn`);
    const nextBtn = document.getElementById(`${kind}-next-btn`);
    const filtered = Number(state.filteredTotal || 0);
    const total = Number(state.total || 0);
    if (metaEl) {
      metaEl.textContent = filtered
        ? `Menampilkan ${filtered} data cocok dari total ${total}`
        : `Tidak ada data yang cocok dari total ${total}`;
    }
    if (pageEl) {
      pageEl.textContent = `Page ${state.page} / ${Math.max(1, state.totalPages || 1)}`;
    }
    if (prevBtn) prevBtn.disabled = state.page <= 1;
    if (nextBtn) nextBtn.disabled = state.page >= Math.max(1, state.totalPages || 1);
  }

  function scheduleTableSearch(kind, value) {
    clearTimeout(searchDebounceTimer);
    searchDebounceTimer = setTimeout(() => {
      tableState[kind].q = String(value || '').trim();
      tableState[kind].page = 1;
      if (kind === 'pppoe') loadSecrets();
      else if (kind === 'hotspot') loadHotspotUsers();
      else if (kind === 'pppoeProfiles') loadPppoeProfiles();
      else if (kind === 'hotspotProfiles') loadHotspotUserProfiles();
    }, 250);
  }

