    stopCustomerTrafficPopup(customerId);
    refreshCustomerTrafficPopup(customerId);
    customerTrafficIntervals[customerId] = setInterval(() => refreshCustomerTrafficPopup(customerId), 3000);
  }

  function stopCustomerTrafficPopup(customerId) {
    const t = customerTrafficIntervals[customerId];
    if (t) clearInterval(t);
    delete customerTrafficIntervals[customerId];
