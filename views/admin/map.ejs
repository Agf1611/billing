  function drawSparkline(canvas, series, maxMbps, color) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const w = canvas.width;
    const h = canvas.height;
    const padX = 6;
    const padY = 8;
    const innerW = w - padX * 2;
    const innerH = h - padY * 2;
    const max = Number.isFinite(maxMbps) && maxMbps > 0 ? maxMbps : 10;
    let vals = Array.isArray(series) ? series : [];

    ctx.clearRect(0, 0, w, h);

    ctx.strokeStyle = 'rgba(148, 163, 184, 0.22)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    for (let i = 0; i <= 3; i++) {
      const y = padY + (innerH * i) / 3;
      ctx.moveTo(padX, y);
      ctx.lineTo(padX + innerW, y);
    }
    ctx.stroke();

    if (vals.length === 1) vals = [vals[0], vals[0]];
    if (vals.length < 2) return;

    const toY = (v) => {
      const n = Math.max(0, Number(v || 0) || 0);
      const r = Math.min(1, n / max);
      return padY + innerH * (1 - r);
    };

    const grad = ctx.createLinearGradient(padX, padY, padX + innerW, padY);
    grad.addColorStop(0, color);
    grad.addColorStop(1, 'rgba(255,255,255,0.0)');

    ctx.beginPath();
    for (let i = 0; i < vals.length; i++) {
      const x = padX + (innerW * i) / (vals.length - 1);
      const y = toY(vals[i]);
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.stroke();

    ctx.lineTo(padX + innerW, padY + innerH);
    ctx.lineTo(padX, padY + innerH);
    ctx.closePath();
    ctx.fillStyle = grad;
    ctx.globalAlpha = 0.22;
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  function setOverlay(customerId, kind, text) {
    const el = document.getElementById(`cust_${customerId}_${kind}_state`);
    if (!el) return;
