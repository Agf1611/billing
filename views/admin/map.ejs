<script id="settings-data" type="application/json"><%- JSON.stringify(settings) %></script>
<script id="customers-data" type="application/json"><%- JSON.stringify(customers).replace(/<\/script/g, '<\\/script').replace(/<!--/g, '<\\!--') %></script>
<script id="odps-data" type="application/json"><%- JSON.stringify(odps).replace(/<\/script/g, '<\\/script').replace(/<!--/g, '<\\!--') %></script>
<script id="network-links-data" type="application/json"><%- JSON.stringify(networkLinks || []).replace(/<\/script/g, '<\\/script').replace(/<!--/g, '<\\!--') %></script>
<script id="staff-locations-data" type="application/json"><%- JSON.stringify(staffLocations || []).replace(/<\/script/g, '<\\/script').replace(/<!--/g, '<\\!--') %></script>
<script>
  const I18N = {
    layerOsm: "<%= t('admin.map.layers.osm', 'OpenStreetMap') %>",
    layerHybrid: "<%= t('admin.map.layers.hybrid', 'Satelit (Hybrid)') %>",
    popupDescription: "<%= t('admin.map.popup.description', 'Deskripsi') %>",
    popupLocation: "<%= t('admin.map.popup.location', 'Lokasi') %>",
    popupEdit: "<%= t('common.edit', 'Edit') %>",
    popupStatus: "<%= t('admin.map.popup.status', 'Status') %>",
    popupPackage: "<%= t('admin.map.popup.package', 'Paket') %>",
    popupAddress: "<%= t('admin.map.popup.address', 'Alamat') %>",
    viewDetails: "<%= t('admin.map.popup.view_details', 'Lihat Detail') %>",
    statusActive: "<%= t('admin.map.status.active', 'Aktif') %>",
    statusSuspended: "<%= t('admin.map.status.suspended', 'Isolir') %>"
  };

  const appSettings = JSON.parse(document.getElementById('settings-data').textContent);
  const officeCoords = {
    lat: parseFloat(appSettings.office_lat) || -7.140868012256965,
    lng: parseFloat(appSettings.office_lng) || 107.00277733308137
  };

  // Initialize Map
  const map = L.map('map', {
    editable: true,
    tap: false
  }).setView([officeCoords.lat, officeCoords.lng], 13);
  map.createPane('customerLabelPane');
  map.getPane('customerLabelPane').style.zIndex = '640';
  map.getPane('customerLabelPane').style.pointerEvents = 'none';

  let currentEditingPolyline = null;
  let currentEditingCustomer = null;
  let activeCustomerCardId = null;
  let activeCustomerMarker = null;
  let activeCustomerAnchorMarker = null;
  let selectedCustomerId = null;
  let selectedCustomerAnchorMarker = null;
  const customerMarkers = [];
  const customerMarkerRefs = new Map();
  let lastCustomerMapTapAt = 0;
  let suppressCustomerOpenUntil = 0;
  let customerLabelRetryTimer = null;
  let relocatingCustomerId = null;
  let relocatingCustomerLatLng = null;
  let relocatingPreviewMarker = null;
  let linkingCustomerId = null;
  let linkingTargetOdpId = null;
  let linkingBackboneSourceOdpId = null;
  let drawingMode = 'customer';
  let currentEditingBackbone = null;
  const MAP_STATE_KEY = 'admin-network-map-state-v3';

  // Layers
  const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: 'Â© OpenStreetMap'
  });

  const googleHybrid = L.tileLayer('https://{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
    maxZoom: 20,
    subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
    attribution: 'Â© Google Satellite'
  });

  osm.addTo(map);
  googleHybrid.addTo(map);

  const baseMaps = {
    [I18N.layerOsm]: osm,
    [I18N.layerHybrid]: googleHybrid
  };

  let customers = [];
  let odps = [];
  let networkLinks = [];
  let staffLocations = [];
  try {
    customers = JSON.parse(document.getElementById('customers-data').textContent || '[]');
    odps = JSON.parse(document.getElementById('odps-data').textContent || '[]');
    networkLinks = JSON.parse(document.getElementById('network-links-data').textContent || '[]');
    staffLocations = JSON.parse(document.getElementById('staff-locations-data').textContent || '[]');
  } catch (e) {
    console.error("Data mapping error:", e);
  }

  const odpLayer = L.layerGroup().addTo(map);
  const backboneLayer = L.layerGroup().addTo(map);
  const customerLayer = L.layerGroup().addTo(map);
  const customerTouchLayer = L.layerGroup().addTo(map);
  const customerLabelLayer = L.layerGroup().addTo(map);
  const customerRelocateLayer = L.layerGroup().addTo(map);
  const staffLayer = L.layerGroup().addTo(map);

  // Add ODP Markers
  function renderOdpBoxIcon(className = '') {
    const extra = className ? ` ${className}` : '';
    return `<span class="odp-box-icon${extra}" aria-hidden="true"></span>`;
  }

  function loadSavedMapState() {
    try {
      const raw = window.sessionStorage ? sessionStorage.getItem(MAP_STATE_KEY) : '';
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (!parsed || !Number.isFinite(Number(parsed.lat)) || !Number.isFinite(Number(parsed.lng)) || !Number.isFinite(Number(parsed.zoom))) {
        return null;
      }
      return {
        lat: Number(parsed.lat),
        lng: Number(parsed.lng),
        zoom: Number(parsed.zoom),
        selectedCustomerId: Number(parsed.selectedCustomerId || 0) || null
      };
    } catch {
      return null;
    }
  }

  function saveMapState(extra = {}) {
    try {
      if (!window.sessionStorage || !map) return;
      const center = map.getCenter();
      const payload = {
        lat: Number(center.lat.toFixed(6)),
        lng: Number(center.lng.toFixed(6)),
        zoom: Number(map.getZoom() || 13),
        selectedCustomerId: selectedCustomerId || null,
        ...extra
      };
      sessionStorage.setItem(MAP_STATE_KEY, JSON.stringify(payload));
    } catch {}
  }

  function restoreSelectedCustomerFromState(state) {
    if (!state?.selectedCustomerId) return;
    const ref = customerMarkerRefs.get(String(state.selectedCustomerId));
    if (!ref?.touchMarker) return;
    selectedCustomerId = Number(state.selectedCustomerId);
    selectedCustomerAnchorMarker = ref.touchMarker;
    requestAnimationFrame(() => {
      try { openCustomerCard(ref.touchMarker); } catch {}
    });
  }

  function getMapLinkStyle(link) {
    const kind = String(link?.link_kind || '').trim().toLowerCase();
    const sizeText = String(link?.cable_size || '').trim();
    const parsedSize = Number((sizeText.match(/\d+/) || [0])[0] || 0);
    const weight = Math.max(3, Math.min(9, parsedSize ? Math.round(parsedSize / 12) + 2 : kind === 'backbone' ? 6 : 4));
    if (kind === 'backbone') {
      return { color: '#8b5cf6', weight, opacity: 0.9, dashArray: null };
    }
    return { color: '#14b8a6', weight, opacity: 0.88, dashArray: '10, 8' };
  }

  function buildBackbonePopupHtml(link) {
    const kindText = String(link?.link_kind || '').trim().toLowerCase() === 'backbone' ? 'Backbone' : 'ODP ke ODP';
    const sizeText = String(link?.cable_size || '').trim() || '-';
    return `
      <div class="odp-popup">
        <div class="odp-popup-head">
          <span class="odp-popup-badge">${escapeHtml(kindText)}</span>
          <div class="odp-popup-name">${escapeHtml(String(link?.from_odp_name || 'ODP').trim())} → ${escapeHtml(String(link?.to_odp_name || 'ODP').trim())}</div>
        </div>
        <div class="odp-popup-section">
          <div class="odp-popup-meta">
            <div class="odp-popup-meta-row"><i class="bi bi-diagram-3"></i><span>${escapeHtml(kindText)}</span></div>
            <div class="odp-popup-meta-row"><i class="bi bi-hdd-network"></i><span>${escapeHtml(sizeText)}</span></div>
          </div>
        </div>
      </div>
    `;
  }

  function normalizeCustomerPath(pathCoords, customerCoord, odpCoord) {
    const valid = Array.isArray(pathCoords) ? pathCoords.filter((item) => Array.isArray(item) && item.length >= 2) : [];
    if (valid.length < 2) return [odpCoord, customerCoord];
    const first = valid[0];
    const last = valid[valid.length - 1];
    const firstToOdp = Math.hypot(Number(first[0] || 0) - Number(odpCoord[0] || 0), Number(first[1] || 0) - Number(odpCoord[1] || 0));
    const lastToOdp = Math.hypot(Number(last[0] || 0) - Number(odpCoord[0] || 0), Number(last[1] || 0) - Number(odpCoord[1] || 0));
    return firstToOdp <= lastToOdp ? valid : valid.slice().reverse();
  }

  function getOdpConnectedCustomers(odpId) {
    return customers
      .filter((cust) => Number(cust.odp_id || 0) === Number(odpId || 0))
      .sort((a, b) => String(a.name || '').localeCompare(String(b.name || ''), 'id-ID', { sensitivity: 'base' }));
  }

  function buildOdpPopupHtml(odp) {
    const connectedCustomers = getOdpConnectedCustomers(odp.id);
    const previewCustomers = connectedCustomers.slice(0, 4);
    const hiddenCount = Math.max(0, connectedCustomers.length - previewCustomers.length);
    const capacity = Math.max(1, Number(odp.port_capacity || 16) || 16);
    const usedCount = connectedCustomers.length;
    const remaining = Math.max(0, capacity - usedCount);
    const usagePercent = Math.max(0, Math.min(100, (usedCount / capacity) * 100));
    const linkedPort = String(odp.pon_port || '').trim();
    const linkedOlt = String(odp.olt_name || '').trim();
    const connectionSource = [linkedOlt, linkedPort].filter(Boolean).join(' • ') || '-';
    const coordinates = `${Number(odp.lat || 0).toFixed(6)}, ${Number(odp.lng || 0).toFixed(6)}`;
    const mapsLink = buildMapsLink(odp.lat, odp.lng);
    const customersHtml = previewCustomers.length
      ? previewCustomers.map((cust) => {
          const label = String(cust.pppoe_username || cust.name || `Customer #${cust.id}`).trim();
          return `<div class="odp-popup-list-item"><span class="odp-popup-list-dot"></span><span>${escapeHtml(label)}</span></div>`;
        }).join('') + (hiddenCount > 0 ? `<div class="odp-popup-list-more">+${hiddenCount} pelanggan lainnya</div>` : '')
      : '<div class="odp-popup-empty">Belum ada pelanggan terhubung.</div>';
    const safePayload = encodeURIComponent(JSON.stringify({
      id: Number(odp.id || 0),
      name: odp.name || '',
      lat: odp.lat || '',
      lng: odp.lng || '',
      description: odp.description || '',
      olt_id: odp.olt_id || '',
      olt_name: odp.olt_name || '',
      pon_port: odp.pon_port || '',
      port_capacity: capacity
    }));

    return `
      <div class="odp-popup">
        <div class="odp-popup-head">
          <span class="odp-popup-badge">ODP Box</span>
          <div class="odp-popup-name">${escapeHtml(odp.name || 'ODP')}</div>
          <a href="${mapsLink}" target="_blank" class="odp-popup-link"><i class="bi bi-pin-map"></i><span>${escapeHtml(coordinates)}</span></a>
          <button type="button" class="odp-copy-btn" onclick="copyOdpInfo(${Number(odp.id || 0)})"><i class="bi bi-copy"></i> Copy Info</button>
        </div>
        <div class="odp-usage-card">
          <div class="odp-usage-head">
            <span>Slot Usage</span>
            <span><strong>${usedCount}</strong> / ${capacity}</span>
          </div>
          <div class="odp-usage-bar"><span style="width:${usagePercent.toFixed(2)}%"></span></div>
          <div class="odp-usage-foot">
            <span>Available:</span>
            <strong>${remaining} port${remaining === 1 ? '' : 's'}</strong>
          </div>
        </div>
        <div class="odp-popup-section">
          <div class="odp-popup-section-title">Connected from:</div>
          <div class="odp-popup-meta">
            <div class="odp-popup-meta-row"><i class="bi bi-diagram-3"></i><span>${escapeHtml(connectionSource)}</span></div>
          </div>
        </div>
        <div class="odp-popup-section">
          <div class="odp-popup-section-title">Connected to ONTs (${usedCount}):</div>
          <div class="odp-popup-list">${customersHtml}</div>
        </div>
        <div class="odp-popup-actions">
          <button type="button" class="btn btn-sm btn-odp-primary" onclick="editOdpFromPopup('${safePayload}')"><i class="bi bi-pencil-square"></i> Edit ODP</button>
          <div class="odp-popup-actions-row">
            <button type="button" class="btn btn-sm btn-g" onclick="startBackboneLinkFromOdp(${Number(odp.id || 0)})"><i class="bi bi-share"></i> Jalur Backbone</button>
          </div>
          <div class="odp-popup-actions-row">
            <button type="button" class="btn btn-sm btn-odp-success" onclick="editOdpLocationFromPopup('${safePayload}')"><i class="bi bi-geo-alt"></i> Edit Lokasi</button>
            <button type="button" class="btn btn-sm btn-odp-danger" onclick="deleteOdpFromPopup(${Number(odp.id || 0)}, '${encodeURIComponent(String(odp.name || 'ODP'))}')"><i class="bi bi-trash"></i> Delete</button>
          </div>
        </div>
      </div>
    `;
  }

  const odpMarkers = {}; // Store ODP coordinates and marker refs for line mapping
  odps.forEach(odp => {
    if (odp.lat && odp.lng) {
      const odpCoord = [parseFloat(odp.lat), parseFloat(odp.lng)];
      const marker = L.marker([odp.lat, odp.lng], {
        bubblingMouseEvents: false,
        icon: L.divIcon({
          html: renderOdpBoxIcon('marker-odp'),
          className: 'custom-div-icon',
          iconSize: [24, 20],
          iconAnchor: [12, 10]
        })
      }).addTo(odpLayer);
      odpCoord.marker = marker;
      odpCoord.odp = odp;
      odpMarkers[String(odp.id)] = odpCoord;
      
      marker.bindPopup(buildOdpPopupHtml(odp), {
        className: 'leaflet-odp-popup',
        closeButton: true,
        autoClose: true,
        closeOnClick: true,
        keepInView: true,
        maxWidth: 300,
        minWidth: 252,
        offset: L.point(0, -6),
        autoPanPaddingTopLeft: L.point(18, 18),
        autoPanPaddingBottomRight: L.point(18, 18)
      });
      marker.on('click', (event) => {
        if (linkingBackboneSourceOdpId) {
          if (event) L.DomEvent.stop(event);
          const sourceId = Number(linkingBackboneSourceOdpId || 0);
          const targetId = Number(odp.id || 0);
          if (sourceId && targetId && sourceId !== targetId) {
            const existing = (networkLinks || []).find((item) =>
              (Number(item.from_odp_id || 0) === sourceId && Number(item.to_odp_id || 0) === targetId)
              || (Number(item.from_odp_id || 0) === targetId && Number(item.to_odp_id || 0) === sourceId)
            );
            linkingBackboneSourceOdpId = null;
            updateBackboneLinkBar();
            startBackboneDrawing(sourceId, targetId, {
              linkKind: existing?.link_kind || 'backbone',
              cableSize: existing?.cable_size || '',
              pathJson: existing?.path_json || ''
            });
          }
          return;
        }
        if (!linkingCustomerId) return;
        if (event) L.DomEvent.stop(event);
        window.selectCustomerOdpTarget(odp.id);
        try { marker.closePopup(); } catch {}
      });
      marker.on('popupopen', () => {
        if (linkingCustomerId) {
          try { marker.closePopup(); } catch {}
        }
      });
    }
  });

  networkLinks.forEach((link) => {
    const fromLat = Number(link?.from_odp_lat);
    const fromLng = Number(link?.from_odp_lng);
    const toLat = Number(link?.to_odp_lat);
    const toLng = Number(link?.to_odp_lng);
    if (!Number.isFinite(fromLat) || !Number.isFinite(fromLng) || !Number.isFinite(toLat) || !Number.isFinite(toLng)) return;
    let pathCoords = [[fromLat, fromLng], [toLat, toLng]];
    if (link?.path_json) {
      try {
        const parsed = JSON.parse(link.path_json);
        if (Array.isArray(parsed) && parsed.length >= 2) pathCoords = parsed;
      } catch {}
    }
    const style = getMapLinkStyle(link);
    const polyline = L.polyline(pathCoords, {
      color: style.color,
      weight: style.weight,
      opacity: style.opacity,
      dashArray: style.dashArray,
      lineCap: 'round',
      lineJoin: 'round'
    }).addTo(backboneLayer);
    polyline.bindPopup(buildBackbonePopupHtml(link), {
      className: 'leaflet-odp-popup',
      closeButton: true,
      autoClose: true,
      closeOnClick: true,
      keepInView: true,
      maxWidth: 260,
      minWidth: 220
    });
  });

  // Add Customer Markers
  customers.forEach(cust => {
    if (cust.lat && cust.lng) {
      const is_active = cust.status === 'active';
      const signalTone = getCustomerSignalTone(cust);
      const iconClass = signalTone === 'warning'
        ? 'marker-cust-warning'
        : signalTone === 'good'
          ? 'marker-cust-good'
          : is_active
            ? 'marker-cust-active'
            : 'marker-cust-suspended';
      const waLink = buildWaLink(cust.phone, cust.name);
      const mapsLink = buildMapsLink(cust.lat, cust.lng);
      
      // Draw line to ODP if connected
      let customerPolyline = null;
      if (cust.odp_id && odpMarkers[String(cust.odp_id)]) {
        const customerCoord = [parseFloat(cust.lat), parseFloat(cust.lng)];
        const odpCoord = odpMarkers[String(cust.odp_id)];
        let pathCoords = [odpCoord, customerCoord];
        
        if (cust.cable_path) {
          try {
            pathCoords = JSON.parse(cust.cable_path);
          } catch(e) {}
        }
        pathCoords = normalizeCustomerPath(pathCoords, customerCoord, odpCoord);

        customerPolyline = L.polyline(pathCoords, {
          color: is_active ? '#3b82f6' : '#ef4444',
          weight: 3,
          opacity: 0.8,
          dashArray: '10, 10',
          className: 'flowing-line',
          interactive: false
        }).addTo(customerLayer);
      }

      const marker = L.marker([cust.lat, cust.lng], {
        interactive: false,
        keyboard: false,
        riseOnHover: true,
        bubblingMouseEvents: false,
        icon: L.divIcon({
          html: `
            <div class="customer-marker-stack">
              <span class="marker-cust-icon ${iconClass}"><i class="bi bi-router-fill"></i></span>
              <span class="customer-name-inline">${escapeHtml(toShortText(cust.name || 'Pelanggan', 20))}</span>
            </div>
          `,
          className: 'customer-div-icon',
          iconSize: [136, 48],
          iconAnchor: [68, 12]
        })
      }).addTo(customerLayer);

      marker._customerId = cust.id;
      marker._customerData = {
        customer: cust,
        isActive: is_active,
        waLink,
        mapsLink
      };
      const touchMarker = L.circleMarker([cust.lat, cust.lng], {
        radius: 22,
        stroke: false,
        fill: true,
        fillColor: '#2563eb',
        fillOpacity: 0.01,
        opacity: 0,
        interactive: true,
        bubblingMouseEvents: false
      }).addTo(customerTouchLayer);

      touchMarker._customerId = cust.id;
      touchMarker._customerData = marker._customerData;
      touchMarker._visualMarkerRef = marker;
      touchMarker._polylineRef = customerPolyline;
      touchMarker.on('click', (event) => {
        if (relocatingCustomerId) {
          const targetLatLng = event?.latlng || touchMarker.getLatLng();
          setCustomerRelocatePoint(targetLatLng);
          return;
        }
        if (Date.now() < suppressCustomerOpenUntil) return;
        lastCustomerMapTapAt = Date.now();
        if (event && event.originalEvent) {
          if (typeof event.originalEvent.preventDefault === 'function') event.originalEvent.preventDefault();
          if (typeof event.originalEvent.stopPropagation === 'function') event.originalEvent.stopPropagation();
        }
        openCustomerCard(touchMarker);
      });

      customerMarkers.push(touchMarker);
      customerMarkerRefs.set(String(cust.id), {
        customer: cust,
        visualMarker: marker,
        touchMarker,
        polyline: customerPolyline,
        odpId: cust.odp_id
      });
    }
  });

  const roleIconMap = {
    technician: 'bi-person-workspace',
    agent: 'bi-person-badge',
    collector: 'bi-person-walking',
    cashier: 'bi-person-vcard'
  };

  function formatLastSeen(seconds) {
    const safe = Math.max(0, Number(seconds || 0) || 0);
    if (safe < 60) return `${safe} dtk lalu`;
    if (safe < 3600) return `${Math.max(1, Math.round(safe / 60))} mnt lalu`;
    return `${Math.max(1, Math.round(safe / 3600))} jam lalu`;
  }

  function buildStaffMapsLink(lat, lng, name) {
    const query = [lat, lng].every((value) => Number.isFinite(Number(value)))
      ? `${lat},${lng}`
      : String(name || '').trim();
    return `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(query)}`;
  }

  let allStaffLocations = Array.isArray(staffLocations) ? staffLocations.slice() : [];
  let currentStaffRoleFilter = 'all';
  const hiddenStaffKeys = new Set();

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getStaffKey(staff) {
    const role = String(staff?.role || '').trim().toLowerCase() || 'staff';
    const employeeId = Number(staff?.employee_id || 0) || 0;
    const username = String(staff?.username || '').trim().toLowerCase();
    return `${role}:${employeeId || username || '0'}`;
  }

  function getStaffMotionMeta(staff) {
    const age = Math.max(0, Number(staff?.last_seen_seconds || 0) || 0);
    const moving = age <= 180;
    return moving
      ? {
          key: 'moving',
          label: 'Bergerak',
          icon: 'bi-activity',
          className: 'staff-live-motion-moving'
        }
      : {
          key: 'idle',
          label: 'Diam',
          icon: 'bi-pause-circle',
          className: 'staff-live-motion-idle'
        };
  }

  function computeStaffCounts(rows) {
    const counts = { all: 0, technician: 0, agent: 0, collector: 0, cashier: 0 };
    for (const row of Array.isArray(rows) ? rows : []) {
      const role = String(row?.role || '').trim().toLowerCase();
      counts.all += 1;
      if (Object.prototype.hasOwnProperty.call(counts, role)) counts[role] += 1;
    }
    return counts;
  }

  function updateStaffCounts(counts) {
    const safe = counts || computeStaffCounts(allStaffLocations);
    const map = {
      all: 'staffCountAll',
      technician: 'staffCountTechnician',
      agent: 'staffCountAgent',
      collector: 'staffCountCollector',
      cashier: 'staffCountCashier'
    };
    Object.entries(map).forEach(([role, id]) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(safe[role] || 0);
    });
    const summary = document.querySelector('.map-stats .msc:last-child .val');
    if (summary) summary.textContent = String(safe.all || 0);
  }

  function syncStaffFilterUi() {
    document.querySelectorAll('[data-staff-role]').forEach((button) => {
      button.classList.toggle('active', button.getAttribute('data-staff-role') === currentStaffRoleFilter);
    });
  }

  let staffPanelCollapsed = window.matchMedia('(max-width: 768px)').matches;

  function syncStaffPanelToggle() {
    const panel = document.getElementById('staffLivePanel');
    const button = document.getElementById('mapStaffPanelToggle');
    if (!panel || !button) return;
    panel.classList.toggle('is-collapsed', !!staffPanelCollapsed);
    button.textContent = staffPanelCollapsed ? 'Tampilkan Karyawan Live' : 'Sembunyikan Karyawan Live';
  }

  window.toggleStaffPanel = function toggleStaffPanel() {
    staffPanelCollapsed = !staffPanelCollapsed;
    syncStaffPanelToggle();
    return false;
  };

  function normalizeSearchText(value) {
    return String(value || '').trim().toLowerCase();
  }

  function findCustomerByQuery(query) {
    const needle = normalizeSearchText(query);
    if (!needle) return null;
    let best = null;
    let bestScore = Number.POSITIVE_INFINITY;
    for (const customer of customers) {
      const fields = [
        String(customer.name || ''),
        String(customer.pppoe_username || ''),
        String(customer.genieacs_tag || ''),
        String(customer.phone || ''),
        String(customer.address || '')
      ];
      for (const rawField of fields) {
        const field = normalizeSearchText(rawField);
        if (!field) continue;
        if (field === needle) return customer;
        const idx = field.indexOf(needle);
        if (idx >= 0) {
          const score = idx + Math.max(0, field.length - needle.length) / 100;
          if (score < bestScore) {
            best = customer;
            bestScore = score;
          }
        }
      }
    }
    return best;
  }

  window.focusCustomerById = function focusCustomerById(id) {
    const ref = customerMarkerRefs.get(String(id));
    if (!ref || !ref.touchMarker) return false;
    const latlng = ref.touchMarker.getLatLng();
    setSelectedCustomer(ref.touchMarker);
    map.setView(latlng, Math.max(17, Number(map.getZoom() || 0)), { animate: true });
    openCustomerCard(ref.touchMarker);
    return true;
  };

  window.submitMapSearch = function submitMapSearch(event) {
    if (event && typeof event.preventDefault === 'function') event.preventDefault();
    const input = document.getElementById('mapCustomerSearch');
    const query = input ? input.value : '';
    const customer = findCustomerByQuery(query);
    if (!customer) {
      alert('Pelanggan tidak ditemukan di peta.');
      return false;
    }
    window.focusCustomerById(customer.id);
    return false;
  };

  function buildStaffPopupHtml(staff) {
    const lat = Number(staff.lat);
    const lng = Number(staff.lng);
    const role = String(staff.role || '').trim().toLowerCase();
    const roleLabel = String(staff.role_label || role || 'Karyawan');
    const markerIcon = roleIconMap[role] || 'bi-person-badge';
    const mapsLink = buildStaffMapsLink(lat, lng, staff.name);
    const phoneDigits = String(staff.phone || '').replace(/\D/g, '');
    const waHref = phoneDigits ? `https://wa.me/${encodeURIComponent(phoneDigits)}` : '';
    const motion = getStaffMotionMeta(staff);

    return `
      <div class="staff-popup">
        <div class="staff-popup-head">
          <div class="staff-avatar"><i class="bi ${markerIcon}"></i></div>
          <div class="staff-title">
            <div class="staff-name">${escapeHtml(staff.name || 'Karyawan')}</div>
            <div class="staff-role"><i class="bi bi-broadcast-pin"></i>${escapeHtml(roleLabel)}</div>
          </div>
        </div>
        <div class="staff-meta">
          <div class="staff-meta-item"><i class="bi bi-person-badge"></i><span>${escapeHtml(staff.username || '-')}</span></div>
          <div class="staff-meta-item"><i class="bi bi-telephone"></i><span>${escapeHtml(staff.phone || '-')}</span></div>
          <div class="staff-meta-item"><i class="bi bi-crosshair"></i><span>Akurasi ${Math.max(0, Math.round(Number(staff.accuracy || 0) || 0))} m</span></div>
          <div class="staff-meta-item"><i class="bi ${motion.icon}"></i><span>${motion.label}</span></div>
          <div class="staff-meta-item"><i class="bi bi-clock-history"></i><span>${escapeHtml(formatLastSeen(staff.last_seen_seconds))}</span></div>
        </div>
        <div class="popup-actions">
          <a href="${mapsLink}" target="_blank" class="btn btn-sm btn-g"><i class="bi bi-sign-turn-right me-1"></i>Rute</a>
          ${waHref ? `<a href="${waHref}" target="_blank" class="btn btn-sm btn-wa"><i class="bi bi-whatsapp"></i></a>` : ''}
        </div>
      </div>
    `;
  }

  function buildStaffListCard(staff) {
    const role = String(staff.role || '').trim().toLowerCase();
    const roleLabel = String(staff.role_label || role || 'Karyawan');
    const markerIcon = roleIconMap[role] || 'bi-person-badge';
    const mapsLink = buildStaffMapsLink(staff.lat, staff.lng, staff.name);
    const phoneDigits = String(staff.phone || '').replace(/\D/g, '');
    const waHref = phoneDigits ? `https://wa.me/${encodeURIComponent(phoneDigits)}` : '';
    const staffKey = getStaffKey(staff);
    const motion = getStaffMotionMeta(staff);
    const isHidden = hiddenStaffKeys.has(staffKey);

    return `
      <div class="staff-live-card ${isHidden ? 'is-hidden' : ''}">
        <div class="staff-live-card-head">
          <div class="staff-live-card-title">
            <div class="staff-live-card-name">${escapeHtml(staff.name || 'Karyawan')}</div>
            <div class="staff-live-card-badges">
              <div class="staff-live-card-role"><i class="bi ${markerIcon}"></i>${escapeHtml(roleLabel)}</div>
              <div class="staff-live-motion ${motion.className}"><i class="bi ${motion.icon}"></i>${motion.label}</div>
            </div>
          </div>
          <div class="staff-live-card-tools">
            <button type="button" class="btn btn-sm btn-ghost" onclick="focusStaffLocation('${escapeHtml(staffKey)}')"><i class="bi bi-crosshair"></i></button>
            <button type="button" class="btn btn-sm btn-icon-toggle ${isHidden ? 'is-off' : 'is-on'}" onclick="toggleStaffVisibility('${escapeHtml(staffKey)}')" title="${isHidden ? 'Tampilkan' : 'Sembunyikan'}"><i class="bi ${isHidden ? 'bi-eye-slash' : 'bi-eye'}"></i></button>
          </div>
        </div>
        <div class="staff-live-meta">
          <div class="staff-live-meta-item"><i class="bi bi-person-badge"></i><span>${escapeHtml(staff.username || '-')}</span></div>
          <div class="staff-live-meta-item"><i class="bi bi-telephone"></i><span>${escapeHtml(staff.phone || '-')}</span></div>
          <div class="staff-live-meta-item"><i class="bi bi-crosshair"></i><span>Akurasi ${Math.max(0, Math.round(Number(staff.accuracy || 0) || 0))} m</span></div>
          <div class="staff-live-meta-item"><i class="bi bi-clock-history"></i><span>${escapeHtml(formatLastSeen(staff.last_seen_seconds))}</span></div>
        </div>
        <div class="staff-live-actions">
          <a href="${mapsLink}" target="_blank" class="btn btn-sm btn-g"><i class="bi bi-sign-turn-right me-1"></i>Rute</a>
          ${waHref ? `<a href="${waHref}" target="_blank" class="btn btn-sm btn-wa"><i class="bi bi-whatsapp"></i> WA</a>` : `<button type="button" class="btn btn-sm btn-ghost" disabled><i class="bi bi-whatsapp"></i> WA</button>`}
        </div>
      </div>
    `;
  }

  function renderStaffLocations() {
    const list = document.getElementById('staffLiveList');
    const last = document.getElementById('staffLiveLast');
    const counts = computeStaffCounts(allStaffLocations);
    const filtered = (Array.isArray(allStaffLocations) ? allStaffLocations : []).filter((item) => {
      if (currentStaffRoleFilter === 'all') return true;
      return String(item?.role || '').trim().toLowerCase() === currentStaffRoleFilter;
    });
    const visibleStaff = filtered.filter((item) => !hiddenStaffKeys.has(getStaffKey(item)));

    updateStaffCounts(counts);
    syncStaffFilterUi();
    staffLayer.clearLayers();
    (Array.isArray(allStaffLocations) ? allStaffLocations : []).forEach((item) => {
      item._markerRef = null;
    });

    for (const staff of visibleStaff) {
      const lat = Number(staff.lat);
      const lng = Number(staff.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) continue;
      const role = String(staff.role || '').trim().toLowerCase();
      const markerIcon = roleIconMap[role] || 'bi-person-badge';
      const markerClass = `marker-staff marker-staff-${role || 'technician'}`;
      const marker = L.marker([lat, lng], {
        bubblingMouseEvents: false,
        icon: L.divIcon({
          html: `<i class="bi ${markerIcon} ${markerClass}"></i>`,
          className: 'custom-div-icon',
          iconSize: [22, 22],
          iconAnchor: [11, 11]
        })
      }).addTo(staffLayer);
      marker.bindPopup(buildStaffPopupHtml(staff));
      staff._markerRef = marker;
    }

    if (list) {
      list.innerHTML = filtered.length
        ? filtered.map(buildStaffListCard).join('')
        : '<div class="staff-live-empty">Belum ada karyawan live untuk filter ini.</div>';
    }
    if (last) {
      last.textContent = `Update lokasi: ${new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' })} • Ditampilkan ${visibleStaff.length}/${filtered.length}`;
    }
  }

  window.setStaffRoleFilter = function setStaffRoleFilter(role) {
    currentStaffRoleFilter = String(role || 'all').trim().toLowerCase() || 'all';
    renderStaffLocations();
  };

  window.toggleStaffVisibility = function toggleStaffVisibility(staffKey) {
    const key = String(staffKey || '').trim();
    if (!key) return;
    if (hiddenStaffKeys.has(key)) hiddenStaffKeys.delete(key);
    else hiddenStaffKeys.add(key);
    renderStaffLocations();
  };

  window.resetHiddenStaffFilters = function resetHiddenStaffFilters() {
    hiddenStaffKeys.clear();
    renderStaffLocations();
  };

  window.focusStaffLocation = function focusStaffLocation(staffKey) {
    const key = String(staffKey || '').trim();
    if (hiddenStaffKeys.has(key)) {
      hiddenStaffKeys.delete(key);
      renderStaffLocations();
    }
    const staff = allStaffLocations.find((item) => getStaffKey(item) === key);
    if (!staff || !staff._markerRef) return;
    const lat = Number(staff.lat);
    const lng = Number(staff.lng);
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;
    map.setView([lat, lng], Math.max(16, map.getZoom() || 16), { animate: true });
    staff._markerRef.openPopup();
  };

  async function refreshStaffLocations(showError = false) {
    try {
      const response = await fetch('/admin/api/staff-locations', {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      });
      const payload = await response.json();
      if (!response.ok) throw new Error(payload.error || 'Gagal memuat lokasi karyawan.');
      allStaffLocations = Array.isArray(payload.locations) ? payload.locations : [];
      renderStaffLocations();
    } catch (error) {
      if (showError) {
        alert(error.message || 'Gagal memuat lokasi karyawan.');
      }
    }
  }

  const overlayMaps = {
    'ODP': odpLayer,
    'Backbone': backboneLayer,
    'Pelanggan': customerLayer,
    'Karyawan': staffLayer
  };

  L.control.layers(baseMaps, overlayMaps).addTo(map);
  syncStaffPanelToggle();
  renderStaffLocations();
  setInterval(() => {
    if (document.visibilityState === 'visible') refreshStaffLocations(false);
  }, 30000);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') refreshStaffLocations(false);
  });

  // Cable Drawing Modal Map
  let drawingMap, drawingPolyline, drawingMarkers = [];
  
  function interpolatePoints(p1, p2, count) {
    const points = [p1];
    for (let i = 1; i <= count; i++) {
      const lat = p1[0] + (p2[0] - p1[0]) * (i / (count + 1));
      const lng = p1[1] + (p2[1] - p1[1]) * (i / (count + 1));
      points.push([lat, lng]);
    }
    points.push(p2);
    return points;
  }

  function renderEditorMarkers() {
    // Clear old markers
    drawingMarkers.forEach(m => drawingMap.removeLayer(m));
    drawingMarkers = [];

    const latlngs = drawingPolyline.getLatLngs();
    
    latlngs.forEach((ll, index) => {
      const isEdge = index === 0 || index === latlngs.length - 1;
      
      const marker = L.marker(ll, {
        draggable: true,
        zIndexOffset: 2000,
        icon: L.divIcon({
          html: `<div style="background: ${isEdge ? '#3b82f6' : '#ff0000'}; width: 16px; height: 16px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 5px rgba(0,0,0,0.5);"></div>`,
          className: 'custom-div-icon',
          iconSize: [16, 16],
          iconAnchor: [8, 8]
        })
      }).addTo(drawingMap);

      marker.on('drag', (e) => {
        const newLatLngs = drawingPolyline.getLatLngs();
        newLatLngs[index] = e.latlng;
        drawingPolyline.setLatLngs(newLatLngs);
      });

      drawingMarkers.push(marker);
    });
  }

  function setCableDrawingMode(mode, options = {}) {
    drawingMode = mode === 'backbone' ? 'backbone' : 'customer';
    const titleEl = document.querySelector('#cablePathModal .mt');
    const hintEl = document.getElementById('cableDrawingHint');
    const metaWrap = document.getElementById('cableDrawingMetaFields');
    const kindEl = document.getElementById('drawingLinkKind');
    const sizeEl = document.getElementById('drawingCableSize');
    if (titleEl) {
      titleEl.innerHTML = drawingMode === 'backbone'
        ? '<i class="bi bi-diagram-3"></i> Gambar Jalur Backbone'
        : '<i class="bi bi-pencil-fill"></i> Gambar Jalur Kabel Pelanggan';
    }
    if (hintEl) {
      hintEl.innerHTML = drawingMode === 'backbone'
        ? '<i class="bi bi-info-circle"></i> Tarik titik oranye untuk mengikuti jalan. Simpan jalur backbone setelah rute sesuai.'
        : '<i class="bi bi-info-circle"></i> Tarik titik oranye untuk mengubah jalur. Klik pada garis untuk menambah titik lekukan baru.';
    }
    if (metaWrap) metaWrap.style.display = drawingMode === 'backbone' ? 'block' : 'none';
    if (drawingMode === 'backbone') {
      if (kindEl) kindEl.value = options.linkKind || 'backbone';
      if (sizeEl) sizeEl.value = options.cableSize || '';
    }
  }

  function startCableDrawing(customerId, lat, lng, odpId) {
    const odpCoord = odpMarkers[String(odpId)];
    if (!odpCoord) return alert('Data ODP tidak ditemukan');

    currentEditingCustomer = customerId;
    currentEditingBackbone = null;
    setCableDrawingMode('customer');
    saveMapState({ selectedCustomerId: customerId });
    openModal('cablePathModal');

    setTimeout(() => {
      try {
        if (drawingMap) drawingMap.remove();
        
        drawingMap = L.map('cable-drawing-map').setView([lat, lng], 17);
        
        L.tileLayer('https://{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
          maxZoom: 20, subdomains: ['mt0', 'mt1', 'mt2', 'mt3']
        }).addTo(drawingMap);

        const customer = customers.find(c => c.id === customerId);
        let pathCoords = [];
        if (customer && customer.cable_path) {
          try { pathCoords = JSON.parse(customer.cable_path); } catch(e) {}
        }
        
        const customerCoord = [parseFloat(lat), parseFloat(lng)];
        if (pathCoords.length <= 2) {
          pathCoords = interpolatePoints(odpCoord, customerCoord, 5);
        }
        pathCoords = normalizeCustomerPath(pathCoords, customerCoord, odpCoord);

        drawingPolyline = L.polyline(pathCoords, {
          color: '#f59e0b', weight: 6, dashArray: '5, 5', interactive: false
        }).addTo(drawingMap);

        renderEditorMarkers();

        setTimeout(() => {
          drawingMap.invalidateSize();
          drawingMap.fitBounds(drawingPolyline.getBounds(), { padding: [50, 50] });
        }, 200);

      } catch (err) {
        console.error("Drawing map error:", err);
      }
    }, 600);
  }

  function startBackboneDrawing(fromOdpId, toOdpId, options = {}) {
    const fromOdp = getOdpById(fromOdpId);
    const toOdp = getOdpById(toOdpId);
    if (!fromOdp || !toOdp) return alert('ODP backbone tidak ditemukan');
    const fromCoord = [Number(fromOdp.lat), Number(fromOdp.lng)];
    const toCoord = [Number(toOdp.lat), Number(toOdp.lng)];
    if (!Number.isFinite(fromCoord[0]) || !Number.isFinite(fromCoord[1]) || !Number.isFinite(toCoord[0]) || !Number.isFinite(toCoord[1])) {
      return alert('Koordinat ODP backbone belum lengkap.');
    }
    currentEditingCustomer = null;
    currentEditingBackbone = {
      fromOdpId: Number(fromOdpId),
      toOdpId: Number(toOdpId)
    };
    setCableDrawingMode('backbone', options);
    saveMapState();
    openModal('cablePathModal');
    setTimeout(() => {
      try {
        if (drawingMap) drawingMap.remove();
        drawingMap = L.map('cable-drawing-map').setView(fromCoord, 17);
        L.tileLayer('https://{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
          maxZoom: 20, subdomains: ['mt0', 'mt1', 'mt2', 'mt3']
        }).addTo(drawingMap);
        let pathCoords = [];
        if (options.pathJson) {
          try { pathCoords = JSON.parse(options.pathJson); } catch {}
        }
        if (!Array.isArray(pathCoords) || pathCoords.length <= 2) {
          pathCoords = interpolatePoints(fromCoord, toCoord, 6);
        }
        drawingPolyline = L.polyline(pathCoords, {
          color: '#8b5cf6', weight: 6, interactive: false
        }).addTo(drawingMap);
        renderEditorMarkers();
        setTimeout(() => {
          drawingMap.invalidateSize();
          drawingMap.fitBounds(drawingPolyline.getBounds(), { padding: [50, 50] });
        }, 200);
      } catch (err) {
        console.error('Backbone drawing map error:', err);
      }
    }, 600);
  }

  function addMorePoints() {
    if (!drawingPolyline || !drawingMap) return;
    const latlngs = drawingPolyline.getLatLngs();
    const newPath = [];
    for (let i = 0; i < latlngs.length - 1; i++) {
      newPath.push(latlngs[i]);
      const midLat = (latlngs[i].lat + latlngs[i+1].lat) / 2;
      const midLng = (latlngs[i].lng + latlngs[i+1].lng) / 2;
      newPath.push(L.latLng(midLat, midLng));
    }
    newPath.push(latlngs[latlngs.length - 1]);
    drawingPolyline.setLatLngs(newPath);
    renderEditorMarkers();
  }

  async function saveDrawingPath() {
    if (!drawingPolyline) return;
    const latlngs = drawingPolyline.getLatLngs().map(ll => [ll.lat, ll.lng]);
    const pathJson = JSON.stringify(latlngs);
    try {
      if (drawingMode === 'backbone') {
        if (!currentEditingBackbone?.fromOdpId || !currentEditingBackbone?.toOdpId) throw new Error('Jalur backbone belum lengkap');
        const res = await fetch('/admin/api/map-links', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            fromOdpId: currentEditingBackbone.fromOdpId,
            toOdpId: currentEditingBackbone.toOdpId,
            linkKind: document.getElementById('drawingLinkKind')?.value || 'backbone',
            cableSize: document.getElementById('drawingCableSize')?.value || '',
            path: latlngs
          })
        });
        const data = await res.json();
        if (!res.ok || !data?.ok) throw new Error(data?.error || 'Gagal menyimpan jalur backbone.');
        alert('Jalur backbone berhasil disimpan!');
        saveMapState();
        location.reload();
        return;
      }

      if (!currentEditingCustomer) throw new Error('Pelanggan jalur kabel tidak valid');
      const res = await fetch(`/admin/api/customers/${currentEditingCustomer}/cable-path`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ path: pathJson })
      });
      const data = await res.json();
      if (!res.ok || !data?.ok) throw new Error(data?.error || 'Gagal menyimpan jalur kabel.');
      alert('Jalur kabel berhasil disimpan!');
      saveMapState({ selectedCustomerId: currentEditingCustomer || selectedCustomerId || null });
      location.reload();
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

