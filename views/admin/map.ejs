  function updatePopupTraffic(customerId, dlMbps, ulMbps, labelOverride) {
    const dlCanvas = document.getElementById(`cust_${customerId}_dl_chart`);
    const ulCanvas = document.getElementById(`cust_${customerId}_ul_chart`);
    const dlMax = Number(dlCanvas && dlCanvas.dataset ? dlCanvas.dataset.max : 10) || 10;
    const ulMax = Number(ulCanvas && ulCanvas.dataset ? ulCanvas.dataset.max : 10) || 10;

    if (!customerTrafficSeries[customerId]) customerTrafficSeries[customerId] = { dl: [], ul: [] };
    const st = customerTrafficSeries[customerId];

    if (labelOverride) {
      setOverlay(customerId, 'dl', labelOverride);
      setOverlay(customerId, 'ul', labelOverride);
      st.dl = [];
      st.ul = [];
      drawSparkline(dlCanvas, [0, 0], dlMax, 'rgba(59,130,246,0.6)');
      drawSparkline(ulCanvas, [0, 0], ulMax, 'rgba(34,197,94,0.6)');
      return;
    }

    setOverlay(customerId, 'dl', '');
    setOverlay(customerId, 'ul', '');

    const dl = Math.max(0, Number(dlMbps || 0) || 0);
    const ul = Math.max(0, Number(ulMbps || 0) || 0);
    st.dl.push(dl);
    st.ul.push(ul);
    if (st.dl.length > 22) st.dl = st.dl.slice(-22);
    if (st.ul.length > 22) st.ul = st.ul.slice(-22);

    drawSparkline(dlCanvas, st.dl, dlMax, '#3b82f6');
    drawSparkline(ulCanvas, st.ul, ulMax, '#22c55e');
  }

  async function refreshCustomerTrafficPopup(customerId) {
    try {
      const r = await fetch(`/admin/api/customers/${customerId}/pppoe-traffic`, { cache: 'no-store' });
      const data = await r.json();
      if (!data || !data.ok) {
        updatePopupTraffic(customerId, 0, 0, '-');
        return;
      }
      if (!data.available) {
        updatePopupTraffic(customerId, 0, 0, 'N/A');
        return;
      }
      if (!data.online) {
        updatePopupTraffic(customerId, 0, 0, 'Offline');
        return;
      }
      if (data.warmup) {
        updatePopupTraffic(customerId, 0, 0, 'Mengukur');
        return;
      }

      const rx = Number(data.rxMbps || 0);
      const tx = Number(data.txMbps || 0);
      updatePopupTraffic(customerId, tx, rx, '');
    } catch {
      updatePopupTraffic(customerId, 0, 0, '-');
    }
  }

