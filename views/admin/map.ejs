    if (!latlng) return 'javascript:void(0)';
    return buildMapsLink(latlng.lat, latlng.lng);
  }

  function applyCustomerLocationChange(customerId, latlng) {
    const ref = customerMarkerRefs.get(String(customerId));
    if (!ref || !latlng) return;
    const formattedLat = Number(latlng.lat).toFixed(6);
    const formattedLng = Number(latlng.lng).toFixed(6);
    ref.customer.lat = formattedLat;
    ref.customer.lng = formattedLng;
    ref.customer.cable_path = null;
    ref.visualMarker.setLatLng(latlng);
    ref.touchMarker.setLatLng(latlng);
    if (ref.visualMarker?._customerData?.customer) {
      ref.visualMarker._customerData.customer.lat = formattedLat;
      ref.visualMarker._customerData.customer.lng = formattedLng;
      ref.visualMarker._customerData.customer.cable_path = null;
      ref.visualMarker._customerData.mapsLink = buildMapsLink(latlng.lat, latlng.lng);
    }
    if (ref.touchMarker?._customerData?.customer) {
      ref.touchMarker._customerData.customer.lat = formattedLat;
      ref.touchMarker._customerData.customer.lng = formattedLng;
      ref.touchMarker._customerData.customer.cable_path = null;
      ref.touchMarker._customerData.mapsLink = buildMapsLink(latlng.lat, latlng.lng);
    }
    const odpCoord = ref.odpId ? odpMarkers[String(ref.odpId)] : null;
    if (odpCoord) {
      if (ref.polyline) {
        ref.polyline.setLatLngs([[latlng.lat, latlng.lng], odpCoord]);
      } else {
        const isActive = String(ref.customer.status || '').toLowerCase() === 'active';
        ref.polyline = L.polyline([[latlng.lat, latlng.lng], odpCoord], {
          color: isActive ? '#3b82f6' : '#ef4444',
          weight: 3,
          opacity: 0.8,
          dashArray: '10, 10',
          className: 'flowing-line',
          interactive: false
        }).addTo(customerLayer);
        ref.touchMarker._polylineRef = ref.polyline;
      }
    }
    if (activeCustomerCardId === customerId) {
      activeCustomerAnchorMarker = ref.touchMarker;
      requestAnimationFrame(() => positionCustomerCard(ref.touchMarker));
    }
    if (selectedCustomerId === customerId) {
      selectedCustomerAnchorMarker = ref.touchMarker;
    }
    syncCustomerNameLabels();
  }

  function applyCustomerOdpLinkChange(customerId, odpId) {
    const ref = customerMarkerRefs.get(String(customerId));
    if (!ref) return;
    const normalizedOdpId = odpId == null ? null : Number(odpId);
    ref.customer.odp_id = normalizedOdpId;
    ref.customer.cable_path = null;
    ref.odpId = normalizedOdpId;
    if (ref.visualMarker?._customerData?.customer) {
      ref.visualMarker._customerData.customer.odp_id = normalizedOdpId;
      ref.visualMarker._customerData.customer.cable_path = null;
    }
    if (ref.touchMarker?._customerData?.customer) {
      ref.touchMarker._customerData.customer.odp_id = normalizedOdpId;
      ref.touchMarker._customerData.customer.cable_path = null;
    }
    const customerLatLng = ref.touchMarker.getLatLng();
    const odpCoord = normalizedOdpId ? odpMarkers[String(normalizedOdpId)] : null;
    if (ref.polyline) {
      customerLayer.removeLayer(ref.polyline);
      ref.polyline = null;
      ref.touchMarker._polylineRef = null;
    }
    if (odpCoord) {
      const isActive = String(ref.customer.status || '').toLowerCase() === 'active';
      ref.polyline = L.polyline([[customerLatLng.lat, customerLatLng.lng], odpCoord], {
        color: isActive ? '#3b82f6' : '#ef4444',
        weight: 3,
        opacity: 0.8,
        dashArray: '10, 10',
        className: 'flowing-line',
        interactive: false
      }).addTo(customerLayer);
      ref.touchMarker._polylineRef = ref.polyline;
    }
  }

  window.saveCustomerRelocate = async function saveCustomerRelocate() {
    if (!relocatingCustomerId || !relocatingCustomerLatLng) return false;
    const saveBtn = document.getElementById('mapRelocateSaveBtn');
    if (saveBtn) saveBtn.disabled = true;
    try {
      const response = await fetch(`/admin/api/customers/${relocatingCustomerId}/location`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lat: Number(relocatingCustomerLatLng.lat),
          lng: Number(relocatingCustomerLatLng.lng),
          clearCablePath: true
        })
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data?.ok) {
        throw new Error(data?.error || 'Gagal menyimpan posisi pelanggan.');
      }
      applyCustomerLocationChange(relocatingCustomerId, relocatingCustomerLatLng);
      stopCustomerRelocate(true);
      alert('Posisi pelanggan berhasil diperbarui.');
    } catch (error) {
      if (saveBtn) saveBtn.disabled = false;
      alert(error.message || 'Gagal memperbarui posisi pelanggan.');
    }
    return false;
  };

  window.saveCustomerOdpLink = async function saveCustomerOdpLink() {
    if (!linkingCustomerId || !linkingTargetOdpId) return false;
    const saveBtn = document.getElementById('mapOdpLinkSaveBtn');
    if (saveBtn) saveBtn.disabled = true;
    try {
      const response = await fetch(`/admin/api/customers/${linkingCustomerId}/odp-link`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          odpId: Number(linkingTargetOdpId),
          clearCablePath: true
        })
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data?.ok) {
        throw new Error(data?.error || 'Gagal menyambungkan pelanggan ke ODP.');
      }
      applyCustomerOdpLinkChange(linkingCustomerId, linkingTargetOdpId);
      const savedOdpId = linkingTargetOdpId;
      const editingCustomerId = linkingCustomerId;
      stopCustomerOdpLink();
      if (Number.isFinite(Number(savedOdpId))) {
        const target = odpMarkers[String(savedOdpId)];
        if (target?.marker) {
          try { target.marker.openPopup(); } catch {}
        }
      }
      const ref = customerMarkerRefs.get(String(editingCustomerId));
      const latlng = ref?.touchMarker?.getLatLng?.();
      if (latlng) {
        startCableDrawing(editingCustomerId, latlng.lat, latlng.lng, savedOdpId);
      }
    } catch (error) {
      if (saveBtn) saveBtn.disabled = false;
      alert(error.message || 'Gagal menyambungkan pelanggan ke ODP.');
    }
    return false;
  };

  function handleRelocateButtonPress(event) {
    const button = event?.target && event.target.closest ? event.target.closest('[data-customer-relocate]') : null;
    if (!button) return false;
    const customerId = Number(button.getAttribute('data-customer-relocate') || 0);
    if (!customerId) return false;
    if (event) {
      if (typeof event.preventDefault === 'function') event.preventDefault();
      if (typeof event.stopPropagation === 'function') event.stopPropagation();
      if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
    }
    window.startCustomerRelocate(customerId, event);
    return true;
  }

  document.addEventListener('click', (event) => {
    handleActionOdpPress(event);
    handleActionCablePress(event);
    handleActionMovePress(event);
    handleRelocateButtonPress(event);
  }, true);

  document.addEventListener('touchstart', (event) => {
    handleActionOdpPress(event);
    handleActionCablePress(event);
    handleActionMovePress(event);
    handleRelocateButtonPress(event);
  }, { capture: true, passive: false });

  document.addEventListener('touchend', (event) => {
    handleActionOdpPress(event);
    handleActionCablePress(event);
    handleActionMovePress(event);
  }, { capture: true, passive: false });

  document.addEventListener('click', (event) => {
    if (relocatingCustomerId || activeCustomerCardId == null) return;
    const target = event.target;
    if (!target || !target.closest) return;
    if (target.closest('#mapCustomerActionBar')) return;
    if (target.closest('.leaflet-popup')) return;
    closeCustomerCard();
  }, true);

  function positionCustomerCard(marker) {
    return marker;
  }

  function renderCustomerHitAreas() {
    const layer = document.getElementById('mapCustomerHitLayer');
    if (!layer) return;
    layer.innerHTML = '';
  }

  function syncCustomerNameLabels() {
    const showLabels = Number(map.getZoom() || 0) >= 13;
    let missingElements = 0;
    customerMarkers.forEach((marker) => {
      const visualMarker = marker?._visualMarkerRef;
      const element = visualMarker && typeof visualMarker.getElement === 'function' ? visualMarker.getElement() : null;
      if (!element) {
        missingElements += 1;
        return;
      }
      element.classList.toggle('show-label', !!showLabels);
    });
    if (missingElements > 0 && !customerLabelRetryTimer) {
      customerLabelRetryTimer = window.setTimeout(() => {
        customerLabelRetryTimer = null;
        syncCustomerNameLabels();
      }, 180);
    }
  }

  function refreshActiveCustomerCardPosition() {
    if (!activeCustomerAnchorMarker || activeCustomerCardId == null) return;
    try {
      const popup = activeCustomerAnchorMarker.getPopup && activeCustomerAnchorMarker.getPopup();
      if (popup && popup.isOpen && popup.isOpen()) {
        activeCustomerAnchorMarker.openPopup();
      }
    } catch {}
  }

  function bindCustomerPopupInteractions(marker) {
    if (!marker || !marker.getPopup) return;
    const popup = marker.getPopup();
    const popupEl = popup && typeof popup.getElement === 'function' ? popup.getElement() : null;
    if (!popupEl) return;
    popupEl.dataset.customerPopupBound = '1';
    ['click', 'dblclick', 'pointerdown', 'touchstart', 'touchend'].forEach((eventName) => {
      popupEl.addEventListener(eventName, (event) => {
        if (typeof event.stopPropagation === 'function') event.stopPropagation();
      }, { passive: eventName === 'touchstart' || eventName === 'touchend' });
    });
    const moveButton = popupEl.querySelector('[data-customer-relocate]');
    if (moveButton) {
      const customerId = Number(moveButton.getAttribute('data-customer-relocate') || 0);
      const triggerRelocate = (event) => {
        if (event) {
          if (typeof event.preventDefault === 'function') event.preventDefault();
          if (typeof event.stopPropagation === 'function') event.stopPropagation();
          if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
        }
        window.startCustomerRelocate(customerId, event);
        return false;
      };
      moveButton.addEventListener('click', triggerRelocate);
      moveButton.addEventListener('touchstart', triggerRelocate, { passive: false });
    }
  }

  function openCustomerCard(marker) {
    if (Date.now() < suppressCustomerOpenUntil) return;
    if (!marker || !marker._customerData || !marker._customerData.customer) return;
    const payload = marker._customerData;
    const customerId = Number(payload.customer.id || 0);
    if (!customerId) return;
    setSelectedCustomer(marker);
    activeCustomerCardId = customerId;
    activeCustomerAnchorMarker = marker;
    updateCustomerActionBar();
    const popupHtml = buildCustomerCardHtml(payload);
    if (!marker.getPopup || !marker.getPopup()) {
      marker.bindPopup(popupHtml, {
        className: 'leaflet-customer-popup',
        closeButton: true,
        autoClose: true,
        closeOnClick: true,
        keepInView: true,
        maxWidth: 280,
        minWidth: 236,
        offset: L.point(0, -8),
        autoPanPaddingTopLeft: L.point(18, 18),
        autoPanPaddingBottomRight: L.point(18, 18)
      });
      marker.on('popupopen', () => {
        bindCustomerPopupInteractions(marker);
      });
      marker.on('popupclose', () => {
        if (activeCustomerCardId === customerId) {
          activeCustomerCardId = null;
          activeCustomerAnchorMarker = null;
          updateCustomerActionBar();
        }
      });
    } else {
      marker.setPopupContent(popupHtml);
    }
    marker.openPopup();
    requestAnimationFrame(() => bindCustomerPopupInteractions(marker));
  }

  function findCustomerMarkerByTap(containerPoint, maxDistance = 26) {
    if (!containerPoint || !customerMarkers.length) return null;
    let nearestMarker = null;
    let nearestDistance = Number.POSITIVE_INFINITY;
    for (const marker of customerMarkers) {
      if (!marker) continue;
      const markerPoint = map.latLngToContainerPoint(marker.getLatLng());
      const dx = markerPoint.x - containerPoint.x;
      const dy = markerPoint.y - containerPoint.y;
      const distance = Math.sqrt((dx * dx) + (dy * dy));
      if (distance <= maxDistance && distance < nearestDistance) {
        nearestDistance = distance;
        nearestMarker = marker;
      }
    }
    return nearestMarker;
  }

  function handleCustomerMapTap(containerPoint) {
    if (relocatingCustomerId) {
      const latlng = map.containerPointToLatLng(containerPoint);
      setCustomerRelocatePoint(latlng);
      return true;
    }
    if (linkingCustomerId) {
      return false;
    }
    const marker = findCustomerMarkerByTap(containerPoint);
    if (marker) {
      openCustomerCard(marker);
      return true;
    }
    if (activeCustomerCardId != null) {
      closeCustomerCard();
      return true;
    }
    if (selectedCustomerId != null) {
      clearSelectedCustomer();
      return true;
    }
    return false;
  }

  map.on('click', (event) => {
    if (!relocatingCustomerId) {
      if (Date.now() < suppressCustomerOpenUntil) return;
      if (Date.now() - lastCustomerMapTapAt < 350) return;
    }
    lastCustomerMapTapAt = Date.now();
    const containerPoint = map.latLngToContainerPoint(event.latlng);
    handleCustomerMapTap(containerPoint);
  });

  map.on('moveend zoomend resize', () => {
    renderCustomerHitAreas();
    syncCustomerNameLabels();
    refreshActiveCustomerCardPosition();
    saveMapState();
  });

  (() => {
    const mapElement = document.getElementById('map');
    if (!mapElement) return;
    let touchStartPoint = null;
    let pointerStartPoint = null;

    const isRelocateBlockedTarget = (target) => {
      if (!target || !target.closest) return false;
      return Boolean(
        target.closest('.leaflet-control') ||
        target.closest('.leaflet-popup') ||
        target.closest('#mapCustomerActionBar') ||
        target.closest('#mapRelocateBar')
      );
    };

    const applyRelocatePointFromClient = (clientX, clientY) => {
      if (!relocatingCustomerId) return false;
      const rect = mapElement.getBoundingClientRect();
      const point = L.point(clientX - rect.left, clientY - rect.top);
      const latlng = map.containerPointToLatLng(point);
      setCustomerRelocatePoint(latlng);
      lastCustomerMapTapAt = Date.now();
      return true;
    };

    mapElement.addEventListener('touchstart', (event) => {
      const touch = event.touches && event.touches[0];
      if (!touch) return;
      touchStartPoint = { x: touch.clientX, y: touch.clientY };
    }, { passive: true });

    mapElement.addEventListener('touchend', (event) => {
      if (!relocatingCustomerId && Date.now() < suppressCustomerOpenUntil) return;
      const touch = event.changedTouches && event.changedTouches[0];
      if (!touch) return;
      if (isRelocateBlockedTarget(event.target)) return;
      if (event.target && event.target.closest && event.target.closest('.leaflet-popup')) return;
      const endPoint = { x: touch.clientX, y: touch.clientY };
      const dx = touchStartPoint ? Math.abs(endPoint.x - touchStartPoint.x) : 0;
      const dy = touchStartPoint ? Math.abs(endPoint.y - touchStartPoint.y) : 0;
      touchStartPoint = null;
      if (dx > 16 || dy > 16) return;
      if (applyRelocatePointFromClient(endPoint.x, endPoint.y)) return;
      const rect = mapElement.getBoundingClientRect();
      const point = L.point(endPoint.x - rect.left, endPoint.y - rect.top);
      lastCustomerMapTapAt = Date.now();
      handleCustomerMapTap(point);
    }, { passive: true });

    mapElement.addEventListener('pointerdown', (event) => {
      if (!event || event.pointerType === 'mouse') return;
      pointerStartPoint = { x: event.clientX, y: event.clientY };
    }, { passive: true });

    mapElement.addEventListener('pointerup', (event) => {
      if (!relocatingCustomerId || !event || event.pointerType === 'mouse') return;
      if (isRelocateBlockedTarget(event.target)) return;
      const dx = pointerStartPoint ? Math.abs(event.clientX - pointerStartPoint.x) : 0;
      const dy = pointerStartPoint ? Math.abs(event.clientY - pointerStartPoint.y) : 0;
      pointerStartPoint = null;
      if (dx > 18 || dy > 18) return;
      applyRelocatePointFromClient(event.clientX, event.clientY);
    }, { passive: true });
  })();

  renderCustomerHitAreas();
  syncCustomerNameLabels();
</script>
</body>
</html>
