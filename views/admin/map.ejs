  window.copyOdpInfo = async function copyOdpInfo(id) {
    const odp = getOdpById(id);
    if (!odp) return false;
    const connectedCustomers = getOdpConnectedCustomers(odp.id);
    const capacity = Math.max(1, Number(odp.port_capacity || 16) || 16);
    const usageText = `${connectedCustomers.length}/${capacity}`;
    const coords = `${Number(odp.lat || 0).toFixed(6)}, ${Number(odp.lng || 0).toFixed(6)}`;
    const source = [String(odp.olt_name || '').trim(), String(odp.pon_port || '').trim()].filter(Boolean).join(' • ') || '-';
    const text = [
      `ODP: ${odp.name || '-'}`,
      `Koordinat: ${coords}`,
      `Connected from: ${source}`,
      `Slot usage: ${usageText}`,
      `Pelanggan: ${connectedCustomers.map((cust) => cust.pppoe_username || cust.name || `#${cust.id}`).join(', ') || '-'}`
    ].join('\n');
    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(text);
        alert('Info ODP berhasil disalin.');
      } else {
        throw new Error('clipboard_unavailable');
      }
    } catch {
      prompt('Salin info ODP ini:', text);
    }
    return false;
  };

