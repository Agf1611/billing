  function ensureRelocatePreviewMarker() {
    if (relocatingPreviewMarker) return relocatingPreviewMarker;
    relocatingPreviewMarker = L.marker([officeCoords.lat, officeCoords.lng], {
      draggable: true,
      autoPan: true,
      bubblingMouseEvents: false,
      zIndexOffset: 1400,
      icon: L.divIcon({
        html: '<span class="customer-relocate-pin"><i class="bi bi-arrows-move"></i></span>',
        className: 'customer-relocate-marker',
        iconSize: [28, 28],
        iconAnchor: [14, 14]
      })
    }).addTo(customerRelocateLayer);
    relocatingPreviewMarker.on('drag', (event) => {
      const latlng = event?.target?.getLatLng?.();
      if (!latlng) return;
      relocatingCustomerLatLng = L.latLng(latlng.lat, latlng.lng);
      updateRelocateBar();
    });
    relocatingPreviewMarker.on('dragend', (event) => {
      const latlng = event?.target?.getLatLng?.();
      if (!latlng) return;
      relocatingCustomerLatLng = L.latLng(latlng.lat, latlng.lng);
      updateRelocateBar();
    });
    return relocatingPreviewMarker;
  }

