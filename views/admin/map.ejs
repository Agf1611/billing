  function normalizePhone(phone) {
    const raw = String(phone || '').trim();
    const digits = raw.replace(/\D/g, '');
    if (!digits) return '';
    if (digits.startsWith('62')) return digits;
    if (digits.startsWith('0')) return `62${digits.slice(1)}`;
    if (digits.length >= 9) return `62${digits}`;
    return digits;
  }

  function buildWaLink(phone, name) {
    const to = normalizePhone(phone);
    const msg = `Halo ${String(name || '').trim()}`;
    if (!to) return 'javascript:void(0)';
    return `https://wa.me/${to}?text=${encodeURIComponent(msg)}`;
  }

  function buildMapsLink(lat, lng) {
    const la = Number(lat);
    const lo = Number(lng);
    if (!Number.isFinite(la) || !Number.isFinite(lo)) return 'javascript:void(0)';
    return `https://www.google.com/maps?q=${encodeURIComponent(String(la))},${encodeURIComponent(String(lo))}`;
  }

  function parseRxPowerValue(value) {
    const raw = String(value || '').trim();
    if (!raw || raw === '-' || raw.toLowerCase() === 'n/a' || raw.toLowerCase() === 'unknown') return null;
    const match = raw.replace(',', '.').match(/-?\d+(?:\.\d+)?/);
    if (!match) return null;
    const parsed = Number(match[0]);
    return Number.isFinite(parsed) ? parsed : null;
  }

  function getCustomerSignalTone(customer) {
    const rx = parseRxPowerValue(customer?.device_rx_power);
    if (String(customer?.status || '').toLowerCase() !== 'active') return 'suspended';
    if (rx === null) return 'default';
    return rx <= -26 ? 'warning' : 'good';
  }

  function formatCustomerRxPower(customer) {
    const rx = parseRxPowerValue(customer?.device_rx_power);
    if (rx === null) {
      return { text: 'Belum ada data', className: 'cp-rx-unknown' };
    }
    return rx <= -26
      ? { text: `${rx} dBm`, className: 'cp-rx-warning' }
      : { text: `${rx} dBm`, className: 'cp-rx-good' };
  }

  function toShortText(value, maxLength = 64) {
    const text = String(value || '').replace(/\s+/g, ' ').trim();
    if (!text) return '-';
    return text.length > maxLength ? `${text.slice(0, Math.max(0, maxLength - 1)).trim()}…` : text;
  }

