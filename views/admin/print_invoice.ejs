<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<%
  function normalizePhoneLocal(input, defaultCountryCode = '62') {
    const raw = String(input || '').trim();
    if (!raw) return '';
    let digits = raw.replace(/\D/g, '');
    if (!digits) return '';
    if (digits.startsWith('00')) digits = digits.slice(2);
    if (digits.startsWith(defaultCountryCode)) return digits;
    if (digits.startsWith('0')) return defaultCountryCode + digits.slice(1);
    if (digits.startsWith('8')) return defaultCountryCode + digits;
    return defaultCountryCode + digits;
  }
  function formatPhoneLocal(input) {
    const digits = normalizePhoneLocal(input);
    return digits ? `+${digits}` : '-';
  }
  function terbilang(input) {
    const angka = Math.floor(Math.abs(Number(input || 0)));
    const words = ['', 'satu', 'dua', 'tiga', 'empat', 'lima', 'enam', 'tujuh', 'delapan', 'sembilan', 'sepuluh', 'sebelas'];
    function say(n) {
      if (n < 12) return words[n];
      if (n < 20) return `${say(n - 10)} belas`;
      if (n < 100) return `${say(Math.floor(n / 10))} puluh${n % 10 ? ` ${say(n % 10)}` : ''}`;
      if (n < 200) return `seratus${n - 100 ? ` ${say(n - 100)}` : ''}`;
      if (n < 1000) return `${say(Math.floor(n / 100))} ratus${n % 100 ? ` ${say(n % 100)}` : ''}`;
      if (n < 2000) return `seribu${n - 1000 ? ` ${say(n - 1000)}` : ''}`;
      if (n < 1000000) return `${say(Math.floor(n / 1000))} ribu${n % 1000 ? ` ${say(n % 1000)}` : ''}`;
      if (n < 1000000000) return `${say(Math.floor(n / 1000000))} juta${n % 1000000 ? ` ${say(n % 1000000)}` : ''}`;
      if (n < 1000000000000) return `${say(Math.floor(n / 1000000000))} miliar${n % 1000000000 ? ` ${say(n % 1000000000)}` : ''}`;
      return `${say(Math.floor(n / 1000000000000))} triliun${n % 1000000000000 ? ` ${say(n % 1000000000000)}` : ''}`;
    }
    return angka > 0 ? `${say(angka).replace(/\s+/g, ' ').trim()} rupiah` : 'nol rupiah';
  }
  const requestedPrintStyle = typeof printStyle !== 'undefined' ? printStyle : 'a4';
  const activeStyle = String(requestedPrintStyle || 'a4').toLowerCase() === 'receipt' ? 'receipt' : 'a4';
  const companyLogo = settings?.company_logo_url || '/img/mss-logo.png';
  const companyName = company || settings?.company_header || 'PT Media Solusi Sukses';
  const companyLegalName = settings?.company_legal_name || '';
  const companyAddress = settings?.company_address || 'Alamat usaha belum diatur';
  const companyPhone = (settings?.whatsapp_admin_numbers && settings.whatsapp_admin_numbers.length > 0)
    ? formatPhoneLocal(settings.whatsapp_admin_numbers[0])
    : formatPhoneLocal(settings?.company_phone || '');
  const companyEmail = settings?.company_email || '';
  const companyManager = settings?.company_manager || 'Admin Pusat';
  const signerTitle = settings?.invoice_signer_title || 'Finance';
  const signatureUrl = settings?.invoice_signature_url || '';
  const stampUrl = settings?.invoice_stamp_url || '';
  const supportByEnabled = settings?.support_by_enabled === true || settings?.support_by_enabled === 'true' || settings?.support_by_enabled === 1 || settings?.support_by_enabled === '1';
  const supportLogo = settings?.support_isp_logo_url || '';
  const partnerBrandEnabled = settings?.partner_brand_enabled === true || settings?.partner_brand_enabled === 'true' || settings?.partner_brand_enabled === 1 || settings?.partner_brand_enabled === '1';
  const partnerBrandName = String(settings?.partner_brand_name || '').trim();
  const partnerLegalName = String(settings?.partner_legal_name || '').trim();
  const partnerLogo = String(settings?.partner_logo_url || '').trim();
  const showPartnerBrand = partnerBrandEnabled && (partnerBrandName || partnerLogo);
  const partnerPrintLabel = partnerBrandName ? `Mitra Resmi MSS: ${partnerBrandName}` : 'Mitra Resmi MSS';
  const partnerPrintCaption = partnerBrandName || 'Mitra Resmi';
  const manualPaymentBank = settings?.manual_payment_bank || '-';
  const manualPaymentAccountNumber = settings?.manual_payment_account_number || '-';
  const manualPaymentAccountName = settings?.manual_payment_account_name || '-';
  const manualPaymentNotes = settings?.manual_payment_notes || '';
  const mns = (lang || 'id') === 'en'
    ? ['January','February','March','April','May','June','July','August','September','October','November','December']
    : ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  const shortMns = (lang || 'id') === 'en'
    ? ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
    : ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
  const now = new Date();
  const invoiceDate = invoice?.created_at ? new Date(invoice.created_at) : now;
  const paidDate = invoice?.paid_at ? new Date(invoice.paid_at) : null;
  const dueDay = Math.min(Number(invoice?.due_day_snapshot || customer?.isolate_day || 28), new Date(Number(invoice?.period_year || now.getFullYear()), Number(invoice?.period_month || (now.getMonth() + 1)), 0).getDate());
  const dueDate = new Date(Number(invoice?.period_year || now.getFullYear()), Number(invoice?.period_month || (now.getMonth() + 1)) - 1, dueDay);
  const invoiceCode = `INV-${invoice.id}-${invoice.period_month}-${invoice.period_year}`;
  const printTarget = printBasePath || '';
  function printStyleUrl(styleName) {
    const base = String(printTarget || '').trim();
    if (!base) return '#';
    const cleanStyle = String(styleName || 'a4').toLowerCase() === 'receipt' ? 'receipt' : 'a4';
    return `${base}${base.includes('?') ? '&' : '?'}style=${cleanStyle}`;
  }
  const normalizedStatus = String(invoice?.status || '').trim().toLowerCase();
  const isPaid = normalizedStatus === 'paid' || normalizedStatus === 'lunas';
  const statusText = isPaid ? 'LUNAS' : 'BELUM LUNAS';
  const documentLabel = isPaid ? 'NOTA PEMBAYARAN' : 'TAGIHAN INTERNET';
  const documentLead = isPaid ? 'Bukti pembayaran layanan internet pelanggan.' : 'Dokumen penagihan layanan internet pelanggan.';
  const documentMetaLabel = isPaid ? 'Pembayaran' : 'Penagihan';
  const amountLabel = isPaid ? 'Total Dibayar' : 'Total Tagihan';
  const paymentInfoTitle = isPaid ? 'Informasi Pembayaran' : 'Cara Pembayaran';
  const footerDocText = isPaid ? 'Dokumen bukti pembayaran pelanggan yang sah.' : 'Dokumen tagihan pelanggan yang sah.';
  function publicPaidByName(value) {
    const raw = String(value || '').trim();
    if (!raw) return 'Admin';
    const cashierMatch = raw.match(/^Kasir(?:\s+(.+?))?(?:\s+\(@[^)]*\))?(\s*-\s*.+)?$/i);
    if (!cashierMatch) return raw;
    const name = String(cashierMatch[1] || '').trim();
    const suffix = String(cashierMatch[2] || '').trim();
    return `Admin${name ? ` ${name}` : ''}${suffix ? ` ${suffix}` : ''}`.trim();
  }
  const paidByDisplay = publicPaidByName(invoice?.paid_by_name);
  const packageName = customer?.package_name || 'Internet Service';
  const invoiceCustomerPrefix = String(settings?.customer_id_prefix || 'SCK').trim().toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10) || 'SCK';
  const customerCode = customer?.customer_code || (customer?.id ? `${invoiceCustomerPrefix}${customer.id}` : '-');
  const customerPhoneDisplay = formatPhoneLocal(customer?.phone || '');
  const customerAddress = String(customer?.address || customer?.install_address || '').trim() || '-';
  const invoicePeriodLabel = `${shortMns[Number(invoice.period_month) - 1] || invoice.period_month} ${invoice.period_year}`;
  const receiptDateLabel = (paidDate || invoiceDate).toLocaleDateString('id-ID');
  const dueDateLabel = dueDate.toLocaleDateString('id-ID');
  const invoiceServiceLabel = `${packageName} - Periode ${invoicePeriodLabel}`;
  const invoiceAmount = Number(invoice?.amount || 0);
  const packageIncludePpn = Number(customer?.package_include_ppn || 0) === 1;
  const packagePpnPercent = packageIncludePpn ? Math.max(0, Number(customer?.package_ppn_percent || 0)) : 0;
  const packageTaxDivisor = 1 + (packagePpnPercent / 100);
  const invoiceBaseAmount = packageIncludePpn && packageTaxDivisor > 0
    ? Math.round(invoiceAmount / packageTaxDivisor)
    : invoiceAmount;
  const invoicePpnAmount = packageIncludePpn
    ? Math.max(0, invoiceAmount - invoiceBaseAmount)
    : 0;
  const invoiceAmountWords = terbilang(invoiceAmount);
  const invoiceUniqueAmount = Number(invoice?.qris_amount_unique || 0) || 0;
  const invoiceUniqueCode = Number(invoice?.qris_unique_code || 0) || 0;
  const supportBrandName = settings?.upstream_provider_name || companyLegalName || companyName;
  const receiptSupportBrandName = String(settings?.upstream_provider_name || companyLegalName || companyName || '').trim();
  const showSupportFooter = supportByEnabled && String(supportBrandName || '').trim().length > 0;
  const supportLines = [companyAddress, companyPhone !== '-' ? `Telp/WA: ${companyPhone}` : '', companyEmail ? `Email: ${companyEmail}` : ''].filter(Boolean);
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= activeStyle === 'receipt' ? (isPaid ? 'Struk Pembayaran' : 'Struk Tagihan') : documentLabel %> #<%= invoice.id %></title>
  <style>
    :root{
      --ink:#0f172a;
      --muted:#64748b;
      --line:#dbe3f0;
      --soft:#f8fbff;
      --accent:#073dcc;
      --accent-soft:#e8f1ff;
      --success:#16a34a;
      --warn:#f59e0b;
      --shadow:0 24px 60px rgba(15, 23, 42, 0.12);
    }
    *{ box-sizing:border-box; }
    html,body{ margin:0; padding:0; color:var(--ink); }
    body{
      font-family: "Times New Roman", Times, serif;
      background:#eef5ff;
      padding:12px;
    }
    .top-actions{
      position:sticky;
      top:0;
      z-index:20;
      display:flex;
      justify-content:flex-end;
      gap:10px;
      margin:0 auto 14px;
      max-width:960px;
    }
    .top-actions a,
    .top-actions button{
      border:0;
      border-radius:999px;
      padding:12px 18px;
      font:600 13px/1 "Segoe UI", Arial, sans-serif;
      cursor:pointer;
      text-decoration:none;
      color:#fff;
      background:var(--accent);
      box-shadow:0 10px 24px rgba(37, 99, 235, 0.24);
    }
    .top-actions a.alt,
    .top-actions button.alt{
      background:#fff;
      color:var(--ink);
      border:1px solid rgba(15,23,42,.08);
      box-shadow:none;
    }
    .invoice-sheet{
      width:210mm;
      margin:0 auto;
      background:#fff;
      border-radius:12px;
      box-shadow:0 14px 32px rgba(15, 23, 42, 0.08);
      overflow:hidden;
      position:relative;
      border:1px solid #cbd5e1;
      border-radius:4px;
    }
    .sheet-head{
      display:grid;
      grid-template-columns:1.18fr .82fr;
      gap:10px;
      padding:15px 16px 9px;
      background:#fff;
      border-bottom:1.5px solid #94a3b8;
    }
    .brand-stack{
      display:grid;
      gap:10px;
      align-content:start;
    }
    .brand-box{
      display:grid;
      grid-template-columns:64px 1fr;
      gap:12px;
      align-items:start;
    }
    .brand-logo-card{
      width:64px;
      min-height:64px;
      border-radius:10px;
      background:linear-gradient(180deg,#fff,#f8fbff);
      border:1px solid #cbd5e1;
      display:grid;
      place-items:center;
      padding:7px;
      box-shadow:0 8px 18px rgba(15,23,42,.06);
    }
    .brand-logo-card img{
      width:100%;
      height:100%;
      max-width:50px;
      max-height:50px;
      object-fit:contain;
      border:0;
      padding:0;
      border-radius:0;
      background:transparent;
    }
    .brand-copy h1{
      margin:0;
      font-size:20px;
      letter-spacing:.02em;
      line-height:1.1;
      font-weight:700;
    }
    .brand-copy h2{
      margin:4px 0 5px;
      font-size:12px;
      letter-spacing:.02em;
      color:var(--muted);
      font-weight:700;
      text-transform:none;
    }
    .brand-copy p{
      margin:2px 0;
      color:var(--muted);
      font-size:11px;
      line-height:1.35;
    }
    .partner-print-card{
      display:grid;
      grid-template-columns:54px 1fr;
      gap:10px;
      align-items:center;
      max-width:430px;
      border:1px solid #cbd5e1;
      border-left:4px solid var(--accent);
      border-radius:10px;
      background:linear-gradient(135deg,#f8fbff 0%,#ffffff 62%,#eef6ff 100%);
      padding:8px 10px;
      color:#0f172a;
      box-shadow:0 8px 20px rgba(15,23,42,.05);
    }
    .partner-print-logo{
      width:54px;
      height:54px;
      border-radius:10px;
      background:#fff;
      border:1px solid #dbe3f0;
      display:grid;
      place-items:center;
      padding:5px;
    }
    .partner-print-logo img{
      width:100%;
      height:100%;
      object-fit:contain;
      border:0;
      padding:0;
      border-radius:0;
      background:transparent;
    }
    .partner-print-kicker{
      margin:0 0 3px;
      color:#475569;
      font-family:"Segoe UI", Arial, sans-serif;
      font-size:8.8px;
      font-weight:900;
      letter-spacing:.12em;
      text-transform:uppercase;
    }
    .partner-print-name{
      display:block;
      color:#073dcc;
      font-size:14px;
      font-weight:900;
      line-height:1.1;
    }
    .partner-print-legal{
      display:block;
      margin-top:3px;
      color:#475569;
      font-size:10px;
      font-weight:700;
      line-height:1.25;
    }
    .partner-print-note{
      display:block;
      margin-top:4px;
      color:#0f172a;
      font-size:9px;
      font-weight:700;
      letter-spacing:.04em;
      text-transform:uppercase;
    }
    .invoice-meta-card{
      background:#fff;
      border:1px solid #cbd5e1;
      border-radius:6px;
      padding:10px 12px;
      align-self:start;
    }
    .invoice-meta-card .label{
      color:var(--muted);
      text-transform:uppercase;
      font-size:11px;
      font-weight:700;
      letter-spacing:.12em;
    }
    .invoice-meta-card .title{
      margin:6px 0 10px;
      font-size:24px;
      line-height:1;
      letter-spacing:.04em;
    }
    .meta-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:6px 10px;
    }
    .meta-grid .meta-item small{
      display:block;
      color:var(--muted);
      margin-bottom:4px;
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.12em;
    }
    .meta-grid .meta-item strong{
      display:block;
      font-size:11px;
    }
    .status-pill{
      display:inline-flex;
      align-items:center;
      gap:6px;
      margin-top:9px;
      padding:6px 11px;
      border-radius:999px;
      font-size:10px;
      font-weight:800;
      letter-spacing:.06em;
      background:<%= isPaid ? '#e8fff1' : '#fff7e7' %>;
      color:<%= isPaid ? '#14803d' : '#b45309' %>;
    }
    .sheet-body{
      padding:9px 16px 10px;
    }
    .hero-grid{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:9px;
      margin-bottom:9px;
    }
    .panel{
      border:1px solid var(--line);
      border-radius:6px;
      padding:10px 11px;
      background:#fff;
      page-break-inside:avoid;
    }
    .panel.soft{
      background:#f8fafc;
    }
    .panel h3{
      margin:0 0 8px;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.1em;
      color:var(--muted);
    }
    .recipient-name{
      margin:0 0 6px;
      font-size:18px;
      line-height:1.1;
    }
    .recipient-lines{
      display:grid;
      gap:5px;
      color:#334155;
      font-size:11px;
    }
    .recipient-lines strong{
      color:var(--ink);
    }
    .summary-total{
      display:flex;
      flex-direction:column;
      gap:4px;
      align-items:flex-end;
      justify-content:center;
      min-height:100%;
    }
    .summary-total small{
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.14em;
      font-weight:700;
      font-size:11px;
    }
    .summary-total strong{
      font-size:24px;
      color:#0f172a;
      line-height:1;
    }
    .service-table{
      width:100%;
      border-collapse:collapse;
      margin-top:6px;
    }
    .service-table th,
    .service-table td{
      padding:8px 7px;
      border-bottom:1px solid var(--line);
      vertical-align:top;
      text-align:left;
    }
    .service-table th{
      font-size:10px;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.1em;
      border-bottom:1.5px solid #94a3b8;
    }
    .service-table td strong{
      font-size:11px;
    }
    .service-note{
      color:var(--muted);
      font-size:9.8px;
      margin-top:3px;
    }
    .totals-card{
      margin-top:8px;
      padding:9px 11px;
      border-radius:6px;
      background:#f8fafc;
      border:1px solid var(--line);
    }
    .totals-row{
      display:flex;
      justify-content:space-between;
      gap:12px;
      padding:4px 0;
      font-size:11px;
    }
    .totals-row + .totals-row{
      border-top:1px dashed rgba(100,116,139,.22);
    }
    .totals-row.total{
      font-size:15px;
      font-weight:800;
      color:#0f172a;
    }
    .footer-grid{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:9px;
      margin-top:9px;
    }
    .payment-card{
      display:flex;
      flex-direction:column;
      gap:5px;
    }
    .bank-pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:5px 9px;
      border-radius:999px;
      background:#edf3ff;
      color:#07307f;
      font-weight:800;
      width:max-content;
      font-size:10px;
    }
    .bank-number{
      font-size:19px;
      font-weight:900;
      letter-spacing:.06em;
    }
    .payment-mini{
      display:grid;
      gap:5px;
      color:#334155;
      font-size:10.5px;
      line-height:1.35;
    }
    .paid-proof-card{
      display:grid;
      gap:8px;
      padding:10px 11px;
      border-radius:6px;
      border:1px solid rgba(22,163,74,.2);
      background:#f0fdf4;
      color:#14532d;
    }
    .paid-proof-title{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      font-size:11px;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .paid-proof-status{
      display:inline-flex;
      border-radius:999px;
      padding:5px 9px;
      background:#16a34a;
      color:#fff;
      font-size:10px;
      font-weight:900;
      white-space:nowrap;
    }
    .paid-proof-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:7px;
    }
    .paid-proof-item{
      padding:8px;
      border-radius:6px;
      background:#fff;
      border:1px solid rgba(22,163,74,.14);
    }
    .paid-proof-item span{
      display:block;
      margin-bottom:4px;
      color:#15803d;
      font-size:9px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .paid-proof-item strong{
      display:block;
      color:#0f172a;
      font-size:10.5px;
      line-height:1.3;
    }
    .info-list{
      margin:0;
      padding-left:16px;
      color:#334155;
      display:grid;
      gap:3px;
      font-size:9.5px;
    }
    .signature-card{
      position:relative;
      min-height:138px;
      padding-top:4px;
    }
    .signature-label{
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.12em;
      font-size:11px;
      font-weight:700;
    }
    .signature-visual{
      position:relative;
      height:82px;
      margin:4px 0 9px;
      width:210px;
      display:flex;
      align-items:flex-end;
      justify-content:flex-start;
      overflow:visible;
    }
    .signature-visual img.signature-img{
      max-width:134px;
      max-height:48px;
      object-fit:contain;
      position:relative;
      z-index:2;
      margin-left:28px;
      margin-bottom:7px;
      filter:contrast(1.02) saturate(1.04);
    }
    .signature-visual img.stamp-img{
      width:92px;
      height:92px;
      object-fit:contain;
      position:absolute;
      left:0;
      top:-4px;
      z-index:3;
      opacity:.9;
      transform:rotate(-11deg);
      transform-origin:center;
      mix-blend-mode:multiply;
    }
    .signature-line{
      border-top:1.5px solid #0f172a;
      padding-top:7px;
      width:210px;
    }
    .signature-line strong{
      display:block;
      font-size:12px;
    }
    .signature-line span{
      color:var(--muted);
      font-size:10px;
    }
    .status-card{
      display:grid;
      gap:9px;
      align-content:start;
    }
    .status-box{
      border:1px dashed var(--line);
      border-radius:6px;
      padding:9px 11px;
      background:#f8fafc;
    }
    .status-box strong{
      display:block;
      font-size:11px;
      margin-bottom:7px;
    }
    .status-box .big{
      font-size:16px;
      font-weight:900;
      color:<%= isPaid ? '#14803d' : '#b45309' %>;
    }
    .sheet-foot{
      padding:7px 16px 9px;
      border-top:1px solid var(--line);
      color:var(--muted);
      font-size:10px;
      display:grid;
      gap:8px;
      justify-items:center;
      text-align:center;
    }
    .sheet-foot-main{
      display:block;
    }
    .support-footer{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      font-size:10px;
      font-weight:700;
      color:#334155;
    }
    .support-footer img{
      width:20px;
      height:20px;
      object-fit:contain;
      border-radius:6px;
      background:#fff;
      border:1px solid rgba(15,23,42,.08);
      padding:2px;
    }
    .invoice-period-line{
      font-size:11px;
      color:var(--muted);
      margin-top:2px;
    }
    .amount-words{
      font-size:10px;
      color:var(--muted);
      text-align:right;
      margin-top:4px;
      font-style:italic;
    }
    .totals-row.ppn strong,
    .totals-row.ppn span{
      color:#0634b0;
    }

    .receipt-page{
      width:min(100%, 460px);
      margin:0 auto;
      background:#fff;
      border-radius:14px;
      box-shadow:var(--shadow);
      padding:14px 14px 15px;
      font-family:"Courier New", Courier, monospace;
      color:#000;
      border:1px solid #e2e8f0;
    }
    .receipt-logo{
      width:58px;
      height:58px;
      object-fit:contain;
      display:block;
      margin:0 auto 6px;
    }
    .receipt-center{text-align:center;}
    .receipt-title{
      font-size:17px;
      font-weight:900;
      text-transform:uppercase;
      margin:0 0 3px;
    }
    .receipt-sub{
      font-size:10.5px;
      line-height:1.32;
      color:#000;
      font-weight:700;
    }
    .receipt-divider{
      border-bottom:1px dashed #111;
      margin:7px 0;
    }
    .receipt-section-title{
      font-size:15px;
      font-weight:900;
      text-align:center;
      text-transform:uppercase;
      margin:4px 0 8px;
      color:#000;
    }
    .receipt-box{
      border:1px dashed #333;
      border-radius:6px;
      padding:8px 8px;
      margin:6px 0;
      background:#fff;
    }
    .receipt-row{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      font-size:18px;
      line-height:1.22;
      margin:6px 0;
      color:#000;
      font-weight:900;
    }
    .receipt-row span{
      flex:1 1 42%;
      min-width:0;
    }
    .receipt-row strong{
      flex:1 1 58%;
      font-size:18px;
      line-height:1.22;
      font-weight:900;
      color:#000;
      text-align:right;
      overflow-wrap:anywhere;
    }
    .receipt-total{
      border-top:2px solid #0f172a;
      border-bottom:2px solid #0f172a;
      padding:7px 0;
      font-size:20px;
      font-weight:900;
      text-align:right;
      margin-top:10px;
      color:#000;
    }
    .receipt-paid-box{
      border:1px dashed #16a34a;
      background:#fff;
      border-radius:6px;
      padding:6px 8px;
      margin-top:7px;
      text-align:center;
      font-size:12px;
      line-height:1.35;
      color:#000;
    }
    .receipt-paid-box .paid-stamp{
      display:inline-block;
      border:1px solid #22c55e;
      border-radius:999px;
      padding:4px 12px;
      margin-bottom:5px;
      font-size:12px;
      font-weight:900;
      letter-spacing:.18em;
    }
    .receipt-foot{
      margin-top:12px;
      text-align:center;
      font-size:10px;
      line-height:1.35;
      color:#000;
      font-weight:800;
    }
    .receipt-support{
      margin-top:4px;
      text-align:center;
      font-size:10.5px;
      line-height:1.25;
      color:#000;
      font-weight:900;
    }

    @media print{
      @page{
        size: <%= activeStyle === 'receipt' ? '58mm auto' : 'A4' %>;
        margin:<%= activeStyle === 'receipt' ? '0' : '6mm' %>;
      }
      body{
        background:#fff;
        padding:0;
      }
      .top-actions{ display:none; }
      .invoice-sheet,
      .receipt-page{
        box-shadow:none;
        border-radius:0;
        width:<%= activeStyle === 'receipt' ? '58mm' : 'auto' %>;
        min-height:auto;
        margin:0;
        border:0;
        padding:<%= activeStyle === 'receipt' ? '1.5mm' : '0' %>;
      }
      .receipt-section-title{
        font-size:<%= activeStyle === 'receipt' ? '13.5px' : '15px' %>;
      }
      .receipt-box{
        padding:<%= activeStyle === 'receipt' ? '6px 5px' : '8px' %>;
      }
      .receipt-row,
      .receipt-row strong{
        font-size:<%= activeStyle === 'receipt' ? '15.5px' : '18px' %>;
        line-height:1.2;
      }
      .receipt-row{
        gap:<%= activeStyle === 'receipt' ? '7px' : '12px' %>;
        margin:<%= activeStyle === 'receipt' ? '5px 0' : '6px 0' %>;
      }
      .receipt-total{
        font-size:<%= activeStyle === 'receipt' ? '18px' : '20px' %>;
      }
      .sheet-head{ padding-top:6px; }
      .sheet-foot{ padding-bottom:5px; }
      .sheet-head,
      .hero-grid,
      .panel,
      .totals-card,
      .footer-grid,
      .sheet-foot{
        page-break-inside:avoid;
      }
    }
  </style>
</head>
<body>
  <div class="top-actions">
    <% if (printTarget) { %>
      <a class="<%= activeStyle === 'a4' ? '' : 'alt' %>" href="<%= printStyleUrl('a4') %>">Mode A4</a>
      <a class="<%= activeStyle === 'receipt' ? '' : 'alt' %>" href="<%= printStyleUrl('receipt') %>">Mode Struk</a>
    <% } %>
    <% if (activeStyle === 'receipt') { %>
      <button type="button" id="saveReceiptBtn">Simpan Gambar</button>
      <button type="button" id="shareReceiptBtn">Bagikan Gambar</button>
    <% } %>
    <button type="button" class="alt" onclick="window.print()">Print</button>
  </div>

  <% if (activeStyle === 'receipt') { %>
    <div class="receipt-page" id="receiptCapture">
      <img class="receipt-logo" src="<%= companyLogo %>" alt="Logo" onerror="this.style.display='none'">
      <div class="receipt-center">
        <div class="receipt-title"><%= companyName %></div>
        <div class="receipt-sub">Telp/WA: <%= companyPhone %></div>
        <% if (companyAddress) { %>
          <div class="receipt-sub"><%= companyAddress %></div>
        <% } %>
      </div>

      <div class="receipt-divider"></div>

      <div class="receipt-section-title"><%= isPaid ? 'STRUK PEMBAYARAN' : 'STRUK TAGIHAN' %></div>
      <div class="receipt-box">
        <div class="receipt-row"><span>No. Invoice</span><strong><%= invoiceCode %></strong></div>
        <div class="receipt-row"><span><%= isPaid ? 'Tanggal Bayar' : 'Tanggal Tagih' %></span><strong><%= receiptDateLabel %></strong></div>
        <div class="receipt-row"><span>Status</span><strong><%= statusText %></strong></div>
      </div>

      <div class="receipt-divider"></div>

      <div class="receipt-section-title">Data Pelanggan</div>
      <div class="receipt-box">
        <div class="receipt-row"><span>ID Pelanggan</span><strong><%= customerCode %></strong></div>
        <div class="receipt-row"><span>Nama</span><strong><%= customer.name %></strong></div>
        <% if (customerPhoneDisplay && customerPhoneDisplay !== '-') { %>
          <div class="receipt-row"><span>Telepon</span><strong><%= customerPhoneDisplay %></strong></div>
        <% } %>
        <% if (customerAddress && customerAddress !== '-') { %>
          <div class="receipt-row"><span>Alamat</span><strong><%= customerAddress %></strong></div>
        <% } %>
        <div class="receipt-row"><span>Paket</span><strong><%= packageName %></strong></div>
        <div class="receipt-row"><span>Periode</span><strong><%= invoicePeriodLabel %></strong></div>
        <% if (isPaid) { %>
          <div class="receipt-row"><span>Dibayar Oleh</span><strong><%= paidByDisplay %></strong></div>
        <% } else { %>
          <div class="receipt-row"><span>Jatuh Tempo</span><strong><%= dueDateLabel %></strong></div>
        <% } %>
      </div>

      <div class="receipt-divider"></div>

      <div class="receipt-section-title">Rincian</div>
      <div class="receipt-box">
        <div class="receipt-row"><span>Layanan</span><strong><%= packageName %></strong></div>
        <div class="receipt-row"><span>Subtotal</span><strong>Rp <%= invoiceBaseAmount.toLocaleString('id-ID') %></strong></div>
        <% if (packageIncludePpn) { %>
          <div class="receipt-row"><span>PPN <%= packagePpnPercent.toLocaleString('id-ID') %>%</span><strong>Rp <%= invoicePpnAmount.toLocaleString('id-ID') %></strong></div>
        <% } %>
        <div class="receipt-row"><span>Biaya Lainnya</span><strong>Rp 0</strong></div>
      </div>

      <div class="receipt-total"><%= isPaid ? 'TOTAL DIBAYAR' : 'TOTAL TAGIHAN' %>: Rp <%= invoiceAmount.toLocaleString('id-ID') %></div>

      <% if (isPaid) { %>
        <div class="receipt-paid-box">
          <span class="paid-stamp">LUNAS</span><br>
          Pembayaran telah diterima pada <%= receiptDateLabel %>.
        </div>
      <% } else { %>
        <div class="receipt-divider"></div>
        <div class="receipt-sub">
          Pembayaran ke: <strong><%= manualPaymentBank %></strong><br>
          No. Rek: <strong><%= manualPaymentAccountNumber %></strong><br>
          A/N: <strong><%= manualPaymentAccountName %></strong>
        </div>
      <% } %>

      <div class="receipt-foot">Simpan struk ini sebagai bukti pembayaran.</div>
      <% if (showPartnerBrand) { %>
        <div class="receipt-support"><%= partnerPrintLabel %></div>
      <% } %>
      <% if (receiptSupportBrandName) { %>
        <div class="receipt-support">Support by <%= receiptSupportBrandName %></div>
      <% } %>
    </div>
  <% } else { %>
    <div class="invoice-sheet">
      <div class="sheet-head">
        <div class="brand-stack">
          <div class="brand-box">
            <div class="brand-logo-card">
              <img src="<%= companyLogo %>" alt="Logo <%= companyLegalName || companyName %>" onerror="this.onerror=null;this.src='/img/mss-logo.png'">
            </div>
            <div class="brand-copy">
              <h1><%= companyLegalName || companyName %></h1>
              <% if (companyLegalName && companyName && companyLegalName !== companyName) { %>
                <h2><%= companyName %></h2>
              <% } %>
              <% supportLines.forEach((line) => { %>
                <p><%= line %></p>
              <% }) %>
            </div>
          </div>
          <% if (showPartnerBrand) { %>
            <div class="partner-print-card">
              <div class="partner-print-logo">
                <% if (partnerLogo) { %>
                  <img src="<%= partnerLogo %>" alt="Logo <%= partnerBrandName || 'Mitra Resmi MSS' %>" onerror="this.style.display='none'">
                <% } else { %>
                  <strong style="font:900 18px/1 'Segoe UI',Arial,sans-serif;color:#073dcc;"><%= (partnerPrintCaption || 'MR').slice(0,2).toUpperCase() %></strong>
                <% } %>
              </div>
              <div>
                <div class="partner-print-kicker">Mitra Resmi ISP</div>
                <strong class="partner-print-name"><%= partnerPrintCaption %></strong>
                <% if (partnerLegalName) { %><small class="partner-print-legal"><%= partnerLegalName %></small><% } %>
                <span class="partner-print-note">Terdaftar sebagai mitra layanan <%= companyLegalName || companyName %></span>
              </div>
            </div>
          <% } %>
        </div>

        <div class="invoice-meta-card">
          <div class="label">Invoice</div>
          <div class="title"><%= isPaid ? 'NOTA' : 'INVOICE' %></div>
          <div style="font-size:10.5px;color:var(--muted);margin-bottom:8px;"><%= documentLabel %></div>
          <div class="meta-grid">
            <div class="meta-item">
              <small>No. Invoice</small>
              <strong><%= invoiceCode %></strong>
            </div>
            <div class="meta-item">
              <small><%= isPaid ? 'Tanggal Bayar' : 'Tanggal Tagih' %></small>
              <strong><%= (paidDate || invoiceDate).toLocaleDateString('id-ID') %></strong>
            </div>
            <div class="meta-item">
              <small>Periode</small>
              <strong><%= `1 - ${new Date(Number(invoice.period_year), Number(invoice.period_month), 0).getDate()} ${mns[Number(invoice.period_month) - 1]} ${invoice.period_year}` %></strong>
            </div>
            <div class="meta-item">
              <small>Jatuh Tempo</small>
              <strong><%= dueDate.toLocaleDateString('id-ID') %></strong>
            </div>
            <div class="meta-item">
              <small>Status Invoice</small>
              <strong><%= statusText %></strong>
            </div>
          </div>
          <div class="status-pill">
            <span>â—</span>
            <span><%= statusText %></span>
          </div>
        </div>
      </div>

      <div class="sheet-body">
        <div class="hero-grid">
          <div class="panel">
            <h3>Tagihan Kepada</h3>
            <h4 class="recipient-name"><%= customer.name %></h4>
            <div class="recipient-lines">
              <div><strong>ID Pelanggan:</strong> <%= customerCode %></div>
              <% if (customerPhoneDisplay && customerPhoneDisplay !== '-') { %>
                <div><strong>Telepon:</strong> <%= customerPhoneDisplay %></div>
              <% } %>
              <div><strong>Alamat:</strong> <%= customerAddress %></div>
              <div><strong>Layanan:</strong> <%= packageName %></div>
            </div>
          </div>

          <div class="panel soft">
            <div class="summary-total">
              <small><%= isPaid ? 'Total Pembayaran' : 'Total Tagihan' %></small>
              <strong>Rp <%= invoiceAmount.toLocaleString('id-ID') %></strong>
              <div class="amount-words"><%= invoiceAmountWords.charAt(0).toUpperCase() + invoiceAmountWords.slice(1) %></div>
              <div style="color:var(--muted);font-size:10px;text-align:right;"><%= isPaid ? `Pembayaran diterima ${paidDate ? paidDate.toLocaleDateString('id-ID') : invoiceDate.toLocaleDateString('id-ID')}` : `Bayar sebelum ${dueDate.toLocaleDateString('id-ID')}` %></div>
            </div>
          </div>
        </div>

        <div class="panel">
          <h3>Rincian Layanan</h3>
          <table class="service-table">
            <thead>
              <tr>
                <th style="width:56px;">No</th>
                <th>Layanan</th>
                <th style="width:150px;">Periode</th>
                <th style="width:170px;">Keterangan</th>
                <th style="width:170px;text-align:right;">Nilai</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>1</td>
                <td>
                  <strong><%= packageName %></strong>
                  <div class="service-note">Internet broadband <%= Number(customer?.speed_down || 0) > 0 ? `${(Number(customer.speed_down) / 1000).toFixed(0)} Mbps` : '' %></div>
                </td>
                <td>
                  <strong><%= invoicePeriodLabel %></strong>
                  <div class="service-note"><%= `1 ${mns[Number(invoice.period_month) - 1]} - ${new Date(Number(invoice.period_year), Number(invoice.period_month), 0).getDate()} ${mns[Number(invoice.period_month) - 1]} ${invoice.period_year}` %></div>
                </td>
                <td>
                  <strong><%= isPaid ? 'Pembayaran layanan internet' : 'Biaya langganan internet' %></strong>
                  <div class="service-note"><%= isPaid ? 'Pembayaran pelanggan internet' : 'Tagihan pelanggan internet' %></div>
                </td>
                <td style="text-align:right;">
                  <strong>Rp <%= invoiceAmount.toLocaleString('id-ID') %></strong>
                </td>
              </tr>
            </tbody>
          </table>

          <div class="totals-card">
            <div class="totals-row">
              <span>Subtotal</span>
              <strong>Rp <%= invoiceBaseAmount.toLocaleString('id-ID') %></strong>
            </div>
            <% if (packageIncludePpn) { %>
            <div class="totals-row ppn">
              <span>PPN <%= packagePpnPercent.toLocaleString('id-ID') %>%</span>
              <strong>Rp <%= invoicePpnAmount.toLocaleString('id-ID') %></strong>
            </div>
            <% } %>
            <div class="totals-row">
              <span>Biaya Lainnya</span>
              <strong>Rp 0</strong>
            </div>
            <div class="totals-row total">
              <span><%= isPaid ? 'Total Dibayar' : 'Total Tagihan' %></span>
              <strong>Rp <%= invoiceAmount.toLocaleString('id-ID') %></strong>
            </div>
          </div>
        </div>

        <div class="footer-grid">
          <div class="panel">
            <h3><%= paymentInfoTitle %></h3>
            <div class="payment-card">
              <% if (isPaid) { %>
              <div class="paid-proof-card">
                <div class="paid-proof-title">
                  <span>Bukti Pembayaran</span>
                  <span class="paid-proof-status">Lunas</span>
                </div>
                <div class="paid-proof-grid">
                  <div class="paid-proof-item">
                    <span>Tanggal Bayar</span>
                    <strong><%= receiptDateLabel %></strong>
                  </div>
                  <div class="paid-proof-item">
                    <span>Dibayar Oleh</span>
                    <strong><%= paidByDisplay %></strong>
                  </div>
                  <div class="paid-proof-item">
                    <span>No. Invoice</span>
                    <strong><%= invoiceCode %></strong>
                  </div>
                  <div class="paid-proof-item">
                    <span>Nominal</span>
                    <strong>Rp <%= invoiceAmount.toLocaleString('id-ID') %></strong>
                  </div>
                </div>
              </div>
              <% } else if (manualPaymentBank !== '-' || manualPaymentAccountNumber !== '-' || manualPaymentAccountName !== '-') { %>
              <span class="bank-pill">Transfer <%= manualPaymentBank %></span>
              <div class="bank-number"><%= manualPaymentAccountNumber %></div>
              <div style="font-size:15px;font-weight:700;"><%= manualPaymentAccountName %></div>
              <% } else { %>
              <span class="bank-pill">Konfirmasi Manual</span>
              <% } %>
              <div class="payment-mini">
                <div><%= isPaid ? 'Tanggal bayar' : 'Jatuh tempo' %>: <strong><%= (isPaid ? (paidDate || invoiceDate) : dueDate).toLocaleDateString('id-ID') %></strong></div>
                <div>Kontak admin: <strong><%= companyPhone %></strong></div>
              </div>
              <ul class="info-list">
                <li><%= isPaid ? 'Dokumen ini menjadi bukti bahwa pembayaran telah terverifikasi.' : 'Invoice dinyatakan lunas setelah dana diterima dan terverifikasi.' %></li>
                <% if (!isPaid && invoiceUniqueAmount > 0) { %>
                  <li>Transfer sesuai nominal tepat: <strong>Rp <%= invoiceUniqueAmount.toLocaleString('id-ID') %></strong><% if (invoiceUniqueCode > 0) { %> (kode unik <%= String(invoiceUniqueCode).padStart(3, '0') %>)<% } %>, lalu kirim bukti pembayaran ke admin.</li>
                <% } %>
                <% if (packageIncludePpn) { %><li>Nominal sudah termasuk PPN <%= packagePpnPercent.toLocaleString('id-ID') %>% sebesar Rp <%= invoicePpnAmount.toLocaleString('id-ID') %>.</li><% } %>
                <% if (!isPaid && manualPaymentNotes) { %><li><%= manualPaymentNotes %></li><% } %>
              </ul>
            </div>
          </div>

          <div class="panel signature-card">
            <div class="signature-label">Pengesahan</div>
            <div class="signature-visual">
              <% if (signatureUrl) { %>
                <img class="signature-img" src="<%= signatureUrl %>" alt="Tanda Tangan">
              <% } %>
              <% if (stampUrl) { %>
                <img class="stamp-img" src="<%= stampUrl %>" alt="Cap Invoice">
              <% } %>
            </div>
            <div class="signature-line">
              <strong><%= companyManager %></strong>
              <span><%= signerTitle %></span>
            </div>
            <div class="status-card" style="margin-top:12px;">
              <div class="status-box">
                <strong><%= isPaid ? 'Status Pembayaran' : 'Status Tagihan' %></strong>
                <div class="big"><%= statusText %></div>
                <div style="font-size:11px;color:#475569;margin-top:6px;">Dicetak pada <%= now.toLocaleDateString('id-ID') %></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="sheet-foot">
        <div class="sheet-foot-main"><%= footerDocText %></div>
        <% if (showSupportFooter) { %>
          <div class="support-footer">
            <% if (supportLogo) { %><img src="<%= supportLogo %>" alt="Logo Support" onerror="this.style.display='none'"><% } %>
            <span>Support by <%= supportBrandName %></span>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <script>
    (function () {
      const activeStyle = <%- JSON.stringify(activeStyle) %>;
      const receiptData = {
        logo: <%- JSON.stringify(companyLogo) %>,
        company: <%- JSON.stringify(companyName) %>,
        address: <%- JSON.stringify(companyAddress) %>,
        phone: <%- JSON.stringify(companyPhone) %>,
        support: <%- JSON.stringify(receiptSupportBrandName) %>,
        partner: <%- JSON.stringify(showPartnerBrand ? partnerPrintLabel : '') %>,
        title: <%- JSON.stringify(isPaid ? 'STRUK PEMBAYARAN' : 'STRUK TAGIHAN') %>,
        invoice: <%- JSON.stringify(invoiceCode) %>,
        dateLabel: <%- JSON.stringify(isPaid ? 'Tanggal Bayar' : 'Tanggal Tagih') %>,
        date: <%- JSON.stringify(receiptDateLabel) %>,
        status: <%- JSON.stringify(statusText) %>,
        customerCode: <%- JSON.stringify(customerCode) %>,
        customer: <%- JSON.stringify(customer?.name || '-') %>,
        customerPhone: <%- JSON.stringify(customerPhoneDisplay) %>,
        customerAddress: <%- JSON.stringify(customerAddress) %>,
        packageName: <%- JSON.stringify(packageName) %>,
        period: <%- JSON.stringify(invoicePeriodLabel) %>,
        subtotal: <%- JSON.stringify('Rp ' + invoiceBaseAmount.toLocaleString('id-ID')) %>,
        ppn: <%- JSON.stringify(packageIncludePpn ? 'Rp ' + invoicePpnAmount.toLocaleString('id-ID') : '') %>,
        ppnLabel: <%- JSON.stringify(packageIncludePpn ? 'PPN ' + packagePpnPercent.toLocaleString('id-ID') + '%' : '') %>,
        paidBy: <%- JSON.stringify(isPaid ? paidByDisplay : '') %>,
        due: <%- JSON.stringify(!isPaid ? dueDateLabel : '') %>,
        amount: <%- JSON.stringify('Rp ' + invoiceAmount.toLocaleString('id-ID')) %>,
        paid: <%- JSON.stringify(isPaid) %>
      };

      function roundRect(ctx, x, y, w, h, r) {
        const rr = Math.min(r, w / 2, h / 2);
        ctx.beginPath();
        ctx.moveTo(x + rr, y);
        ctx.arcTo(x + w, y, x + w, y + h, rr);
        ctx.arcTo(x + w, y + h, x, y + h, rr);
        ctx.arcTo(x, y + h, x, y, rr);
        ctx.arcTo(x, y, x + w, y, rr);
        ctx.closePath();
      }

      function loadImage(src) {
        return new Promise((resolve) => {
          const url = String(src || '').trim();
          if (!url) return resolve(null);
          try {
            const parsed = new URL(url, window.location.origin);
            if (parsed.origin !== window.location.origin && !url.startsWith('data:')) return resolve(null);
          } catch (e) {
            if (!url.startsWith('/')) return resolve(null);
          }
          const img = new Image();
          img.onload = () => resolve(img);
          img.onerror = () => resolve(null);
          img.src = url;
        });
      }

      function fitText(ctx, text, x, y, maxWidth, size, weight, color, align, minSize) {
        const value = String(text || '-');
        let fontSize = size;
        const minFontSize = Number(minSize || 16);
        ctx.fillStyle = color;
        ctx.textAlign = align || 'left';
        do {
          ctx.font = `${weight || 800} ${fontSize}px Arial, sans-serif`;
          if (ctx.measureText(value).width <= maxWidth || fontSize <= minFontSize) break;
          fontSize -= 1;
        } while (fontSize > minFontSize);
        ctx.fillText(value, x, y);
        ctx.textAlign = 'left';
      }

      async function buildReceiptBlob() {
        const canvas = document.createElement('canvas');
        canvas.width = 384;
        canvas.height = 1040;
        const ctx = canvas.getContext('2d');
        const W = canvas.width;
        const left = 8;
        const right = W - 8;
        const mid = W / 2;
        const boxW = W - 16;
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        const logo = await loadImage(receiptData.logo);
        if (logo) {
          const ratio = Math.min(58 / logo.width, 38 / logo.height);
          const w = logo.width * ratio;
          const h = logo.height * ratio;
          ctx.drawImage(logo, 163 + (58 - w) / 2, 10 + (38 - h) / 2, w, h);
        }

        fitText(ctx, receiptData.company.toUpperCase(), mid, 66, 350, 19, 900, '#000000', 'center', 16);
        fitText(ctx, 'Telp/WA: ' + receiptData.phone, mid, 86, 350, 13, 900, '#000000', 'center', 11);
        fitText(ctx, receiptData.address, mid, 103, 350, 11, 900, '#000000', 'center', 9);
        ctx.setLineDash([5, 5]);
        ctx.strokeStyle = '#111111';
        ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.moveTo(left, 114); ctx.lineTo(right, 114); ctx.stroke();
        ctx.setLineDash([]);

        fitText(ctx, receiptData.title, mid, 140, 350, 17, 900, '#000000', 'center', 14);

        function drawRows(title, rows, y) {
          const rowHeight = 39;
          fitText(ctx, title, mid, y, 330, 16, 900, '#000000', 'center', 13);
          y += 11;
          ctx.setLineDash([3, 3]);
          ctx.strokeStyle = '#333333';
          ctx.lineWidth = 1.2;
          roundRect(ctx, left, y, boxW, (rows.length * rowHeight) + 22, 5);
          ctx.stroke();
          ctx.setLineDash([]);
          y += 30;
          rows.forEach(([label, value]) => {
            ctx.fillStyle = '#000000';
            ctx.font = '900 17px Arial, sans-serif';
            ctx.fillText(label, left + 10, y);
            fitText(ctx, value, right - 8, y, 232, 18, 900, '#000000', 'right', 14);
            y += rowHeight;
          });
          return y + 14;
        }

        let y = 170;
        y = drawRows('DATA INVOICE', [
          ['No. Invoice', receiptData.invoice],
          [receiptData.dateLabel, receiptData.date],
          ['Status', receiptData.status]
        ], y);

        const customerRows = [
          ['ID Pelanggan', receiptData.customerCode],
          ['Nama', receiptData.customer],
          ['Telepon', receiptData.customerPhone],
          ['Paket', receiptData.packageName],
          ['Periode', receiptData.period]
        ];
        if (receiptData.paidBy) customerRows.push(['Dibayar Oleh', receiptData.paidBy]);
        if (receiptData.due) customerRows.push(['Jatuh Tempo', receiptData.due]);
        y = drawRows('DATA PELANGGAN', customerRows, y);

        const detailRows = [
          ['Subtotal', receiptData.subtotal],
          ['Biaya Lainnya', 'Rp 0']
        ];
        if (receiptData.ppn) detailRows.splice(1, 0, [receiptData.ppnLabel, receiptData.ppn]);
        y = drawRows('RINCIAN', detailRows, y);

        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;
        ctx.beginPath(); ctx.moveTo(left, y + 6); ctx.lineTo(right, y + 6); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(left, y + 44); ctx.lineTo(right, y + 44); ctx.stroke();
        fitText(ctx, receiptData.paid ? 'TOTAL DIBAYAR' : 'TOTAL TAGIHAN', left + 2, y + 34, 160, 17, 900, '#000000', 'left', 14);
        fitText(ctx, receiptData.amount, right - 2, y + 36, 210, 24, 900, '#000000', 'right', 18);
        y += 62;

        if (receiptData.paid) {
          roundRect(ctx, 116, y, 152, 30, 999);
          ctx.setLineDash([4, 4]);
          ctx.strokeStyle = '#111111';
          ctx.lineWidth = 1.2;
          ctx.stroke();
          ctx.setLineDash([]);
          fitText(ctx, 'LUNAS', mid, y + 21, 120, 13, 900, '#000000', 'center');
          y += 43;
        }
        ctx.setLineDash([5, 5]);
        ctx.strokeStyle = '#111111';
        ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.moveTo(left, y); ctx.lineTo(right, y); ctx.stroke();
        ctx.setLineDash([]);
        fitText(ctx, 'Simpan struk ini sebagai bukti pembayaran.', mid, y + 24, 340, 11, 900, '#000000', 'center');
        if (receiptData.partner) {
          fitText(ctx, receiptData.partner, mid, y + 42, 340, 11, 900, '#000000', 'center');
        }
        if (receiptData.support) {
          fitText(ctx, 'Support by ' + receiptData.support, mid, y + (receiptData.partner ? 60 : 42), 340, 11, 900, '#000000', 'center');
        }
        return new Promise((resolve) => {
          try { canvas.toBlob(resolve, 'image/png', 0.95); } catch (e) { resolve(null); }
        });
      }

      async function saveOrShareReceipt(share) {
        const blob = await buildReceiptBlob();
        if (!blob) return window.print();
        const fileName = `struk-${receiptData.invoice.replace(/[^\w.-]+/g, '-')}.png`;
        const file = new File([blob], fileName, { type: 'image/png' });
        if (share && navigator.canShare && navigator.canShare({ files: [file] }) && navigator.share) {
          try {
            await navigator.share({ files: [file], title: receiptData.title, text: receiptData.invoice });
            return;
          } catch (e) {}
        }
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 3000);
      }

      document.getElementById('saveReceiptBtn')?.addEventListener('click', () => saveOrShareReceipt(false));
      document.getElementById('shareReceiptBtn')?.addEventListener('click', () => saveOrShareReceipt(true));
      if (activeStyle !== 'receipt') {
        window.onload = function () {
          setTimeout(function () { window.print(); }, 450);
        };
      }
    })();
  </script>
</body>
</html>
