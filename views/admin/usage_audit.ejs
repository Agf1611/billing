<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title>Audit Usage Pelanggan | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .usage-audit-stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:16px}
    .usage-audit-stat{background:var(--bg2);border:1px solid var(--border);border-radius:22px;padding:16px;display:grid;gap:6px}
    .usage-audit-stat small{font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
    .usage-audit-stat strong{font-size:28px;line-height:1;color:var(--text)}
    .usage-audit-stat span{font-size:12px;color:var(--muted)}
    .usage-audit-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .usage-audit-actions{display:flex;gap:8px;flex-wrap:wrap}
    .usage-badge{display:inline-flex;align-items:center;gap:6px;padding:7px 10px;border-radius:999px;font-size:11px;font-weight:800}
    .usage-badge.good{background:rgba(34,197,94,.12);color:#16a34a}
    .usage-badge.warn{background:rgba(245,158,11,.14);color:#d97706}
    .usage-strong{font-weight:800;color:var(--text)}
    .usage-sub{font-size:11px;color:var(--muted)}
    .usage-table td{vertical-align:top}
    .usage-mobile-list{display:none;gap:10px}
    .usage-mobile-card{background:var(--bg2);border:1px solid var(--border);border-radius:18px;padding:14px;display:grid;gap:10px}
    .usage-mobile-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .usage-mobile-title strong{display:block;font-size:15px;line-height:1.2}
    .usage-mobile-title span{display:block;font-size:11px;color:var(--muted);margin-top:3px;word-break:break-word}
    .usage-mobile-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .usage-mobile-box{padding:10px;border-radius:14px;background:rgba(255,255,255,.03);border:1px solid rgba(148,163,184,.1)}
    .usage-mobile-box small{display:block;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
    .usage-mobile-box strong{display:block;font-size:13px;line-height:1.25}
    .usage-mobile-actions{display:flex;gap:8px;flex-wrap:wrap}
    .usage-empty{padding:30px 18px;text-align:center;color:var(--muted);display:grid;gap:10px}
    .usage-empty i{font-size:34px;color:var(--primary)}
    @media (max-width: 1024px){
      .usage-audit-stats{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media (max-width: 720px){
      .usage-audit-stats{grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
      .usage-audit-stat{padding:14px}
      .usage-audit-stat strong{font-size:22px}
      .usage-audit-toolbar{align-items:stretch}
      .usage-audit-actions{width:100%}
      .usage-audit-actions .btn{flex:1 1 0;justify-content:center}
      .usage-table-wrap{display:none}
      .usage-mobile-list{display:grid}
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'usage_audit', company, settings }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-clipboard2-pulse"></i> Audit Usage Pelanggan</div>
    <div class="tb-right">
      <a href="/admin/customers" class="btn btn-g btn-sm"><i class="bi bi-people"></i> Pelanggan</a>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i> Logout</a>
    </div>
  </div>

  <div class="page">
    <% if (msg) { %>
      <div class="alert alert-<%= msg.type === 'success' ? 's' : 'd' %>">
        <i class="bi bi-<%= msg.type === 'success' ? 'check-circle' : 'exclamation-circle' %>"></i> <%= msg.text %>
      </div>
    <% } %>

    <div class="usage-audit-stats">
      <div class="usage-audit-stat">
        <small>Pelanggan Mencurigakan</small>
        <strong><%= Number(stats.total || 0) %></strong>
        <span>Baris usage yang perlu diperiksa</span>
      </div>
      <div class="usage-audit-stat">
        <small>Siap Repair</small>
        <strong><%= Number(stats.repairable || 0) %></strong>
        <span>Bisa dibetulkan otomatis</span>
      </div>
      <div class="usage-audit-stat">
        <small>Selisih Saat Ini</small>
        <strong><%= ((Number(stats.totalDiffBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</strong>
        <span>Stored usage vs runtime aktif</span>
      </div>
      <div class="usage-audit-stat">
        <small>Potensi Hemat</small>
        <strong><%= ((Number(stats.totalRepairSavedBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</strong>
        <span>Duplikasi yang bisa dibersihkan</span>
      </div>
    </div>

    <div class="card">
      <div class="card-hd usage-audit-toolbar">
        <h6><i class="bi bi-search-heart"></i> Daftar Audit Usage Bulan Berjalan</h6>
        <div class="usage-audit-actions">
          <a href="/admin/usage-audit" class="btn btn-g btn-sm"><i class="bi bi-arrow-clockwise"></i> Refresh</a>
          <form method="POST" action="/admin/usage-audit/repair-all" style="display:inline" onsubmit="return confirm('Repair otomatis semua pelanggan yang terdeteksi duplikasi usage?')">
            <button type="submit" class="btn btn-p btn-sm"><i class="bi bi-magic"></i> Repair Semua</button>
          </form>
        </div>
      </div>
      <div class="card-bd">
        <% if (!rows.length) { %>
          <div class="usage-empty">
            <i class="bi bi-check2-circle"></i>
            <strong class="usage-strong">Tidak ada usage mencurigakan</strong>
            <div>Semua pelanggan yang bisa terdeteksi duplikasi pada bulan ini sudah normal.</div>
          </div>
        <% } else { %>
          <div class="tbl-wrap usage-table-wrap">
            <table class="dtbl usage-table">
              <thead>
                <tr>
                  <th>Nama</th>
                  <th>Stored</th>
                  <th>Runtime</th>
                  <th>Selisih</th>
                  <th>Rasio</th>
                  <th>Status</th>
                  <th>Anchor</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach((row) => { %>
                  <tr>
                    <td>
                      <div class="usage-strong"><%= row.name %></div>
                      <div class="usage-sub"><%= row.username || '-' %></div>
                    </td>
                    <td>
                      <div class="usage-strong"><%= ((Number(row.storedTotalBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</div>
                      <div class="usage-sub">Update <%= row.usageUpdatedAt || '-' %></div>
                    </td>
                    <td>
                      <div class="usage-strong"><%= ((Number(row.runtimeTotalBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</div>
                      <div class="usage-sub">Sesi <%= row.sessionId || '-' %></div>
                    </td>
                    <td>
                      <div class="usage-strong"><%= ((Number(row.diffBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</div>
                      <div class="usage-sub">Potensi repair <%= ((Number(row.repairSavedBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</div>
                    </td>
                    <td>
                      <div class="usage-strong"><%= row.ratio ? `${Number(row.ratio).toFixed(2)}x` : '-' %></div>
                      <div class="usage-sub"><%= row.uptimeSeconds ? `${Math.floor(Number(row.uptimeSeconds || 0) / 3600)} jam` : 'uptime kosong' %></div>
                    </td>
                    <td>
                      <span class="usage-badge <%= row.repairable ? 'good' : 'warn' %>">
                        <i class="bi bi-<%= row.repairable ? 'check2-circle' : 'exclamation-triangle' %>"></i>
                        <%= row.repairable ? 'Bisa repair' : 'Cek manual' %>
                      </span>
                    </td>
                    <td>
                      <div class="usage-sub"><%= row.anchorCreatedAt || '-' %></div>
                    </td>
                    <td>
                      <form method="POST" action="/admin/usage-audit/<%= row.customerId %>/repair" style="display:inline" onsubmit="return confirm('Repair usage pelanggan ini sekarang?')">
                        <button type="submit" class="btn <%= row.repairable ? 'btn-p' : 'btn-g' %> btn-sm">
                          <i class="bi bi-wrench-adjustable-circle"></i> Repair
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="usage-mobile-list">
            <% rows.forEach((row) => { %>
              <div class="usage-mobile-card">
                <div class="usage-mobile-head">
                  <div class="usage-mobile-title">
                    <strong><%= row.name %></strong>
                    <span><%= row.username || '-' %></span>
                  </div>
                  <span class="usage-badge <%= row.repairable ? 'good' : 'warn' %>">
                    <i class="bi bi-<%= row.repairable ? 'check2-circle' : 'exclamation-triangle' %>"></i>
                    <%= row.repairable ? 'Repair' : 'Manual' %>
                  </span>
                </div>
                <div class="usage-mobile-grid">
                  <div class="usage-mobile-box">
                    <small>Stored</small>
                    <strong><%= ((Number(row.storedTotalBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</strong>
                  </div>
                  <div class="usage-mobile-box">
                    <small>Runtime</small>
                    <strong><%= ((Number(row.runtimeTotalBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</strong>
                  </div>
                  <div class="usage-mobile-box">
                    <small>Selisih</small>
                    <strong><%= ((Number(row.diffBytes || 0) / (1024 ** 3)) || 0).toFixed(2) %> GB</strong>
                  </div>
                  <div class="usage-mobile-box">
                    <small>Rasio</small>
                    <strong><%= row.ratio ? `${Number(row.ratio).toFixed(2)}x` : '-' %></strong>
                  </div>
                </div>
                <div class="usage-sub">Anchor: <%= row.anchorCreatedAt || '-' %></div>
                <div class="usage-mobile-actions">
                  <form method="POST" action="/admin/usage-audit/<%= row.customerId %>/repair" style="display:inline-flex;flex:1" onsubmit="return confirm('Repair usage pelanggan ini sekarang?')">
                    <button type="submit" class="btn <%= row.repairable ? 'btn-p' : 'btn-g' %> btn-sm" style="width:100%;justify-content:center">
                      <i class="bi bi-wrench-adjustable-circle"></i> Repair
                    </button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
</body>
</html>
