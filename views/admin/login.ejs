<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<%
  const logoSrc = logoUrl || '/img/mss-logo.png';
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title><%= t('common.login', 'Login') %> Admin | <%= company %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    :root {
      --page-bg: #f5f8ff;
      --page-bg-2: #ffffff;
      --surface: rgba(255, 255, 255, 0.96);
      --surface-soft: #f8fbff;
      --line: rgba(28, 54, 102, 0.14);
      --text-main: #07163f;
      --text-soft: #62708c;
      --text-faint: #8d98b1;
      --blue: #073dcc;
      --blue-deep: #0634b0;
      --shadow: 0 28px 70px rgba(18, 47, 102, 0.14);
      --shell-width: min(100vw, 430px);
    }

    * { box-sizing: border-box; }

    html, body {
      min-height: 100%;
      margin: 0;
      color: var(--text-main);
      font-family: "Plus Jakarta Sans", "Manrope", system-ui, -apple-system, sans-serif;
      background: linear-gradient(180deg, var(--page-bg-2) 0%, var(--page-bg) 100%);
      -webkit-tap-highlight-color: transparent;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.10;
      background-image:
        linear-gradient(rgba(111, 141, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(111, 141, 255, 0.05) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    body {
      display: flex;
      justify-content: center;
      padding: 14px;
    }

    .login-shell {
      position: relative;
      width: var(--shell-width);
      min-height: calc(100vh - 28px);
      min-height: calc(100dvh - 28px);
      display: flex;
      align-items: center;
    }

    .login-main {
      width: 100%;
      display: grid;
      gap: 12px;
    }

    .brand-panel {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 24px;
      background: rgba(17, 24, 39, 0.86);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.16);
      backdrop-filter: blur(18px);
    }

    .brand-logo {
      width: 64px;
      height: 64px;
      flex: 0 0 64px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(111, 141, 255, 0.08));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18), 0 18px 34px rgba(79, 110, 247, 0.14);
    }

    .brand-logo img {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }

    .brand-copy {
      min-width: 0;
      flex: 1;
    }

    .brand-copy strong {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin-bottom: 7px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(111, 141, 255, 0.12);
      border: 1px solid rgba(111, 141, 255, 0.18);
      color: var(--blue);
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .brand-copy h1 {
      margin: 0 0 4px;
      font-size: 22px;
      line-height: 1.04;
      font-weight: 800;
      letter-spacing:0;
    }

    .brand-copy p {
      margin: 0;
      color: var(--text-soft);
      font-size: 12px;
      line-height: 1.45;
    }

    .login-card {
      background: var(--surface);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 28px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
      overflow: hidden;
    }

    .login-card-head {
      padding: 18px 18px 10px;
      text-align: center;
    }

    .portal-icon {
      width: 60px;
      height: 60px;
      margin: 0 auto 14px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(111, 141, 255, 0.18), rgba(79, 110, 247, 0.3));
      border: 1px solid rgba(111, 141, 255, 0.2);
      color: #fff;
      font-size: 24px;
      box-shadow: 0 20px 34px rgba(79, 110, 247, 0.22);
    }

    .login-card-head h2 {
      margin: 0 0 5px;
      font-size: 20px;
      font-weight: 800;
      letter-spacing:0;
    }

    .login-card-head p {
      margin: 0;
      font-size: 12px;
      line-height: 1.5;
      color: var(--text-soft);
    }

    .form-container {
      padding: 12px 18px 18px;
    }

    .field {
      margin-bottom: 12px;
    }

    .field-label {
      display: block;
      margin-bottom: 7px;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-faint);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .field-wrap {
      position: relative;
    }

    .field-wrap i {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-soft);
      font-size: 15px;
      pointer-events: none;
    }

    .fc {
      width: 100%;
      min-height: 54px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(15, 23, 42, 0.88);
      color: var(--text-main);
      padding: 14px 14px 14px 42px;
      font-size: 14px;
      outline: none;
      box-shadow: none;
      transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
    }

    .fc::placeholder { color: rgba(150, 163, 191, 0.85); }

    .fc:focus {
      border-color: rgba(111, 141, 255, 0.42);
      box-shadow: 0 0 0 4px rgba(111, 141, 255, 0.12);
      background: rgba(17, 24, 39, 0.96);
    }

    .remember-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: 2px 0 14px;
      color: var(--text-soft);
      font-size: 12px;
    }

    .remember-check {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      cursor: pointer;
      user-select: none;
      font-weight: 700;
      color: var(--text-main);
    }

    .remember-check input {
      width: 16px;
      height: 16px;
      margin: 0;
      accent-color: var(--blue);
    }

    .btn-login {
      width: 100%;
      min-height: 52px;
      border: none;
      border-radius: 18px;
      background: linear-gradient(135deg, var(--blue) 0%, var(--blue-deep) 100%);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 14px;
      font-weight: 800;
      box-shadow: 0 20px 34px rgba(79, 110, 247, 0.24);
    }

    .btn-login:hover,
    .btn-login:focus {
      background: linear-gradient(135deg, #5f7dfa 0%, #4462eb 100%);
    }

    .alert-d {
      background: rgba(255, 114, 134, 0.12);
      color: #ffc5cf;
      border: 1px solid rgba(255, 114, 134, 0.18);
      padding: 12px 13px;
      border-radius: 16px;
      font-size: 12px;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 9px;
    }

    .first-install-note {
      margin-bottom: 12px;
      padding: 12px 13px;
      border-radius: 16px;
      background: rgba(111, 141, 255, 0.12);
      color: #dbe5ff;
      border: 1px solid rgba(111, 141, 255, 0.2);
      font-size: 12px;
      line-height: 1.55;
    }

    .first-install-note strong {
      display: block;
      margin-bottom: 4px;
      color: #fff;
      font-weight: 800;
    }

    .first-install-note code {
      color: #fff;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      font-weight: 800;
    }

    .support-note {
      margin-top: 12px;
      padding: 12px 13px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.03));
      border: 1px solid rgba(255, 255, 255, 0.07);
      font-size: 11px;
      line-height: 1.55;
      color: var(--text-soft);
      text-align: center;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 12px;
      width: 100%;
      min-height: 46px;
      border-radius: 16px;
      border: 1px solid rgba(111, 141, 255, 0.14);
      background: rgba(111, 141, 255, 0.08);
      color: var(--blue);
      text-decoration: none;
      font-size: 12px;
      font-weight: 800;
    }

    @media (max-width: 576px) {
      body { padding: 12px; }
      .login-shell {
        min-height: calc(100vh - 24px);
        min-height: calc(100dvh - 24px);
      }
      .brand-panel,
      .login-card-head,
      .form-container {
        padding-left: 14px;
        padding-right: 14px;
      }
      .brand-panel {
        gap: 12px;
        align-items: center;
      }
      .brand-logo {
        width: 58px;
        height: 58px;
        flex-basis: 58px;
      }
      .brand-logo img {
        width: 44px;
        height: 44px;
      }
      .brand-copy h1 { font-size: 20px; }
      .login-card-head h2 { font-size: 18px; }
      .remember-row {
        display: grid;
        gap: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="login-shell">
    <main class="login-main">
      <section class="brand-panel">
        <div class="brand-logo">
          <img src="<%= logoSrc %>" alt="Logo <%= company %>">
        </div>
        <div class="brand-copy">
          <strong><i class="bi bi-grid-1x2-fill"></i> Admin Panel</strong>
          <h1><%= company %></h1>
          <p>Akses admin sistem.</p>
        </div>
      </section>

      <section class="login-card">
        <div class="login-card-head">
          <div class="portal-icon"><i class="bi bi-shield-check"></i></div>
          <h2>Masuk ke Portal Admin</h2>
          <p>Masuk dengan akun admin atau kasir.</p>
        </div>

        <div class="form-container">
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-d">
              <i class="bi bi-exclamation-octagon"></i>
              <%= error %>
            </div>
          <% } %>

          <% if (typeof firstInstallLoginEnabled !== 'undefined' && firstInstallLoginEnabled) { %>
            <div class="first-install-note">
              <strong>Login awal instalasi</strong>
              Gunakan <code>admin</code> / <code>admin123</code>, lalu segera ganti password dan session secret di Pengaturan Admin.
            </div>
          <% } %>

          <form method="POST" action="/admin/login">
            <div class="field">
              <label class="field-label" for="admin-username"><%= t('admin.login.username', 'Username') %></label>
              <label class="field-wrap">
                <i class="bi bi-person-circle"></i>
                <input id="admin-username" class="fc" name="username" placeholder="Masukkan username admin" autocomplete="username" required value="<%= (form && form.username) ? form.username : '' %>">
              </label>
            </div>

            <div class="field">
              <label class="field-label" for="admin-password"><%= t('admin.login.password', 'Password') %></label>
              <label class="field-wrap">
                <i class="bi bi-key-fill"></i>
                <input id="admin-password" class="fc" type="password" name="password" placeholder="Masukkan password" autocomplete="current-password" required>
              </label>
            </div>

            <div class="remember-row">
              <label class="remember-check">
                <input type="checkbox" name="remember_me" <%= (form && form.rememberMe) ? 'checked' : '' %>>
                <span>Tetap ingat saya</span>
              </label>
              <span>Simpan sesi di perangkat ini.</span>
            </div>

            <button type="submit" class="btn-login">
              <i class="bi bi-box-arrow-in-right"></i>
              <span><%= t('admin.login.sign_in', 'Masuk') %></span>
            </button>
          </form>

          <a href="/customer/login" class="back-btn">
            <i class="bi bi-arrow-left-circle"></i>
            <span><%= t('admin.login.back_customer', 'Kembali ke Portal Pelanggan') %></span>
          </a>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
