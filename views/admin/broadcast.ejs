<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.broadcast.title', 'Broadcast WhatsApp') %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .wa-card-actions { border-top:1px solid var(--border); background:var(--bg2); display:flex; justify-content:flex-end; gap:10px; }
    .wa-card-actions .btn { min-width:180px; justify-content:center; }
    .wa-template-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:16px; }
    .wa-template-note { font-size:11px; color:var(--muted); margin-top:6px; line-height:1.5; }
    .wa-template-note code { font-size:11px; }
    .wa-inline-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:14px; }
    .wa-media-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:12px; margin-bottom:18px; }
    .wa-media-item { border:1px solid var(--border); background:var(--bg2); border-radius:12px; padding:12px; min-width:0; }
    .wa-media-preview { width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:8px; border:1px solid var(--border); background:var(--bg); margin:8px 0; }
    .wa-media-empty { display:flex; align-items:center; justify-content:center; color:var(--muted); font-size:12px; }
    .wa-media-remove { display:flex; align-items:center; gap:7px; font-size:11px; color:var(--muted); margin-top:8px; }
    .wa-stack { display:flex; flex-direction:column; gap:18px; }
    .wa-muted-box {
      border:1px dashed var(--border);
      background:var(--bg2);
      border-radius:16px;
      padding:14px 16px;
      color:var(--muted);
      font-size:12px;
      line-height:1.55;
    }
    .wa-form-pending {
      display:none;
      align-items:center;
      gap:10px;
      margin-top:14px;
      padding:11px 14px;
      border-radius:14px;
      border:1px solid rgba(96, 165, 250, 0.22);
      background:rgba(59,130,246,0.10);
      color:var(--text);
      font-size:13px;
      font-weight:700;
    }
    .wa-form-pending.show { display:flex; }
    @media (max-width: 1024px) {
      .wa-template-grid, .wa-inline-grid, .wa-media-grid { grid-template-columns:1fr; }
    }
    @media (max-width: 768px) {
      .wa-tabs { overflow:auto; padding-bottom:12px; scrollbar-width:none; }
      .wa-tabs::-webkit-scrollbar { display:none; }
      .wa-tab { white-space:nowrap; }
      .wa-card-actions { flex-direction:column; }
      .wa-card-actions .btn { width:100%; min-width:0; }
      .topbar .tb-right { gap:10px; }
      .card-bd .form-row { gap:12px; }
      textarea.fc { min-height:180px; }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'whatsapp', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-megaphone"></i> <%= t('admin.broadcast.title', 'Broadcast WhatsApp') %></div>
    <div class="tb-right">
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %></span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>
<div class="page admin-shell-page">
    <% const waTab = 'broadcast'; %>
    <% const defaultBroadcastDelay = getSetting('whatsapp_broadcast_delay', 2); %>
    <% const defaultGroupLink = String(getSetting('whatsapp_group_invite_link', '') || '').trim(); %>
    <% const billingTemplate = String(getSetting('whatsapp_billing_message', templateDefaults.billing) || templateDefaults.billing); %>
    <% const dueReminderTemplate = String(getSetting('whatsapp_due_reminder_message', templateDefaults.dueReminder) || templateDefaults.dueReminder); %>
    <% const isolationTemplate = String(getSetting('whatsapp_isolation_message', templateDefaults.isolation) || templateDefaults.isolation); %>
    <% const welcomeTemplate = String(getSetting('whatsapp_welcome_message', templateDefaults.welcome) || templateDefaults.welcome); %>
    <% const reactivationTemplate = String(getSetting('whatsapp_reactivation_message', templateDefaults.reactivation) || templateDefaults.reactivation); %>
    <% const paidTemplate = String(getSetting('whatsapp_paid_message', templateDefaults.paid) || templateDefaults.paid); %>

    <% if (msg) { %>
    <div class="alert alert-<%= msg.type==='success'?'s':'d' %>">
      <i class="bi bi-<%= msg.type==='success'?'check-circle':'exclamation-circle' %>"></i> <%= msg.text %>
    </div>
    <% } %>

    <div class="wa-tabs">
      <a href="/admin/whatsapp" class="wa-tab <%= waTab==='status' ? 'active' : '' %>"><i class="bi bi-phone"></i> Status</a>
      <a href="/admin/whatsapp/broadcast" class="wa-tab <%= waTab==='broadcast' ? 'active' : '' %>"><i class="bi bi-megaphone"></i> Broadcast & Template</a>
    </div>

    <div class="wa-stack">
      <div class="card">
        <div class="card-hd" style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
          <h6><i class="bi bi-send-fill"></i> <%= t('admin.broadcast.send_mass', 'Kirim Pesan Massal') %></h6>
          <div id="broadcastCounter" class="badge bp" style="display:none;">
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            Mengirim <span id="sentCount">0</span>/<span id="totalCount">0</span>
            (<span id="failedCount" class="text-danger ms-1">0</span> gagal)
          </div>
        </div>
        <form id="broadcastForm" method="POST" action="/admin/whatsapp/broadcast" enctype="multipart/form-data" data-confirm="Kirim pesan broadcast sekarang? Pastikan target dan isi pesannya sudah benar.">
          <div class="card-bd">
            <div class="alert alert-i" style="margin-bottom:14px;">
              <i class="bi bi-info-circle"></i> Pesan akan dikirim memakai akun WhatsApp bot yang sedang terhubung. Gunakan jeda aman agar pengiriman lebih stabil.
            </div>
            <div class="alert alert-d alert-permanent" style="margin-bottom:18px; border:1px solid rgba(248,81,73,0.4);">
              <i class="bi bi-exclamation-triangle-fill"></i> Gunakan broadcast seperlunya. Pengiriman massal berlebihan tetap berisiko dibatasi oleh WhatsApp.
            </div>
            <div class="wa-inline-grid" style="margin-bottom:14px;">
              <div class="fg">
                <label class="fl">Target Penerima</label>
                <select class="fs" name="target" id="targetSelect" required>
                  <option value="all">Semua Pelanggan</option>
                  <option value="active">Hanya Pelanggan Aktif</option>
                  <option value="suspended">Hanya Pelanggan Terisolir</option>
                  <option value="unpaid">Hanya Pelanggan Menunggak</option>
                </select>
              </div>
              <div class="fg">
                <label class="fl">Jeda Antar Pesan (Detik)</label>
                <input class="fc" type="number" name="delay" value="<%= defaultBroadcastDelay %>" min="1" max="60">
              </div>
              <div class="fg">
                <label class="fl">Limit per Jam</label>
                <input class="fc" type="number" name="hourlyLimit" value="80" min="10" max="300">
              </div>
            </div>
            <div class="fg">
              <label class="fl">Isi Pesan WhatsApp</label>
              <textarea class="fc" name="message" id="messageBox" rows="9" required></textarea>
              <div class="wa-template-note">
                Variabel yang bisa dipakai:
                <code>{{nama}}</code>,
                <code>{{paket}}</code>,
                <code>{{tagihan}}</code>,
                <code>{{rincian}}</code>,
                <code>{{link}}</code>,
                <code>{{portal_link}}</code>,
                <code>{{invoice_link}}</code>,
                <code>{{invoice_no}}</code>,
                <code>{{login_id}}</code>,
                <code>{{group_link}}</code>,
                <code>{{group_line}}</code>.
              </div>
            </div>
            <div class="wa-inline-grid" style="margin-top:14px;">
              <div class="fg">
                <label class="fl">Foto Pengumuman</label>
                <input class="fc" type="file" name="announcement_image" accept="image/*">
                <div class="wa-template-note">Opsional. Foto akan tampil di inbox pelanggan dan push app; jika WhatsApp aktif, foto ikut dikirim sebagai gambar.</div>
              </div>
              <div class="fg">
                <label class="fl">Test ke 1 Pelanggan</label>
                <input class="fc" name="test_lookup" placeholder="Nama / nomor HP / PPPoE / tag">
                <div class="wa-template-note">Isi ini lalu tekan tombol test untuk cek dulu sebelum broadcast massal.</div>
              </div>
              <div class="wa-muted-box">
                Test memakai isi pesan, foto, dan channel yang dicentang di bawah. Broadcast massal tetap mengikuti target penerima.
              </div>
            </div>
            <div class="wa-inline-grid" style="margin-top:14px;">
              <div class="fg">
                <label class="fl">Kirim via WhatsApp</label>
                <label style="display:flex; align-items:center; gap:10px; font-weight:800; color:var(--text);">
                  <input type="checkbox" name="send_whatsapp" value="1" <%= getSetting('whatsapp_enabled', false) ? 'checked' : '' %>>
                  Aktifkan broadcast WhatsApp
                </label>
              </div>
              <div class="fg">
                <label class="fl">Kirim juga Push App</label>
                <label style="display:flex; align-items:center; gap:10px; font-weight:800; color:var(--text);">
                  <input type="checkbox" name="send_push" value="1" <%= (getSetting('onesignal_enabled', false) && getSetting('onesignal_push_announcement_enabled', true)) ? 'checked' : '' %>>
                  Aktifkan push pengumuman ke aplikasi pelanggan
                </label>
              </div>
              <div class="fg">
                <label class="fl">Judul Push App</label>
                <input class="fc" type="text" name="push_title" value="Pengumuman Pelanggan" placeholder="Judul notifikasi aplikasi">
              </div>
            </div>
          </div>
          <div class="card-bd wa-card-actions">
            <button type="submit" class="btn btn-g" name="broadcast_mode" value="test" id="broadcastTestBtn"><i class="bi bi-person-check"></i> Test 1 Pelanggan</button>
            <button type="submit" class="btn btn-p" name="broadcast_mode" value="broadcast" id="broadcastSubmitBtn"><i class="bi bi-send"></i> Mulai Broadcast</button>
          </div>
        </form>
      </div>

      <div class="card">
        <div class="card-hd">
          <h6><i class="bi bi-bell-fill"></i> Test Push OneSignal</h6>
        </div>
        <form method="POST" action="/admin/whatsapp/test-push" enctype="multipart/form-data" data-wa-submit data-waiting-text="Sedang mengirim test push OneSignal..." onsubmit="return confirm('Kirim test push OneSignal ke pelanggan ini?');">
          <div class="card-bd">
            <div class="alert alert-i" style="margin-bottom:14px;">
              <i class="bi bi-info-circle"></i> Test ini hanya memakai OneSignal dan inbox portal, tidak mengirim WhatsApp.
            </div>
            <div class="wa-inline-grid">
              <div class="fg">
                <label class="fl">Pelanggan Tujuan</label>
                <input class="fc" name="customer_lookup" placeholder="ID / nomor HP / PPPoE / tag" required>
              </div>
              <div class="fg">
                <label class="fl">Judul Push</label>
                <input class="fc" name="push_title" value="Test Push Portal" placeholder="Judul notifikasi">
              </div>
              <div class="fg">
                <label class="fl">Isi Push</label>
                <input class="fc" name="push_message" value="Jika notifikasi ini masuk, push OneSignal portal pelanggan sudah aktif." placeholder="Isi notifikasi" required>
              </div>
              <div class="fg">
                <label class="fl">Foto Test</label>
                <input class="fc" type="file" name="announcement_image" accept="image/*">
              </div>
            </div>
            <div id="pushTestPending" class="wa-form-pending" aria-live="polite">
              <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
              <span>Sedang mengirim test push OneSignal...</span>
            </div>
          </div>
          <div class="card-bd wa-card-actions">
            <button type="submit" class="btn btn-p"><i class="bi bi-bell"></i> Kirim Test Push</button>
          </div>
        </form>
      </div>

      <div class="card">
        <div class="card-hd">
          <h6><i class="bi bi-alarm"></i> Pengingat Tagihan Otomatis</h6>
        </div>
        <form method="POST" action="/admin/whatsapp/auto-billing" onsubmit="return confirm('Simpan pengaturan pengingat tagihan otomatis?');">
          <div class="card-bd">
            <div class="wa-inline-grid">
              <div class="fg">
                <label class="fl">Status</label>
                <label style="display:flex; align-items:center; gap:10px; font-weight:800; color:var(--text);">
                  <input type="checkbox" name="enabled" value="1" <%= getSetting('whatsapp_auto_billing_enabled', false) ? 'checked' : '' %>>
                  Aktifkan pengingat otomatis
                </label>
              </div>
              <div class="fg">
                <label class="fl">Jeda Antar Pesan (Detik)</label>
                <input class="fc" type="number" name="delay" value="<%= defaultBroadcastDelay %>" min="1" max="60">
              </div>
              <div class="wa-muted-box">
                Reminder berjalan otomatis pada H-3, H-2, dan H-1 sebelum jatuh tempo. Isi pesannya mengikuti template <b>Pengingat Jatuh Tempo</b> di bawah.
              </div>
            </div>
          </div>
          <div class="card-bd wa-card-actions">
            <button type="submit" class="btn btn-p" data-submit-label="Simpan Pengingat"><i class="bi bi-save"></i> Simpan Pengingat</button>
          </div>
        </form>
      </div>

      <div class="card">
        <div class="card-hd">
          <h6><i class="bi bi-chat-square-heart"></i> Template Chat Pelanggan</h6>
        </div>
        <form method="POST" action="/admin/whatsapp/templates" enctype="multipart/form-data" data-wa-submit data-waiting-text="Sedang menyimpan template WhatsApp..." onsubmit="return confirm('Simpan template WhatsApp pelanggan?');">
          <div class="card-bd">
            <div class="fg" style="margin-bottom:16px;">
              <label class="fl">Link Grup WhatsApp Pelanggan</label>
              <input class="fc" type="url" name="whatsapp_group_invite_link" value="<%= defaultGroupLink %>" placeholder="https://chat.whatsapp.com/...">
              <div class="wa-template-note">Link ini opsional. Jika diisi, template welcome dan aktif kembali bisa otomatis menyisipkan link grup pelanggan.</div>
            </div>

            <% const templateMediaItems = [
              { key: 'welcome', setting: 'whatsapp_welcome_image_url', label: 'Selamat Datang' },
              { key: 'billing', setting: 'whatsapp_billing_image_url', label: 'Tagihan / Invoice' },
              { key: 'due_reminder', setting: 'whatsapp_due_reminder_image_url', label: 'Jatuh Tempo' },
              { key: 'isolation', setting: 'whatsapp_isolation_image_url', label: 'Pelanggan Terisolir' },
              { key: 'paid', setting: 'whatsapp_paid_image_url', label: 'Pembayaran Lunas' },
              { key: 'reactivation', setting: 'whatsapp_reactivation_image_url', label: 'Aktif Kembali' }
            ]; %>
            <div class="wa-media-grid">
              <% templateMediaItems.forEach((item) => { const imageUrl = String(getSetting(item.setting, '') || '').trim(); %>
                <div class="wa-media-item">
                  <label class="fl"><%= item.label %></label>
                  <% if (imageUrl) { %>
                    <img class="wa-media-preview" src="<%= imageUrl %>" alt="<%= item.label %>">
                  <% } else { %>
                    <div class="wa-media-preview wa-media-empty"><i class="bi bi-image"></i>&nbsp; Teks saja</div>
                  <% } %>
                  <input class="fc" type="file" name="<%= item.key %>_image_file" accept="image/png,image/jpeg,image/webp">
                  <% if (imageUrl) { %>
                    <label class="wa-media-remove">
                      <input type="checkbox" name="remove_<%= item.key %>_image" value="1">
                      Hapus gambar
                    </label>
                  <% } %>
                </div>
              <% }); %>
            </div>

            <div class="wa-template-grid">
              <div class="fg">
                <label class="fl">Template Selamat Datang</label>
                <textarea class="fc" name="whatsapp_welcome_message" rows="9"><%= welcomeTemplate %></textarea>
                <div class="wa-template-note">Dikirim otomatis setelah pelanggan baru berhasil dibuat.</div>
              </div>
              <div class="fg">
                <label class="fl">Template Pengingat Jatuh Tempo</label>
                <textarea class="fc" name="whatsapp_due_reminder_message" rows="9"><%= dueReminderTemplate %></textarea>
                <div class="wa-template-note">Dipakai oleh reminder otomatis H-3, H-2, dan H-1 sebelum jatuh tempo.</div>
              </div>
              <div class="fg">
                <label class="fl">Template Tagihan / Invoice</label>
                <textarea class="fc" name="whatsapp_billing_message" rows="9"><%= billingTemplate %></textarea>
                <div class="wa-template-note">Dipakai saat kirim tagihan manual dari menu tagihan atau broadcast terarah.</div>
              </div>
              <div class="fg">
                <label class="fl">Template Lunas Bayar / Nota</label>
                <textarea class="fc" name="whatsapp_paid_message" rows="9"><%= paidTemplate %></textarea>
                <div class="wa-template-note">Dipakai saat pembayaran berhasil agar pelanggan menerima nota/link resmi.</div>
              </div>
              <div class="fg">
                <label class="fl">Template Pelanggan Terisolir</label>
                <textarea class="fc" name="whatsapp_isolation_message" rows="9"><%= isolationTemplate %></textarea>
                <div class="wa-template-note">Dikirim saat layanan pelanggan diisolir karena menunggak.</div>
              </div>
              <div class="fg">
                <label class="fl">Template Aktif Kembali</label>
                <textarea class="fc" name="whatsapp_reactivation_message" rows="9"><%= reactivationTemplate %></textarea>
                <div class="wa-template-note">Dikirim saat pelanggan diaktifkan kembali setelah pembayaran atau pembukaan isolir.</div>
              </div>
              <div class="fg">
                <label class="fl">Panduan Variabel</label>
                <div class="wa-muted-box">
                  <div><code>{{nama}}</code> nama pelanggan</div>
                  <div><code>{{paket}}</code> nama paket</div>
                  <div><code>{{tagihan}}</code> total tagihan</div>
                  <div><code>{{rincian}}</code> periode tagihan</div>
                  <div><code>{{link}}</code> link cek tagihan</div>
                  <div><code>{{portal_link}}</code> link login portal</div>
                  <div><code>{{invoice_link}}</code> link invoice publik</div>
                  <div><code>{{receipt_link}}</code> link nota / struk publik</div>
                  <div><code>{{invoice_no}}</code> nomor invoice</div>
                  <div><code>{{login_id}}</code> ID login pelanggan</div>
                  <div><code>{{group_link}}</code> link grup WhatsApp</div>
                  <div><code>{{group_line}}</code> baris otomatis berisi link grup</div>
                  <div><code>{{alasan}}</code> alasan isolir</div>
                  <div><code>{{paid_by}}</code> metode / petugas pembayaran</div>
                  <div><code>{{paid_at}}</code> waktu pembayaran</div>
                </div>
              </div>
            </div>
          </div>
          <div class="card-bd">
            <div class="wa-form-pending" data-wa-pending>
              <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
              <span>Sedang menyimpan template WhatsApp...</span>
            </div>
          </div>
          <div class="card-bd wa-card-actions">
            <button type="submit" class="btn btn-p" data-submit-label="Simpan Template"><i class="bi bi-save"></i> Simpan Template</button>
          </div>
        </form>
      </div>

      <div class="card">
        <div class="card-hd">
          <h6><i class="bi bi-envelope-paper-heart"></i> Test Message</h6>
        </div>
        <form method="POST" action="/admin/whatsapp/test-template" data-wa-submit data-waiting-text="Sedang mengirim test message WhatsApp. Mohon tunggu beberapa saat..." onsubmit="return confirm('Kirim test message ke nomor test ini?');">
          <div class="card-bd">
            <div class="wa-inline-grid">
              <div class="fg">
                <label class="fl">Pilih Template</label>
                <select class="fs" name="template_key" required>
                  <option value="welcome">Selamat Datang</option>
                  <option value="due_reminder">Pengingat Jatuh Tempo</option>
                  <option value="billing">Tagihan / Invoice</option>
                  <option value="paid">Lunas Bayar / Nota</option>
                  <option value="isolation">Pelanggan Terisolir</option>
                  <option value="reactivation">Aktif Kembali</option>
                </select>
              </div>
              <div class="fg">
                <label class="fl">Nomor Test WA</label>
                <input class="fc" name="test_phone" value="<%= getSetting('whatsapp_test_number', '') || '' %>" inputmode="tel" autocomplete="tel" placeholder="6281xxx">
              </div>
              <div class="wa-muted-box">
                Isi nomor tujuan test supaya aman. Jika kosong, sistem memakai Nomor Test WA dari pengaturan, lalu fallback ke nomor admin yang tersimpan.
              </div>
            </div>
          </div>
          <div class="card-bd">
            <div class="wa-form-pending" data-wa-pending>
              <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
              <span>Sedang mengirim test message WhatsApp. Mohon tunggu beberapa saat...</span>
            </div>
          </div>
          <div class="card-bd wa-card-actions">
            <button type="submit" class="btn btn-p" data-submit-label="Kirim Test Message"><i class="bi bi-send-check"></i> Kirim Test Message</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
const I18N = {
  confirmChangeTarget: "Ganti target penerima? Pesan yang sedang diketik akan diganti ke template default target baru.",
  sendingText: "Sedang Mengirim...",
  donePrefix: "Selesai:",
  sentSuffix: "terkirim",
  startBtn: "Mulai Broadcast",
  submitting: "Memproses..."
};

const templates = {
  all: `Halo {{nama}},\n\nKami ingin menyampaikan informasi penting untuk pelanggan {{company}}.\n\nPaket Anda: {{paket}}\nPortal pelanggan: {{portal_link}}\nCek tagihan: {{link}}\n{{group_line}}\n\nTerima kasih.`,
  active: `Halo {{nama}},\n\nTerima kasih sudah memakai layanan {{company}}.\n\nPaket Anda: {{paket}}\nPortal pelanggan: {{portal_link}}\nCek tagihan: {{link}}\n{{group_line}}\n\nSemoga layanan kami selalu nyaman dipakai.`,
  suspended: `Halo {{nama}},\n\nLayanan internet Anda saat ini sedang dinonaktifkan sementara.\n\nTagihan belum lunas: Rp {{tagihan}}\nPeriode: {{rincian}}\nCek tagihan: {{link}}\nLihat invoice: {{invoice_link}}\n\nSilakan hubungi admin jika sudah melakukan pembayaran.`,
  unpaid: `Halo {{nama}},\n\nIni pengingat tagihan internet Anda.\n\nPaket: {{paket}}\nTotal tagihan: Rp {{tagihan}}\nPeriode: {{rincian}}\nCek tagihan: {{link}}\nLihat invoice: {{invoice_link}}\n\nTerima kasih.`
};

const targetSelect = document.getElementById('targetSelect');
const messageBox = document.getElementById('messageBox');

if (targetSelect && messageBox) {
  messageBox.value = templates[targetSelect.value];
  targetSelect.addEventListener('change', function() {
    if (confirm(I18N.confirmChangeTarget)) {
      messageBox.value = templates[this.value];
    }
  });
}

setTimeout(() => {
  document.querySelectorAll('.alert:not(.alert-permanent)').forEach((a) => {
    a.style.display = 'none';
  });
}, 5000);

const broadcastCounter = document.getElementById('broadcastCounter');
const sentCountEl = document.getElementById('sentCount');
const totalCountEl = document.getElementById('totalCount');
const failedCountEl = document.getElementById('failedCount');
const submitBtn = document.getElementById('broadcastSubmitBtn');
const broadcastForm = document.getElementById('broadcastForm');

if (broadcastForm) {
  broadcastForm.addEventListener('submit', function (e) {
    const submitter = e.submitter;
    const mode = String(submitter?.value || '').trim();
    const msg = mode === 'test'
      ? 'Kirim test pengumuman ke 1 pelanggan dulu?'
      : String(broadcastForm.dataset.confirm || '').trim();
    if (msg && !confirm(msg)) e.preventDefault();
  });
}

document.querySelectorAll('form[data-wa-submit]').forEach((form) => {
  form.addEventListener('submit', () => {
    const pendingBox = form.querySelector('[data-wa-pending]');
    if (pendingBox) pendingBox.classList.add('show');
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.dataset.originalHtml = submitBtn.innerHTML;
      submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>${I18N.submitting}`;
    }
  });
});

async function checkBroadcastStatus() {
  try {
    const res = await fetch('/admin/api/whatsapp/broadcast-status');
    const status = await res.json();
    if (status.active) {
      broadcastCounter.style.display = 'inline-flex';
      sentCountEl.textContent = status.sent;
      totalCountEl.textContent = status.total;
      failedCountEl.textContent = status.failed;
      submitBtn.disabled = true;
      submitBtn.replaceChildren();
      const spinner = document.createElement('span');
      spinner.className = 'spinner-border spinner-border-sm me-2';
      submitBtn.appendChild(spinner);
      submitBtn.append(document.createTextNode(I18N.sendingText));
      return;
    }

    if (status.total > 0 && status.sent + status.failed === status.total) {
      broadcastCounter.style.display = 'inline-flex';
      broadcastCounter.className = 'badge bs';
      broadcastCounter.replaceChildren();
      const icon = document.createElement('i');
      icon.className = 'bi bi-check-circle-fill me-1';
      broadcastCounter.appendChild(icon);
      broadcastCounter.append(document.createTextNode(` ${I18N.donePrefix} ${status.sent}/${status.total} ${I18N.sentSuffix}`));
    } else {
      broadcastCounter.style.display = 'none';
    }
    submitBtn.disabled = false;
    submitBtn.replaceChildren();
    const icon = document.createElement('i');
    icon.className = 'bi bi-send';
    submitBtn.appendChild(icon);
    submitBtn.append(document.createTextNode(` ${I18N.startBtn}`));
  } catch (e) {
    console.error('Status check failed', e);
  }
}

setInterval(checkBroadcastStatus, 2000);
checkBroadcastStatus();
</script>
</body>
</html>
