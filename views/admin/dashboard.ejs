    body[data-theme="light"] .ops-tone-neutral{--icon-bg:rgba(148,163,184,.16);--icon-color:#64748b;--icon-shadow:rgba(148,163,184,.14);--tone-soft:rgba(226,232,240,.22);--tone-orb:rgba(226,232,240,.18);--tone-border:rgba(148,163,184,.16);--tone-border-strong:rgba(148,163,184,.24);--tone-accent:rgba(214,221,230,.88)}
    .admin-dashboard-page{--sw:224px}
    .admin-dashboard-page .mw{padding:12px 14px 14px}
    .admin-dashboard-page .sidebar{padding-top:16px}
    .admin-dashboard-page .sidebar .sb-brand{padding:14px 12px}
    .admin-dashboard-page .sidebar .brand-avatar{width:54px;height:54px;border-radius:18px}
