            ${row("<%= t('admin.dashboard.detail.rx_power', 'RX Power') %>",d.rxPower||'-')}${row("<%= t('admin.dashboard.detail.uptime', 'Uptime') %>",d.uptime||'-')}
            ${row("<%= t('admin.dashboard.detail.last_inform', 'Last Inform') %>",d.lastInform||'-')}${row("<%= t('admin.dashboard.detail.user_conn', 'User Conn.') %>",d.totalAssociations||'-')}
          </table>
        </div>
      </div>
      ${d.connectedUsers && d.connectedUsers.length > 0 ? `
      <div style="margin-top:16px">
        <h6 style="font-size:13px;font-weight:600;margin-bottom:10px"><i class="bi bi-devices"></i> ${I18N.connectedDevicesTitlePrefix} (${d.connectedUsers.length})</h6>
        <div class="tbl-wrap"><table class="dtbl">
          <thead><tr><th>Hostname</th><th>IP</th><th>MAC</th><th>Interface</th><th><%= t('admin.dashboard.detail.status', 'Status') %></th></tr></thead>
          <tbody>${d.connectedUsers.map(u=>`<tr><td>${u.hostname}</td><td>${u.ip}</td><td style="font-size:11px">${u.mac}</td><td>${u.iface}</td><td><span class="badge ${u.status==='Online'?'bs':'bm'}">${u.status}</span></td></tr>`).join('')}</tbody>
        </table></div>
      </div>` : '<p class="text-muted" style="margin-top:12px;font-size:13px"><i class="bi bi-info-circle"></i> ' + I18N.noConnectedDevices + '</p>'}
    `);
  } catch(e) { detailEl.replaceChildren(); detailEl.insertAdjacentHTML('beforeend', '<p class="text-muted text-center" style="padding:20px">' + I18N.detailLoadFailed + '</p>'); }
}
function row(k,v){return `<tr><td style="padding:6px 0;color:var(--muted);font-size:12px">${k}</td><td style="padding:6px 0;font-weight:500">${v||'-'}</td></tr>`;}

function editSsid(tag, currentSsid) { document.getElementById('edit-tag').value = tag; document.getElementById('new-ssid').value = (currentSsid && currentSsid !== '-') ? currentSsid : ''; openModal('ssidModal'); }
function editPassword(tag) { document.getElementById('edit-pass-tag').value = tag; document.getElementById('new-password').value = ''; openModal('passwordModal'); }

async function rebootDevice(tag) {
  if (!confirm(I18N.rebootConfirmPrefix + ' ' + tag + '?')) return;
  try {
    const res  = await fetch('/admin/api/device/' + encodeURIComponent(tag) + '/reboot', { method: 'POST' });
    const data = await res.json();
    showToast(data.message || (data.ok ? I18N.rebootSent : I18N.failed), data.ok ? 's' : 'd');
  } catch(e) { showToast('Error: ' + e.message, 'd'); }
}

document.getElementById('btn-save-ssid').addEventListener('click', async function() {
  const btn = this;
  const txt = btn.querySelector('.btn-text');
  const ldr = btn.querySelector('.btn-loader');
  const tag  = document.getElementById('edit-tag').value;
  const ssid = document.getElementById('new-ssid').value.trim();
  
  if (!ssid) return showToast(I18N.ssidRequired, 'd');
  
  btn.disabled = true;
  txt.style.display = 'none';
  ldr.style.display = 'inline-block';

  try {
    const res  = await fetch('/admin/api/device/' + encodeURIComponent(tag) + '/ssid', { 
      method:'POST', 
      headers:{'Content-Type':'application/json'}, 
      body: JSON.stringify({ ssid }) 
    });
    const data = await res.json();
    if (data.success) {
      showToast(I18N.ssidSent, 's');
      closeModal('ssidModal');
      setTimeout(loadDevices, 2000);
    } else {
      showToast(data.message || I18N.ssidFailed, 'd');
    }
  } catch(e) {
    showToast(I18N.connectionError, 'd');
  } finally {
    btn.disabled = false;
    txt.style.display = 'inline-block';
    ldr.style.display = 'none';
  }
});

