    body[data-theme="light"] .ops-shortcut-panel{
      background:rgba(255,255,255,.84);
      border-color:rgba(148,163,184,.2);
      box-shadow:0 22px 44px rgba(165,162,211,.14)
    }
    body[data-theme="light"] .ops-shortcut-card{
      background:
        linear-gradient(160deg, rgba(255,255,255,.94), rgba(255,255,255,.9) 56%, rgba(247,248,255,.84)),
        radial-gradient(circle at top left, var(--tone-soft, rgba(105,88,255,.18)), transparent 58%),
        #fff;
      box-shadow:0 16px 34px rgba(162,166,199,.14);
    }
    body[data-theme="light"] .ops-shortcut-card p{color:#6e7c98}
    body[data-theme="light"] .ops-shortcut-icon{
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.75), 0 10px 22px var(--icon-shadow, rgba(47,107,255,.14));
    }
    body[data-theme="light"] .ops-mobile-icon-wrap::before{opacity:1}
    body[data-theme="light"] .ops-mobile-label{color:#24304a}
    body[data-theme="light"] .ops-mobile-count{
      background:#fff;
      border-color:rgba(148,163,184,.32);
      color:#24304a;
      box-shadow:0 8px 18px rgba(163,170,208,.16)
    }
    body[data-theme="light"] .ops-shortcut-count{
      border-color:rgba(255,255,255,.45);
      box-shadow:0 10px 22px rgba(120,136,196,.22), inset 0 1px 0 rgba(255,255,255,.22);
    }
