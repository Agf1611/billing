    .ops-tone-cyan{--icon-bg:rgba(34,180,221,.18);--icon-color:#8de7ff;--icon-shadow:rgba(34,180,221,.18);--tone-soft:rgba(34,180,221,.24);--tone-orb:rgba(34,180,221,.16);--tone-border:rgba(34,180,221,.18);--tone-border-strong:rgba(34,180,221,.32);--tone-accent:rgba(160,240,255,.88)}
    .ops-tone-emerald{--icon-bg:rgba(29,169,106,.18);--icon-color:#8ff0ba;--icon-shadow:rgba(29,169,106,.18);--tone-soft:rgba(29,169,106,.24);--tone-orb:rgba(29,169,106,.16);--tone-border:rgba(29,169,106,.18);--tone-border-strong:rgba(29,169,106,.32);--tone-accent:rgba(170,250,205,.88)}
    .ops-tone-sky{--icon-bg:rgba(49,149,255,.18);--icon-color:#99d4ff;--icon-shadow:rgba(49,149,255,.18);--tone-soft:rgba(49,149,255,.24);--tone-orb:rgba(49,149,255,.16);--tone-border:rgba(49,149,255,.18);--tone-border-strong:rgba(49,149,255,.32);--tone-accent:rgba(173,218,255,.88)}
