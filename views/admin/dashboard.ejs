    .ops-tone-orange{--icon-bg:rgba(244,126,43,.18);--icon-color:#ffc08c;--icon-shadow:rgba(244,126,43,.18);--tone-soft:rgba(244,126,43,.24);--tone-orb:rgba(244,126,43,.16);--tone-border:rgba(244,126,43,.18);--tone-border-strong:rgba(244,126,43,.32);--tone-accent:rgba(255,205,170,.88)}
