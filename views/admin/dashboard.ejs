function closeMobileDashboardFilter() {
  const panel = document.getElementById('dash-mobile-filter-panel');
  const toggle = document.querySelector('.dash-mobile-filter-toggle');
  if (panel) panel.classList.remove('is-open');
  if (toggle) toggle.setAttribute('aria-expanded', 'false');
}

function toggleMobileDashboardFilter(event) {
  if (window.innerWidth > 767) return;
  const panel = document.getElementById('dash-mobile-filter-panel');
  const toggle = event && event.currentTarget ? event.currentTarget : document.querySelector('.dash-mobile-filter-toggle');
  if (!panel || !toggle) return;
  if (event) {
    event.preventDefault();
    event.stopPropagation();
  }
  const willOpen = !panel.classList.contains('is-open');
  panel.classList.toggle('is-open', willOpen);
  toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
}

document.addEventListener('click', (event) => {
  if (window.innerWidth > 767) return;
  const panel = document.getElementById('dash-mobile-filter-panel');
  const toggle = document.querySelector('.dash-mobile-filter-toggle');
  if (!panel || !toggle) return;
  if (panel.contains(event.target) || toggle.contains(event.target)) return;
  closeMobileDashboardFilter();
});

window.addEventListener('resize', () => {
  if (window.innerWidth > 767) closeMobileDashboardFilter();
});

function showTab(tab) {
  const isDash = tab === 'dashboard';
  document.getElementById('dashboard-section').style.display = isDash ? 'block' : 'none';
  document.getElementById('monitoring-section').style.display = isDash ? 'none' : 'block';
  document.getElementById('tab-dash').classList.toggle('active', isDash);
  document.getElementById('tab-mon').classList.toggle('active', !isDash);
  document.getElementById('page-title').textContent = isDash ? I18N.pageDashboard : I18N.pageMonitoring;
  if (!isDash) loadDevices();
}

