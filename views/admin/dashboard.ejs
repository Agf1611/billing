async function loadStats() {
  try {
    const res = await fetch('/admin/api/stats');
    const d   = await res.json();
    const total   = d.total   || 0;
    const online  = d.online  || 0;
    const offline = d.offline || 0;
    const pct     = total > 0 ? Math.round(online / total * 100) : 0;

    // Dashboard stats
    const statTotal = document.getElementById('stat-total');
    const statOnline = document.getElementById('stat-online');
    const statOffline = document.getElementById('stat-offline');
    const statWarning = document.getElementById('stat-warning');
    if (statTotal) statTotal.textContent = total;
    if (statOnline) statOnline.textContent = online;
    if (statOffline) statOffline.textContent = offline;
    if (statWarning) statWarning.textContent = d.warning || 0;

    // Monitoring mini stats
    const mTotal = document.getElementById('m-total');
    const mOnline = document.getElementById('m-online');
    const mOffline = document.getElementById('m-offline');
    const mPct = document.getElementById('m-pct');
    if (mTotal) mTotal.textContent = total;
    if (mOnline) mOnline.textContent = online;
    if (mOffline) mOffline.textContent = offline;
    if (mPct) mPct.textContent = pct + '%';

    // Donut
    const donutPct = document.getElementById('donut-pct');
    const legOnline = document.getElementById('leg-online');
    const legOffline = document.getElementById('leg-offline');
    const lastUpdate = document.getElementById('last-update-time');
    const kpiOnuValue = document.getElementById('kpi-onu-value');
    const kpiOnuSub = document.getElementById('kpi-onu-sub');
    const kpiOnuFoot = document.getElementById('kpi-onu-foot');
    const attentionOffline = document.querySelectorAll('.attention-offline-onu');
    const attentionOfflineCopy = document.querySelectorAll('.attention-offline-copy');
    if (donutPct) donutPct.textContent = pct + '%';
    if (legOnline) legOnline.textContent = online;
    if (legOffline) legOffline.textContent = offline;
    if (lastUpdate) lastUpdate.textContent = 'Update: ' + new Date().toLocaleTimeString('id-ID');
    if (kpiOnuValue) kpiOnuValue.textContent = online + ' / ' + total;
    if (kpiOnuSub) kpiOnuSub.innerHTML = '<i class="bi bi-arrow-up-short"></i> ' + pct + '% online';
    if (kpiOnuFoot) kpiOnuFoot.textContent = online + ' / ' + total;
    attentionOffline.forEach((node) => { node.textContent = offline; });
    attentionOfflineCopy.forEach((node) => { node.textContent = offline > 0 ? 'perlu cek jaringan' : 'semua ONU online'; });

    updateDonut(online, offline);
  } catch(e) { console.error('Stats error:', e); }
}

function initInvoiceStatusChart() { return; }

function showDashboardCategory(category) {
  const tabs = document.querySelectorAll('[data-dashboard-tab]');
  const panels = document.querySelectorAll('[data-dashboard-panel]');
  if (!tabs.length || !panels.length) return;
  const activeCategory = category || 'penagihan';
  tabs.forEach((tab) => {
    const isActive = tab.getAttribute('data-dashboard-tab') === activeCategory;
    tab.classList.toggle('is-active', isActive);
    tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
  });
  panels.forEach((panel) => {
    panel.classList.toggle('is-active', panel.getAttribute('data-dashboard-panel') === activeCategory);
  });
}

document.addEventListener('click', (event) => {
  const tab = event.target.closest('[data-dashboard-tab]');
  if (!tab) return;
  event.preventDefault();
  showDashboardCategory(tab.getAttribute('data-dashboard-tab'));
});

// â”€â”€ DONUT CHART â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function updateDonut(online, offline) {
  const ctx = document.getElementById('donutChart');
  if (donutChart) { donutChart.data.datasets[0].data = [online, offline]; donutChart.update(); return; }
  donutChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      datasets: [{
        data: [online, offline],
        backgroundColor: ['#3fb950', '#f85149'],
        borderWidth: 0,
        hoverOffset: 4
      }]
    },
    options: {
      cutout: '72%',
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ctx.label + ': ' + ctx.raw } } },
      animation: { animateRotate: true, duration: 600 }
    }
  });
}

function initFinanceChart() {
  const canvas = document.getElementById('financeChart');
  if (!canvas || typeof Chart === 'undefined') return;
  const labels = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agt', 'Sep', 'Okt', 'Nov', 'Des'];
  const monthlyRevenue = new Array(12).fill(0);
  const monthlyPayments = new Array(12).fill(0);
  (Array.isArray(financeChartData) ? financeChartData : []).forEach((item) => {
    const month = Math.max(1, Math.min(12, Number(item?.month || 0)));
    if (!month) return;
    monthlyRevenue[month - 1] = Number(item?.revenue || 0);
    monthlyPayments[month - 1] = Number(item?.paid_amount || 0);
  });

  if (financeChart) financeChart.destroy();
  financeChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels,
        datasets: [{
          label: 'Pendapatan',
          data: monthlyRevenue,
          borderColor: '#8b5cf6',
          backgroundColor: 'rgba(139,92,246,.18)',
          borderWidth: 3,
          pointRadius: labels.map((_, idx) => idx === (financeSelectedMonth - 1) ? 5 : 3),
          pointHoverRadius: 6,
          pointBackgroundColor: labels.map((_, idx) => idx === (financeSelectedMonth - 1) ? '#22c55e' : '#8b5cf6'),
          pointBorderColor: '#ffffff',
          pointBorderWidth: 2,
          fill: true,
          tension: 0.35
        },{
          label: 'Pembayaran',
          data: monthlyPayments,
          borderColor: '#38bdf8',
          backgroundColor: 'rgba(56,189,248,.08)',
          borderWidth: 3,
          pointRadius: 3,
          pointHoverRadius: 6,
          pointBackgroundColor: '#38bdf8',
          pointBorderColor: '#ffffff',
          pointBorderWidth: 2,
          fill: false,
          tension: 0.35
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label(ctx) {
                return (ctx.dataset?.label || 'Nominal') + ': Rp ' + Number(ctx.raw || 0).toLocaleString('id-ID');
              }
            }
          }
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: { color: '#94a3b8' }
        },
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(148,163,184,.16)' },
          ticks: {
            color: '#94a3b8',
            callback(value) {
              const amount = Number(value || 0);
              if (amount >= 1000000) return 'Rp ' + Math.round(amount / 1000000) + 'jt';
              if (amount >= 1000) return 'Rp ' + Math.round(amount / 1000) + 'rb';
              return 'Rp ' + amount;
            }
          }
        }
      }
    }
  });
}

// â”€â”€ LOAD DEVICES â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
async function loadDevices() {
  const tbody   = document.getElementById('devices-tbody');
  const loading = document.getElementById('loading-devices');
  loading.style.display = 'block';
  tbody.replaceChildren();

  try {
    const search = document.getElementById('search-device')?.value || '';
    const status = document.getElementById('filter-status')?.value || 'all';
    let url = '/admin/api/devices?limit=200';
    if (search) url += '&search=' + encodeURIComponent(search);
    if (status && status !== 'all') url += '&status=' + status;

    const res = await fetch(url);
    const data = await res.json();
    devicesData = data.devices || [];

    document.getElementById('device-count').textContent = devicesData.length + I18N.devicesSuffix;

    if (devicesData.length === 0) {
      tbody.insertAdjacentHTML('beforeend', '<tr><td colspan="6" class="text-center text-muted" style="padding:32px">' + I18N.noDevicesFound + '</td></tr>');
    } else {
      tbody.insertAdjacentHTML('beforeend', devicesData.map((d, i) => {
        const isOn = d.status === 'online';
        const tagStr = d.tags.join(', ') || '-';
        const lastInformStr = d.lastInform ? new Date(d.lastInform).toLocaleString('id-ID', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '-';
        return `<tr>
          <td class="text-muted">${i + 1}</td>
          <td>
            <span class="badge bm">${tagStr}</span>
            <div style="font-size:11px;color:var(--muted);margin-top:4px" title="Last Inform"><i class="bi bi-clock"></i> ${lastInformStr}</div>
          </td>
          <td>
            <div class="fw6" style="font-size:13px">${d.model !== '-' ? d.model : I18N.onuDevice}</div>
            <div style="font-size:11px;color:var(--muted)">SN: <code style="color:var(--info);background:transparent;padding:0">${d.serialNumber}</code></div>
            <div style="font-size:11px;color:var(--muted)">SW: ${d.softwareVersion}</div>
          </td>
          <td>
            <div style="font-size:12px;margin-bottom:2px" title="IP Address"><i class="bi bi-globe" style="color:var(--primary)"></i> ${d.pppoeIP !== '-' ? d.pppoeIP : I18N.noIp}</div>
            <div style="font-size:12px;margin-bottom:2px" title="PPPoE Username"><i class="bi bi-person-badge" style="color:var(--warning)"></i> ${d.pppoeUsername && d.pppoeUsername !== 'N/A' ? d.pppoeUsername : '<span class="text-muted">-</span>'}</div>
            <div style="font-size:12px;margin-bottom:2px" title="SSID"><i class="bi bi-wifi" style="color:var(--success)"></i> ${d.ssid}</div>
            <div style="font-size:11px;color:var(--muted)"><i class="bi bi-people"></i> ${d.userConnected} ${I18N.connectedSuffix}</div>
          </td>
          <td>
            <div><span class="badge ${isOn ? 'ds-on' : 'ds-off'}"><span class="dot ${isOn ? 'dot-on' : 'dot-off'}"></span>${isOn ? I18N.online : I18N.offline}</span></div>
            <div style="font-size:11px;color:var(--muted);margin-top:4px" title="RX Power"><i class="bi bi-activity"></i> ${d.rxPower}</div>
            <div style="font-size:11px;color:var(--muted)" title="Uptime"><i class="bi bi-clock-history"></i> ${d.uptime}</div>
          </td>
          <td>
            <button class="btn btn-g btn-icon btn-sm" title="${I18N.titleDetail}" onclick="showDetail('${d.tags[0] || d.id}')"><i class="bi bi-eye"></i></button>
            <button class="btn btn-p btn-icon btn-sm" title="${I18N.titleEditSsid}" onclick="editSsid('${d.tags[0] || d.id}', '${(d.ssid || '').replace(/'/g, "\\'")}')"><i class="bi bi-wifi"></i></button>
            <button class="btn btn-g btn-icon btn-sm" title="${I18N.titleEditPassword}" onclick="editPassword('${d.tags[0] || d.id}')"><i class="bi bi-key"></i></button>
            <button class="btn btn-d btn-icon btn-sm" title="${I18N.titleReboot}" onclick="rebootDevice('${d.tags[0] || d.id}')"><i class="bi bi-power"></i></button>
          </td>
        </tr>`;
      }).join(''));
    }

    // Update offline list on dashboard
    renderOfflineList(devicesData.filter(d => d.status === 'offline'));

  } catch(e) {
    tbody.replaceChildren();
    tbody.insertAdjacentHTML('beforeend', '<tr><td colspan="6" class="text-center" style="padding:32px;color:var(--danger)"><i class="bi bi-exclamation-circle"></i> ' + I18N.errorLoadData + '</td></tr>');
  } finally {
    loading.style.display = 'none';
  }
}

// â”€â”€ OFFLINE LIST (dashboard) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function renderOfflineList(offlineDevices) {
  const el = document.getElementById('offline-list');
  if (!el) return;
  if (offlineDevices.length === 0) {
    el.replaceChildren();
    el.insertAdjacentHTML('beforeend', '<div class="dash-empty" style="padding:24px;color:var(--success)"><i class="bi bi-check-circle-fill"></i> ' + I18N.allOnuOnline + '</div>');
    return;
  }
  el.replaceChildren();
  el.insertAdjacentHTML('beforeend', offlineDevices.map(d => {
    const ago = d.lastInform ? timeSince(new Date(d.lastInform)) : I18N.never;
    const tagLabel = Array.isArray(d.tags) && d.tags.length ? d.tags.join(', ') : '-';
    const networkLabel = d.pppoeIP && d.pppoeIP !== '-' ? d.pppoeIP : (d.ssid || '-');
    const customerLabel = d.pppoeUsername && d.pppoeUsername !== 'N/A' ? d.pppoeUsername : (d.serialNumber || '-');
    const signalLabel = d.rxPower && d.rxPower !== '-' ? d.rxPower : (d.model || 'ONU');
    return `<div class="dash-offline-item">
      <div class="dash-offline-device">
        <strong>${tagLabel}</strong>
        <small>${networkLabel}</small>
        <small>${customerLabel}</small>
      </div>
      <div class="dash-offline-meta">
        <span class="dash-offline-badge">${I18N.offlineBadge}</span>
        <div class="dash-offline-signal">${signalLabel}</div>
        <div class="dash-offline-ago">${ago}</div>
      </div>
    </div>`;
  }).join(''));
}

function timeSince(date) {
  const sec = Math.floor((Date.now() - date) / 1000);
  if (sec < 60) return sec + ' ' + I18N.secondsAgo;
  if (sec < 3600) return Math.floor(sec/60) + ' ' + I18N.minutesAgo;
  if (sec < 86400) return Math.floor(sec/3600) + ' ' + I18N.hoursAgo;
  return Math.floor(sec/86400) + ' ' + I18N.daysAgo;
}

