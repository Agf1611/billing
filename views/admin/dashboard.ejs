<body class="admin-dashboard-page">
<%- include('partials/sidebar', { activePage: activePage || 'dashboard', company }) %>

<div class="mw">
  <!-- TOPBAR -->
  <div class="topbar dashboard-topbar">
    <div class="dash-topbar-left">
      <div class="tb-title dash-page-title">
        <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
        <i class="bi bi-speedometer2"></i>
        <span id="page-title"><%= t('admin.nav.dashboard', 'Dashboard') %></span>
      </div>
    </div>
    <div class="dash-topbar-right tb-right">
      <div class="dash-topbar-date tb-chip" aria-label="Waktu dashboard">
        <span id="admin-live-date">---</span>
        <span id="admin-live-clock">--:--</span>
      </div>
      <button type="button" class="dash-mobile-filter-toggle" aria-label="Filter dashboard" aria-expanded="false" onclick="toggleMobileDashboardFilter(event)">
        <i class="bi bi-funnel"></i>
      </button>
      <form method="get" action="/admin" class="dash-topbar-filter" id="dash-mobile-filter-panel">
        <select class="fs" name="month" aria-label="Pilih bulan dashboard" onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()">
          <% ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'].forEach((label, idx) => { %>
            <option value="<%= idx + 1 %>" <%= Number(typeof dashboardFilterMonth !== 'undefined' ? dashboardFilterMonth : (new Date().getMonth() + 1)) === (idx + 1) ? 'selected' : '' %>><%= label %></option>
          <% }) %>
        </select>
        <select class="fs" name="year" aria-label="Pilih tahun dashboard" onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()">
          <% const currentTopYear = new Date().getFullYear(); const selectedTopYear = Number(typeof dashboardFilterYear !== 'undefined' ? dashboardFilterYear : currentTopYear); for (let y = currentTopYear - 2; y <= currentTopYear + 1; y++) { %>
            <option value="<%= y %>" <%= selectedTopYear === y ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
      </form>
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
      </button>
      <a href="/admin/logout" class="dash-topbar-avatar" aria-label="<%= t('common.logout', 'Logout') %>" title="<%= t('common.logout', 'Logout') %>">
        <i class="bi bi-box-arrow-right"></i>
      </a>
    </div>
  </div>

  <div class="page admin-shell-page dashboard-shell">
    <!-- TAB NAVIGATION -->
    <div class="tab-bar" style="display:none">
      <button class="tab-btn active" id="tab-dash" onclick="showTab('dashboard')">
        <i class="bi bi-speedometer2"></i><%= t('admin.nav.dashboard', 'Dashboard') %>
      </button>
      <button class="tab-btn" id="tab-mon" onclick="showTab('monitoring')">
        <i class="bi bi-router"></i><%= t('admin.dashboard.monitoring_onu', 'Monitoring ONU') %>
      </button>
    </div>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <!-- DASHBOARD SECTION                                       -->
    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <div id="dashboard-section">
      <% const ops = (typeof opsSummary !== 'undefined' && opsSummary) ? opsSummary : {}; %>
      <% const dashboardRecentPayments = (typeof recentPayments !== 'undefined' && Array.isArray(recentPayments)) ? recentPayments : []; %>
      <% const dashboardTopUnpaid = (typeof topUnpaid !== 'undefined' && Array.isArray(topUnpaid)) ? topUnpaid : []; %>
      <% const dashboardChart = (typeof dashboardChartData !== 'undefined' && Array.isArray(dashboardChartData)) ? dashboardChartData : []; %>
      <% const finance = (typeof dashboardFinance !== 'undefined' && dashboardFinance) ? dashboardFinance : {}; %>
      <% const dashboardMonth = Math.max(1, Math.min(12, Number(typeof dashboardFilterMonth !== 'undefined' ? dashboardFilterMonth : (new Date().getMonth() + 1)) || (new Date().getMonth() + 1))); %>
      <% const dashboardYear = Math.max(2000, Number(typeof dashboardFilterYear !== 'undefined' ? dashboardFilterYear : new Date().getFullYear()) || new Date().getFullYear()); %>
      <% const monthNamesDash = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember']; %>
      <% const priorityTodayCount = dashboardTopUnpaid.filter((item) => Number(item.daysLeft || 0) === 0).length; %>
      <% const priorityOverdueCount = dashboardTopUnpaid.filter((item) => Number(item.daysLeft || 0) < 0).length; %>
      <% const prioritySevereCount = dashboardTopUnpaid.filter((item) => Number(item.daysLeft || 0) <= -7).length; %>
      <% const priorityAmountTotal = dashboardTopUnpaid.reduce((sum, item) => sum + Number(item.total_unpaid || item.amount || 0), 0); %>
      <% const dashboardQuickActions = (typeof session !== 'undefined' && session.isCashier && !session.isAdmin)
        ? [
            { href: '/admin/billing', icon: 'bi-file-earmark-plus', label: 'Buka Tagihan' },
            { href: '/admin/customers', icon: 'bi-people', label: 'Lihat Pelanggan' },
            { href: '/admin/bookkeeping', icon: 'bi-cash-coin', label: 'Pembayaran' },
            { href: '/admin/agents', icon: 'bi-person-badge', label: 'Monitor Agent' }
          ]
        : [
            { href: '/admin/billing', icon: 'bi-file-earmark-plus', label: 'Buat Tagihan' },
            { href: '/admin/whatsapp/broadcast', icon: 'bi-whatsapp', label: 'Pengingat WA' },
            { href: '/admin/customers/create', icon: 'bi-person-plus', label: 'Tambah Pelanggan' },
            { href: '/admin/tickets', icon: 'bi-life-preserver', label: 'Buka Tiket' },
            { href: '/admin/reports', icon: 'bi-bar-chart-line', label: 'Laporan' }
          ]; %>
      <% const dashboardMobileActions = (typeof session !== 'undefined' && session.isCashier && !session.isAdmin)
        ? [
            { href: '/admin/customers', icon: 'bi-people', label: 'Pelanggan', tone: 'violet' },
            { href: '/admin/billing', icon: 'bi-receipt', label: 'Tagihan', tone: 'mint', badge: Number(ops.unpaidInvoices || 0) },
            { href: '/admin/bookkeeping', icon: 'bi-cash-coin', label: 'Pembayaran', tone: 'amber' },
            { href: '/admin/agents', icon: 'bi-person-badge', label: 'Agent', tone: 'sky' }
          ]
        : [
            { href: '/admin/customers', icon: 'bi-people', label: 'Pelanggan', tone: 'violet' },
            { href: '/admin/billing', icon: 'bi-receipt', label: 'Tagihan', tone: 'mint', badge: Number(ops.unpaidInvoices || 0) },
            { href: '/admin/tickets', icon: 'bi-file-earmark-text', label: 'Tiket', tone: 'amber', badge: Number(ops.openTickets || 0) },
            { href: '/admin/technician-tasks', icon: 'bi-tools', label: 'Tugas Teknisi', tone: 'sky' },
            { href: '/admin/mikrotik', icon: 'bi-hdd-stack', label: 'PPPoE', tone: 'mint' },
            { href: '/admin/accounts', icon: 'bi-briefcase', label: 'Karyawan', tone: 'violet' },
            { href: '/admin/bookkeeping', icon: 'bi-cash-coin', label: 'Pembukuan', tone: 'amber' },
            { href: '/admin/reports', icon: 'bi-bar-chart', label: 'Laporan', tone: 'rose' }
          ]; %>

      <% const dashboardTickets = (typeof recentActiveTickets !== 'undefined' && Array.isArray(recentActiveTickets)) ? recentActiveTickets : []; %>
      <% const dashboardRecentPaymentsPreview = dashboardRecentPayments; %>
      <% const collectionRate = Number(finance.total_invoices || 0) > 0 ? Math.round((Number(finance.paid_count || 0) / Number(finance.total_invoices || 1)) * 100) : 0; %>
      <% const previousFinance = dashboardChart.find((item) => Number(item.month || 0) === Math.max(1, dashboardMonth - 1)) || null; %>
      <% const revenueDelta = Number(finance.revenue || 0) - Number(previousFinance?.revenue || 0); %>
      <% const unpaidDelta = Number(finance.unpaid_count || 0) - Number(previousFinance?.unpaid_count || 0); %>
      <% const paymentTodayAmount = dashboardRecentPayments.reduce((sum, item) => sum + Number(item.amount || 0), 0); %>
      <% const totalPriorityCustomers = Number(dashboardTopUnpaid.length || 0); %>
      <% const totalDueToday = Number(priorityTodayCount || 0); %>
      <% const totalOverdueHard = Number(prioritySevereCount || 0); %>
      <% const monthlyRevenue = (typeof billing !== 'undefined' && billing) ? Number(billing.thisMonth || 0) : Number(finance.revenue || 0); %>
      <% const monthlyReceivable = Number(ops.pendingAmount || 0); %>
      <% const monthlyPaymentsToday = Number(paymentTodayAmount || 0); %>
      <% const dashboardCashierOnly = (typeof session !== 'undefined' && session.isCashier && !session.isAdmin); %>
      <% const activeCustomersHref = '/admin/customers?status=active'; %>
      <% const unpaidInvoicesHref = '/admin/billing?status=unpaid'; %>
      <% const suspendedCustomersHref = '/admin/billing?status=isolated'; %>
      <% const openTicketsHref = dashboardCashierOnly ? '/admin/billing?status=unpaid' : '/admin/tickets?status=open'; %>
      <% const paidInvoicesHref = '/admin/billing?status=paid'; %>
      <% const monitoringHref = dashboardCashierOnly ? '/admin/customers?status=active' : '/admin/monitoring'; %>
      <% function formatRupiah(value) {
           return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
         } %>
      <% function formatCompactRupiah(value) {
           const amount = Math.abs(Number(value || 0));
           const sign = Number(value || 0) < 0 ? '-' : '';
           if (amount >= 1000000000) {
             return sign + 'Rp ' + (amount / 1000000000).toLocaleString('id-ID', { minimumFractionDigits: amount < 10000000000 ? 1 : 0, maximumFractionDigits: 1 }) + ' M';
           }
           if (amount >= 1000000) {
             return sign + 'Rp ' + (amount / 1000000).toLocaleString('id-ID', { minimumFractionDigits: amount < 10000000 ? 1 : 0, maximumFractionDigits: 1 }) + ' Jt';
           }
           if (amount >= 1000) {
             return sign + 'Rp ' + (amount / 1000).toLocaleString('id-ID', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' Rb';
           }
           return sign + 'Rp ' + amount.toLocaleString('id-ID');
         } %>

      <section class="dash-kpi-board">
        <section class="dash-finance-hero" aria-label="Ringkasan keuangan dashboard">
          <div class="dash-finance-hero-head">
            <div class="dash-finance-hero-copy">
              <span class="dash-finance-hero-kicker">Ringkasan Keuangan</span>
              <h3 class="dash-finance-hero-title">Pendapatan Bulan Ini</h3>
              <p class="dash-finance-hero-value"><%= formatCompactRupiah(monthlyRevenue) %></p>
              <p class="dash-finance-hero-meta">
                <strong><%= monthNamesDash[dashboardMonth - 1] %> <%= dashboardYear %></strong> fokus cashflow.
                Piutang <strong><%= formatCompactRupiah(monthlyReceivable) %></strong>
                · Hari ini <strong><%= formatCompactRupiah(monthlyPaymentsToday) %></strong>
                · <strong><%= Number(collectionRate || 0).toLocaleString('id-ID') %>%</strong> kolektibilitas.
              </p>
            </div>
            <div class="dash-finance-hero-side">
              <span class="dash-finance-hero-period"><%= monthNamesDash[dashboardMonth - 1] %> <%= dashboardYear %></span>
              <span class="dash-finance-hero-badge"><i class="bi bi-broadcast-pin"></i> Live</span>
            </div>
          </div>
          <div class="dash-finance-hero-metrics">
            <div class="dash-finance-pill">
              <small>Pendapatan</small>
              <strong><%= formatCompactRupiah(monthlyRevenue) %></strong>
              <span><%= revenueDelta >= 0 ? 'Naik' : 'Turun' %> <%= formatCompactRupiah(Math.abs(revenueDelta)) %></span>
            </div>
            <div class="dash-finance-pill">
              <small>Piutang</small>
              <strong><%= formatCompactRupiah(monthlyReceivable) %></strong>
              <span><%= Number(ops.unpaidInvoices || 0).toLocaleString('id-ID') %> invoice tertunda</span>
            </div>
            <div class="dash-finance-pill">
              <small>Hari Ini</small>
              <strong><%= formatCompactRupiah(monthlyPaymentsToday) %></strong>
              <span><%= Number(finance.paid_count || 0).toLocaleString('id-ID') %> invoice lunas</span>
            </div>
          </div>
        </section>
        <div class="dash-quick-top">
          <% dashboardQuickActions.forEach((item) => { %>
            <a href="<%= item.href %>" class="dash-quick-chip">
              <i class="bi <%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }) %>
        </div>
        <div class="dashboard-mobile-shortcuts">
          <div class="dashboard-mobile-shortcuts-head">
            <strong>Akses Cepat</strong>
          </div>
          <div class="dashboard-mobile-shortcuts-grid">
            <% dashboardMobileActions.forEach((item) => { %>
              <a href="<%= item.href %>" class="dashboard-mobile-shortcut dashboard-mobile-shortcut-<%= item.tone %>">
                <span class="dashboard-mobile-shortcut-icon">
                  <i class="bi <%= item.icon %>"></i>
                  <% if (Number(item.badge || 0) > 0) { %>
                    <em class="dashboard-mobile-shortcut-badge"><%= Number(item.badge || 0).toLocaleString('id-ID') %></em>
                  <% } %>
                </span>
                <span><%= item.label %></span>
              </a>
            <% }) %>
          </div>
        </div>
        <div class="dash-kpi-grid-pro">
          <a href="<%= activeCustomersHref %>" class="dash-kpi-card kpi-tier-core kpi-card-hero accent-violet">
            <span class="dash-kpi-icon"><i class="bi bi-people-fill"></i></span>
            <div class="dash-kpi-copy">
              <small>Pelanggan Aktif</small>
              <strong class="dash-kpi-value"><%= Number(ops.activeCustomers || 0).toLocaleString('id-ID') %></strong>
              <span><i class="bi bi-arrow-up-short"></i> <%= Number(ops.totalCustomers || 0).toLocaleString('id-ID') %> total pelanggan</span>
            </div>
          </a>
          <a href="<%= unpaidInvoicesHref %>" class="dash-kpi-card kpi-tier-core accent-blue">
            <span class="dash-kpi-icon"><i class="bi bi-file-earmark-text-fill"></i></span>
            <div class="dash-kpi-copy">
              <small>Invoice Belum Bayar</small>
              <strong class="dash-kpi-value"><%= Number(ops.unpaidInvoices || 0).toLocaleString('id-ID') %></strong>
              <span class="<%= unpaidDelta > 0 ? 'trend-down' : 'trend-up' %>"><i class="bi <%= unpaidDelta > 0 ? 'bi-arrow-down-short' : 'bi-arrow-up-short' %>"></i> <%= Math.abs(unpaidDelta).toLocaleString('id-ID') %> dari bulan lalu</span>
            </div>
          </a>
          <a href="<%= suspendedCustomersHref %>" class="dash-kpi-card kpi-tier-support accent-rose">
            <span class="dash-kpi-icon"><i class="bi bi-pause-circle-fill"></i></span>
            <div class="dash-kpi-copy">
              <small>Suspend</small>
              <strong class="dash-kpi-value"><%= Number(ops.suspendedCustomers || 0).toLocaleString('id-ID') %></strong>
              <span><i class="bi bi-exclamation-circle"></i> pelanggan perlu dicek</span>
            </div>
          </a>
          <a href="<%= openTicketsHref %>" class="dash-kpi-card kpi-tier-support accent-red">
            <span class="dash-kpi-icon"><i class="bi bi-exclamation-triangle-fill"></i></span>
            <div class="dash-kpi-copy">
              <small>Gangguan Aktif</small>
              <strong class="dash-kpi-value"><%= Number(ops.openTickets || 0).toLocaleString('id-ID') %></strong>
              <span><i class="bi bi-arrow-up-short"></i> <%= Number(ops.openOnlyTickets || 0).toLocaleString('id-ID') %> tiket baru</span>
            </div>
          </a>
          <a href="<%= paidInvoicesHref %>" class="dash-kpi-card kpi-tier-support accent-cyan">
            <span class="dash-kpi-icon"><i class="bi bi-pie-chart-fill"></i></span>
            <div class="dash-kpi-copy">
              <small>Kolektibilitas</small>
              <strong class="dash-kpi-value"><%= Number(collectionRate || 0).toLocaleString('id-ID') %>%</strong>
              <span><i class="bi bi-check2-circle"></i> <%= Number(finance.paid_count || 0).toLocaleString('id-ID') %> invoice lunas</span>
            </div>
          </a>
          <a href="<%= monitoringHref %>" class="dash-kpi-card kpi-tier-support accent-sky">
            <span class="dash-kpi-icon"><i class="bi bi-wifi"></i></span>
            <div class="dash-kpi-copy">
              <small>ONU Online</small>
              <strong id="kpi-onu-value" class="dash-kpi-value">-- / --</strong>
              <span id="kpi-onu-sub"><i class="bi bi-arrow-repeat"></i> sinkron live</span>
            </div>
          </a>
        </div>
      </section>

      <section class="dash-board-row dash-board-primary">
        <article class="dash-board-card dash-finance-status-card">
          <div class="dash-finance-block dash-chart-card">
            <div class="dash-board-head">
              <div>
                <h6>Tren Pendapatan &amp; Pembayaran</h6>
                <p><%= monthNamesDash[dashboardMonth - 1] %> <%= dashboardYear %> sebagai fokus utama penagihan dan cashflow.</p>
              </div>
              <a href="/admin/reports?month=<%= dashboardMonth %>&year=<%= dashboardYear %>" class="btn btn-g btn-sm">Lihat Semua</a>
            </div>
            <div class="dash-chart-legend">
              <span><i class="bi bi-circle-fill text-violet"></i> Pendapatan</span>
              <span><i class="bi bi-circle-fill text-info"></i> Pembayaran</span>
            </div>
            <div class="dash-chart-surface">
              <canvas id="financeChart"></canvas>
            </div>
          </div>
          <div class="dash-status-block dash-status-card">
            <div class="dash-board-head">
              <div>
                <h6>Status Tagihan</h6>
                <p><strong><%= Number(finance.total_invoices || 0).toLocaleString('id-ID') %></strong> total tagihan periode <%= monthNamesDash[dashboardMonth - 1] %> <%= dashboardYear %>.</p>
              </div>
            </div>
            <div class="dash-status-wrap dash-status-wrap-compact">
              <div class="dash-status-list">
                <div class="dash-status-row tone-success">
                  <small>Lunas</small>
                  <strong><%= Number(finance.paid_count || 0).toLocaleString('id-ID') %></strong>
                </div>
                <div class="dash-status-row tone-danger">
                  <small>Belum Bayar</small>
                  <strong><%= Number(finance.unpaid_count || 0).toLocaleString('id-ID') %></strong>
                </div>
                <div class="dash-status-row tone-warning">
                  <small>Tempo Hari Ini</small>
                  <strong><%= Number(priorityTodayCount || 0).toLocaleString('id-ID') %></strong>
                </div>
                <div class="dash-status-row tone-primary">
                  <small>&gt; 7 Hari</small>
                  <strong><%= Number(prioritySevereCount || 0).toLocaleString('id-ID') %></strong>
                </div>
              </div>
            </div>
          </div>
        </article>

        <article class="dash-board-card dash-payments-preview-card dash-primary-payments-card">
            <div class="dash-board-head">
              <div>
                <h6>Pembayaran Terbaru</h6>
                <p>Preview pembayaran yang masuk pada periode aktif.</p>
              </div>
              <a href="/admin/reports?month=<%= dashboardMonth %>&year=<%= dashboardYear %>" class="btn btn-g btn-sm">Lihat Semua</a>
            </div>
            <% if (dashboardRecentPaymentsPreview.length === 0) { %>
              <div class="dash-payments-preview-list">
                <div class="dash-empty">Belum ada pembayaran untuk periode ini.</div>
              </div>
            <% } else { %>
              <div class="dash-payments-preview-list">
                <div class="dash-payments-preview-scroll">
                <% dashboardRecentPaymentsPreview.forEach((item) => { %>
                  <% const paymentMethod = String(item.payment_method || item.channel || '').trim(); %>
                  <% const paymentLabel = paymentMethod ? paymentMethod.toUpperCase() : (item.paid_by_name ? 'ADMIN' : 'TUNAI'); %>
                  <div class="dash-payments-preview-item">
                    <div class="dash-payments-preview-main">
                      <strong><%= item.customer_name || '-' %></strong>
                      <small>
                        <%= item.paid_at ? new Date(item.paid_at).toLocaleString('id-ID', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) : '-' %>
                        · <%= paymentLabel %>
                      </small>
                    </div>
                    <div class="dash-payments-preview-amount"><%= formatCompactRupiah(item.amount || 0) %></div>
                  </div>
                <% }) %>
                </div>
                <div class="dash-payments-preview-foot">
                  <span>Hari ini <strong><%= formatCompactRupiah(monthlyPaymentsToday) %></strong></span>
                  <span><strong><%= Number(finance.paid_count || 0).toLocaleString('id-ID') %></strong> invoice lunas</span>
                </div>
              </div>
            <% } %>
        </article>
      </section>

      <section class="dash-category-section">
        <div class="dash-category-tabs" role="tablist" aria-label="Kategori dashboard operasional">
          <button type="button" class="dash-category-tab is-active" data-dashboard-tab="penagihan" aria-selected="true">Penagihan</button>
          <button type="button" class="dash-category-tab" data-dashboard-tab="gangguan" aria-selected="false">Gangguan</button>
