<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    /* â”€â”€ ONU STATUS DOT â”€â”€ */
    .dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px}
    .dot-on{background:var(--success);box-shadow:0 0 6px var(--success)}
    .dot-off{background:var(--danger)}

    /* â”€â”€ PULSE ANIMATION (online) â”€â”€ */
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    .pulse{animation:pulse 2s infinite}

    /* â”€â”€ MONITORING SECTION â”€â”€ */
    #monitoring-section{display:none}
    #dashboard-section{display:block}

    /* â”€â”€ NAV TABS â”€â”€ */
    .tab-bar{display:flex;gap:6px;background:var(--surface);padding:5px;border-radius:16px;margin-bottom:14px;width:fit-content;border:1px solid var(--border);box-shadow:var(--shadow-soft)}
    .tab-btn{padding:9px 18px;border-radius:12px;border:none;background:transparent;color:var(--muted);font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s;letter-spacing:-0.01em}
    .tab-btn.active{background:var(--surface-strong);color:var(--text);box-shadow:0 10px 24px rgba(0,0,0,.12)}
    .tab-btn i{margin-right:6px}

    /* â”€â”€ DEVICE STATUS BADGE â”€â”€ */
    .ds-on{background:rgba(63,185,80,.15);color:#3fb950;border:1px solid rgba(63,185,80,.3)}
    .ds-off{background:rgba(248,81,73,.15);color:#f85149;border:1px solid rgba(248,81,73,.3)}

    /* â”€â”€ LIVE INDICATOR â”€â”€ */
    .live-dot{width:8px;height:8px;border-radius:50%;background:var(--success);display:inline-block;animation:pulse 1.5s infinite}
    .realtime-bar{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted)}

    /* â”€â”€ CHART WRAPPER â”€â”€ */
    #donut-wrap{position:relative;width:160px;height:160px;margin:0 auto}
    .donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
    .donut-num{font-size:28px;font-weight:700;line-height:1}
    .donut-lbl{font-size:11px;color:var(--muted);margin-top:2px}

    .ops-home-shell{display:grid;gap:12px;margin-bottom:16px}
    .ops-metric-panel{background:var(--surface-strong);border:1px solid var(--border);border-radius:20px;padding:12px;box-shadow:var(--shadow-soft)}
    .ops-panel-head{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-bottom:7px}
    .ops-panel-head h3{margin:0;font-size:14px;font-weight:800;letter-spacing:-0.03em}
    .ops-panel-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 8px;border-radius:999px;background:rgba(99,102,241,.12);color:#a5b4fc;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.05em}
    .ops-metric-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:7px}
    .ops-metric{padding:10px 10px;border-radius:16px;background:var(--panel-soft);border:1px solid var(--panel-border)}
    .ops-metric small{display:block;font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.03em;text-transform:uppercase}
    .ops-metric strong{display:block;margin-top:4px;font-size:16px;line-height:1;font-weight:800;letter-spacing:-0.05em;color:var(--text)}
    .ops-metric span{display:block;margin-top:3px;color:var(--muted);font-size:9.5px}
    .ops-shortcut-panel{background:var(--surface-strong);border:1px solid var(--border);border-radius:22px;padding:14px 14px 12px;box-shadow:var(--shadow-soft)}
    .ops-shortcut-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:8px}
    .ops-shortcut-head h3{margin:0;font-size:15px;font-weight:800;letter-spacing:-0.03em}
    .ops-shortcut-head p{margin:3px 0 0;color:var(--muted);font-size:10px;line-height:1.4}
    .ops-shortcut-note{display:inline-flex;align-items:center;gap:8px;padding:7px 10px;border-radius:999px;background:rgba(99,102,241,.12);color:#a5b4fc;font-size:10px;font-weight:700}
    .ops-shortcut-desktop{display:block}
    .ops-shortcut-mobile{display:none}
    .ops-shortcut-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px}
    .ops-shortcut-card{
      position:relative;display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-end;gap:7px;min-height:90px;height:90px;padding:10px 10px 11px;border-radius:18px;
      text-decoration:none;color:var(--text);border:1px solid var(--tone-border, rgba(255,255,255,.08));overflow:hidden;
      background:
        linear-gradient(160deg, rgba(255,255,255,.1), rgba(255,255,255,.02) 54%, rgba(15,23,42,.1)),
        radial-gradient(circle at top left, var(--tone-soft, rgba(99,102,241,.18)), transparent 56%),
        var(--surface-strong);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.04), var(--shadow-soft);
      transition:transform .2s ease,border-color .2s ease,box-shadow .2s ease,filter .2s ease
    }
    .ops-shortcut-card:hover{transform:translateY(-2px);border-color:var(--tone-border-strong, rgba(255,255,255,.18));box-shadow:inset 0 1px 0 rgba(255,255,255,.05), 0 16px 28px rgba(0,0,0,.22);filter:saturate(1.04)}
    .ops-shortcut-card::before{
      content:'';position:absolute;inset:auto -22px -28px auto;width:88px;height:88px;border-radius:50%;
      background:var(--tone-orb, rgba(255,255,255,.08))
    }
    .ops-shortcut-card::after{
      content:'';position:absolute;left:0;right:0;top:0;height:3px;
      background:linear-gradient(90deg, var(--tone-accent, rgba(255,255,255,.45)), transparent 78%);
      opacity:.9
    }
    .ops-shortcut-count{
      position:absolute;right:10px;top:10px;z-index:3;display:inline-flex;align-items:center;justify-content:center;
      min-width:30px;height:30px;padding:0 9px;border-radius:999px;
      border:1px solid rgba(255,255,255,.16);font-size:13px;font-weight:900;line-height:1;color:#fff;
      box-shadow:0 10px 20px rgba(15,23,42,.24), inset 0 1px 0 rgba(255,255,255,.12);
      text-shadow:0 1px 1px rgba(0,0,0,.18)
    }
    .ops-tone-danger .ops-shortcut-count{background:linear-gradient(135deg,#ef4444,#dc2626)}
    .ops-tone-primary .ops-shortcut-count{background:linear-gradient(135deg,#6366f1,#4f46e5)}
    .ops-tone-cyan .ops-shortcut-count{background:linear-gradient(135deg,#06b6d4,#0891b2)}
    .ops-tone-emerald .ops-shortcut-count{background:linear-gradient(135deg,#22c55e,#16a34a)}
    .ops-tone-sky .ops-shortcut-count{background:linear-gradient(135deg,#3b82f6,#2563eb)}
    .ops-tone-gold .ops-shortcut-count{background:linear-gradient(135deg,#f59e0b,#d97706)}
    .ops-tone-rose .ops-shortcut-count{background:linear-gradient(135deg,#ec4899,#db2777)}
    .ops-tone-violet .ops-shortcut-count{background:linear-gradient(135deg,#8b5cf6,#7c3aed)}
    .ops-tone-orange .ops-shortcut-count{background:linear-gradient(135deg,#f97316,#ea580c)}
    .ops-tone-mint .ops-shortcut-count{background:linear-gradient(135deg,#14b8a6,#0f766e)}
    .ops-tone-slate .ops-shortcut-count{background:linear-gradient(135deg,#64748b,#475569)}
    .ops-tone-neutral .ops-shortcut-count{background:linear-gradient(135deg,#94a3b8,#64748b)}
    .ops-shortcut-icon{
      position:relative;z-index:1;width:31px;height:31px;border-radius:11px;display:inline-flex;align-items:center;justify-content:center;
      font-size:13px;background:var(--icon-bg, rgba(47,107,255,.1));box-shadow:inset 0 0 0 1px rgba(255,255,255,.06), 0 10px 18px var(--icon-shadow, rgba(47,107,255,.14));color:var(--icon-color, var(--primary))
    }
    .ops-shortcut-card strong{position:relative;z-index:1;font-size:11.5px;line-height:1.15;font-weight:800;letter-spacing:-0.02em}
    .ops-shortcut-label-short{display:none}
    .ops-shortcut-card p{position:relative;z-index:1;margin:0;color:var(--muted);font-size:10px;line-height:1.35}
    .ops-mobile-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px 8px}
    .ops-mobile-link{
      display:flex;flex-direction:column;align-items:center;justify-content:flex-start;gap:8px;
      padding:2px 0 4px;text-decoration:none;color:var(--text);text-align:center;min-width:0
    }
    .ops-mobile-link:hover{transform:translateY(-1px)}
    .ops-mobile-icon-wrap{
      position:relative;display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px
    }
    .ops-mobile-icon-wrap::before{
      content:'';position:absolute;inset:1px;border-radius:999px;
      background:radial-gradient(circle, var(--tone-soft, rgba(99,102,241,.22)) 0%, rgba(255,255,255,0) 74%);
      opacity:.95
    }
    .ops-mobile-icon{
      position:relative;z-index:1;font-size:23px;line-height:1;color:var(--icon-color, var(--primary))
    }
    .ops-mobile-count{
      position:absolute;right:-7px;top:-4px;z-index:2;display:inline-flex;align-items:center;justify-content:center;
      min-width:18px;height:18px;padding:0 5px;border-radius:999px;background:var(--surface-strong);
      border:1px solid var(--tone-border-strong, rgba(255,255,255,.2));font-size:9px;font-weight:900;line-height:1;color:#fff;
      box-shadow:0 8px 16px rgba(15,23,42,.22)
    }
    .ops-tone-danger .ops-mobile-count{background:linear-gradient(135deg,#ef4444,#dc2626)}
    .ops-tone-primary .ops-mobile-count{background:linear-gradient(135deg,#6366f1,#4f46e5)}
    .ops-tone-cyan .ops-mobile-count{background:linear-gradient(135deg,#06b6d4,#0891b2)}
    .ops-tone-emerald .ops-mobile-count{background:linear-gradient(135deg,#22c55e,#16a34a)}
    .ops-tone-sky .ops-mobile-count{background:linear-gradient(135deg,#3b82f6,#2563eb)}
    .ops-tone-gold .ops-mobile-count{background:linear-gradient(135deg,#f59e0b,#d97706)}
    .ops-tone-rose .ops-mobile-count{background:linear-gradient(135deg,#ec4899,#db2777)}
    .ops-tone-violet .ops-mobile-count{background:linear-gradient(135deg,#8b5cf6,#7c3aed)}
    .ops-tone-orange .ops-mobile-count{background:linear-gradient(135deg,#f97316,#ea580c)}
    .ops-tone-mint .ops-mobile-count{background:linear-gradient(135deg,#14b8a6,#0f766e)}
    .ops-tone-slate .ops-mobile-count{background:linear-gradient(135deg,#64748b,#475569)}
    .ops-tone-neutral .ops-mobile-count{background:linear-gradient(135deg,#94a3b8,#64748b)}
    .ops-mobile-label{
      display:block;max-width:74px;font-size:11px;font-weight:700;line-height:1.2;
      color:var(--text);word-break:break-word
    }
    .ops-tone-danger{--icon-bg:rgba(238,83,96,.18);--icon-color:#ff97a3;--icon-shadow:rgba(238,83,96,.18);--tone-soft:rgba(238,83,96,.24);--tone-orb:rgba(238,83,96,.16);--tone-border:rgba(238,83,96,.18);--tone-border-strong:rgba(238,83,96,.32);--tone-accent:rgba(255,170,178,.88)}
