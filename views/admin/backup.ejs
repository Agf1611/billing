<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= title %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .backup-page { display: grid; gap: 16px; }
    .backup-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
    .backup-help {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      padding: 14px 16px;
      border-radius: 18px;
      background: color-mix(in srgb, var(--card) 82%, var(--pri) 18%);
      border: 1px solid color-mix(in srgb, var(--line) 72%, var(--pri) 28%);
    }
    .backup-help i { font-size: 22px; color: var(--pri); }
    .backup-help p { margin: 4px 0 0; color: var(--muted); font-size: 13px; line-height: 1.6; }
    .backup-dir {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 12px;
      color: var(--muted);
      word-break: break-all;
      background: color-mix(in srgb, var(--bg) 74%, var(--card) 26%);
      border: 1px dashed var(--line);
      border-radius: 14px;
      padding: 10px 12px;
    }
    .backup-form-grid { display: grid; gap: 12px; }
    .backup-form-grid .fg:last-child { margin-bottom: 0; }
    .backup-form-note { display: block; margin-top: 6px; color: var(--muted); font-size: 12px; line-height: 1.5; }
    .backup-list { display: grid; gap: 12px; }
    .backup-item {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: color-mix(in srgb, var(--card) 92%, var(--bg) 8%);
      padding: 14px;
      display: grid;
      gap: 12px;
    }
    .backup-item-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }
    .backup-file {
      min-width: 0;
      display: grid;
      gap: 4px;
    }
    .backup-file-name {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.5;
      color: var(--text);
      word-break: break-word;
    }
    .backup-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 12px;
      color: var(--muted);
    }
    .backup-type-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .02em;
      white-space: nowrap;
    }
    .backup-type-badge.database { background: color-mix(in srgb, var(--pri) 14%, transparent); color: var(--pri); }
    .backup-type-badge.settings { background: color-mix(in srgb, var(--success) 14%, transparent); color: var(--success); }
    .backup-type-badge.archive,
    .backup-type-badge.file { background: color-mix(in srgb, var(--warning) 18%, transparent); color: var(--warning); }
    .backup-item-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .backup-item-actions .btn { flex: 1 1 120px; }
    .backup-empty {
      text-align: center;
      padding: 36px 20px;
      color: var(--muted);
    }
    .backup-empty i { font-size: 40px; opacity: .35; }
    @media (max-width: 720px) {
      .backup-item { padding: 12px; border-radius: 16px; }
      .backup-item-top { align-items: stretch; flex-direction: column; }
      .backup-item-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .backup-item-actions .btn { width: 100%; }
    }
    @media (max-width: 420px) {
      .backup-grid { grid-template-columns: 1fr; }
      .backup-item-actions { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: activePage || 'backup', company }) %>

<div class="mw">
  <div class="topbar">
    <div class="tb-title">
      <button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <i class="bi bi-hdd-stack"></i>
      <span id="page-title">Backup & Recovery</span>
    </div>
    <div class="tb-right">
      <span class="adm-badge">
        <i class="bi bi-person-fill"></i>
        <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %>
      </span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>

  <div class="page backup-page">
    <% if (msg) { %>
      <div class="alert alert-<%= msg.type === 'danger' ? 'd' : msg.type === 'success' ? 's' : msg.type === 'warning' ? 'w' : 'i' %>">
        <i class="bi bi-<%= msg.type === 'success' ? 'check-circle' : 'exclamation-triangle' %>"></i>
        <%= msg.text %>
      </div>
    <% } %>

    <div class="backup-help">
      <i class="bi bi-shield-check"></i>
      <div>
        <div class="fw7">Backup sekarang bisa langsung diunduh dan restore dari file lokal.</div>
        <p>Restore database memakai sinkronisasi isi tabel, jadi lebih aman saat aplikasi sedang berjalan. Sebelum restore, sistem otomatis membuat backup cadangan terlebih dahulu.</p>
      </div>
    </div>

    <div class="stat-grid">
      <div class="sc p">
        <i class="bi bi-files sc-icon"></i>
        <div class="sc-label">Total File</div>
        <div class="sc-val"><%= total %></div>
        <div class="sc-sub">Semua backup tersimpan</div>
      </div>
      <div class="sc s">
        <i class="bi bi-arrow-repeat sc-icon"></i>
        <div class="sc-label">Bisa Restore</div>
        <div class="sc-val"><%= backups.filter((b) => b.restorable).length %></div>
        <div class="sc-sub">Database & settings</div>
      </div>
      <div class="sc w">
        <i class="bi bi-download sc-icon"></i>
        <div class="sc-label">File Arsip</div>
        <div class="sc-val"><%= backups.filter((b) => !b.restorable).length %></div>
        <div class="sc-sub">Download saja</div>
      </div>
      <div class="sc i">
        <i class="bi bi-hdd sc-icon"></i>
        <div class="sc-label">Total Size</div>
        <div class="sc-val"><%= (backups.reduce((sum, b) => sum + b.sizeKB, 0) / 1024).toFixed(1) %><span style="font-size:14px"> MB</span></div>
        <div class="sc-sub">Kapasitas backup</div>
      </div>
    </div>

    <div class="backup-dir"><strong>Folder backup:</strong> <%= backupDir %></div>

    <div class="backup-grid">
      <div class="card">
        <div class="card-hd"><h6><i class="bi bi-cloud-arrow-up"></i> Buat Backup Baru</h6></div>
        <div class="card-bd">
          <form action="/admin/backup/create" method="POST" class="backup-form-grid">
            <div class="fg">
              <label class="fl">Tipe Backup</label>
              <select class="fs" name="type">
                <option value="all">Lengkap: Database + Settings</option>
                <option value="database">Database Saja</option>
                <option value="settings">Settings Saja</option>
              </select>
              <small class="backup-form-note">Pilih backup lengkap jika ingin cadangan operasional yang paling aman sebelum update atau restore.</small>
            </div>
            <button type="submit" class="btn btn-p w-100">
              <i class="bi bi-plus-circle"></i> Buat Backup Sekarang
            </button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-hd"><h6><i class="bi bi-laptop"></i> Restore Dari File Lokal</h6></div>
        <div class="card-bd">
          <form action="/admin/backup/upload-restore" method="POST" enctype="multipart/form-data" class="backup-form-grid">
            <div class="fg">
              <label class="fl">Jenis File Restore</label>
              <select class="fs" name="restoreType">
                <option value="database">Database (.db / .sqlite)</option>
                <option value="settings">Settings (.json)</option>
              </select>
            </div>
            <div class="fg">
              <label class="fl">Pilih File</label>
              <input type="file" class="fc" name="restoreFile" accept=".db,.sqlite,.sqlite3,.json" required>
              <small class="backup-form-note">File akan disimpan ke folder backup, lalu langsung diverifikasi dan direstore jika valid.</small>
            </div>
            <button type="submit" class="btn btn-s w-100">
              <i class="bi bi-arrow-repeat"></i> Upload & Restore
            </button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-hd"><h6><i class="bi bi-stars"></i> Cleanup Otomatis</h6></div>
        <div class="card-bd">
          <form action="/admin/backup/cleanup" method="POST" class="backup-form-grid">
            <div class="fg">
              <label class="fl">Retensi Backup (hari)</label>
              <input type="number" class="fc" name="retentionDays" value="30" min="1" max="365">
              <small class="backup-form-note">Backup yang lebih lama dari periode ini akan dihapus agar folder backup tidak menumpuk terlalu besar.</small>
            </div>
            <button type="submit" class="btn btn-w w-100">
              <i class="bi bi-trash3"></i> Bersihkan Backup Lama
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-hd">
        <h6><i class="bi bi-clock-history"></i> Riwayat Backup</h6>
      </div>
      <div class="card-bd">
        <% if (!backups.length) { %>
          <div class="backup-empty">
            <i class="bi bi-inbox"></i>
            <div class="mt8">Belum ada file backup di folder ini.</div>
          </div>
        <% } else { %>
          <div class="backup-list">
            <% backups.forEach((backup) => { %>
              <div class="backup-item">
                <div class="backup-item-top">
                  <div class="backup-file">
                    <div class="backup-file-name"><%= backup.fileName %></div>
                    <div class="backup-meta">
                      <span><i class="bi bi-hdd"></i> <%= backup.sizeKB %> KB</span>
                      <span>
                        <i class="bi bi-calendar3"></i>
                        <% if (backup.createdDate) { %>
                          <%= new Date(backup.createdDate).toLocaleString('id-ID', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                          }) %>
                        <% } else { %>
                          -
                        <% } %>
                      </span>
                    </div>
                  </div>
                  <span class="backup-type-badge <%= backup.type %>">
                    <i class="bi bi-<%= backup.type === 'database' ? 'database' : backup.type === 'settings' ? 'gear' : 'file-earmark-zip' %>"></i>
                    <%= backup.typeLabel %>
                  </span>
                </div>
                <div class="backup-item-actions">
                  <a href="/admin/backup/download/<%= encodeURIComponent(backup.fileName) %>" class="btn btn-g btn-sm">
                    <i class="bi bi-download"></i> Download
                  </a>
                  <% if (backup.restorable) { %>
                    <button type="button" class="btn btn-p btn-sm" onclick='restoreBackup(<%- JSON.stringify(backup.fileName) %>, <%- JSON.stringify(backup.type) %>)'>
                      <i class="bi bi-arrow-counterclockwise"></i> Restore
                    </button>
                  <% } else { %>
                    <button type="button" class="btn btn-g btn-sm" disabled>
                      <i class="bi bi-slash-circle"></i> Tidak Bisa Restore
                    </button>
                  <% } %>
                  <button type="button" class="btn btn-g btn-sm text-danger" onclick='deleteBackup(<%- JSON.stringify(backup.fileName) %>)'>
                    <i class="bi bi-trash"></i> Hapus
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  function restoreBackup(fileName, type) {
    if (!confirm('Yakin ingin restore file ini? Sistem akan membuat backup cadangan dulu sebelum data saat ini diganti.')) {
      return;
    }
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/backup/restore';
    const fileInput = document.createElement('input');
    fileInput.type = 'hidden';
    fileInput.name = 'fileName';
    fileInput.value = fileName;
    const typeInput = document.createElement('input');
    typeInput.type = 'hidden';
    typeInput.name = 'type';
    typeInput.value = type;
    form.appendChild(fileInput);
    form.appendChild(typeInput);
    document.body.appendChild(form);
    form.submit();
  }

  function deleteBackup(fileName) {
    if (!confirm('Yakin ingin menghapus file backup ini?')) {
      return;
    }
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/backup/delete';
    const fileInput = document.createElement('input');
    fileInput.type = 'hidden';
    fileInput.name = 'fileName';
    fileInput.value = fileName;
    form.appendChild(fileInput);
    document.body.appendChild(form);
    form.submit();
  }

  function toggleSidebar() {
    const sidebar = document.querySelector('.sidebar');
    if (sidebar) sidebar.classList.toggle('open');
  }
</script>
</body>
</html>
