<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('partials/theme_init') %>
  <title><%= t('admin.billing.title', 'Tagihan') %> | <%= company %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .filter-bar{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:10px 12px;margin-bottom:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .paid-row td{opacity:.7}
    .mobile-stack{display:none}
    .mobile-filter-toggle{display:none;position:relative}
    .desktop-search-block{display:grid;gap:5px;min-width:0}
    .desktop-filter-eyebrow{
      display:block;
      font-size:10px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .desktop-filter-hint{
      margin:0;
      font-size:11px;
      line-height:1.45;
      color:var(--muted);
    }
    .desktop-filter-field{
      display:grid;
      gap:6px;
      min-width:0;
    }
    .desktop-filter-field > span{
      font-size:11px;
      font-weight:800;
      letter-spacing:.05em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .mobile-filter-badge{
      position:absolute;
      top:-5px;
      right:-5px;
      min-width:18px;
      height:18px;
      padding:0 5px;
      border-radius:999px;
      background:#ef4444;
      color:#fff;
      font-size:10px;
      font-weight:800;
      display:none;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 18px rgba(239,68,68,.24)
    }
    .mobile-filter-badge.show{display:inline-flex}
    .billing-summary-grid{grid-template-columns:repeat(6,minmax(0,1fr)) !important;gap:8px;margin-bottom:12px}
    .billing-summary-grid .sc{min-height:auto;padding:10px 12px;border-radius:15px}
    .billing-summary-grid .sc-icon{top:10px;right:10px;width:30px;height:30px;border-radius:10px;font-size:14px}
    .billing-summary-grid .sc-label{font-size:10px;letter-spacing:.03em;margin-bottom:5px;padding-right:34px}
    .billing-summary-grid .sc-val{font-size:16px;line-height:1.05;letter-spacing:0}
    .billing-summary-grid .sc-sub{font-size:10px;margin-top:3px;line-height:1.25}
    .billing-period-summary{display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;margin-top:8px}
    .billing-period-copy{display:grid;gap:2px}
    .billing-period-copy strong{font-size:13px;color:var(--text)}
    .billing-period-copy span{font-size:11px;color:var(--muted)}
    .billing-filter-quick{display:flex;gap:6px;flex-wrap:wrap}
    .billing-filter-quick .btn{
      display:inline-flex;
      align-items:center;
      gap:6px;
      min-width:0;
    }
    .billing-filter-quick .btn i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:15px;
      height:15px;
      font-size:13px;
      line-height:1;
      flex:0 0 15px;
    }
    .billing-filter-quick .btn.is-active{background:var(--primary);border-color:var(--primary);color:#fff;box-shadow:0 10px 20px rgba(79,70,229,.22)}
    .billing-filter-form{display:flex;align-items:center;gap:8px;flex-wrap:nowrap;width:100%}
    .billing-search-row{display:flex;gap:8px;align-items:center;flex-wrap:nowrap;width:100%;min-width:0}
    .billing-search-row .sinput{flex:1 1 auto;min-width:0}
    .billing-filter-form .billing-search-row{flex:1 1 430px;max-width:520px}
    .billing-filter-panel{display:flex;gap:8px;align-items:center;justify-content:flex-end;flex:1 1 auto;min-width:0;max-width:none;box-sizing:border-box;flex-wrap:nowrap;overflow-x:auto;overflow-y:hidden;scrollbar-width:none}
    .billing-filter-panel::-webkit-scrollbar{display:none}
    .billing-filter-main-row{display:flex;gap:8px;align-items:center;flex-wrap:nowrap;justify-content:flex-end;flex:0 0 auto;min-width:0}
    .billing-filter-panel .mobile-filter-field{min-width:0}
    .billing-filter-panel .mobile-date-row{display:flex;gap:6px;align-items:center;flex-wrap:nowrap;flex:0 0 auto}
    .billing-filter-panel .mobile-filter-actions{display:flex;gap:6px;align-items:center;flex-wrap:nowrap;flex:0 0 auto}
    .billing-filter-panel .fs,
    .billing-filter-panel .fc,
    .billing-filter-panel .btn{white-space:nowrap}
    .billing-filter-panel .mobile-filter-actions .btn{
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .billing-filter-chip{display:inline-flex;align-items:center;gap:5px;padding:5px 8px;border-radius:999px;background:rgba(99,102,241,.12);color:var(--primary);font-size:10.5px;font-weight:700}
    .table-empty-state{
      display:grid;
      justify-items:center;
      gap:10px;
      padding:18px 12px;
      text-align:center;
    }
    .table-empty-state i{
      width:48px;
      height:48px;
      border-radius:16px;
      display:grid;
      place-items:center;
      font-size:22px;
      color:var(--primary);
      background:rgba(99,102,241,.12);
      box-shadow:inset 0 0 0 1px rgba(99,102,241,.12);
    }
    .table-empty-state strong{
      font-size:15px;
      line-height:1.3;
      color:var(--text);
    }
    .table-empty-state span{
      max-width:420px;
      font-size:12px;
      line-height:1.55;
      color:var(--muted);
    }
    .billing-table{
      position:relative;
      overflow:auto;
      scrollbar-gutter:stable;
    }
    .billing-table.is-loading::before{
      content:'';
      position:absolute;
      inset:0;
      background:rgba(7,12,24,.42);
      backdrop-filter:blur(3px);
      z-index:5;
    }
    .billing-table.is-loading::after{
      content:attr(data-loading-text);
      position:absolute;
      top:24px;
      right:24px;
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:12px 16px;
      border-radius:14px;
      background:rgba(15,23,42,.94);
      color:#fff;
      font-size:12px;
      font-weight:800;
      letter-spacing:.02em;
      box-shadow:0 16px 34px rgba(15,23,42,.24);
      z-index:6;
    }
    .billing-table.is-loading .dtbl{
      pointer-events:none;
    }
    @media(min-width:769px){
      .desktop-search-block{
        gap:0;
      }
      .desktop-search-block .desktop-filter-eyebrow,
      .desktop-search-block .desktop-filter-hint{
        display:none;
      }
      .billing-filter-form{
        display:flex;
        align-items:center;
        gap:8px;
        flex-wrap:nowrap;
      }
      .billing-search-row{
        display:flex;
        align-items:center;
        flex:0 0 220px;
        max-width:220px;
      }
      .billing-filter-form .billing-search-row{
        flex:0 0 220px;
        max-width:220px;
      }
      .billing-search-row .desktop-search-block,
      .billing-search-row .sinput{
        width:100%;
      }
      .billing-search-row .sinput{
        max-width:none !important;
      }
      .billing-search-row .sinput .fc{
        min-height:38px;
        height:38px;
        font-size:12px;
        padding-left:36px;
        padding-right:10px;
      }
      .billing-filter-panel{
        padding:0;
        border:0;
        border-radius:0;
        background:transparent;
        overflow:visible;
        display:flex;
        align-items:center;
        gap:6px;
        flex:1 1 auto;
        min-width:0;
      }
      .billing-filter-main-row,
      .billing-filter-panel .mobile-date-row{
        display:flex;
        align-items:center;
        gap:6px;
        flex-wrap:nowrap;
        width:auto;
      }
      .billing-filter-panel .mobile-filter-actions{
        display:flex;
        align-items:center;
        justify-content:flex-end;
        gap:6px;
        margin-left:auto;
        width:auto;
        flex:0 0 auto;
      }
      .billing-filter-panel .desktop-filter-field{
        gap:0;
      }
      .billing-filter-panel .desktop-filter-field > span{
        display:none;
      }
      .billing-filter-panel .desktop-filter-field .fs,
      .billing-filter-panel .desktop-filter-field .fc{
        width:auto !important;
        min-height:36px;
        height:36px;
        font-size:11.5px;
        padding-left:9px;
        padding-right:24px;
      }
      .billing-filter-panel select[name="status"]{min-width:106px}
      .billing-filter-panel select[name="month"]{min-width:82px}
      .billing-filter-panel select[name="year"]{min-width:68px}
      .billing-filter-panel input[name="billingDayStart"],
      .billing-filter-panel input[name="billingDayEnd"]{
        width:66px !important;
        padding-left:6px;
        padding-right:6px;
        text-align:center;
      }
      .billing-filter-panel .mobile-filter-actions .btn{
        min-height:36px;
        height:36px;
        padding:0 9px;
        font-size:11.5px;
        gap:5px;
      }
      .billing-period-summary{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:8px;
        flex-wrap:wrap;
      }
      .billing-filter-quick{
        display:flex;
        flex-wrap:nowrap;
        overflow:auto;
        scrollbar-width:none;
        gap:6px;
        width:auto;
        margin-top:8px;
        padding:4px;
        padding-bottom:5px;
        border:1px solid rgba(255,255,255,.05);
        border-radius:12px;
        background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.018));
        align-items:center;
      }
      .billing-filter-quick::-webkit-scrollbar{display:none}
      .billing-filter-quick .btn{
        min-height:30px;
        padding:4px 8px;
        border-radius:10px;
        justify-content:flex-start;
        font-weight:700;
        flex:0 0 auto;
        background:transparent;
        border-color:transparent;
        box-shadow:none;
      }
      .billing-filter-quick .btn i{
        width:13px;
        height:13px;
        font-size:11px;
        flex:0 0 13px;
      }
      .billing-filter-quick .btn:hover{
        background:rgba(255,255,255,.045);
        border-color:rgba(255,255,255,.05);
      }
      .billing-filter-quick .btn.is-active{
        border-color:rgba(99,102,241,.22);
        background:rgba(99,102,241,.16);
        color:#fff;
        box-shadow:none;
      }
      .billing-table .dtbl{
        table-layout:fixed;
        min-width:1095px;
      }
      .billing-table .dtbl thead th{
        padding:11px 12px;
        font-size:11px;
        font-weight:800;
        letter-spacing:.07em;
        text-transform:uppercase;
        color:var(--muted);
        position:sticky;
        top:0;
        z-index:2;
        background:color-mix(in srgb, var(--bg2) 92%, transparent);
        backdrop-filter:blur(10px);
        box-shadow:0 1px 0 rgba(255,255,255,.04);
      }
      .billing-table .dtbl thead th:nth-child(1){width:42px}
      .billing-table .dtbl thead th:nth-child(2){width:160px}
      .billing-table .dtbl thead th:nth-child(3){width:116px}
      .billing-table .dtbl thead th:nth-child(4){width:104px}
      .billing-table .dtbl thead th:nth-child(5){width:140px}
      .billing-table .dtbl thead th:nth-child(6){width:116px}
      .billing-table .dtbl thead th:nth-child(7){width:130px}
      .billing-table .dtbl thead th:nth-child(8){width:126px}
      .billing-table .dtbl thead th:nth-child(9){width:210px}
      .billing-table .dtbl tbody td{
        padding:10px 12px;
        vertical-align:top;
      }
      .billing-table .dtbl tbody tr{
        transition:background .18s ease, box-shadow .18s ease;
      }
      .billing-table .dtbl tbody tr:hover{
        background:linear-gradient(90deg, rgba(99,102,241,.06), rgba(99,102,241,.02));
        box-shadow:inset 4px 0 0 rgba(99,102,241,.55);
      }
      .billing-index{
        font-size:12px;
        font-weight:700;
      }
      .billing-group-row td{
        padding:14px 16px;
        background:rgba(255,255,255,.03);
        font-weight:800;
        color:var(--text);
      }
      .billing-group-row span{
        font-size:11px;
        color:var(--muted);
        font-weight:700;
        margin-left:8px;
      }
      .billing-customer-primary{
        font-size:13px;
        font-weight:800;
        line-height:1.28;
        color:var(--text);
        display:-webkit-box;
        -webkit-box-orient:vertical;
        -webkit-line-clamp:2;
        overflow:hidden;
      }
      .billing-customer-secondary,
      .billing-period-note,
      .billing-package-text,
      .billing-paidby-note,
      .billing-time-text{
        margin-top:4px;
        font-size:11px;
        line-height:1.32;
        color:var(--muted);
      }
      .billing-period-stack,
      .billing-status-stack,
      .billing-paidby-stack{
        display:grid;
        gap:5px;
      }
      .billing-package-text{
        margin-top:0;
        font-size:11.5px;
        line-height:1.28;
        display:-webkit-box;
        -webkit-box-orient:vertical;
        -webkit-line-clamp:2;
        overflow:hidden;
        word-break:break-word;
      }
      .billing-amount-stack{
        display:grid;
        gap:4px;
      }
      .billing-amount-main{
        font-size:14px;
        font-weight:800;
        color:var(--success);
        line-height:1.3;
      }
      .billing-online-note{
        font-size:11px;
        line-height:1.3;
        color:var(--muted);
      }
      .billing-action-cluster{
        display:grid;
        grid-template-columns:repeat(5,32px);
        gap:5px;
        align-items:flex-start;
        min-width:180px;
      }
      .billing-action-cluster form{
        display:inline-flex;
        margin:0;
      }
      .billing-action-cluster .btn{
        min-height:32px;
        min-width:32px;
        width:32px;
        padding:0;
        border-radius:10px;
      }
      .billing-action-cluster .btn-wa{
        background:#25d366;
        color:#fff;
      }
    }
    .billing-group{display:grid;gap:10px}
    .billing-group + .billing-group{margin-top:16px}
    .billing-group-label{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 14px;border-radius:16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06)}
    .billing-group-label strong{font-size:14px;color:var(--text)}
    .billing-group-label span{font-size:11px;color:var(--muted)}
    .invoice-card{background:var(--bg2);border:1px solid var(--border);border-radius:15px;padding:10px;display:grid;gap:7px}
    .invoice-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .invoice-head strong{display:block;font-size:13px;line-height:1.1}
    .invoice-sub{margin-top:2px;font-size:10px;color:var(--muted);line-height:1.28}
    .invoice-amount{font-size:20px;font-weight:800;letter-spacing:-0.04em;color:var(--success)}
    .invoice-side{display:grid;justify-items:end;gap:6px;min-width:110px}
    .invoice-side .invoice-amount{font-size:15px}
    .invoice-meta-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .invoice-meta{padding:7px 8px;border-radius:11px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05)}
    .invoice-meta small{display:block;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px}
    .invoice-meta span,.invoice-meta strong{display:block;font-size:10px;line-height:1.22}
    .invoice-actions{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:6px}
    .invoice-actions > *{min-width:0}
    .invoice-actions > a,
    .invoice-actions > button{width:100%}
    .invoice-actions > form{
      width:100%;
      margin:0;
      display:block !important;
      align-self:stretch;
    }
    .invoice-actions .btn,
    .invoice-actions form .btn{
      justify-content:center;
      padding:0;
      height:32px;
      min-height:32px;
      width:100%;
      display:flex;
    }
    .action-mini{display:inline-flex;align-items:center;justify-content:center;gap:6px}
    .action-mini i{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:14px;
      height:14px;
      font-size:12px;
      line-height:1;
      flex:0 0 14px;
    }
    .action-mini i.is-strong{
      font-size:14px;
      transform:scale(1.08);
      transform-origin:center;
    }
    .action-mini .action-label{display:none}
    .pay-quick-grid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:6px;
      margin-bottom:12px;
    }
    .pay-quick-grid .btn{
      min-height:42px;
      padding:6px 8px;
      justify-content:center;
      gap:5px;
      font-size:11px;
      border-radius:12px;
    }
    .pay-quick-grid .btn i{
      font-size:13px;
    }
    body[data-theme="light"] .filter-bar,
    body[data-theme="light"] .invoice-card{
      background:rgba(255,255,255,.9);
      box-shadow:0 14px 30px rgba(165,162,211,.12);
    }
    body[data-theme="light"] .billing-group-label{
      background:rgba(255,255,255,.92);
      box-shadow:0 10px 24px rgba(165,162,211,.10);
      border-color:rgba(148,163,184,.16);
    }
    body[data-theme="light"] .billing-filter-chip{
      background:rgba(105,88,255,.08);
    }
    @media(max-width:1200px){
      .billing-summary-grid{grid-template-columns:repeat(3,minmax(0,1fr)) !important}
    }
    body[data-theme="light"] .invoice-meta{
      background:rgba(105,88,255,.04);
      border-color:rgba(148,163,184,.18);
    }
    body[data-theme="light"] .invoice-head strong,
    body[data-theme="light"] .billing-group-label strong,
    body[data-theme="light"] .invoice-meta strong,
    body[data-theme="light"] .invoice-meta span,
    body[data-theme="light"] .invoice-amount{
      color:#24304a;
    }
    body[data-theme="light"] .invoice-sub{
      color:#6f7d98;
    }
    body[data-theme="light"] .billing-group-label span,
    body[data-theme="light"] .billing-period-copy span{
      color:#6f7d98;
    }
    @media(max-width:768px){
      .topbar{
        display:grid;
        grid-template-columns:minmax(0,1fr) auto;
        align-items:start;
        gap:8px;
      }
      .topbar .tb-title{min-width:0}
      .topbar .tb-right{
        justify-self:end;
        display:flex;
        align-items:center;
        gap:6px;
        flex-wrap:nowrap;
      }
      .topbar .tb-right .adm-badge{display:none}
      .topbar .tb-right .tb-theme-btn{min-width:42px;padding:0 10px}
      .topbar .tb-right .tb-theme-btn span{display:none}
      .topbar .tb-right > .btn.btn-g.btn-sm:last-child{min-width:42px;padding:0 10px}
      .topbar-generate-btn{min-width:42px;padding:0 10px}
      .filter-bar{padding:14px;gap:10px;border-radius:20px}
      .filter-bar .sinput{max-width:none !important;flex:1 1 100%}
      #billingSearchForm{display:block !important;width:100%}
      .billing-filter-form{display:block !important;width:100%}
      .mobile-filter-toggle{
        display:inline-flex;
        flex:0 0 52px;
        min-width:52px;
        height:52px;
        padding:0;
        justify-content:center;
        align-items:center;
        border-radius:16px;
      }
      .billing-search-row{
        display:grid;
        grid-template-columns:minmax(0,1fr) 52px;
        align-items:center;
        gap:10px;
        width:100%;
        margin-bottom:10px;
      }
      .billing-search-row .sinput{
        min-width:0;
        width:100%;
        max-width:none !important;
        height:52px;
        align-items:center;
      }
      .billing-filter-form .billing-search-row{max-width:none}
      .billing-search-row .mobile-filter-toggle{align-self:center}
      .billing-filter-panel{
        display:none;
        position:static !important;
        float:none !important;
        width:100%;
        min-width:0;
        gap:8px;
        margin-top:10px;
        padding:10px;
        border:1px solid var(--border);
        border-radius:16px;
        background:rgba(255,255,255,.03);
        overflow:visible;
      }
      .billing-filter-panel.show{display:grid !important;grid-template-columns:1fr}
      .billing-filter-main-row{
        display:grid;
        grid-template-columns:repeat(3,minmax(0,1fr));
        gap:8px;
        width:100%;
      }
      .billing-filter-panel .mobile-filter-field{width:100%}
      .billing-filter-panel .mobile-date-row{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:8px;
        margin-top:8px;
        width:100%;
      }
      .billing-filter-panel .mobile-filter-actions{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:8px;
        margin-top:8px;
        width:100%;
      }
      .billing-filter-panel .fs,
      .billing-filter-panel .fc,
      .billing-filter-panel .btn{width:100% !important;max-width:none !important}
      .billing-filter-panel .btn{justify-content:center}
      .billing-period-summary{align-items:flex-start}
      .billing-filter-quick{width:100%}
      .billing-filter-quick{
        display:flex;
        flex-wrap:nowrap;
        overflow-x:auto;
        overflow-y:hidden;
        gap:6px;
        padding-bottom:2px;
        scrollbar-width:none;
      }
      .billing-filter-quick::-webkit-scrollbar{display:none}
      .billing-filter-quick .btn{
        flex:0 0 auto;
        justify-content:center;
        min-height:38px;
        padding:6px 10px;
        font-size:10.5px;
        white-space:nowrap;
      }
      .tbl-wrap{display:none}
      .mobile-stack{display:grid;gap:8px;padding:0 0 12px}
      .invoice-actions{grid-template-columns:repeat(8,minmax(0,1fr));gap:4px}
      .invoice-actions .btn,.invoice-actions form .btn{height:40px;min-height:40px;border-radius:10px}
      .invoice-actions .action-mini{flex-direction:column;gap:1px;line-height:1}
      .invoice-actions .action-mini i{
        width:16px;
        height:16px;
        font-size:13px;
        flex-basis:16px;
      }
      .invoice-actions .action-mini i.is-strong{
        font-size:15px;
      }
      .invoice-actions .action-mini .action-label{display:block;font-size:7.5px;font-weight:700;letter-spacing:0}
      .pay-quick-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
      .pay-quick-grid .btn{font-size:10px}
    }
    @media(max-width:576px){
      .billing-filter-main-row{grid-template-columns:repeat(3,minmax(0,1fr))}
      .billing-summary-grid{grid-template-columns:repeat(3,minmax(0,1fr)) !important}
      .billing-summary-grid .sc{padding:10px 11px;border-radius:14px}
      .billing-summary-grid .sc:nth-child(3){order:-4}
      .billing-summary-grid .sc:nth-child(4){order:-3}
      .billing-summary-grid .sc:nth-child(5){order:-2}
      .billing-summary-grid .sc:nth-child(2){order:-1}
      .billing-summary-grid .sc:nth-child(6){order:1}
      .billing-summary-grid .sc:nth-child(1){order:2}
      .billing-summary-grid .sc-label{font-size:9.5px}
      .billing-summary-grid .sc-val{font-size:15px}
      .billing-summary-grid .sc-sub{font-size:10px}
      .billing-summary-grid .sc-icon{width:34px;height:34px;font-size:15px}
      .invoice-card{padding:9px;gap:6px}
      .invoice-head strong{font-size:12px}
      .invoice-sub{font-size:9px}
      .invoice-side{min-width:96px;gap:5px}
      .invoice-side .invoice-amount{font-size:14px}
      .invoice-meta-grid{grid-template-columns:repeat(4,minmax(0,1fr));gap:6px}
      .invoice-meta{padding:6px 6px}
      .invoice-meta small{font-size:8px;margin-bottom:2px}
      .invoice-meta span,.invoice-meta strong{font-size:9.5px}
      .invoice-actions{grid-template-columns:repeat(8,minmax(0,1fr));gap:4px}
      .invoice-actions .btn,.invoice-actions form .btn{height:40px;min-height:40px;border-radius:10px}
      .invoice-actions .action-mini{flex-direction:column;gap:1px;line-height:1}
      .invoice-actions .action-mini i{
        width:16px;
        height:16px;
        font-size:13px;
        flex-basis:16px;
      }
      .invoice-actions .action-mini i.is-strong{
        font-size:15px;
      }
      .invoice-actions .action-mini .action-label{display:block;font-size:7.5px;font-weight:700;letter-spacing:0}
      .topbar-generate-btn span{display:none}
      .topbar-generate-btn{padding:8px 10px}
    }
    @media(max-width:430px){
      .topbar .tb-title{
        font-size:0;
        display:flex;
        align-items:center;
        gap:8px;
      }
      .topbar .tb-title::after{
        content:"Manajemen Tagihan";
        font-size:14px;
        font-weight:800;
        color:var(--text);
        white-space:nowrap;
        overflow:hidden;
        text-overflow:ellipsis;
      }
      .billing-filter-panel{gap:6px;padding:8px}
      .billing-filter-main-row{grid-template-columns:repeat(3,minmax(0,1fr));gap:6px}
      .billing-filter-panel .mobile-date-row{
        grid-template-columns:1fr 1fr;
        gap:6px;
      }
      .billing-filter-quick{gap:5px}
      .billing-filter-quick .btn{font-size:9.5px;padding:6px 8px}
      .invoice-meta-grid{grid-template-columns:repeat(4,minmax(0,1fr));gap:5px}
      .invoice-meta{padding:5px 5px}
      .invoice-meta small{font-size:7.5px}
      .invoice-meta span,.invoice-meta strong{font-size:9px}
      .invoice-side{min-width:88px}
      .invoice-side .invoice-amount{font-size:13px}
      .invoice-actions{gap:3px}
      .invoice-actions .btn,.invoice-actions form .btn{height:38px;min-height:38px}
      .invoice-actions .action-mini i{
        width:15px;
        height:15px;
        font-size:12px;
        flex-basis:15px;
      }
      .invoice-actions .action-mini .action-label{font-size:7px}
      .billing-filter-panel .fs,
      .billing-filter-panel .fc{
        min-height:42px;
        font-size:11px;
        padding-left:10px;
        padding-right:28px;
      }
      .billing-filter-panel .mobile-filter-actions{
        grid-template-columns:1fr 1fr;
      }
    }
  </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'billing', company }) %>
<div class="mw">
  <div class="topbar">
    <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-receipt"></i> <%= t('admin.billing.manage_title', 'Manajemen Tagihan') %></div>
    <div class="tb-right">
      <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
      <button class="btn btn-p btn-sm topbar-generate-btn" onclick="openModal('genModal')"><i class="bi bi-lightning-charge"></i> <span><%= t('admin.billing.generate', 'Generate Tagihan') %></span></button>
      <% } %>
      <button type="button" class="btn btn-g btn-sm tb-theme-btn" data-theme-toggle aria-label="Ganti tema admin">
        <i class="bi bi-sun"></i>
        <span>Terang</span>
      </button>
      <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? t('admin.role.cashier', 'Kasir') : t('admin.role.admin', 'Admin') %></span>
      <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
    </div>
  </div>
<div class="page admin-shell-page">

    <% if (msg) { %>
    <div class="alert alert-<%= msg.type==='success'?'s':'d' %>">
      <i class="bi bi-<%= msg.type==='success'?'check-circle':'exclamation-circle' %>"></i> <%= msg.text %>
    </div>
    <% } %>

    <%
      const safeSummary = {
        total: { count: Number(summary?.total?.count || 0), total: Number(summary?.total?.total || 0) },
        paid: { count: Number(summary?.paid?.count || 0), total: Number(summary?.paid?.total || 0) },
        unpaid: { count: Number(summary?.unpaid?.count || 0), total: Number(summary?.unpaid?.total || 0) },
        isolated: { count: Number(summary?.isolated?.count || 0), total: Number(summary?.isolated?.total || 0) },
        overdue: { count: Number(summary?.overdue?.count || 0), total: Number(summary?.overdue?.total || 0) }
      };
      const collectedPct = safeSummary.total.count > 0
        ? Math.round((safeSummary.paid.count / safeSummary.total.count) * 100)
        : 0;
    %>

    <!-- Summary Cards -->
    <div class="stat-grid billing-summary-grid">
      <div class="sc p"><i class="bi bi-receipt sc-icon"></i><div class="sc-label"><%= t('admin.billing.summary.total', 'Total Tagihan') %></div><div class="sc-val"><%= safeSummary.total.count %></div><div class="sc-sub">Rp <%= safeSummary.total.total.toLocaleString('id-ID') %></div></div>
      <div class="sc s"><i class="bi bi-check-circle sc-icon"></i><div class="sc-label"><%= t('admin.billing.summary.paid', 'Sudah Bayar') %></div><div class="sc-val"><%= safeSummary.paid.count %></div><div class="sc-sub">Rp <%= safeSummary.paid.total.toLocaleString('id-ID') %></div></div>
      <div class="sc d"><i class="bi bi-hourglass sc-icon"></i><div class="sc-label"><%= t('admin.billing.summary.unpaid', 'Belum Bayar') %></div><div class="sc-val"><%= safeSummary.unpaid.count %></div><div class="sc-sub">Rp <%= safeSummary.unpaid.total.toLocaleString('id-ID') %></div></div>
      <div class="sc w"><i class="bi bi-exclamation-circle sc-icon"></i><div class="sc-label">Telat/Terlewat</div><div class="sc-val"><%= safeSummary.overdue.count %></div><div class="sc-sub">Rp <%= safeSummary.overdue.total.toLocaleString('id-ID') %></div></div>
      <div class="sc i"><i class="bi bi-wifi-off sc-icon"></i><div class="sc-label">Isolir</div><div class="sc-val"><%= safeSummary.isolated.count %></div><div class="sc-sub">Rp <%= safeSummary.isolated.total.toLocaleString('id-ID') %></div></div>
      <div class="sc p"><i class="bi bi-percent sc-icon"></i><div class="sc-label"><%= t('admin.billing.summary.collected_pct', '% Terkumpul') %></div><div class="sc-val"><%= collectedPct %>%</div></div>
    </div>

    <%
      const currentSearch = typeof search !== 'undefined' ? search : '';
      const currentFilterMonth = typeof filterMonth !== 'undefined' ? filterMonth : '';
      const currentFilterYear = typeof filterYear !== 'undefined' ? filterYear : new Date().getFullYear();
      const currentFilterStatus = typeof filterStatus !== 'undefined' ? filterStatus : 'all';
      const currentSort = typeof sort !== 'undefined' ? sort : 'smart';
      const currentPayChannel = typeof payChannel !== 'undefined' ? payChannel : 'all';
      const currentChipCounts = typeof chipCounts !== 'undefined' ? chipCounts : {};
      const currentBillingDayStart = typeof billingDayStart !== 'undefined' ? billingDayStart : '';
      const currentBillingDayEnd = typeof billingDayEnd !== 'undefined' ? billingDayEnd : '';
      const currentPageNumber = typeof currentPage !== 'undefined' ? currentPage : 1;
      const totalPageCount = typeof totalPages !== 'undefined' ? totalPages : 1;
      const totalInvoiceRows = typeof totalInvoicesCount !== 'undefined' ? totalInvoicesCount : invoices.length;
      const invoiceRowOffset = (currentPageNumber - 1) * (typeof pageSize !== 'undefined' ? pageSize : invoices.length || 25);
      const defaultMonthValue = typeof defaultMonth !== 'undefined' ? defaultMonth : (new Date().getMonth() + 1);
      const defaultYearValue = typeof defaultYear !== 'undefined' ? defaultYear : new Date().getFullYear();
      const overdueCount = typeof overdueCountBase !== 'undefined' ? overdueCountBase : 0;
      const isolatedCount = typeof isolatedCountBase !== 'undefined' ? isolatedCountBase : 0;
      const allMonthNames = (lang === 'en')
        ? ['January','February','March','April','May','June','July','August','September','October','November','December']
        : ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
      const currentPeriodLabel = currentFilterMonth
        ? `${allMonthNames[Number(currentFilterMonth) - 1]} ${currentFilterYear}`
        : `Semua bulan ${currentFilterYear}`;
      const currentStatusLabel = currentFilterStatus === 'paid'
        ? 'Lunas'
        : currentFilterStatus === 'unpaid'
          ? 'Belum Bayar'
          : currentFilterStatus === 'overdue'
            ? 'Telat Bayar'
            : currentFilterStatus === 'isolated'
              ? 'Terisolir'
          : 'Semua Status';
      const currentPayChannelLabel = currentPayChannel === 'cash'
        ? 'Cash'
        : currentPayChannel === 'online'
          ? 'Online'
          : currentPayChannel === 'staff'
            ? 'Petugas'
            : currentPayChannel === 'agent'
              ? 'Agent'
              : currentPayChannel === 'admin'
                ? 'Admin'
                : currentPayChannel === 'cashier'
                  ? 'Kasir'
                  : currentPayChannel === 'collector'
                    ? 'Kolektor'
                    : currentPayChannel === 'technician'
                      ? 'Teknisi'
                      : '';
      function buildBillingFilterHref(overrides = {}) {
        const params = new URLSearchParams();
        const merged = {
          search: currentSearch || '',
          month: currentFilterMonth || '',
          year: currentFilterYear || '',
          status: currentFilterStatus || 'all',
          sort: currentSort || 'smart',
          pay_channel: currentPayChannel || 'all',
          billingDayStart: currentBillingDayStart || '',
          billingDayEnd: currentBillingDayEnd || '',
          page: currentPageNumber || 1,
          ...overrides
        };
        Object.entries(merged).forEach(([key, value]) => {
          if (value !== '' && value != null) params.set(key, String(value));
        });
        const qs = params.toString();
        return `/admin/billing${qs ? '?' + qs : ''}`;
      }
      const invoiceMonthGroups = Array.isArray(invoiceGroups) ? invoiceGroups : [];
    %>

    <!-- Filter -->
    <div class="page-filter-card card admin-compact-card" style="margin-bottom:18px">
      <div class="card-bd">
        <form method="GET" action="/admin/billing" class="filter-bar billing-filter-form" style="margin-bottom:0;width:100%" id="billingSearchForm">
          <input type="hidden" name="sort" value="<%= currentSort %>">
          <input type="hidden" name="pay_channel" value="<%= currentPayChannel %>">
          <div class="billing-search-row">
            <div class="desktop-search-block">
              <span class="desktop-filter-eyebrow">Pencarian Tagihan</span>
              <div class="sinput" style="max-width:420px">
                <i class="bi bi-search"></i>
                <input class="fc" id="billingSearchInput" name="search" list="billingSearchSuggestions" autocomplete="off" placeholder="<%= t('admin.billing.search_placeholder', 'Cari nama / telepon...') %>" value="<%= currentSearch %>">
                <datalist id="billingSearchSuggestions"></datalist>
              </div>
            </div>
            <button class="btn btn-g btn-sm mobile-filter-toggle" type="button" onclick="toggleBillingFilterPanel()" aria-label="Filter tagihan">
              <i class="bi bi-funnel"></i>
              <span class="mobile-filter-badge" id="billingFilterBadge"></span>
            </button>
          </div>
          <div class="billing-filter-panel" id="billingFilterPanel">
            <div class="billing-filter-main-row">
              <label class="desktop-filter-field">
                <span>Status Invoice</span>
                <select class="fs mobile-filter-field" name="status" style="width:130px">
                  <option value="all" <%= currentFilterStatus==='all'?'selected':'' %>><%= t('admin.billing.all_status', 'Semua Status') %></option>
                  <option value="unpaid" <%= currentFilterStatus==='unpaid'?'selected':'' %>><%= t('admin.billing.unpaid', 'Belum Bayar') %></option>
                  <option value="paid" <%= currentFilterStatus==='paid'?'selected':'' %>><%= t('admin.billing.paid', 'Sudah Bayar') %></option>
                  <option value="overdue" <%= currentFilterStatus==='overdue'?'selected':'' %>>Telat Bayar</option>
                  <option value="isolated" <%= currentFilterStatus==='isolated'?'selected':'' %>>Terisolir</option>
                </select>
              </label>
              <label class="desktop-filter-field">
                <span>Bulan Periode</span>
                <select class="fs mobile-filter-field" name="month" style="width:130px">
                  <option value=""><%= t('admin.billing.all_months', 'Semua Bulan') %></option>
                  <% const monthNames = (lang === 'en')
                    ? ['January','February','March','April','May','June','July','August','September','October','November','December']
                    : ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
                     for(let m=1;m<=12;m++){%>
                  <option value="<%= m %>" <%= currentFilterMonth==m?'selected':'' %>><%= monthNames[m-1] %></option>
                  <% } %>
                </select>
              </label>
              <label class="desktop-filter-field">
                <span>Tahun Periode</span>
                <select class="fs mobile-filter-field" name="year" style="width:100px">
                  <% for(let y=new Date().getFullYear(); y>=2023; y--){ %>
                  <option value="<%= y %>" <%= currentFilterYear==y?'selected':'' %>><%= y %></option>
                  <% } %>
                </select>
              </label>
            </div>
            <div class="mobile-date-row">
              <label class="desktop-filter-field">
                <span>Tanggal Tagih Dari</span>
                <input class="fc mobile-advanced-filter" type="number" name="billingDayStart" min="1" max="31" placeholder="Tgl dari" value="<%= currentBillingDayStart %>" style="width:110px">
              </label>
              <label class="desktop-filter-field">
                <span>Tanggal Tagih Sampai</span>
                <input class="fc mobile-advanced-filter" type="number" name="billingDayEnd" min="1" max="31" placeholder="Tgl sampai" value="<%= currentBillingDayEnd %>" style="width:110px">
              </label>
            </div>
            <div class="mobile-filter-actions">
              <button class="btn btn-g btn-sm" type="submit"><i class="bi bi-check2"></i> <%= t('common.filter', 'Filter') %></button>
              <a href="/admin/billing?month=<%= defaultMonthValue %>&year=<%= defaultYearValue %>" class="btn btn-g btn-sm"><i class="bi bi-x"></i> <%= t('common.reset', 'Reset') %></a>
            </div>
          </div>
        </form>
        <div class="billing-period-summary">
          <div class="billing-period-copy">
            <strong><%= currentPeriodLabel %></strong>
            <span><%= totalInvoiceRows %> tagihan - <%= currentStatusLabel %><%= currentPayChannelLabel ? ` - ${currentPayChannelLabel}` : '' %></span>
          </div>
          <div class="billing-filter-chip"><i class="bi bi-calendar3"></i> Tahun <%= currentFilterYear %></div>
          <div class="billing-filter-quick">
            <a href="<%= buildBillingFilterHref({ status: 'unpaid', sort: 'smart', pay_channel: 'all', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'unpaid' && currentSort !== 'due_today' ? 'is-active' : '' %>"><i class="bi bi-hourglass"></i> Belum Bayar <%= currentChipCounts.unpaid ? `(${currentChipCounts.unpaid})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'unpaid', sort: 'due_today', pay_channel: 'all', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'unpaid' && currentSort === 'due_today' ? 'is-active' : '' %>"><i class="bi bi-calendar-check"></i> Hari Ini <%= currentChipCounts.dueToday ? `(${currentChipCounts.dueToday})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'overdue', sort: 'due_latest', pay_channel: 'all', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'overdue' ? 'is-active' : '' %>"><i class="bi bi-exclamation-circle"></i> Telat <%= overdueCount > 0 ? `(${overdueCount})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'isolated', sort: 'smart', pay_channel: 'all', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'isolated' ? 'is-active' : '' %>"><i class="bi bi-wifi-off"></i> Isolir <%= isolatedCount > 0 ? `(${isolatedCount})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'paid', sort: 'paid_latest', pay_channel: 'all', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'paid' && currentPayChannel === 'all' ? 'is-active' : '' %>"><i class="bi bi-check-circle"></i> Lunas <%= currentChipCounts.paid ? `(${currentChipCounts.paid})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'paid', sort: 'paid_latest', pay_channel: 'cash', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'paid' && currentPayChannel === 'cash' ? 'is-active' : '' %>"><i class="bi bi-cash-stack"></i> Cash <%= currentChipCounts.cash ? `(${currentChipCounts.cash})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'paid', sort: 'paid_latest', pay_channel: 'online', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'paid' && currentPayChannel === 'online' ? 'is-active' : '' %>"><i class="bi bi-credit-card-2-front"></i> Online <%= currentChipCounts.online ? `(${currentChipCounts.online})` : '' %></a>
            <a href="<%= buildBillingFilterHref({ status: 'paid', sort: 'paid_latest', pay_channel: 'staff', page: 1 }) %>" class="btn btn-g btn-sm <%= currentFilterStatus === 'paid' && currentPayChannel === 'staff' ? 'is-active' : '' %>"><i class="bi bi-person-check"></i> Petugas <%= currentChipCounts.staff ? `(${currentChipCounts.staff})` : '' %></a>
          </div>
        </div>
      </div>
    </div>

    <!-- Table -->
    <div class="card">
      <div class="card-hd">
        <h6><i class="bi bi-list-ul"></i> <%= t('admin.billing.list', 'Daftar Tagihan') %> (<%= totalInvoiceRows %>)</h6>
      </div>
      <div class="tbl-wrap billing-table">
        <table class="dtbl">
          <thead>
            <tr>
              <th>#</th>
              <th><%= t('admin.billing.table.customer', 'Pelanggan') %></th>
              <th><%= t('admin.billing.table.period', 'Periode') %></th>
              <th><%= t('admin.billing.table.package', 'Paket') %></th>
              <th class="num"><%= t('admin.billing.table.amount', 'Jumlah') %></th>
              <th><%= t('admin.billing.table.status', 'Status') %></th>
              <th><%= t('admin.billing.table.paid_by', 'Dibayar Oleh') %></th>
              <th><%= t('admin.billing.table.paid_time', 'Waktu Bayar') %></th>
              <th><%= t('admin.billing.table.actions', 'Aksi') %></th>
            </tr>
          </thead>
          <tbody>
          <% if (invoices.length===0) { %>
            <tr>
              <td colspan="9" class="text-center text-muted" style="padding:32px">
                <div class="table-empty-state">
                  <i class="bi bi-receipt"></i>
                  <strong><%= t('admin.billing.empty', 'Tidak ada tagihan. Generate tagihan bulanan terlebih dahulu.') %></strong>
                </div>
              </td>
            </tr>
          <% } %>
          <% let invoiceIndexCounter = invoiceRowOffset; %>
          <% invoiceMonthGroups.forEach((group)=>{ %>
            <% const desktopMonthName = allMonthNames[Math.max(0, Number(group.month || 1) - 1)] || '-'; %>
            <% if (!currentFilterMonth) { %>
              <tr class="billing-group-row">
                <td colspan="9">
                  <%= desktopMonthName %> <%= group.year %>
                  <span><%= group.invoices.length %> tagihan</span>
                </td>
              </tr>
            <% } %>
            <% group.invoices.forEach((inv)=>{ invoiceIndexCounter++; %>
            <%
              const invConnectionType = String(inv.connection_type || 'pppoe');
              const invServiceInfo = invConnectionType === 'hotspot_binding'
                ? [inv.hotspot_username, inv.mac_address, inv.static_ip].filter(Boolean).join(' - ')
                : invConnectionType === 'static'
                  ? [inv.static_ip, inv.mac_address].filter(Boolean).join(' - ')
                  : invConnectionType === 'billing_only'
                    ? [inv.customer_phone, 'Billing saja'].filter(Boolean).join(' - ')
                  : [inv.customer_phone, inv.pppoe_username, inv.genieacs_tag].filter(Boolean).join(' - ');
            %>
            <tr class="<%= inv.status==='paid'?'paid-row':'' %>">
              <td class="text-muted billing-index"><%= invoiceIndexCounter %></td>
              <td>
                <div class="billing-customer-primary"><%= inv.customer_name %></div>
                <div class="billing-customer-secondary"><%= invServiceInfo || inv.customer_phone || '' %></div>
              </td>
              <td>
                <% const mns = (lang === 'en')
                  ? ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
                  : ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des']; %>
                <div class="billing-period-stack">
                  <span class="badge bm"><%= mns[inv.period_month-1] %> <%= inv.period_year %></span>
                  <div class="billing-period-note">Tgl <%= inv.due_day_snapshot || 10 %></div>
                </div>
              </td>
              <td><div class="billing-package-text"><%= inv.package_name||'-' %></div></td>
              <td class="num">
                <div class="billing-amount-stack">
                <div class="billing-amount-main">Rp <%= inv.amount.toLocaleString('id-ID') %></div>
                <% if (inv.status === 'unpaid' && inv.qris_amount_unique) { %>
                  <div class="billing-online-note">
                    Online: <span class="mono">Rp <%= Number(inv.qris_amount_unique).toLocaleString('id-ID') %></span>
                    <% if (inv.qris_unique_code) { %>
                      <span class="badge bm" style="margin-left:6px">Kode <%= String(inv.qris_unique_code).padStart(3, "0") %></span>
                    <% } %>
                  </div>
                <% } %>
                </div>
              </td>
              <td>
                <div class="billing-status-stack">
                <% if(inv.status==='paid'){%><span class="badge bs"><i class="bi bi-check-circle-fill" style="font-size:9px"></i> <%= t('admin.billing.status.paid', 'Lunas') %></span>
                <%}else if(inv.status==='void'){%><span class="badge bm"><i class="bi bi-slash-circle" style="font-size:9px"></i> Hangus Prabayar</span>
                <%}else if (String(inv.customer_status || '').toLowerCase() === 'suspended') { %><span class="badge bw"><i class="bi bi-wifi-off" style="font-size:9px"></i> Isolir</span>
                <%}else{%><span class="badge bd"><i class="bi bi-clock-fill" style="font-size:9px"></i> <%= t('admin.billing.status.unpaid', 'Belum Bayar') %></span><%}%>
                </div>
              </td>
              <td>
                <div class="billing-paidby-stack">
                <div class="billing-customer-primary" style="font-size:13px;font-weight:700"><%= inv.paid_by_name||'-' %></div>
                <% if (inv.status === 'paid' && inv.payment_channel_label) { %>
                  <div class="billing-paidby-note"><%= inv.payment_channel_label %></div>
                <% } %>
                <% if (inv.notes) { %>
                  <div class="billing-paidby-note"><%= inv.notes %></div>
                <% } %>
                </div>
              </td>
              <td><div class="billing-time-text"><%= inv.paid_at ? new Date(inv.paid_at).toLocaleString('id-ID',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></div></td>
              <td>
                <div class="billing-action-cluster">
                <% if(inv.status==='unpaid'){%>
                  <button class="btn btn-s btn-icon btn-sm pay-btn" title="<%= t('admin.billing.actions.mark_paid', 'Tandai Lunas') %>"
                    data-id="<%= inv.id %>"
                    data-customer-id="<%= inv.customer_id %>"
                    data-name="<%= inv.customer_name.replace(/'/g, '&#39;') %>"
                    data-period="<%= mns[inv.period_month-1] %> <%= inv.period_year %>">
                    <i class="bi bi-check-lg"></i>
                  </button>
                  <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                  <form method="POST" action="/admin/billing/<%= inv.id %>/qris-assign" style="display:inline" title="Buat nominal Bayar Online otomatis" onsubmit="return true">
                    <button class="btn btn-g btn-icon btn-sm" aria-label="Siapkan Bayar Online"><i class="bi bi-credit-card-2-front"></i></button>
                  </form>
                  <% if (inv.qris_amount_unique) { %>
                    <form method="POST" action="/admin/billing/<%= inv.id %>/qris-assign?force=1" style="display:inline" title="Regenerate kode Bayar Online" onsubmit="return confirm('Ganti kode pembayaran online untuk tagihan ini?')">
                      <button class="btn btn-w btn-icon btn-sm"><i class="bi bi-arrow-repeat"></i></button>
                    </form>
                    <form method="POST" action="/admin/billing/<%= inv.id %>/qris-clear" style="display:inline" title="Hapus kode Bayar Online" onsubmit="return confirm('Hapus kode pembayaran online dari tagihan ini?')">
                      <button class="btn btn-d btn-icon btn-sm"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } %>
                  <% } %>
                  <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                  <form method="POST" action="/admin/customers/<%= inv.customer_id %>/unisolate" style="display:inline" class="needs-confirm" data-confirm-key="confirmUnisolate">
                    <button class="btn btn-p btn-icon btn-sm" title="<%= t('admin.billing.actions.unisolate', 'Buka Isolir') %>"><i class="bi bi-wifi"></i></button>
                  </form>
                  <% } %>
                  <form method="POST" action="/admin/billing/<%= inv.id %>/whatsapp" style="display:inline" data-wa-submit data-wa-waiting="Sedang mengirim tagihan WhatsApp. Mohon tunggu beberapa saat...">
                    <button class="btn btn-icon btn-sm btn-wa" title="<%= t('admin.billing.actions.send_wa', 'Kirim Tagihan WA') %>" data-submit-label="WA"><i class="bi bi-whatsapp"></i></button>
                  </form>
                  <form method="POST" action="/admin/billing/<%= inv.id %>/push" style="display:inline" title="Kirim notifikasi tagihan ke aplikasi pelanggan" onsubmit="return confirm('Kirim notifikasi tagihan ke aplikasi pelanggan?')">
                    <button class="btn btn-p btn-icon btn-sm" title="Kirim Push Tagihan"><i class="bi bi-bell-fill"></i></button>
                  </form>
                  <a href="/admin/billing/<%= inv.id %>/print?style=a4" target="_blank" class="btn btn-s btn-icon btn-sm" title="Cetak Invoice A4"><i class="bi bi-printer"></i></a>
                <%}else{%>
                  <a href="/admin/billing/<%= inv.id %>/print?style=a4" target="_blank" class="btn btn-s btn-icon btn-sm" title="Cetak Invoice A4"><i class="bi bi-printer"></i></a>
                  <a href="/admin/billing/<%= inv.id %>/print?style=receipt" target="_blank" class="btn btn-g btn-icon btn-sm" title="Cetak Struk Kecil"><i class="bi bi-receipt-cutoff"></i></a>
                  <% const canCancelManualPaid = inv.status === 'paid' && Boolean(inv.can_cancel_paid); %>
                  <% if (canCancelManualPaid && !(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                  <form method="POST" action="/admin/billing/<%= inv.id %>/unpay" style="display:inline" class="needs-confirm" data-confirm-key="confirmUnpay" data-require-admin-password="1">
                    <button class="btn btn-w btn-icon btn-sm" title="<%= t('admin.billing.actions.unpay', 'Batalkan Lunas') %>"><i class="bi bi-arrow-counterclockwise"></i></button>
                  </form>
                  <% } %>
                <%}%>
                  <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                  <form method="POST" action="/admin/customers/<%= inv.customer_id %>/isolate" style="display:inline" class="needs-confirm" data-confirm-key="confirmIsolateManual">
                    <button class="btn btn-w btn-icon btn-sm" title="<%= t('admin.billing.actions.isolate_manual', 'Isolir Manual') %>"><i class="bi bi-wifi-off"></i></button>
                  </form>
                  <form method="POST" action="/admin/billing/<%= inv.id %>/delete" style="display:inline" class="needs-confirm" data-confirm-key="confirmDelete">
                    <button class="btn btn-d btn-icon btn-sm" title="<%= t('common.delete', 'Hapus') %>"><i class="bi bi-trash"></i></button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          <% }) %>
          </tbody>
        </table>
      </div>
      <div class="mobile-stack">
        <% if (invoices.length===0) { %>
          <div class="text-center text-muted" style="padding:18px 6px"><%= t('admin.billing.empty', 'Tidak ada tagihan. Generate tagihan bulanan terlebih dahulu.') %></div>
        <% } %>
        <% invoiceMonthGroups.forEach((group)=>{ %>
          <% const mobileMonthName = allMonthNames[Math.max(0, Number(group.month || 1) - 1)] || '-'; %>
          <div class="billing-group">
            <% if (!currentFilterMonth) { %>
              <div class="billing-group-label">
                <strong><%= mobileMonthName %> <%= group.year %></strong>
                <span><%= group.invoices.length %> tagihan</span>
              </div>
            <% } %>
            <% group.invoices.forEach((inv)=>{ %>
          <% const mns = (lang === 'en') ? ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'] : ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des']; %>
          <% const mobileInvConnectionType = String(inv.connection_type || 'pppoe');
             const mobileInvServiceInfo = mobileInvConnectionType === 'hotspot_binding'
               ? [inv.hotspot_username, inv.mac_address, inv.static_ip].filter(Boolean).join(' - ')
               : mobileInvConnectionType === 'static'
                 ? [inv.static_ip, inv.mac_address].filter(Boolean).join(' - ')
                 : mobileInvConnectionType === 'billing_only'
                   ? [inv.customer_phone, 'Billing saja'].filter(Boolean).join(' - ')
                 : [inv.customer_phone, inv.pppoe_username, inv.genieacs_tag].filter(Boolean).join(' - '); %>
          <div class="invoice-card">
            <div class="invoice-head">
              <div>
                <strong><%= inv.customer_name %></strong>
                <div class="invoice-sub"><%= mobileInvServiceInfo || inv.customer_phone || '' %> &bull; <%= mns[inv.period_month-1] %> <%= inv.period_year %> &bull; Tgl <%= inv.due_day_snapshot || 10 %></div>
              </div>
              <div class="invoice-side">
                <% if(inv.status==='paid'){%><span class="badge bs"><i class="bi bi-check-circle-fill" style="font-size:9px"></i> Lunas</span>
                <%}else if(inv.status==='void'){%><span class="badge bm"><i class="bi bi-slash-circle" style="font-size:9px"></i> Hangus Prabayar</span>
                <%}else if (String(inv.customer_status || '').toLowerCase() === 'suspended') { %><span class="badge bw"><i class="bi bi-wifi-off" style="font-size:9px"></i> Isolir</span>
                <%}else{%><span class="badge bd"><i class="bi bi-clock-fill" style="font-size:9px"></i> Belum Bayar</span><%}%>
                <div class="invoice-amount">Rp <%= inv.amount.toLocaleString('id-ID') %></div>
              </div>
            </div>

            <div class="invoice-meta-grid">
              <% if(inv.status==='paid'){ %>
                <div class="invoice-meta">
                  <small>Bayar</small>
                  <span><%= inv.paid_at ? new Date(inv.paid_at).toLocaleString('id-ID',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) : '-' %></span>
                </div>
                <div class="invoice-meta">
                  <small>Oleh</small>
                  <span><%= inv.paid_by_name||'-' %></span>
                </div>
                <div class="invoice-meta">
                  <small>Kanal</small>
                  <span><%= inv.payment_channel_label || '-' %></span>
                </div>
                <div class="invoice-meta">
                  <small>Paket</small>
                  <span><%= inv.package_name||'-' %></span>
                </div>
              <% } else { %>
                <div class="invoice-meta">
                  <small>Jatuh Tempo</small>
                  <strong>Tgl <%= inv.due_day_snapshot || 10 %></strong>
                </div>
                <div class="invoice-meta">
                  <small>Paket</small>
                  <span><%= inv.package_name||'-' %></span>
                </div>
                <div class="invoice-meta">
                  <small>Periode</small>
                  <span><%= mns[inv.period_month-1] %> <%= inv.period_year %></span>
                </div>
                <% if (inv.qris_amount_unique) { %>
                  <div class="invoice-meta">
                    <small>Online</small>
                    <strong>Rp <%= Number(inv.qris_amount_unique).toLocaleString('id-ID') %></strong>
                  </div>
                <% } else { %>
                  <div class="invoice-meta">
                    <small>Status</small>
                    <span><%= String(inv.customer_status || '').toLowerCase() === 'suspended' ? 'Isolir' : 'Belum Bayar' %></span>
                  </div>
                <% } %>
              <% } %>
            </div>

            <div class="invoice-actions">
              <% if(inv.status==='unpaid'){%>
                <button class="btn btn-s btn-sm pay-btn" type="button"
                  data-id="<%= inv.id %>"
                  data-customer-id="<%= inv.customer_id %>"
                  data-name="<%= inv.customer_name.replace(/'/g, '&#39;') %>"
                  data-period="<%= mns[inv.period_month-1] %> <%= inv.period_year %>">
                  <span class="action-mini"><i class="bi bi-check-circle"></i><span class="action-label">Lunas</span></span>
                </button>
                <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                <form method="POST" action="/admin/billing/<%= inv.id %>/qris-assign">
                  <button class="btn btn-g btn-sm" type="submit">
                    <span class="action-mini"><i class="bi bi-credit-card-2-front is-strong"></i><span class="action-label">Online</span></span>
                  </button>
                </form>
                <form method="POST" action="/admin/customers/<%= inv.customer_id %>/unisolate" class="needs-confirm" data-confirm-key="confirmUnisolate">
                  <button class="btn btn-p btn-sm" type="submit">
                    <span class="action-mini"><i class="bi bi-unlock-fill is-strong"></i><span class="action-label">Buka</span></span>
                  </button>
                </form>
                <% } %>
                <form method="POST" action="/admin/billing/<%= inv.id %>/whatsapp" data-wa-submit data-wa-waiting="Sedang mengirim tagihan WhatsApp. Mohon tunggu beberapa saat...">
                  <button class="btn btn-sm" type="submit" style="background:#25d366;color:white;width:100%" data-submit-label="WA">
                    <span class="action-mini"><i class="bi bi-whatsapp"></i><span class="action-label">WA</span></span>
                  </button>
                </form>
                <form method="POST" action="/admin/billing/<%= inv.id %>/push" onsubmit="return confirm('Kirim notifikasi tagihan ke aplikasi pelanggan?')">
                  <button class="btn btn-p btn-sm" type="submit" style="width:100%">
                    <span class="action-mini"><i class="bi bi-bell-fill"></i><span class="action-label">Push</span></span>
                  </button>
                </form>
                <a href="/admin/billing/<%= inv.id %>/print?style=a4" target="_blank" class="btn btn-s btn-sm">
                  <span class="action-mini"><i class="bi bi-printer"></i><span class="action-label">Cetak</span></span>
                </a>
              <%}else{%>
                <a href="/admin/billing/<%= inv.id %>/print?style=a4" target="_blank" class="btn btn-s btn-sm">
                  <span class="action-mini"><i class="bi bi-printer"></i><span class="action-label">Cetak</span></span>
                </a>
                <a href="/admin/billing/<%= inv.id %>/print?style=receipt" target="_blank" class="btn btn-g btn-sm">
                  <span class="action-mini"><i class="bi bi-receipt-cutoff"></i><span class="action-label">Struk</span></span>
                </a>
                <% const canCancelManualPaidMobile = inv.status === 'paid' && Boolean(inv.can_cancel_paid); %>
                <% if (canCancelManualPaidMobile && !(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
                <form method="POST" action="/admin/billing/<%= inv.id %>/unpay" class="needs-confirm" data-confirm-key="confirmUnpay" data-require-admin-password="1">
                  <button class="btn btn-w btn-sm" type="submit">
                    <span class="action-mini"><i class="bi bi-arrow-counterclockwise"></i><span class="action-label">Batal</span></span>
                  </button>
                </form>
                <% } %>
              <%}%>
              <% if (!(typeof session !== 'undefined' && session.isCashier && !session.isAdmin)) { %>
              <form method="POST" action="/admin/customers/<%= inv.customer_id %>/isolate" class="needs-confirm" data-confirm-key="confirmIsolateManual">
                <button class="btn btn-w btn-sm" type="submit" style="width:100%">
                  <span class="action-mini"><i class="bi bi-ban"></i><span class="action-label">Isolir</span></span>
                </button>
              </form>
              <form method="POST" action="/admin/billing/<%= inv.id %>/delete" class="needs-confirm" data-confirm-key="confirmDelete">
                <button class="btn btn-d btn-sm" type="submit" style="width:100%">
                  <span class="action-mini"><i class="bi bi-trash"></i><span class="action-label">Hapus</span></span>
                </button>
              </form>
              <% } %>
            </div>
          </div>
            <% }) %>
          </div>
        <% }) %>
      </div>
      <% if (totalPageCount > 1) { %>
      <div class="card-bd" style="border-top:1px solid var(--border);display:flex;justify-content:center;gap:8px;flex-wrap:wrap">
        <a href="<%= buildBillingFilterHref({ page: Math.max(1, currentPageNumber - 1) }) %>" class="btn btn-g btn-sm <%= currentPageNumber <= 1 ? 'disabled' : '' %>"><i class="bi bi-chevron-left"></i></a>
        <% for (let p = 1; p <= totalPageCount; p++) { %>
          <a href="<%= buildBillingFilterHref({ page: p }) %>" class="btn btn-sm <%= p === currentPageNumber ? 'btn-p' : 'btn-g' %>"><%= p %></a>
        <% } %>
        <a href="<%= buildBillingFilterHref({ page: Math.min(totalPageCount, currentPageNumber + 1) }) %>" class="btn btn-g btn-sm <%= currentPageNumber >= totalPageCount ? 'disabled' : '' %>"><i class="bi bi-chevron-right"></i></a>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal Generate -->
