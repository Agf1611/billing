  <div class="mb">
    <div class="mh"><span class="mt"><i class="bi bi-cash-coin"></i> <%= t('admin.billing.actions.mark_paid', 'Tandai Lunas') %></span><button class="mc" onclick="closeModal('payModal')">&times;</button></div>
    <form method="POST" id="payForm">
      <div class="mbody">
        <p class="text-muted" id="payDesc" style="margin-bottom:14px;font-size:13px"></p>
        
        <div id="multiPaySection" style="display:none; margin-bottom: 20px; background: rgba(255,255,255,0.03); padding: 12px; border-radius: 8px; border: 1px solid var(--border);">
          <label class="fl" style="margin-bottom:8px"><%= t('admin.billing.choose_invoice', 'Pilih Tagihan yang akan dilunasi:') %></label>
          <div id="unpaidList" style="display:flex; flex-direction:column; gap:8px">
            <!-- Dynamic list of checkboxes -->
          </div>
        </div>

        <% const payByDefault = (typeof session !== 'undefined' && session.isCashier)
          ? (`Admin ${(session.cashierName || session.cashierUsername || '').trim()}`).trim()
          : 'Admin'; %>
        <div class="alert alert-i" style="margin-bottom:12px">
          <i class="bi bi-info-circle"></i>
          Utamakan payment gateway / Bayar Online agar pelanggan terbaca lunas otomatis. Gunakan opsi manual hanya jika pembayaran diterima di luar sistem.
        </div>
        <div class="pay-quick-grid" aria-label="Pilihan cepat penerima pembayaran">
          <button type="button" class="btn btn-p" data-pay-by="Online / Payment Gateway" data-pay-note="Pembayaran online otomatis"><i class="bi bi-credit-card-2-front"></i> Lunas Online</button>
          <button type="button" class="btn btn-g" data-pay-by="Transfer BRI" data-pay-note="Transfer manual BRI"><i class="bi bi-bank2"></i> Lunas BRI</button>
          <button type="button" class="btn btn-g" data-pay-by="Transfer Manual" data-pay-note="Transfer manual"><i class="bi bi-arrow-left-right"></i> Lunas Transfer</button>
          <button type="button" class="btn btn-g" data-pay-by="Tunai / Cash" data-pay-note="Pembayaran tunai"><i class="bi bi-cash-stack"></i> Lunas Cash</button>
          <button type="button" class="btn btn-g" data-pay-by="Admin Cash" data-pay-note="Tunai admin"><i class="bi bi-person-badge"></i> Admin</button>
          <button type="button" class="btn btn-g" data-pay-by="Kasir" data-pay-note="Tunai kasir"><i class="bi bi-person-vcard"></i> Kasir</button>
          <button type="button" class="btn btn-g" data-pay-by="Kolektor" data-pay-note="Tunai kolektor"><i class="bi bi-person-lines-fill"></i> Kolektor</button>
          <button type="button" class="btn btn-g" data-pay-by="Teknisi" data-pay-note="Tunai teknisi"><i class="bi bi-tools"></i> Teknisi</button>
        </div>
        <div class="fg"><label class="fl"><%= t('admin.billing.received_by', 'Diterima Oleh') %></label><input class="fc" id="payByNameInput" name="paid_by_name" placeholder="<%= t('admin.billing.received_by_placeholder', 'Nama petugas / teknisi') %>" value="<%= payByDefault || 'Admin' %>"></div>
        <div class="fg"><label class="fl"><%= t('admin.billing.notes_optional', 'Catatan (opsional)') %></label><textarea class="fc" id="payNotesInput" name="notes" placeholder="<%= t('admin.billing.notes_placeholder', 'Transfer BRI, tunai, dll...') %>"></textarea></div>
      </div>
      <div class="mf">
        <button type="button" class="btn btn-g" onclick="closeModal('payModal')"><%= t('common.cancel', 'Batal') %></button>
        <button type="submit" class="btn btn-s"><i class="bi bi-check-lg"></i> <%= t('admin.billing.confirm_paid', 'Konfirmasi Lunas') %></button>
      </div>
    </form>
  </div>
</div>

<script>
function openModal(id){document.getElementById(id).classList.add('show')}
function closeModal(id){document.getElementById(id).classList.remove('show')}
function syncBillingMobileFilterLayout() {
  const form = document.getElementById('billingSearchForm');
  const searchRow = form?.querySelector('.billing-search-row');
  const panel = document.getElementById('billingFilterPanel');
  const dateRow = panel?.querySelector('.mobile-date-row');
  const actionRow = panel?.querySelector('.mobile-filter-actions');
  if (!form || !searchRow || !panel) return;
  const isMobile = window.innerWidth <= 768;
  searchRow.removeAttribute('style');
  panel.removeAttribute('style');
  dateRow?.removeAttribute('style');
  actionRow?.removeAttribute('style');
  if (!isMobile) panel.classList.remove('show');
}
function toggleBillingFilterPanel(force) {
  const panel = document.getElementById('billingFilterPanel');
  if (!panel) return;
  syncBillingMobileFilterLayout();
  if (window.innerWidth > 768) return;
  if (typeof force === 'boolean') {
    panel.classList.toggle('show', force);
    return;
  }
  panel.classList.toggle('show');
}

function getActiveBillingFilterCount() {
  const monthValue = String(document.querySelector('#billingSearchForm [name="month"]')?.value || '').trim();
  const yearValue = String(document.querySelector('#billingSearchForm [name="year"]')?.value || '').trim();
  const statusValue = String(document.querySelector('#billingSearchForm [name="status"]')?.value || '').trim();
  const sortValue = String(document.querySelector('#billingSearchForm [name="sort"]')?.value || '').trim();
  const payChannelValue = String(document.querySelector('#billingSearchForm [name="pay_channel"]')?.value || '').trim();
  const billingDayStartValue = String(document.querySelector('#billingSearchForm [name="billingDayStart"]')?.value || '').trim();
  const billingDayEndValue = String(document.querySelector('#billingSearchForm [name="billingDayEnd"]')?.value || '').trim();
  let count = 0;
  if (statusValue && statusValue !== 'all') count += 1;
  if (sortValue && sortValue !== 'smart') count += 1;
  if (payChannelValue && payChannelValue !== 'all') count += 1;
  if (monthValue && Number(monthValue) !== Number('<%= defaultMonthValue %>')) count += 1;
  if (yearValue && Number(yearValue) !== Number('<%= defaultYearValue %>')) count += 1;
  if (billingDayStartValue) count += 1;
  if (billingDayEndValue) count += 1;
  return count;
}

function syncBillingFilterBadge() {
  const badge = document.getElementById('billingFilterBadge');
  if (!badge) return;
  const count = getActiveBillingFilterCount();
  badge.textContent = count > 99 ? '99+' : String(count);
  badge.classList.toggle('show', count > 0);
}
function setBillingTableLoading(message = 'Memuat daftar tagihan...') {
  const table = document.querySelector('.billing-table');
  if (!table) return;
  table.dataset.loadingText = String(message || 'Memuat daftar tagihan...');
  table.classList.add('is-loading');
}
document.querySelectorAll('.mo').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('show')}));
document.querySelectorAll('[data-pay-by]').forEach((button) => {
  button.addEventListener('click', () => {
    const payByInput = document.getElementById('payByNameInput');
    const notesInput = document.getElementById('payNotesInput');
    if (payByInput) payByInput.value = String(button.dataset.payBy || '').trim();
    if (notesInput) notesInput.value = String(button.dataset.payNote || '').trim();
  });
});
const LANG = "<%= lang || 'id' %>";
const MONTHS = (LANG === "en")
  ? ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
  : ['','Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
const I18N = {
  customerPrefix: "<%= t('admin.billing.js.customer_prefix', 'Pelanggan:') %>",
  loadingOther: "<%= t('admin.billing.loading_other_invoices', 'Loading tagihan lainnya...') %>",
  periodPrefix: "<%= t('admin.billing.table.period', 'Periode') %>",
  packageFallback: "<%= t('admin.billing.js.package_fallback', 'Internet') %>",
  confirmUnisolate: "<%= t('admin.billing.confirm.unisolate_without_payment', 'Buka isolir pelanggan ini tanpa bayar?') %>",
  confirmUnpay: "<%= t('admin.billing.confirm.unpay', 'Batalkan status lunas?') %>",
  confirmIsolateManual: "<%= t('admin.billing.confirm.isolate_manual', 'Isolir pelanggan ini secara manual?') %>",
  confirmDelete: "<%= t('admin.billing.confirm.delete', 'Hapus tagihan ini?') %>",
  waPendingDefault: "Menyiapkan kirim WhatsApp di latar belakang...",
  payPending: "Sedang menyimpan pembayaran dan mengirim notifikasi WhatsApp bila aktif...",
  isolatePending: "Sedang mengisolir pelanggan. Setelah berhasil, notifikasi dikirim di belakang layar...",
  submitProcessing: "Memproses..."
};

function ensureBillingPendingBar() {
  let pending = document.getElementById('billingPendingBar');
  if (pending) return pending;
  pending = document.createElement('div');
  pending.id = 'billingPendingBar';
  pending.style.position = 'fixed';
  pending.style.left = '50%';
  pending.style.bottom = '24px';
  pending.style.transform = 'translateX(-50%)';
  pending.style.zIndex = '9999';
  pending.style.display = 'none';
  pending.style.alignItems = 'center';
  pending.style.gap = '10px';
  pending.style.padding = '12px 16px';
  pending.style.borderRadius = '14px';
  pending.style.background = 'rgba(15,23,42,.94)';
  pending.style.color = '#fff';
  pending.style.boxShadow = '0 12px 30px rgba(15,23,42,.28)';
  pending.style.fontSize = '13px';
  pending.style.fontWeight = '700';
  pending.style.maxWidth = 'calc(100vw - 28px)';
  pending.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span><span id="billingPendingText"></span>';
  document.body.appendChild(pending);
  return pending;
}

function showBillingPending(message) {
  const pending = ensureBillingPendingBar();
  const textEl = document.getElementById('billingPendingText');
  const spinner = pending.querySelector('.spinner-border');
  if (spinner) spinner.style.display = '';
  if (textEl) textEl.textContent = String(message || I18N.waPendingDefault);
  pending.style.display = 'inline-flex';
}

function finishBillingPending(message, ok = true) {
  const pending = ensureBillingPendingBar();
  const spinner = pending.querySelector('.spinner-border');
  const textEl = document.getElementById('billingPendingText');
  if (spinner) spinner.style.display = 'none';
  pending.style.background = ok ? 'rgba(21,128,61,.94)' : 'rgba(185,28,28,.94)';
  if (textEl) textEl.textContent = String(message || (ok ? 'Berhasil.' : 'Gagal.'));
  pending.style.display = 'inline-flex';
  window.clearTimeout(window.__billingPendingHideTimer);
  window.__billingPendingHideTimer = window.setTimeout(() => {
    pending.style.display = 'none';
    pending.style.background = 'rgba(15,23,42,.94)';
  }, ok ? 2400 : 4200);
}

async function submitBillingWhatsappInline(form) {
  const submitBtn = form.querySelector('button[type="submit"], button:not([type]), .btn');
  const originalHtml = submitBtn ? submitBtn.innerHTML : '';
  showBillingPending(String(form.dataset.waWaiting || I18N.waPendingDefault));
  if (submitBtn) {
    submitBtn.disabled = true;
    submitBtn.dataset.originalHtml = originalHtml;
    submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>${I18N.submitProcessing}`;
  }
  try {
    const body = new FormData(form);
    body.set('ajax', '1');
    const response = await fetch(form.action, {
      method: 'POST',
      body,
      credentials: 'same-origin',
      cache: 'no-store',
      headers: {
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }
    });
    const result = await response.json().catch(() => ({}));
    if (!response.ok || result.success === false) {
      throw new Error(result.error || result.message || 'Gagal kirim WhatsApp.');
    }
    finishBillingPending(result.message || 'Tagihan WhatsApp berhasil dikirim.', true);
  } catch (error) {
    finishBillingPending(error.message || String(error), false);
  } finally {
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalHtml || submitBtn.dataset.originalHtml || submitBtn.innerHTML;
    }
  }
}

document.addEventListener('submit', function(e) {
  const form = e.target;
  if (!(form instanceof HTMLFormElement)) return;
  if (!form.classList.contains('needs-confirm')) return;
  const key = String(form.dataset.confirmKey || '');
  const msg = I18N[key] || 'Lanjutkan?';
  if (!confirm(msg)) {
    e.preventDefault();
    return;
  }
  if (form.dataset.requireAdminPassword === '1') {
    const password = prompt('Masukkan password admin untuk batalkan lunas:');
    if (!password) {
      e.preventDefault();
      return;
    }
    let input = form.querySelector('input[name="confirm_password"]');
    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'confirm_password';
      form.appendChild(input);
    }
    input.value = password;
  }
});

document.addEventListener('submit', function(e) {
  const form = e.target;
  if (!(form instanceof HTMLFormElement)) return;
  if (e.defaultPrevented) return;
  const action = String(form.getAttribute('action') || '');
  const isWaSubmit = form.hasAttribute('data-wa-submit') || /\/admin\/billing\/\d+\/whatsapp$/i.test(action);
  const isPaySubmit = form.id === 'payForm' || /\/admin\/billing\/(\d+\/pay|pay-bulk)$/i.test(action);
  const isIsolateSubmit = /\/admin\/customers\/\d+\/isolate$/i.test(action);
  if (!isWaSubmit && !isPaySubmit && !isIsolateSubmit) return;
  if (isWaSubmit) {
    e.preventDefault();
    submitBillingWhatsappInline(form);
    return;
  }

  const waitingText = isPaySubmit
    ? I18N.payPending
    : isIsolateSubmit
      ? I18N.isolatePending
    : String(form.dataset.waWaiting || I18N.waPendingDefault);
  showBillingPending(waitingText);

  const submitBtn = form.querySelector('button[type="submit"]');
  if (submitBtn) {
    submitBtn.disabled = true;
    submitBtn.dataset.originalHtml = submitBtn.innerHTML;
    submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>${I18N.submitProcessing}`;
  }
});

// Handle "Tandai Lunas" via data-* attributes (avoid EJS/HTML quote conflict)
document.addEventListener('click', async function(e) {
  const btn = e.target.closest('.pay-btn');
  if (!btn) return;
  
  const id         = btn.dataset.id;
  const customerId = btn.dataset.customerId;
  const name       = btn.dataset.name;
  const period     = btn.dataset.period;
  
  const form = document.getElementById('payForm');
  const multiSection = document.getElementById('multiPaySection');
  const unpaidList = document.getElementById('unpaidList');
  const payDesc = document.getElementById('payDesc');

  const setUnpaidListMessage = (message) => {
    if (!unpaidList) return;
    unpaidList.replaceChildren();
    const info = document.createElement('div');
    info.className = 'text-muted small';
    info.textContent = String(message || '');
    unpaidList.appendChild(info);
  };
  
  payDesc.textContent = I18N.customerPrefix + ' ' + name;
  setUnpaidListMessage(I18N.loadingOther);
  multiSection.style.display = 'block';
  
  openModal('payModal');

  try {
    const res = await fetch('/admin/api/billing/unpaid/' + customerId);
    const invoices = await res.json();
    
    unpaidList.replaceChildren();
    if (invoices.length > 0) {
      invoices.forEach(inv => {
        const div = document.createElement('div');
        div.style.display = 'flex';
        div.style.alignItems = 'center';
        div.style.gap = '10px';
        const isCurrent = inv.id == id;
        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.name = 'invoice_ids';
        checkbox.value = String(inv.id);
        checkbox.id = `inv_${inv.id}`;
        checkbox.checked = Boolean(isCurrent);
        checkbox.style.width = '16px';
        checkbox.style.height = '16px';

        const label = document.createElement('label');
        label.htmlFor = checkbox.id;
        label.style.fontSize = '13px';
        label.style.cursor = 'pointer';
        label.append(document.createTextNode(`${I18N.periodPrefix} ${(MONTHS[inv.period_month] || '')} ${inv.period_year} `));

        const packageSpan = document.createElement('span');
        packageSpan.className = 'text-muted';
        packageSpan.textContent = `(${inv.package_name || I18N.packageFallback})`;
        label.appendChild(packageSpan);
        label.append(document.createTextNode(' - '));

        const amountStrong = document.createElement('strong');
        amountStrong.style.color = 'var(--success)';
        amountStrong.textContent = `Rp ${Number(inv.amount || 0).toLocaleString('id-ID')}`;
        label.appendChild(amountStrong);

        div.appendChild(checkbox);
        div.appendChild(label);
        unpaidList.appendChild(div);
      });
      form.action = '/admin/billing/pay-bulk';
    } else {
      multiSection.style.display = 'none';
      form.action = '/admin/billing/' + id + '/pay';
    }
  } catch (err) {
    console.error('Failed to load unpaid invoices:', err);
    multiSection.style.display = 'none';
    form.action = '/admin/billing/' + id + '/pay';
  }
});

setTimeout(()=>document.querySelectorAll('.alert').forEach(a=>a.style.display='none'),5000);

let billingSearchAbortController = null;
async function syncBillingSearchSuggestions(query) {
  const input = document.getElementById('billingSearchInput');
  const list = document.getElementById('billingSearchSuggestions');
  if (!input || !list) return;
  const keyword = String(query || '').trim();
  if (keyword.length < 2) {
    list.replaceChildren();
    return;
  }
  try {
    if (billingSearchAbortController) billingSearchAbortController.abort();
    billingSearchAbortController = new AbortController();
    const res = await fetch(`/admin/api/customers/suggest?q=${encodeURIComponent(keyword)}`, {
      signal: billingSearchAbortController.signal
    });
    if (!res.ok) return;
    const rows = await res.json();
    list.replaceChildren();
    (Array.isArray(rows) ? rows : []).forEach((row) => {
      const option = document.createElement('option');
      const name = String(row.name || '').trim();
      const phone = String(row.phone || '').trim();
      const pppoe = String(row.pppoe_username || '').trim();
      const hotspot = String(row.hotspot_username || '').trim();
      const mac = String(row.mac_address || '').trim();
      const tag = String(row.genieacs_tag || '').trim();
      option.value = name || phone || pppoe || hotspot || mac || tag;
      option.label = [phone, pppoe, tag].filter(Boolean).join(' • ');
      option.label = [phone, pppoe, hotspot, mac, tag].filter(Boolean).join(' - ');
      list.appendChild(option);
    });
  } catch (error) {
    if (error && error.name === 'AbortError') return;
    console.error('Failed to load billing suggestions', error);
  }
}

document.getElementById('billingSearchInput')?.addEventListener('input', (event) => {
  syncBillingSearchSuggestions(event.target.value);
});

function triggerBillingAutoSearch(force = false) {
  const input = document.getElementById('billingSearchInput');
  const form = document.getElementById('billingSearchForm');
  if (!input || !form) return;
  const keyword = String(input.value || '').trim();
  if (!force && keyword.length > 0 && keyword.length < 2) return;
  const params = new URLSearchParams(new FormData(form));
  params.set('page', '1');
  const nextUrl = `${form.action}?${params.toString()}`;
  if (`${window.location.pathname}${window.location.search}` === `${form.action.replace(window.location.origin, '')}?${params.toString()}`) return;
  setBillingTableLoading('Menyegarkan daftar tagihan...');
  window.location.assign(nextUrl);
}

document.getElementById('billingSearchInput')?.addEventListener('change', () => {
  triggerBillingAutoSearch(true);
});

syncBillingMobileFilterLayout();
syncBillingFilterBadge();
window.addEventListener('resize', syncBillingMobileFilterLayout);

document.querySelectorAll('#billingFilterPanel select, #billingFilterPanel input').forEach((field) => {
  field.addEventListener('change', () => {
    syncBillingFilterBadge();
  });
});

document.getElementById('billingSearchForm')?.addEventListener('submit', () => {
  const form = document.getElementById('billingSearchForm');
  const statusField = form?.querySelector('[name="status"]');
  const sortField = form?.querySelector('[name="sort"]');
  const channelField = form?.querySelector('[name="pay_channel"]');
  const statusValue = String(statusField?.value || '').trim();
  if (channelField && statusValue !== 'paid') channelField.value = 'all';
  if (sortField && statusValue !== 'unpaid' && sortField.value === 'due_today') sortField.value = statusValue === 'paid' ? 'paid_latest' : 'smart';
  if (window.innerWidth <= 768) toggleBillingFilterPanel(false);
  setBillingTableLoading('Menerapkan filter tagihan...');
});

document.querySelectorAll('.billing-filter-quick a, .pagi a').forEach((link) => {
  link.addEventListener('click', () => {
    setBillingTableLoading('Membuka data tagihan...');
  });
});
</script>
