<% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
<style>
  .customer-bottom-shell {
    position: fixed;
    left: 50%;
    right: auto;
    transform: translateX(-50%);
    width: min(calc(100vw - 20px), 420px);
    bottom: calc(10px + env(safe-area-inset-bottom));
    z-index: 1050;
    display: none;
  }

  .customer-bottom-nav {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 3px;
    padding: 10px 8px;
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 26px;
    box-shadow: 0 16px 36px rgba(15, 23, 42, 0.12);
    backdrop-filter: blur(18px);
  }

  .customer-bottom-nav .nav-item {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 6px 3px;
    color: #667085;
    text-decoration: none;
    font-size: 10.5px;
    font-weight: 600;
    border-radius: 18px;
    transition: transform 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .customer-bottom-nav .nav-item i {
    font-size: 20px;
    line-height: 1;
  }

  .customer-bottom-nav .nav-item.active {
    color: #2f6bff;
    background: rgba(47, 107, 255, 0.10);
  }

  .customer-bottom-nav .nav-item:active {
    transform: scale(0.98);
  }

  @media (max-width: 991.98px) {
    .customer-bottom-shell {
      display: block;
    }

    body {
      padding-bottom: 102px !important;
    }
  }

  @media (max-width: 389.98px) {
    .customer-bottom-shell {
      width: min(calc(100vw - 14px), 420px);
      bottom: calc(7px + env(safe-area-inset-bottom));
    }

    .customer-bottom-nav .nav-item i {
      font-size: 18px;
    }

    .customer-bottom-nav .nav-item {
      font-size: 9.5px;
    }
  }
</style>

<nav class="customer-bottom-shell">
  <div class="customer-bottom-nav">
    <a href="/customer/dashboard#home-section" class="nav-item <%= activeNav === 'home' ? 'active' : '' %>">
      <i class="bi bi-grid-1x2-fill"></i>
      <span>Home</span>
    </a>
    <a href="/customer/dashboard#ticket-section" class="nav-item <%= activeNav === 'ticket' ? 'active' : '' %>">
      <i class="bi bi-ticket-perforated"></i>
      <span>Ticketing</span>
    </a>
    <a href="/customer/dashboard#profile-section" class="nav-item <%= activeNav === 'profile' ? 'active' : '' %>">
      <i class="bi bi-person"></i>
      <span>Profile</span>
    </a>
    <a href="/customer/dashboard#activity-section" class="nav-item <%= activeNav === 'activity' ? 'active' : '' %>">
      <i class="bi bi-bell"></i>
      <span>Aktivitas</span>
    </a>
    <a href="/customer/dashboard#settings-section" class="nav-item <%= activeNav === 'settings' ? 'active' : '' %>">
      <i class="bi bi-gear"></i>
      <span>Settings</span>
    </a>
  </div>
</nav>

<script>
  function updateCustomerBottomNav() {
    const hash = window.location.hash || '#home-section';
    const items = document.querySelectorAll('.customer-bottom-nav .nav-item');
    items.forEach((item) => item.classList.remove('active'));

    const matching = Array.from(items).find((item) => item.getAttribute('href').includes(hash));
    if (matching) {
      matching.classList.add('active');
      return;
    }

    const homeItem = document.querySelector('.customer-bottom-nav .nav-item[href*="home-section"]');
    if (homeItem) homeItem.classList.add('active');
  }

  window.addEventListener('hashchange', updateCustomerBottomNav);
  window.addEventListener('load', updateCustomerBottomNav);
</script>
<% } %>
