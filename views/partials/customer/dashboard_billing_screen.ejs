<%
  const safeUnpaidInvoices = Array.isArray(unpaidInvoices) ? unpaidInvoices : [];
  const safePaidInvoices = Array.isArray(paidInvoices) ? paidInvoices : [];
  const safeMonthNames = Array.isArray(monthNames)
    ? monthNames
    : [null, 'Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  const safeUpstreamProviderName = typeof upstreamProviderName !== 'undefined' ? upstreamProviderName : '';
  const safePaymentChannels = Array.isArray(paymentChannels) ? paymentChannels : [];
  function publicPaidByName(value) {
    const raw = String(value || '').trim();
    if (!raw) return 'Customer';
    const cashierMatch = raw.match(/^Kasir(?:\s+(.+?))?(?:\s+\(@[^)]*\))?(\s*-\s*.+)?$/i);
    if (!cashierMatch) return raw;
    const name = String(cashierMatch[1] || '').trim();
    const suffix = String(cashierMatch[2] || '').trim();
    return `Admin${name ? ` ${name}` : ''}${suffix ? ` ${suffix}` : ''}`.trim();
  }
%>
<section class="app-screen" data-tab="billing">
  <div class="billing-card">
    <div class="billing-card-head">
      <div>
        <h4>Tagihan Aktif</h4>
        <div class="soft-muted"><%= safeUnpaidInvoices.length %> tagihan belum dibayar</div>
      </div>
      <% if (safeUnpaidInvoices.length > 0) { %>
        <button class="mini-button" type="button" onclick="openPaymentModal()">
          <i class="bi bi-credit-card-2-front"></i> Bayar Online
        </button>
      <% } %>
    </div>

    <% if (safeUnpaidInvoices.length === 0) { %>
      <div class="empty-card">
        <i class="bi bi-patch-check"></i>
        <strong>Semua tagihan lunas</strong>
        <div>Tagihan baru akan muncul otomatis pada periode billing berikutnya.</div>
      </div>
    <% } else { %>
      <div class="billing-list">
        <% safeUnpaidInvoices.forEach((inv) => { %>
          <div class="billing-item">
            <div class="item-text">
              <div class="billing-topline">
                <div>
                  <div class="billing-code">INV-<%= inv.id %></div>
                  <div class="billing-period"><%= safeMonthNames[Number(inv.period_month)] || inv.period_month %> <%= inv.period_year %></div>
                </div>
                <div class="billing-amount"><%= formatCurrency(inv.amount) %></div>
              </div>
              <div class="billing-detail-line">
                <span><i class="bi bi-box-seam"></i> <%= inv.package_name || packageName %></span>
                <span><i class="bi bi-calendar-event"></i> Tgl <%= Math.min(Number(inv.due_day_snapshot || profileData.isolate_day || 28), new Date(Number(inv.period_year), Number(inv.period_month), 0).getDate()) %></span>
              </div>
              <div class="billing-badges">
                <span class="billing-badge status-unpaid"><i class="bi bi-clock-history"></i> Belum Lunas</span>
                <% if (inv.payment_gateway) { %>
                  <span class="billing-badge"><i class="bi bi-credit-card"></i> <%= String(inv.payment_gateway).toUpperCase() %></span>
                <% } %>
              </div>
            </div>
            <div class="item-meta">
              <div class="billing-actions">
                <a class="pay-action" href="/customer/payment/select/<%= inv.id %>">
                  <i class="bi bi-credit-card-2-front"></i> Bayar Online
                </a>
                <a class="pay-action secondary" target="_blank" href="/customer/invoices/<%= inv.id %>/print?style=a4">
                  <i class="bi bi-printer"></i> Invoice
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="billing-card" style="margin-top:16px;">
    <div class="billing-card-head">
      <div>
        <h4>Riwayat Pembayaran</h4>
        <div class="soft-muted">Transaksi yang sudah lunas</div>
      </div>
    </div>

    <% if (safePaidInvoices.length === 0) { %>
      <div class="empty-card">
        <i class="bi bi-clock-history"></i>
        <strong>Belum ada riwayat lunas</strong>
        <div>Setelah pembayaran berhasil, histori akan muncul di sini.</div>
      </div>
    <% } else { %>
      <div class="billing-list">
        <% safePaidInvoices.slice(0, 10).forEach((inv) => { %>
          <div class="billing-item">
            <div class="item-text">
              <div class="billing-topline">
                <div>
                  <div class="billing-code">INV-<%= inv.id %></div>
                  <div class="billing-period"><%= safeMonthNames[Number(inv.period_month)] || inv.period_month %> <%= inv.period_year %></div>
                </div>
                <div class="billing-amount"><%= formatCurrency(inv.amount) %></div>
              </div>
              <div class="billing-detail-line">
                <span><i class="bi bi-check2-circle"></i> <%= formatDateTime(inv.paid_at) %></span>
                <span><i class="bi bi-person-check"></i> <%= publicPaidByName(inv.paid_by_name) %></span>
              </div>
              <div class="billing-badges">
                <span class="billing-badge status-paid"><i class="bi bi-check-circle"></i> Lunas</span>
              </div>
            </div>
            <div class="item-meta">
              <div class="billing-actions">
                <a class="pay-action secondary" target="_blank" href="/customer/invoices/<%= inv.id %>/print?style=receipt">
                  <i class="bi bi-receipt-cutoff"></i> Struk
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (safePaymentChannels.length > 0) { %>
      <div class="payment-method-row">
        <% safePaymentChannels.slice(0, 8).forEach((channel) => { %>
          <% if (channel.active) { %>
            <span class="payment-method-chip"><%= channel.name || channel.code %></span>
          <% } %>
        <% }) %>
      </div>
    <% } %>
  </div>

  <% const pageCompanyName = typeof companyName !== 'undefined'
       ? companyName
       : (settings?.company_header || 'Portal Pelanggan');
     const pageCompanyLogoUrl = typeof companyLogoUrl !== 'undefined'
       ? companyLogoUrl
       : (settings?.company_logo_url || '/img/logo.png'); %>
  <% if (companyLegalName || companyAddressText || companyPhoneText || companyEmailText || hasManualPayment) { %>
    <div class="business-card">
      <div class="business-topline">
        <h4 class="business-title">Informasi Perusahaan</h4>
        <span class="business-chip"><i class="bi bi-building"></i> Resmi</span>
      </div>

      <div class="business-head">
        <img src="<%= pageCompanyLogoUrl %>" alt="Logo Usaha" onerror="this.onerror=null;this.src='/img/logo.png'">
        <div>
          <strong><%= pageCompanyName %></strong>
          <span><%= companyLegalName || 'Identitas usaha dapat diatur dari menu admin.' %></span>
        </div>
      </div>

      <div class="business-info-grid">
        <% if (companyAddressText) { %>
          <div class="business-info-card">
            <i class="bi bi-geo-alt"></i>
            <div>
              <strong>Alamat Usaha</strong>
              <span><%= companyAddressText %></span>
            </div>
          </div>
        <% } %>
        <% if (companyPhoneText) { %>
          <div class="business-info-card">
            <i class="bi bi-telephone"></i>
            <div>
              <strong>Kontak</strong>
              <span><%= companyPhoneText %></span>
            </div>
          </div>
        <% } %>
        <% if (companyEmailText) { %>
          <div class="business-info-card">
            <i class="bi bi-envelope"></i>
            <div>
              <strong>Email</strong>
              <span><%= companyEmailText %></span>
            </div>
          </div>
        <% } %>
        <% if (safeUpstreamProviderName) { %>
          <div class="business-info-card">
            <i class="bi bi-hdd-network"></i>
            <div>
              <strong>Sumber Internet</strong>
              <span><%= safeUpstreamProviderName %></span>
            </div>
          </div>
        <% } %>
      </div>

      <% if (hasManualPayment) { %>
        <div class="manual-payment-box">
          <h5>Transfer Manual <span style="font-size:11px;font-weight:700;color:#64748b">(opsional)</span></h5>
          <div style="font-size:12px;line-height:1.5;color:#64748b;margin:-4px 0 10px">
            Disarankan memakai Bayar Online agar tagihan otomatis terbaca lunas. Transfer manual dipakai jika kanal online sedang tidak memungkinkan.
          </div>
          <div class="manual-payment-bank"><%= manualPaymentBank %></div>
          <div class="manual-payment-grid">
            <div class="manual-payment-line">
              <strong>No. Rek</strong>
              <span><%= manualPaymentAccountNumber %></span>
            </div>
            <% if (manualPaymentAccountName) { %>
              <div class="manual-payment-line">
                <strong>Atas Nama</strong>
                <span><%= manualPaymentAccountName %></span>
              </div>
            <% } %>
            <% if (manualPaymentNotes) { %>
              <div class="manual-payment-line full">
                <strong>Catatan</strong>
                <span><%= manualPaymentNotes %></span>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</section>
