<section class="app-screen is-active" data-tab="home">
  <%
    const homeHasUnpaid = Boolean(typeof hasUnpaidInvoice !== 'undefined' ? hasUnpaidInvoice : (latestInvoice && String(latestInvoice.status || '').toLowerCase() === 'unpaid'));
    const homeTotalUnpaid = Number(typeof totalUnpaidAmount !== 'undefined' ? totalUnpaidAmount : (homeHasUnpaid && latestInvoice ? latestInvoice.amount : 0)) || 0;
    const homeBillingInvoice = homeHasUnpaid
      ? (typeof primaryUnpaidInvoice !== 'undefined' && primaryUnpaidInvoice ? primaryUnpaidInvoice : latestInvoice)
      : (typeof latestPaidInvoice !== 'undefined' && latestPaidInvoice ? latestPaidInvoice : latestInvoice);
    const homeDueDate = homeBillingInvoice
      ? new Date(
          Number(homeBillingInvoice.period_year),
          Number(homeBillingInvoice.period_month) - 1,
          Math.min(
            Number(homeBillingInvoice.due_day_snapshot || profileData.isolate_day || 28),
            new Date(Number(homeBillingInvoice.period_year), Number(homeBillingInvoice.period_month), 0).getDate()
          )
        )
      : null;
  %>
  <div class="home-compact">
    <div class="home-intro">
      <h1>Selamat datang kembali,</h1>
      <div class="home-intro-line">
        <strong><%= customerName %></strong>
        <span class="mini-status"><i class="bi bi-check-circle-fill"></i> <%= portalAccountLabel || 'Aktif' %></span>
      </div>
      <div class="home-code-row">
        <span class="home-code"><%= customerCode %></span>
        <button class="home-code-copy" type="button" aria-label="Salin kode pelanggan" onclick="copyCustomerCode()">
          <i class="bi bi-copy"></i>
        </button>
      </div>
    </div>

    <% if (appNotif && appNotif.text) { %>
      <div class="status-banner banner-<%= appNotif.type === 'danger' ? 'danger' : appNotif.type === 'warning' ? 'warning' : appNotif.type === 'success' ? 'success' : 'info' %>">
        <div class="status-banner-main">
          <i class="bi <%= appNotif.type === 'danger' ? 'bi-x-octagon-fill' : appNotif.type === 'warning' ? 'bi-exclamation-triangle-fill' : appNotif.type === 'success' ? 'bi-check-circle-fill' : 'bi-info-circle-fill' %>"></i>
          <div>
            <strong><%= appNotif.type === 'danger' ? 'Perlu perhatian' : appNotif.type === 'warning' ? 'Informasi penting' : appNotif.type === 'success' ? 'Berhasil' : 'Info' %></strong>
            <p><%= appNotif.text %></p>
          </div>
        </div>
        <button class="status-detail" type="button" onclick="openAppTab('profile')">Detail</button>
      </div>
    <% } %>

    <div class="hero-card home-hero-card">
      <div class="home-hero-grid">
        <div class="home-hero-top">
          <div class="home-hero-main">
            <div class="hero-eyebrow">Paket Anda</div>
            <div class="hero-package"><%= packageName %></div>
            <div class="hero-sub home-hero-meta">
              <span><i class="bi bi-speedometer2"></i> <%= liveDownloadCap %>/<%= liveUploadCap %> Mbps</span>
              <span><i class="bi bi-wifi"></i> <%= isPppoeOnline ? 'Internet normal' : (pppoeStatusText || 'Status belum terbaca') %></span>
            </div>
          </div>
          <div class="home-hero-side">
            <span class="home-plan-state"><%= portalAccountLabel || 'Aktif' %></span>
          </div>
        </div>

        <div class="home-hero-body">
          <div class="home-hero-info-grid">
            <div class="home-hero-info-box">
              <small>Status Tagihan</small>
              <strong class="home-bill-state <%= homeHasUnpaid ? 'warn' : 'okay' %>">
                <%= homeHasUnpaid ? 'Belum Bayar' : 'Lunas' %>
              </strong>
            </div>
            <div class="home-hero-info-box">
              <small><%= homeHasUnpaid ? 'Jatuh Tempo' : (homeBillingInvoice ? 'Terakhir Lunas' : 'Status') %></small>
              <strong><%= homeHasUnpaid && homeDueDate ? formatDate(homeDueDate) : (homeBillingInvoice && homeBillingInvoice.paid_at ? formatDate(homeBillingInvoice.paid_at) : 'Tidak ada tagihan') %></strong>
            </div>
          </div>
          <div class="home-hero-payment-card">
            <small><%= homeHasUnpaid ? 'Total Tagihan' : 'Status Pembayaran' %></small>
            <strong><%= homeHasUnpaid ? formatCurrency(homeTotalUnpaid) : 'Aman' %></strong>
            <button class="primary-button home-pay-button" type="button" onclick="<%= homeHasUnpaid ? 'openPaymentModal()' : "openAppTab('billing')" %>">
              <i class="bi <%= homeHasUnpaid ? 'bi-wallet2' : 'bi-receipt-cutoff' %>"></i> <%= homeHasUnpaid ? 'Bayar Sekarang' : 'Riwayat' %>
            </button>
          </div>
        </div>
      </div>

      <div class="home-hero-divider"></div>

      <div class="home-usage-grid">
        <div class="home-usage-card upload">
          <small>Upload</small>
          <strong><%= formatBytes(uploadBytes) %></strong>
        </div>
        <div class="home-usage-card download">
          <small>Download</small>
          <strong><%= formatBytes(downloadBytes) %></strong>
        </div>
      </div>
    </div>

    <div class="home-quick-section">
      <h3 class="home-quick-title">Aksi Cepat</h3>
      <div class="quick-grid home-quick-grid">
        <button class="quick-card home-quick-card" type="button" onclick="openAppTab('billing')">
          <div class="quick-icon quick-green"><i class="bi bi-wallet2"></i></div>
          <h4>Tagihan</h4>
        </button>
        <% if (hasRouterPortalAccess) { %>
          <button class="quick-card home-quick-card" type="button" onclick="openAppTab('settings')">
            <div class="quick-icon quick-cyan"><i class="bi bi-router"></i></div>
            <h4>Router</h4>
          </button>
        <% } %>
        <button class="quick-card home-quick-card" type="button" onclick="openAppTab('traffic')">
          <div class="quick-icon quick-lilac"><i class="bi bi-graph-up-arrow"></i></div>
          <h4>Traffic</h4>
        </button>
        <button class="quick-card home-quick-card" type="button" onclick="openAppTab('packages')">
          <div class="quick-icon quick-sky"><i class="bi bi-box-seam"></i></div>
          <h4>Paket WiFi</h4>
        </button>
        <button class="quick-card home-quick-card" type="button" onclick="openAppTab('speedtest')">
          <div class="quick-icon quick-rose"><i class="bi bi-speedometer2"></i></div>
          <h4>Tes Speed</h4>
        </button>
        <button class="quick-card home-quick-card" type="button" onclick="openTicketModal()">
          <div class="quick-icon quick-gold"><i class="bi bi-chat-dots"></i></div>
          <h4>Bantuan</h4>
        </button>
      </div>
    </div>
  </div>
</section>
