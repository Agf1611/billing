<%
  const customerDetailScope = typeof scope !== 'undefined' ? String(scope) : 'admin';
  const customerDetailAllowPayment = Boolean(typeof allowPayment !== 'undefined' ? allowPayment : false);
  const customerDetailAllowDeviceActions = Boolean(typeof allowDeviceActions !== 'undefined' ? allowDeviceActions : true);
  const customerDetailApiBase = typeof detailApiBase !== 'undefined' ? String(detailApiBase) : (customerDetailScope === 'tech' ? '/tech/api/customers' : '/admin/api/customers');
  const customerDetailDeviceApiBase = typeof deviceApiBase !== 'undefined' ? String(deviceApiBase) : (customerDetailScope === 'tech' ? '/tech/api/device' : '/admin/api/device');
  const customerDetailPaymentApiBase = typeof paymentApiBase !== 'undefined' ? String(paymentApiBase) : customerDetailApiBase;
%>
<style>
  .customer-detail-overlay{position:fixed;inset:0;background:rgba(2,6,23,.58);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;z-index:1400;padding:16px}
  .customer-detail-overlay.show{display:flex}
  .customer-detail-shell{
    width:min(920px,100%);
    max-height:calc(100vh - 32px);
    overflow:auto;
    border-radius:28px;
    border:1px solid var(--border, var(--tech-border, rgba(148,163,184,.18)));
    background:var(--bg2, var(--tech-bg-soft, #111827));
    box-shadow:0 34px 88px rgba(15,23,42,.34);
    overscroll-behavior:contain
  }
  .customer-detail-shell::-webkit-scrollbar{width:10px}
  .customer-detail-shell::-webkit-scrollbar-thumb{background:rgba(148,163,184,.35);border-radius:999px}
  .customer-detail-hero{position:relative;padding:20px 20px 16px;background:linear-gradient(135deg,#1f2f73 0%,#2f8fe8 55%,#0ea5e9 100%);color:#fff;min-height:0}
  .customer-detail-hero.has-photo{background-size:cover;background-position:center}
  .customer-detail-hero::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(15,23,42,.18),rgba(15,23,42,.74))}
  .customer-detail-hero > *{position:relative;z-index:1}
  .customer-detail-topbar{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:6px;position:relative}
  .customer-detail-title{flex:1;min-width:0}
  .customer-detail-title h3{margin:0;font-size:23px;font-weight:900;line-height:1.02;letter-spacing:-.03em}
  .customer-hero-kicker{font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;opacity:.72;margin-bottom:5px}
  .customer-detail-title .sub{margin-top:6px;font-size:13px;opacity:.92}
  .customer-hero-pills{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px}
  .customer-hero-pill{display:inline-flex;align-items:center;gap:5px;padding:6px 9px;min-height:38px;border-radius:999px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.14);font-size:10px;font-weight:700}
  .customer-detail-close{border:0;background:rgba(255,255,255,.18);color:#fff;width:38px;height:38px;border-radius:14px;font-size:18px;flex:0 0 auto;box-shadow:0 14px 24px rgba(15,23,42,.14)}
  .customer-detail-summary-grid,.customer-detail-network-grid,.customer-detail-data-grid{display:grid;gap:8px}
  .customer-detail-summary-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
  .customer-detail-network-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  .customer-detail-data-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  .customer-detail-body{padding:16px;background:var(--bg, var(--tech-bg, #0f172a))}
  .customer-detail-section{background:var(--bg2, var(--tech-bg-soft, #111827));border:1px solid var(--border, var(--tech-border, rgba(148,163,184,.16)));border-radius:18px;padding:12px 12px 10px;margin-bottom:10px;box-shadow:0 10px 26px rgba(15,23,42,.08)}
  .customer-detail-section h4{margin:0 0 10px;font-size:14px;font-weight:900;display:flex;align-items:center;gap:8px}
  .customer-section-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}
  .customer-section-head h4{margin:0}
  .customer-inline-action{border:1px solid rgba(148,163,184,.16);background:rgba(255,255,255,.06);color:inherit;border-radius:999px;padding:6px 10px;font-size:10px;font-weight:800;display:inline-flex;align-items:center;gap:6px}
  .customer-detail-cell{padding:9px 10px;border-radius:14px;background:rgba(255,255,255,.035);border:1px solid rgba(148,163,184,.12)}
  .customer-detail-cell.emphasis{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.16)}
  .customer-detail-cell .label{font-size:9.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted, var(--tech-muted, #94a3b8));margin-bottom:3px}
  .customer-detail-cell .value{font-size:12px;font-weight:700;line-height:1.32;word-break:break-word}
  .customer-detail-cell .value.status-chip{display:flex;align-items:flex-start}
  .customer-detail-cell.emphasis .value{font-size:14px;font-weight:900}
  .customer-span-2{grid-column:span 2}
  .customer-span-3{grid-column:span 3}
  .customer-detail-cell.compact{padding:8px 9px}
  .customer-detail-cell.compact .label{margin-bottom:3px}
  .customer-detail-cell.compact .value{font-size:11.5px}
  .customer-docs{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
  .customer-doc-card{border-radius:18px;border:1px solid rgba(148,163,184,.14);padding:10px;background:rgba(255,255,255,.03)}
  .customer-doc-card img{width:100%;height:160px;object-fit:cover;border-radius:14px;display:block}
  .customer-doc-empty{height:160px;border-radius:14px;border:1px dashed rgba(148,163,184,.24);display:grid;place-items:center;color:var(--muted,var(--tech-muted,#94a3b8));font-size:12px}
  .customer-billing-toolbar{display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:10px}
  .customer-live-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:rgba(16,185,129,.18);border:1px solid rgba(52,211,153,.22);font-size:11px;font-weight:800;color:#bbf7d0}
  .customer-collapsible{padding:0}
  .customer-collapsible summary{list-style:none;cursor:pointer;padding:14px 14px 12px;display:flex;align-items:center;justify-content:space-between;gap:10px}
  .customer-collapsible summary::-webkit-details-marker{display:none}
  .customer-collapsible summary .chev{transition:transform .18s ease}
  .customer-collapsible[open] summary .chev{transform:rotate(180deg)}
  .customer-collapsible-body{padding:0 14px 12px}
  .customer-billing-months{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}
  .billing-month{padding:10px 11px;border-radius:16px;border:1px solid rgba(148,163,184,.14);background:rgba(255,255,255,.03)}
  .billing-month .head{display:flex;justify-content:space-between;gap:6px;align-items:center;margin-bottom:6px}
  .billing-month .name{font-size:12px;font-weight:800}
  .billing-month .status{font-size:10px;font-weight:800;padding:4px 7px;border-radius:999px}
  .billing-month .status.paid{background:rgba(34,197,94,.14);color:#22c55e}
  .billing-month .status.unpaid{background:rgba(245,158,11,.14);color:#f59e0b}
  .billing-month .status.isolated{background:rgba(239,68,68,.14);color:#ef4444}
  .billing-month .status.missing{background:rgba(148,163,184,.14);color:var(--muted,var(--tech-muted,#94a3b8))}
  .billing-month .meta{font-size:11px;color:var(--muted,var(--tech-muted,#94a3b8));line-height:1.45}
  .billing-pay-btn{margin-top:8px;width:100%;border:0;border-radius:12px;padding:8px 10px;background:var(--primary,var(--tech-primary,#3b82f6));color:#fff;font-size:12px;font-weight:800}
  .device-actions{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}
  .device-action-card{padding:11px 12px;border-radius:16px;border:1px solid rgba(148,163,184,.14);background:rgba(255,255,255,.035)}
  .device-action-card label{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted,var(--tech-muted,#94a3b8));margin-bottom:6px}
  .device-action-card input{width:100%;border-radius:12px;border:1px solid rgba(148,163,184,.18);background:rgba(255,255,255,.06);color:inherit;padding:10px 11px}
  .device-action-card button{margin-top:8px;width:100%;border:0;border-radius:12px;padding:8px 10px;background:rgba(59,130,246,.18);color:inherit;font-weight:800}
  .customer-detail-muted{color:var(--muted,var(--tech-muted,#94a3b8))}
  .customer-mobile-secondary{display:block}
  .customer-avatar{width:62px;height:62px;border-radius:50%;display:grid;place-items:center;background:rgba(255,255,255,.12);border:2px solid rgba(255,255,255,.18);font-size:28px;overflow:hidden;flex:0 0 auto}
  .customer-avatar img{width:100%;height:100%;object-fit:cover}
  .customer-detail-actions{display:flex;flex-direction:column;align-items:flex-end;gap:8px;margin-left:auto;flex:0 0 auto}
  .customer-hero-main{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
  .customer-hero-identity{display:flex;gap:10px;align-items:center;min-width:0;flex:1}
  .customer-hero-meta{min-width:0}
  .customer-hero-name-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .customer-hero-name-row h3{margin:0}
  .customer-hero-contact{display:flex;flex-wrap:wrap;gap:7px;margin-top:5px;font-size:12px;opacity:.9}
  .customer-hero-bottom-row{display:flex;gap:8px;align-items:stretch;justify-content:flex-start;margin-top:7px;min-width:0}
  .customer-code-pill{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;min-height:38px;border-radius:999px;background:#3ea3ff;color:#fff;font-size:10px;font-weight:800;box-shadow:0 10px 24px rgba(59,130,246,.22)}
  .customer-hero-traffic{
    display:flex;flex-direction:column;align-items:flex-end;justify-content:center;gap:3px;min-width:86px;min-height:38px;
    padding:0;background:transparent;border:0;text-align:right;box-shadow:none;margin-left:auto;flex:0 0 auto
  }
  .customer-traffic-rate{display:flex;flex-direction:column;align-items:flex-end;gap:4px;font-size:10.5px;font-weight:800;line-height:1.1}
  .customer-traffic-total{font-size:9px;font-weight:800;opacity:.82;text-align:right}
  .customer-rate-row{
    display:flex;align-items:center;justify-content:flex-end;gap:6px;max-width:100%;
    padding:0;border-radius:0;background:transparent;border:0
  }
  .customer-rate-row i{font-size:10px;flex:0 0 auto}
  .customer-rate-row span{display:block;white-space:nowrap}
  .customer-rate-down{color:#60a5fa}
  .customer-rate-up{color:#4ade80}
  .customer-hero-pills{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:6px;
    margin-top:6px
  }
  .customer-hero-pills .customer-hero-pill{
    min-width:0;
    justify-content:center;
    padding:5px 8px;
    font-size:9.5px;
    line-height:1.2;
    text-align:center
  }
  .customer-detail-tabs{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:0;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.16);border-radius:16px;padding:3px;margin:6px 0 0;backdrop-filter:blur(8px);width:100%}
  .customer-tab-btn{border:0;background:transparent;color:rgba(255,255,255,.78);padding:7px 4px;border-radius:11px;font-size:10px;font-weight:800;font-family:inherit;text-align:center;justify-content:center}
  .customer-tab-btn.active{background:rgba(59,130,246,.16);color:#fff;box-shadow:inset 0 -2px 0 rgba(255,255,255,.08)}
  .customer-tab-panel{display:none}
  .customer-tab-panel.active{display:block}
  .customer-state-banner{
    display:flex;align-items:center;justify-content:center;gap:12px;padding:16px 18px;border-radius:20px;
    background:linear-gradient(135deg,rgba(34,197,94,.22),rgba(22,163,74,.24));border:1px solid rgba(74,222,128,.24);color:#dcfce7;
    font-size:16px;font-weight:900;letter-spacing:-.02em;margin-bottom:12px
  }
  .customer-state-banner.unpaid{background:linear-gradient(135deg,rgba(245,158,11,.18),rgba(249,115,22,.2));border-color:rgba(251,191,36,.24);color:#fef3c7}
  .customer-state-banner.suspended{background:linear-gradient(135deg,rgba(239,68,68,.18),rgba(220,38,38,.22));border-color:rgba(248,113,113,.24);color:#fee2e2}
  .customer-state-banner i{font-size:24px}
  .customer-network-status{
    display:inline-flex;align-items:center;gap:7px;padding:7px 12px;border-radius:999px;font-size:12px;font-weight:900;
    border:1px solid transparent
  }
  .customer-network-status.online{background:rgba(34,197,94,.14);color:#22c55e;border-color:rgba(34,197,94,.22)}
  .customer-network-status.offline{background:rgba(239,68,68,.14);color:#ef4444;border-color:rgba(239,68,68,.22)}
  .customer-network-status.warn{background:rgba(245,158,11,.14);color:#f59e0b;border-color:rgba(245,158,11,.22)}
  .customer-detail-cardline{display:flex;align-items:center;justify-content:space-between;gap:10px}
  .customer-detail-cardline .value{margin-top:0!important}
  .customer-traffic-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
  .customer-traffic-card{padding:11px 12px;border-radius:16px;border:1px solid rgba(148,163,184,.12);background:rgba(255,255,255,.04);min-width:0}
  .customer-traffic-card .label{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted,var(--tech-muted,#94a3b8))}
  .customer-traffic-card .value{font-size:18px;font-weight:900;line-height:1.1;margin-top:6px}
  .customer-traffic-card .sub{font-size:11px;color:var(--muted,var(--tech-muted,#94a3b8));margin-top:4px}
  .customer-traffic-card.download .value{color:#60a5fa}
  .customer-traffic-card.upload .value{color:#4ade80}
  .customer-list-rows{display:grid;gap:10px}
  .customer-list-row{padding:12px 13px;border-radius:16px;border:1px solid rgba(148,163,184,.12);background:rgba(255,255,255,.035)}
  .customer-list-row .top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
  .customer-list-row .title{font-size:13px;font-weight:800}
  .customer-list-row .meta{font-size:11px;color:var(--muted,var(--tech-muted,#94a3b8));margin-top:4px;line-height:1.45}
  .customer-tech-status{display:inline-flex;align-items:center;gap:6px;padding:5px 9px;border-radius:999px;font-size:10px;font-weight:800}
  .customer-tech-status.open{background:rgba(245,158,11,.14);color:#f59e0b}
  .customer-tech-status.in_progress{background:rgba(59,130,246,.14);color:#60a5fa}
  .customer-tech-status.resolved{background:rgba(34,197,94,.14);color:#22c55e}
  .customer-tech-status.closed{background:rgba(100,116,139,.14);color:#94a3b8}
  .customer-doc-title{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:8px}
  .customer-note-box{padding:12px 13px;border-radius:16px;border:1px solid rgba(148,163,184,.12);background:rgba(255,255,255,.035)}
  .customer-note-box .big{font-size:13px;font-weight:700;line-height:1.5}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-overlay{background:rgba(94,112,146,.22)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-shell{
    background:#f8fbff;
    border-color:rgba(170,186,215,.36);
    box-shadow:0 34px 88px rgba(98,112,148,.22)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-hero{
    background:linear-gradient(145deg,#f9fbff 0%,#e9f3ff 46%,#d6e8ff 100%);
    color:#1d2c46;
    border-bottom:1px solid rgba(163,180,214,.28)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-hero.has-photo::after{
    background:linear-gradient(180deg,rgba(255,255,255,.34),rgba(233,243,255,.92))
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-hero:not(.has-photo)::after{
    background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.02))
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-body{background:linear-gradient(180deg,#f8fbff 0%,#eef4ff 52%,#edf3ff 100%)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-section,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-cell,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-doc-card,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-traffic-card,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-list-row,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-note-box,
  :is(body[data-theme="light"], html[data-theme="light"]) .billing-month{
    background:rgba(255,255,255,.95);
    border-color:rgba(178,191,219,.36);
    box-shadow:0 10px 28px rgba(129,145,180,.08)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-section{
    box-shadow:0 14px 34px rgba(141,156,189,.12)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-cell{
    background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(248,250,255,.92));
    border-color:rgba(182,196,223,.34)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-cell.emphasis{background:linear-gradient(180deg,rgba(233,241,255,.92),rgba(225,236,255,.84));border-color:rgba(115,148,220,.24)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-cell .value,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-section h4,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-note-box .big{color:var(--text,var(--tech-text,#1f2940))}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-cell .label,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-traffic-card .label{color:rgba(74,92,128,.72)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-tab-btn{color:rgba(76,91,122,.84)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-tab-btn.active{
    color:#19304f;
    background:linear-gradient(180deg,#ffffff 0%,#eef4ff 100%);
    box-shadow:0 8px 18px rgba(129,145,180,.16)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-tabs{
    background:rgba(255,255,255,.72);
    border-color:rgba(182,196,223,.42)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-tab-btn{color:rgba(76,91,122,.84)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-hero-pill{
    background:rgba(255,255,255,.52);
    border-color:rgba(255,255,255,.68);
    color:#23406b;
    box-shadow:0 8px 20px rgba(165,184,218,.18)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-close{
    background:rgba(255,255,255,.72);
    color:#284266;
    border:1px solid rgba(176,193,224,.38);
    box-shadow:0 12px 28px rgba(138,155,190,.16)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-code-pill{
    background:linear-gradient(135deg,#3f85ff 0%,#5aa0ff 100%);
    box-shadow:0 12px 26px rgba(63,133,255,.24)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-hero-traffic{
    color:#1b3153;
    background:transparent;
    border:0;
    box-shadow:none
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-network-status.online{background:rgba(34,197,94,.12);color:#15803d;border-color:rgba(34,197,94,.16)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-network-status.offline{background:rgba(239,68,68,.12);color:#dc2626;border-color:rgba(239,68,68,.16)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-network-status.warn{background:rgba(245,158,11,.12);color:#d97706;border-color:rgba(245,158,11,.16)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-state-banner{
    background:linear-gradient(135deg,#eefcf4 0%,#ddf8e8 100%);
    border-color:rgba(74,222,128,.28);
    color:#166534;
    box-shadow:0 12px 30px rgba(135,170,144,.14)
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-state-banner.unpaid{
    background:linear-gradient(135deg,#fff7ea 0%,#ffefdb 100%);
    border-color:rgba(251,191,36,.28);
    color:#b45309
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-state-banner.suspended{
    background:linear-gradient(135deg,#fff1f2 0%,#ffe4e6 100%);
    border-color:rgba(248,113,113,.28);
    color:#be123c
  }
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-traffic-total,
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-detail-muted{color:rgba(31,41,64,.72)!important}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-doc-empty{background:rgba(255,255,255,.72);border-color:rgba(148,163,184,.22)}
  :is(body[data-theme="light"], html[data-theme="light"]) .customer-inline-action{background:rgba(255,255,255,.78);border-color:rgba(178,191,219,.42);box-shadow:0 8px 18px rgba(141,156,189,.1)}
  :is(body[data-theme="light"], html[data-theme="light"]) .device-action-card{
    background:rgba(255,255,255,.94);
    border-color:rgba(182,196,223,.34);
