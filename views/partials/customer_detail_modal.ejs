<div class="customer-detail-overlay" id="customerDetailOverlay" onclick="if(event.target===this) closeCustomerDetailModal()">
  <div class="customer-detail-shell">
    <div id="customerDetailContent"></div>
  </div>
</div>

<script>
  const CUSTOMER_DETAIL_OPTIONS = {
    scope: <%- JSON.stringify(customerDetailScope) %>,
    allowPayment: <%- JSON.stringify(customerDetailAllowPayment) %>,
    allowDeviceActions: <%- JSON.stringify(customerDetailAllowDeviceActions) %>,
    detailApiBase: <%- JSON.stringify(customerDetailApiBase) %>,
    deviceApiBase: <%- JSON.stringify(customerDetailDeviceApiBase) %>,
    paymentApiBase: <%- JSON.stringify(customerDetailPaymentApiBase) %>
  };
  let customerDetailState = { customerId: null, year: new Date().getFullYear(), data: null, activeTab: 'detail', refreshTimer: null, pendingController: null, loading: false };
  const customerTrafficHistory = new Map();

  function escapeCustomerDetailHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function customerDetailRupiah(value) {
    return 'Rp ' + (Number(value || 0) || 0).toLocaleString('id-ID');
  }

  function customerDetailBytesToGb(bytes) {
    return ((Number(bytes || 0) || 0) / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
  }

  function customerDetailDateTime(value, fallback = '-') {
    if (!value) return fallback;
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return fallback;
    return new Intl.DateTimeFormat('id-ID', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    }).format(date);
  }

  function customerDetailDate(value, fallback = '-') {
    if (!value) return fallback;
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return fallback;
    return new Intl.DateTimeFormat('id-ID', {
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    }).format(date);
  }

  function customerDetailMonthName(month) {
    return ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'][Math.max(0, (Number(month || 1) - 1))] || '-';
  }

  function customerDetailStatusChip(status) {
    const normalized = String(status || '').toLowerCase();
    if (normalized === 'active') return 'Aktif';
    if (normalized === 'suspended') return 'Suspend';
    if (normalized === 'inactive') return 'Nonaktif';
    return normalized || '-';
  }

  function customerDetailInvoiceStatus(invoice) {
    if (!invoice) return { label: 'Belum Ada Tagihan', cls: 'missing' };
    if (String(invoice.status || '').toLowerCase() === 'paid') return { label: 'Lunas', cls: 'paid' };
    return { label: 'Belum Lunas', cls: 'unpaid' };
  }

  function customerDetailFormatRate(bytesPerSecond) {
    const value = Number(bytesPerSecond || 0) || 0;
    if (value <= 0) return '0 kb/s';
    const kbPerSecond = value / 1024;
    if (kbPerSecond >= 1024) return (kbPerSecond / 1024).toFixed(1) + ' Mb/s';
    return kbPerSecond.toFixed(1) + ' kb/s';
  }

  function customerDetailFormatThroughput(mbps) {
    const value = Number(mbps || 0) || 0;
    if (value <= 0) return '0 kb/s';
    if (value < 1) return `${(value * 1024).toFixed(value * 1024 >= 100 ? 0 : 1)} kb/s`;
    return `${value.toFixed(value >= 10 ? 0 : 1)} Mb/s`;
  }

  function customerDetailComputeTrafficState(detail) {
    const usage = detail?.usage || {};
    const network = detail?.network || {};
    const directDownMbps = Number(network.txMbps || 0) || 0;
    const directUpMbps = Number(network.rxMbps || 0) || 0;
    if (directDownMbps > 0 || directUpMbps > 0) {
      return {
        downRateText: customerDetailFormatThroughput(directDownMbps),
        upRateText: customerDetailFormatThroughput(directUpMbps)
      };
    }
    const now = Date.now();
    const key = String(customerDetailState.customerId || '0');
    const currentDown = Number(usage.liveDownloadBytes || usage.downloadBytes || 0) || 0;
    const currentUp = Number(usage.liveUploadBytes || usage.uploadBytes || 0) || 0;
    const previous = customerTrafficHistory.get(key);
    let downRate = 0;
    let upRate = 0;

    if (previous && usage.isLive) {
      const seconds = Math.max(1, (now - previous.time) / 1000);
      downRate = Math.max(0, currentDown - previous.down) / seconds;
      upRate = Math.max(0, currentUp - previous.up) / seconds;
    }

    customerTrafficHistory.set(key, { down: currentDown, up: currentUp, time: now });

    return {
      downRateText: customerDetailFormatRate(downRate),
      upRateText: customerDetailFormatRate(upRate)
    };
  }

  function customerDetailNetworkStatusChip(online, status) {
    const normalized = String(status || '').trim() || (online ? 'Online' : 'Offline');
    const lower = normalized.toLowerCase();
    const cls = online ? 'online' : (lower.includes('disable') || lower.includes('suspend') ? 'warn' : 'offline');
    return `<span class="customer-network-status ${cls}"><i class="bi bi-circle-fill"></i>${escapeCustomerDetailHtml(normalized)}</span>`;
  }

  function customerDetailCurrentCode(customer) {
    return customer?.customerCode || customer?.genieacsTag || customer?.pppoeUsername || customer?.phone || String(customer?.id || '-');
  }

  function customerDetailBanner(invoiceStatus, currentInvoice, network) {
    if (!currentInvoice) {
      return { text: 'Belum ada tagihan aktif', cls: '', icon: 'bi-clock-history' };
    }
    if (invoiceStatus.cls === 'paid') {
      return { text: 'Tidak ada tagihan', cls: '', icon: 'bi-check-circle' };
    }
    if (String(customerDetailStatusChip(network?.status || '')).toLowerCase().includes('suspend')) {
      return { text: 'Tagihan belum lunas dan layanan tersuspend', cls: 'suspended', icon: 'bi-x-octagon' };
    }
    return { text: 'Tagihan aktif ' + customerDetailRupiah(currentInvoice.amount), cls: 'unpaid', icon: 'bi-receipt' };
  }

  function customerDetailSwitchTab(tabName) {
    customerDetailState.activeTab = String(tabName || 'detail');
    document.querySelectorAll('[data-customer-tab]').forEach((button) => {
      button.classList.toggle('active', button.dataset.customerTab === customerDetailState.activeTab);
    });
    document.querySelectorAll('[data-customer-panel]').forEach((panel) => {
      panel.classList.toggle('active', panel.dataset.customerPanel === customerDetailState.activeTab);
    });
  }

  function customerDetailCanPoll() {
    const overlay = document.getElementById('customerDetailOverlay');
    if (!overlay?.classList.contains('show')) return false;
    if (!customerDetailState.customerId || customerDetailState.loading) return false;
    return customerDetailState.activeTab === 'detail';
  }

  function customerDetailStartPolling() {
    if (customerDetailState.refreshTimer) clearInterval(customerDetailState.refreshTimer);
    customerDetailState.refreshTimer = setInterval(() => {
      if (document.hidden) return;
      if (!customerDetailCanPoll()) return;
      loadCustomerDetail(customerDetailState.year, true);
    }, 15000);
  }

  function openCustomerDetail(customerId, year = null) {
    if (customerDetailState.refreshTimer) {
      clearInterval(customerDetailState.refreshTimer);
      customerDetailState.refreshTimer = null;
    }
    if (customerDetailState.pendingController) {
      try { customerDetailState.pendingController.abort(); } catch {}
      customerDetailState.pendingController = null;
    }
    customerDetailState.loading = false;
    customerDetailState.customerId = Number(customerId || 0) || 0;
    customerDetailState.year = Number(year || new Date().getFullYear()) || new Date().getFullYear();
    customerDetailState.data = null;
    customerDetailState.activeTab = customerDetailState.activeTab || 'detail';
    const overlay = document.getElementById('customerDetailOverlay');
    const content = document.getElementById('customerDetailContent');
    if (!overlay || !content || !customerDetailState.customerId) return;
    overlay.classList.add('show');
    content.replaceChildren();
    content.insertAdjacentHTML('afterbegin', '<div class="customer-detail-hero"><div class="customer-detail-title"><h3>Memuat detail pelanggan...</h3><div class="sub">Mohon tunggu sebentar</div></div></div>');
    loadCustomerDetail(customerDetailState.year, false);
  }

  function closeCustomerDetailModal() {
    if (customerDetailState.refreshTimer) {
      clearInterval(customerDetailState.refreshTimer);
      customerDetailState.refreshTimer = null;
    }
    if (customerDetailState.pendingController) {
      try { customerDetailState.pendingController.abort(); } catch {}
      customerDetailState.pendingController = null;
    }
    customerDetailState.loading = false;
    document.getElementById('customerDetailOverlay')?.classList.remove('show');
  }

  async function parseCustomerDetailResponse(res) {
    const contentType = String(res?.headers?.get('content-type') || '').toLowerCase();
    if (contentType.includes('application/json')) {
      return await res.json();
    }

    const raw = await res.text();
    if (res.redirected || /<!doctype|<html/i.test(raw)) {
      throw new Error('Sesi admin sudah berakhir. Silakan login ulang.');
    }

    throw new Error('Server tidak mengirim detail pelanggan yang valid.');
  }

  async function loadCustomerDetail(year = null, forceNetworkRefresh = false) {
    const customerId = customerDetailState.customerId;
    const targetYear = Number(year || customerDetailState.year || new Date().getFullYear()) || new Date().getFullYear();
    customerDetailState.year = targetYear;
    const content = document.getElementById('customerDetailContent');
    if (!customerId || !content) return;
    if (customerDetailState.pendingController) {
      try { customerDetailState.pendingController.abort(); } catch {}
      customerDetailState.pendingController = null;
    }
    customerDetailState.loading = false;
    const params = new URLSearchParams({ year: String(targetYear) });
    if (forceNetworkRefresh) params.set('refreshNetwork', '1');
    const url = `${CUSTOMER_DETAIL_OPTIONS.detailApiBase}/${encodeURIComponent(String(customerId))}/detail?${params.toString()}`;
    const controller = new AbortController();
    const hadExistingData = Boolean(customerDetailState.data);
    customerDetailState.pendingController = controller;
    customerDetailState.loading = true;
    const timeoutId = setTimeout(() => controller.abort(), 18000);
    try {
      const res = await fetch(url, {
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'fetch'
        },
        credentials: 'same-origin',
        signal: controller.signal
      });
      const json = await parseCustomerDetailResponse(res);
      if (!res.ok) throw new Error(json?.error || 'Gagal memuat detail pelanggan');
      customerDetailState.data = json;
      renderCustomerDetail(json);
      const shouldAutoRefreshNetwork = !forceNetworkRefresh &&
        Boolean(json?.customer?.pppoeUsername) &&
        (
          (
            String(json?.network?.remoteAddress || '-').trim() === '-' &&
            String(json?.network?.uptime || '-').trim() === '-' &&
            String(json?.network?.lastOnlineAt || '').trim() === '' &&
            !(Number(json?.network?.rxMbps || 0) || Number(json?.network?.txMbps || 0))
          )
        );
      if (shouldAutoRefreshNetwork) {
        window.setTimeout(() => {
          if (customerDetailState.customerId !== customerId) return;
          if (!customerDetailCanPoll()) return;
          loadCustomerDetail(targetYear, true);
        }, 1200);
      }
      customerDetailStartPolling();
    } catch (error) {
      if (hadExistingData) return;
      const message = error?.name === 'AbortError'
        ? 'Memuat detail terlalu lama. Silakan coba lagi.'
        : (error.message || String(error));
      content.replaceChildren();
      content.insertAdjacentHTML('afterbegin', `<div class="customer-detail-hero"><div class="customer-detail-title"><h3>Gagal memuat detail</h3><div class="sub">${escapeCustomerDetailHtml(message)}</div></div></div>`);
    } finally {
      clearTimeout(timeoutId);
      if (customerDetailState.pendingController === controller) {
        customerDetailState.pendingController = null;
      }
      customerDetailState.loading = false;
    }
  }

  async function customerDetailRefreshNetwork() {
    if (!customerDetailState.customerId || customerDetailState.loading) return;
    await loadCustomerDetail(customerDetailState.year, true);
  }

  function renderCustomerDetail(detail) {
    const content = document.getElementById('customerDetailContent');
    if (!content) return;
    const customer = detail?.customer || {};
    const usage = detail?.usage || {};
    const network = detail?.network || {};
    const device = detail?.device || null;
    const currentInvoice = detail?.currentInvoice || null;
    const billing = detail?.billing || { months: [], year: new Date().getFullYear() };
    const technicianHistory = Array.isArray(detail?.technicianHistory) ? detail.technicianHistory : [];
    const invoiceStatus = customerDetailInvoiceStatus(currentInvoice);
    const banner = customerDetailBanner(invoiceStatus, currentInvoice, network);
    const heroClass = customer.housePhotoUrl ? 'customer-detail-hero has-photo' : 'customer-detail-hero';
    const heroStyle = customer.housePhotoUrl ? ` style="background-image:url('${escapeCustomerDetailHtml(customer.housePhotoUrl)}')"` : '';
    const packageSpeedText = customer.speedDown
      ? `${Math.round(Number(customer.speedDown || 0) / 1000)} / ${Math.round(Number(customer.speedUp || 0) / 1000)} Mbps`
      : '-';
    const routerText = customer.routerName || customer.oltName || 'Tanpa router';
    const trafficLabel = usage?.isLive ? 'Traffic Live' : 'Traffic Tersimpan';
    const sessionPillText = usage?.isLive ? 'Live MikroTik' : 'Data tersimpan';
    const monthlyTrafficText = customerDetailBytesToGb(usage.storedTotalBytes || usage.totalBytes);
    const trafficState = customerDetailComputeTrafficState(detail);
    const showPayTab = CUSTOMER_DETAIL_OPTIONS.allowPayment;
    const codeLabel = customerDetailCurrentCode(customer);
    const activeTab = customerDetailState.activeTab || 'detail';
    const hasLocation = Boolean(customer.lat && customer.lng);
    const locationHref = hasLocation
      ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(String(customer.lat).trim())},${encodeURIComponent(String(customer.lng).trim())}`
      : '';
    const locationLabel = hasLocation
      ? `${escapeCustomerDetailHtml(String(customer.lat).trim())}, ${escapeCustomerDetailHtml(String(customer.lng).trim())}`
      : 'Belum ada titik GPS';
    const duePillText = currentInvoice ? `JT tgl ${currentInvoice.dueDay || 10}` : 'Belum ada invoice';

    content.replaceChildren();
    content.insertAdjacentHTML('afterbegin', `
      <div class="${heroClass}"${heroStyle}>
        <div class="customer-detail-topbar">
          <div class="customer-detail-title">
            <div class="customer-hero-kicker">Detail Pelanggan</div>
            <div class="customer-hero-main">
              <div class="customer-hero-identity">
                <div class="customer-avatar">
                  ${customer.housePhotoUrl ? `<img src="${escapeCustomerDetailHtml(customer.housePhotoUrl)}" alt="Foto rumah">` : '<i class="bi bi-person-circle"></i>'}
                </div>
                <div class="customer-hero-meta">
                  <div class="customer-hero-name-row">
                    <h3>${escapeCustomerDetailHtml(customer.name || '-')}</h3>
                    ${customerDetailNetworkStatusChip(Boolean(network.online), network.status)}
                  </div>
                  <div class="customer-hero-contact">
                    <span><i class="bi bi-telephone-fill"></i> ${escapeCustomerDetailHtml(customer.phone || '-')}</span>
                    <span><i class="bi bi-box-seam"></i> ${escapeCustomerDetailHtml(customer.packageName || '-')}</span>
                  </div>
                  <div class="customer-hero-bottom-row">
                    <span class="customer-code-pill">ID Pel : ${escapeCustomerDetailHtml(codeLabel)}</span>
                    <span class="customer-hero-pill"><i class="bi bi-hdd-network"></i>${escapeCustomerDetailHtml(routerText)}</span>
                    <div class="customer-hero-traffic">
                      <div class="customer-traffic-rate">
                        <div class="customer-rate-row customer-rate-up" title="Upload sekarang">
                          <i class="bi bi-arrow-up"></i>
                          <span>${escapeCustomerDetailHtml(trafficState.upRateText)}</span>
                        </div>
                        <div class="customer-rate-row customer-rate-down" title="Download sekarang">
                          <i class="bi bi-arrow-down"></i>
                          <span>${escapeCustomerDetailHtml(trafficState.downRateText)}</span>
                        </div>
                      </div>
                      <div class="customer-traffic-total">${customerDetailBytesToGb(usage.totalBytes)}</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="customer-detail-actions">
            <button type="button" class="customer-detail-close" onclick="closeCustomerDetailModal()">&times;</button>
          </div>
        </div>
        <div class="customer-detail-tabs">
          <button type="button" class="customer-tab-btn ${activeTab === 'detail' ? 'active' : ''}" data-customer-tab="detail" onclick="customerDetailSwitchTab('detail')">Detail</button>
          <button type="button" class="customer-tab-btn ${activeTab === 'month' ? 'active' : ''}" data-customer-tab="month" onclick="customerDetailSwitchTab('month')">Bulan</button>
          ${showPayTab ? `<button type="button" class="customer-tab-btn ${activeTab === 'pay' ? 'active' : ''}" data-customer-tab="pay" onclick="customerDetailSwitchTab('pay')">Bayar</button>` : ''}
          <button type="button" class="customer-tab-btn ${activeTab === 'tech' ? 'active' : ''}" data-customer-tab="tech" onclick="customerDetailSwitchTab('tech')">H. Teknis</button>
        </div>
        <div class="customer-detail-summary-grid" style="display:none">
          <div class="customer-detail-cell emphasis">
            <div class="label">Tagihan</div>
            <div class="value">${currentInvoice ? customerDetailRupiah(currentInvoice.amount) : 'Belum dibuat'}</div>
          </div>
          <div class="customer-detail-cell emphasis">
            <div class="label">Status</div>
            <div class="value">${escapeCustomerDetailHtml(invoiceStatus.label)}</div>
          </div>
          <div class="customer-detail-cell emphasis">
            <div class="label">${trafficLabel} Download</div>
            <div class="value">${customerDetailBytesToGb(usage.downloadBytes)}</div>
          </div>
          <div class="customer-detail-cell emphasis">
            <div class="label">${trafficLabel} Upload</div>
            <div class="value">${customerDetailBytesToGb(usage.uploadBytes)}</div>
          </div>
        </div>
        <div class="customer-hero-pills">
          <span class="customer-hero-pill"><i class="bi bi-calendar-check"></i>${duePillText}</span>
          <span class="customer-hero-pill"><i class="bi bi-speedometer2"></i>${escapeCustomerDetailHtml(packageSpeedText)}</span>
          <span class="customer-hero-pill"><i class="bi bi-bar-chart-line"></i>${customerDetailBytesToGb(usage.totalBytes)}</span>
          <span class="customer-hero-pill"><i class="bi bi-hdd-network"></i>${escapeCustomerDetailHtml(sessionPillText)}</span>
        </div>
      </div>
      <div class="customer-detail-body">
        <section class="customer-tab-panel ${activeTab === 'detail' ? 'active' : ''}" data-customer-panel="detail">
          <div class="customer-state-banner ${banner.cls}">
            <i class="bi ${banner.icon}"></i>
            <span>${escapeCustomerDetailHtml(banner.text)}</span>
          </div>
          <div class="customer-detail-section">
            <div class="customer-section-head">
              <h4><i class="bi bi-router"></i> Rincian Jaringan</h4>
              <button type="button" class="customer-inline-action" onclick="customerDetailRefreshNetwork()"><i class="bi bi-arrow-clockwise"></i>Refresh</button>
            </div>
            <div class="customer-detail-network-grid">
              <div class="customer-detail-cell compact">
                <div class="label">Akun PPPoE</div>
                <div class="value">${escapeCustomerDetailHtml(network.username || customer.pppoeUsername || '-')}</div>
              </div>
              <div class="customer-detail-cell compact">
                <div class="label">Status</div>
                <div class="value status-chip">${customerDetailNetworkStatusChip(Boolean(network.online), network.status)}</div>
              </div>
              <div class="customer-detail-cell compact">
                <div class="label">Uptime</div>
                <div class="value">${escapeCustomerDetailHtml(network.uptime || '-')}</div>
              </div>
              <div class="customer-detail-cell compact">
                <div class="label">Remote Address</div>
                <div class="value">${escapeCustomerDetailHtml(network.remoteAddress || network.activeAddress || '-')}</div>
              </div>
              <div class="customer-detail-cell compact">
                <div class="label">Profile</div>
                <div class="value">${escapeCustomerDetailHtml(network.profile || '-')}</div>
              </div>
              <div class="customer-detail-cell compact">
                <div class="label">Terakhir Online</div>
                <div class="value">${escapeCustomerDetailHtml(customerDetailDateTime(network.lastOnlineAt, 'Belum ada data'))}</div>
              </div>
              <div class="customer-detail-cell compact customer-span-2">
                <div class="label">Jalur Jaringan</div>
                <div class="value">${escapeCustomerDetailHtml(customer.odpName || 'Belum ada ODP')}</div>
                <div class="customer-detail-muted" style="font-size:11px;margin-top:6px">${escapeCustomerDetailHtml(customer.ponPort || 'PON belum diisi')}</div>
              </div>
              <div class="customer-detail-cell compact customer-mobile-secondary">
                <div class="label">PPPoE / Modem</div>
                <div class="value">${escapeCustomerDetailHtml((network.username || '-') + ' - ' + (device?.model || customer.macAddress || '-'))}</div>
                <div class="customer-detail-muted" style="font-size:11px;margin-top:6px">${escapeCustomerDetailHtml(routerText)}</div>
              </div>
              <div class="customer-detail-cell compact customer-mobile-secondary">
                <div class="label">Sumber Data</div>
                <div class="value">${escapeCustomerDetailHtml(usage.usageSource || usage.snapshotSource || network.source || 'database')}</div>
                <div class="customer-detail-muted" style="font-size:11px;margin-top:6px">${escapeCustomerDetailHtml(usage.updatedAt ? `Update ${customerDetailDateTime(usage.updatedAt, '-')}` : 'Data pemakaian terakhir tersimpan')}</div>
              </div>
            </div>
          </div>

          <div class="customer-detail-section">
            <h4><i class="bi bi-person-vcard"></i> Rincian Data</h4>
            <div class="customer-detail-data-grid">
              <div class="customer-detail-cell compact"><div class="label">Tanggal Daftar</div><div class="value">${escapeCustomerDetailHtml(customerDetailDate(customer.createdAt || customer.installDate, '-'))}</div></div>
              <div class="customer-detail-cell compact"><div class="label">Tagihan Tanggal</div><div class="value">${escapeCustomerDetailHtml(String(currentInvoice?.dueDay || customer.isolateDay || '-'))}</div></div>
              <div class="customer-detail-cell compact"><div class="label">Tanggal Isolir</div><div class="value">${escapeCustomerDetailHtml(String(customer.isolateDay || currentInvoice?.dueDay || '-'))}</div></div>
              <div class="customer-detail-cell compact"><div class="label">Lokasi GPS / Rute</div><div class="value">${hasLocation ? `<a href="${locationHref}" target="_blank" rel="noopener" style="color:inherit;text-decoration:none;font-weight:800">${locationLabel}</a>` : 'Belum ada titik GPS'}</div></div>
              <div class="customer-detail-cell compact customer-span-2"><div class="label">Alamat</div><div class="value">${escapeCustomerDetailHtml(customer.address || '-')}</div></div>
              <div class="customer-detail-cell compact customer-mobile-secondary"><div class="label">Password App</div><div class="value">${escapeCustomerDetailHtml(customer.phone ? 'Kirim Password Pelanggan' : '-')}</div></div>
            </div>
          </div>

          <div class="customer-detail-section">
            <h4><i class="bi bi-cash-coin"></i> Rincian Biaya</h4>
            <div class="customer-detail-data-grid">
              <div class="customer-detail-cell compact"><div class="label">Paket</div><div class="value">${escapeCustomerDetailHtml(customer.packageName || '-')}</div></div>
              <div class="customer-detail-cell compact"><div class="label">PPN / FUP</div><div class="value">${customer.useFup ? 'FUP aktif' : 'PPN 0%'}</div></div>
              <div class="customer-detail-cell compact customer-span-2"><div class="label">Total per Bulan</div><div class="value">${customer.packagePrice ? customerDetailRupiah(customer.packagePrice) : '-'}</div></div>
            </div>
          </div>

          <div class="customer-detail-section">
            <h4><i class="bi bi-journal-text"></i> Catatan</h4>
            <div class="customer-note-box"><div class="big">${escapeCustomerDetailHtml(customer.notes || 'Tidak ada Catatan')}</div></div>
          </div>
        </section>

        <section class="customer-tab-panel ${activeTab === 'month' ? 'active' : ''}" data-customer-panel="month">
          <div class="customer-detail-section">
            <div class="customer-billing-toolbar">
              <h4 style="margin:0"><i class="bi bi-calendar-check"></i> Tagihan per Bulan</h4>
              <div style="display:flex;align-items:center;gap:8px">
                <span class="customer-live-badge"><i class="bi bi-pie-chart"></i> Total ${monthlyTrafficText}</span>
                <select id="customerDetailYearSelect" onchange="loadCustomerDetail(this.value)" style="border-radius:12px;padding:8px 10px;background:rgba(255,255,255,.06);color:inherit;border:1px solid rgba(148,163,184,.16)">
                  ${[new Date().getFullYear() + 1, new Date().getFullYear(), new Date().getFullYear() - 1, new Date().getFullYear() - 2].map((yr) => `<option value="${yr}" ${Number(billing.year) === yr ? 'selected' : ''}>${yr}</option>`).join('')}
                </select>
              </div>
            </div>
            <div class="customer-billing-months">
              ${(Array.isArray(billing.months) ? billing.months : []).map((row) => `
                <div class="billing-month">
                  <div class="head">
                    <div class="name">${customerDetailMonthName(row.month)} ${billing.year}</div>
                    <div class="status ${escapeCustomerDetailHtml(row.status)}">${escapeCustomerDetailHtml(row.label)}</div>
                  </div>
                  <div class="meta">
                    <div>${row.invoiceId ? customerDetailRupiah(row.amount) : 'Belum ada invoice'}</div>
                    <div>${row.paidAt ? 'Lunas: ' + customerDetailDateTime(row.paidAt, '-') : (row.dueDay ? 'Jatuh tempo tgl ' + row.dueDay : '')}</div>
                  </div>
                  ${CUSTOMER_DETAIL_OPTIONS.allowPayment && row.invoiceId && row.status !== 'paid' ? `<button type="button" class="billing-pay-btn" onclick="customerDetailMarkPaid(${Number(row.invoiceId)})">Lunaskan</button>` : ''}
                </div>
              `).join('')}
            </div>
          </div>
        </section>

        ${showPayTab ? `
          <section class="customer-tab-panel ${activeTab === 'pay' ? 'active' : ''}" data-customer-panel="pay">
            <div class="customer-detail-section">
              <h4><i class="bi bi-wallet2"></i> Pembayaran</h4>
              <div class="customer-list-rows">
                ${currentInvoice ? `
                  <div class="customer-list-row">
                    <div class="top">
                      <div>
                        <div class="title">Tagihan Bulan Ini</div>
                        <div class="meta">${customerDetailRupiah(currentInvoice.amount)} • Jatuh tempo tgl ${currentInvoice.dueDay || '-'}</div>
                      </div>
                      <div>${customerDetailNetworkStatusChip(invoiceStatus.cls === 'paid', invoiceStatus.label)}</div>
                    </div>
                    ${invoiceStatus.cls !== 'paid' ? `<button type="button" class="billing-pay-btn" onclick="customerDetailMarkPaid(${Number(currentInvoice.id)})">Tandai Lunas</button>` : ''}
                  </div>
                ` : `<div class="customer-note-box"><div class="big">Belum ada tagihan aktif.</div></div>`}
                ${(Array.isArray(detail.unpaidInvoices) ? detail.unpaidInvoices : []).filter((item) => item && item.id && (!currentInvoice || Number(item.id) !== Number(currentInvoice.id))).map((item) => `
                  <div class="customer-list-row">
                    <div class="top">
                      <div>
                        <div class="title">${customerDetailMonthName(item.periodMonth)} ${item.periodYear}</div>
                        <div class="meta">${customerDetailRupiah(item.amount)} • ${item.packageName || 'Tagihan pelanggan'}</div>
                      </div>
                      <div>${customerDetailNetworkStatusChip(false, 'Belum Lunas')}</div>
                    </div>
                    <button type="button" class="billing-pay-btn" onclick="customerDetailMarkPaid(${Number(item.id)})">Lunaskan</button>
                  </div>
                `).join('')}
              </div>
            </div>
          </section>
        ` : ''}

        <section class="customer-tab-panel ${activeTab === 'tech' ? 'active' : ''}" data-customer-panel="tech">
          <div class="customer-detail-section">
            <h4><i class="bi bi-tools"></i> Histori Perbaikan Teknisi</h4>
            ${technicianHistory.length ? `
              <div class="customer-list-rows">
                ${technicianHistory.map((item) => `
                  <div class="customer-list-row">
                    <div class="top">
                      <div>
                        <div class="title">${escapeCustomerDetailHtml(item.subject || 'Laporan teknisi')}</div>
                        <div class="meta">${escapeCustomerDetailHtml(customerDetailDateTime(item.createdAt, '-'))}${item.technicianName ? ` • ${escapeCustomerDetailHtml(item.technicianName)}` : ''}</div>
                      </div>
                      <span class="customer-tech-status ${escapeCustomerDetailHtml(item.status || 'open')}">${escapeCustomerDetailHtml(
                        item.status === 'resolved' ? 'Selesai' :
                        item.status === 'in_progress' ? 'Dikerjakan' :
                        item.status === 'closed' ? 'Ditutup' : 'Baru'
                      )}</span>
                    </div>
                    <div class="meta" style="margin-top:8px">${escapeCustomerDetailHtml(item.message || 'Tidak ada catatan pekerjaan.')}</div>
                    ${item.updatedAt ? `<div class="customer-detail-muted" style="font-size:11px;margin-top:8px">Update terakhir ${escapeCustomerDetailHtml(customerDetailDateTime(item.updatedAt, '-'))}</div>` : ''}
                  </div>
                `).join('')}
              </div>
            ` : `
              <div class="customer-note-box">
                <div class="big">Belum ada histori perbaikan teknisi untuk pelanggan ini.</div>
              </div>
            `}
          </div>

          <div class="customer-detail-section">
            <h4><i class="bi bi-wifi"></i> Modem & Perangkat</h4>
            ${device ? `
              <div class="customer-detail-network-grid" style="margin-bottom:10px">
                <div class="customer-detail-cell"><div class="label">Tag / Token</div><div class="value">${escapeCustomerDetailHtml(device.token || customer.genieacsTag || '-')}</div></div>
                <div class="customer-detail-cell"><div class="label">SSID</div><div class="value">${escapeCustomerDetailHtml(device.ssid || '-')}</div></div>
                <div class="customer-detail-cell"><div class="label">Status Modem</div><div class="value">${customerDetailNetworkStatusChip(String(device.status || '').toLowerCase().includes('online'), device.status || '-')}</div></div>
                <div class="customer-detail-cell"><div class="label">Uptime Modem</div><div class="value">${escapeCustomerDetailHtml(device.uptime || '-')}</div></div>
                <div class="customer-detail-cell"><div class="label">Model</div><div class="value">${escapeCustomerDetailHtml(device.model || '-')}</div></div>
                <div class="customer-detail-cell"><div class="label">Serial</div><div class="value">${escapeCustomerDetailHtml(device.serialNumber || '-')}</div></div>
              </div>
            ` : `<div class="customer-detail-muted">Data modem belum ditemukan di GenieACS.</div>`}
            ${CUSTOMER_DETAIL_OPTIONS.allowDeviceActions ? `
              <div class="device-actions" style="margin-top:10px">
                <div class="device-action-card">
                  <label>Nama WiFi</label>
                  <input type="text" id="customerDetailSsidInput" value="${escapeCustomerDetailHtml(device?.ssid || '')}" placeholder="Nama WiFi">
                  <button type="button" onclick="customerDetailUpdateDeviceField('ssid')">Simpan SSID</button>
                </div>
                <div class="device-action-card">
                  <label>Password WiFi</label>
                  <input type="text" id="customerDetailPasswordInput" placeholder="Minimal 8 karakter">
                  <button type="button" onclick="customerDetailUpdateDeviceField('password')">Simpan Password</button>
                </div>
                <div class="device-action-card">
                  <label>Akses Modem</label>
                  <div class="customer-detail-muted" style="font-size:12px">Gunakan untuk paksa reconnect modem pelanggan.</div>
                  <button type="button" onclick="customerDetailRebootDevice()">Cek / Reboot Modem</button>
                </div>
              </div>
            ` : ''}
          </div>

          <div class="customer-detail-section">
            <h4><i class="bi bi-image"></i> Dokumen</h4>
            <div class="customer-docs">
              <div class="customer-doc-card">
                <div class="customer-doc-title"><span class="customer-detail-muted" style="font-size:12px">Foto Rumah</span></div>
                ${customer.housePhotoUrl ? `<img src="${escapeCustomerDetailHtml(customer.housePhotoUrl)}" alt="Foto rumah">` : '<div class="customer-doc-empty">Belum ada foto rumah</div>'}
              </div>
              <div class="customer-doc-card">
                <div class="customer-doc-title"><span class="customer-detail-muted" style="font-size:12px">Foto KTP</span></div>
                ${customer.ktpPhotoUrl ? `<img src="${escapeCustomerDetailHtml(customer.ktpPhotoUrl)}" alt="Foto KTP">` : '<div class="customer-doc-empty">Belum ada foto KTP</div>'}
              </div>
            </div>
          </div>
        </section>
      </div>
    `);
    customerDetailSwitchTab(activeTab);
  }

  async function customerDetailUpdateDeviceField(kind) {
    const detail = customerDetailState.data;
    const token = detail?.device?.token || detail?.customer?.genieacsTag || detail?.customer?.pppoeUsername;
    if (!token) return alert('Tag perangkat tidak ditemukan.');
    try {
      let endpoint = '';
      let payload = {};
      if (kind === 'ssid') {
        endpoint = `${CUSTOMER_DETAIL_OPTIONS.deviceApiBase}/${encodeURIComponent(token)}/ssid`;
        payload = { ssid: document.getElementById('customerDetailSsidInput')?.value || '' };
      } else {
        endpoint = `${CUSTOMER_DETAIL_OPTIONS.deviceApiBase}/${encodeURIComponent(token)}/password`;
        payload = { password: document.getElementById('customerDetailPasswordInput')?.value || '' };
      }
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || json?.success === false) throw new Error(json?.error || 'Gagal menyimpan pengaturan modem');
      alert('Pengaturan modem berhasil disimpan.');
      loadCustomerDetail();
    } catch (error) {
      alert(error.message || String(error));
    }
  }

  async function customerDetailRebootDevice() {
    const detail = customerDetailState.data;
    const token = detail?.device?.token || detail?.customer?.genieacsTag || detail?.customer?.pppoeUsername;
    if (!token) return alert('Tag perangkat tidak ditemukan.');
    if (!confirm('Reboot modem pelanggan sekarang?')) return;
    try {
      const res = await fetch(`${CUSTOMER_DETAIL_OPTIONS.deviceApiBase}/${encodeURIComponent(token)}/reboot`, { method: 'POST' });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || json?.success === false) throw new Error(json?.error || 'Gagal reboot modem');
      alert('Permintaan reboot modem berhasil dikirim.');
    } catch (error) {
      alert(error.message || String(error));
    }
  }

  async function customerDetailMarkPaid(invoiceId) {
    if (!CUSTOMER_DETAIL_OPTIONS.allowPayment) return;
    const customerId = customerDetailState.customerId;
    if (!customerId || !invoiceId) return;
    const defaultNote = CUSTOMER_DETAIL_OPTIONS.scope === 'tech'
      ? 'Lunas oleh teknisi'
      : 'Dilunasi oleh admin';
    const note = prompt('Catatan pembayaran (opsional):', defaultNote) || '';
    try {
      const res = await fetch(`${CUSTOMER_DETAIL_OPTIONS.paymentApiBase}/${encodeURIComponent(String(customerId))}/invoices/${encodeURIComponent(String(invoiceId))}/pay`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes: note })
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || json?.success === false) throw new Error(json?.error || 'Gagal melunaskan tagihan');
      alert('Tagihan berhasil dilunasi.');
      loadCustomerDetail();
    } catch (error) {
      alert(error.message || String(error));
    }
  }
</script>
